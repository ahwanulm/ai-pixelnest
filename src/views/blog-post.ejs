<!DOCTYPE html>
<html lang="id" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= post.excerpt || post.title %>">
    <title><%= title %></title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    <style>
        .article-content h2 {
            font-size: 2rem;
            font-weight: 800;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #a78bfa 0%, #ec4899 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .article-content h3 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-top: 2rem;
            margin-bottom: 0.75rem;
            color: #e5e7eb;
        }
        .article-content p {
            margin-bottom: 1.25rem;
            line-height: 1.8;
            color: #d1d5db;
        }
        .article-content ul, .article-content ol {
            margin-left: 1.5rem;
            margin-bottom: 1.25rem;
            color: #9ca3af;
        }
        .article-content li {
            margin-bottom: 0.5rem;
            line-height: 1.7;
        }
        .article-content strong {
            color: #f3f4f6;
            font-weight: 600;
        }
        .article-content em {
            color: #a78bfa;
            font-style: italic;
        }
        .article-content a {
            color: #a78bfa;
            text-decoration: underline;
        }
        .article-content a:hover {
            color: #c4b5fd;
        }
        .article-content .code-block {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(167, 139, 250, 0.2);
            border-radius: 0.5rem;
            padding: 1rem;
            margin: 1.5rem 0;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.875rem;
            line-height: 1.7;
            color: #d1d5db;
            overflow-x: auto;
        }
    </style>
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-16">
        <!-- Article Header -->
        <section class="relative py-10 overflow-hidden">
            <!-- Background Effects -->
            <div class="absolute inset-0 opacity-20">
                <div class="absolute top-20 left-10 w-72 h-72 bg-violet-600/30 rounded-full blur-3xl animate-pulse"></div>
                <div class="absolute bottom-20 right-10 w-96 h-96 bg-fuchsia-600/30 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
            </div>

            <div class="section-container relative z-10">
                <div class="max-w-4xl mx-auto">
                    <!-- Back Button -->
                    <a href="/blog" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors mb-8 group">
                        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                        Kembali ke Blog
                    </a>

                    <!-- Category Badge -->
                    <% if (post.category) { %>
                        <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6 <%= 
                            post.category.includes('Strategi') ? 'text-violet-400' :
                            post.category.includes('Teknologi') ? 'text-blue-400' :
                            post.category.includes('Fakta') ? 'text-green-400' :
                            post.category.includes('Tutorial') ? 'text-orange-400' :
                            post.category.includes('Tren') ? 'text-pink-400' :
                            post.category.includes('Case') ? 'text-yellow-400' :
                            'text-purple-400'
                        %>">
                            <%= post.category %>
                        </span>
                    <% } %>

                    <!-- Title -->
                    <h1 class="text-4xl md:text-6xl font-black mb-6 tracking-tight leading-tight">
                        <%= post.title %>
                    </h1>

                    <!-- Meta Information -->
                    <div class="flex flex-wrap items-center gap-6 text-sm text-gray-400 pb-8 border-b border-white/10">
                        <% if (post.author) { %>
                            <div class="flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                <span><%= post.author %></span>
                            </div>
                        <% } %>
                        
                        <div class="flex items-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <span><%= new Date(post.created_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                        </div>
                        
                        <div class="flex items-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            <span><%= post.views || 0 %> views</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Article Content -->
        <section class="section-container py-12">
            <div class="max-w-4xl mx-auto">
                <article class="glass rounded-3xl p-8 md:p-12 article-content">
                    <%- post.content %>
                </article>

                <!-- Tags -->
                <% if (post.tags) { %>
                    <div class="mt-8 glass rounded-2xl p-6">
                        <div class="flex flex-wrap items-center gap-3">
                            <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                            </svg>
                            <% const tags = post.tags.split(','); %>
                            <% tags.forEach(function(tag) { %>
                                <span class="px-3 py-1.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm text-gray-300 transition-colors">
                                    <%= tag.trim() %>
                                </span>
                            <% }); %>
                        </div>
                    </div>
                <% } %>

                <!-- Share Buttons -->
                <div class="mt-8 glass rounded-2xl p-6">
                    <div class="flex items-center justify-between">
                        <h3 class="text-lg font-bold">Bagikan Artikel Ini</h3>
                        <div class="flex items-center gap-3">
                            <a href="https://twitter.com/intent/tweet?url=<%= `https://pixelnest.com/blog/${post.slug}` %>&text=<%= encodeURIComponent(post.title) %>" target="_blank" rel="noopener" class="w-10 h-10 glass rounded-xl flex items-center justify-center hover:glass-strong hover:text-blue-400 transition-all duration-300">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
                                </svg>
                            </a>
                            <a href="https://www.facebook.com/sharer/sharer.php?u=<%= `https://pixelnest.com/blog/${post.slug}` %>" target="_blank" rel="noopener" class="w-10 h-10 glass rounded-xl flex items-center justify-center hover:glass-strong hover:text-blue-500 transition-all duration-300">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                                </svg>
                            </a>
                            <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= `https://pixelnest.com/blog/${post.slug}` %>&title=<%= encodeURIComponent(post.title) %>" target="_blank" rel="noopener" class="w-10 h-10 glass rounded-xl flex items-center justify-center hover:glass-strong hover:text-blue-600 transition-all duration-300">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                </svg>
                            </a>
                            <button onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied!')" class="w-10 h-10 glass rounded-xl flex items-center justify-center hover:glass-strong hover:text-green-400 transition-all duration-300">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- CTA Box -->
                <div class="mt-12 relative overflow-hidden rounded-2xl">
                    <div class="absolute inset-0 bg-gradient-to-r from-violet-600 to-fuchsia-600 opacity-10"></div>
                    <div class="absolute inset-0 glass"></div>
                    
                    <div class="relative z-10 p-8 md:p-12 text-center">
                        <h3 class="text-2xl md:text-3xl font-black mb-4">
                            Siap Terapkan Tips Ini?
                        </h3>
                        <p class="text-gray-400 mb-6 max-w-2xl mx-auto">
                            Mulai buat video AI berkualitas profesional dengan PixelNest. Gratis untuk dicoba!
                        </p>
                        <a href="/contact" class="btn-primary inline-block px-8 py-3">
                            Coba Gratis Sekarang
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>
    
    <%- include('partials/footer') %>
    
    <script src="/js/main.js"></script>
</body>
</html>

