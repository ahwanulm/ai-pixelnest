<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Real-time FAL.AI Pricing - PixelNest Admin</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/favicon.png">
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%- include('../partials/admin-styles') %>
  <style>
    .sync-status {
      animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: .5; }
    }
    
    .price-card {
      transition: all 0.3s ease;
      border: 1px solid rgba(75, 85, 99, 0.3);
    }
    
    .price-card:hover {
      transform: translateY(-2px);
      border-color: rgba(59, 130, 246, 0.5);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }
    
    .model-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }
    
    .video-icon { background: linear-gradient(135deg, #ec4899, #be185d); }
    .image-icon { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
    
    .refresh-btn {
      background: linear-gradient(135deg, #10b981, #059669);
      transform: rotate(0deg);
      transition: all 0.3s ease;
    }
    
    .refresh-btn.spinning {
      transform: rotate(360deg);
    }
    
    .refresh-btn:hover {
      background: linear-gradient(135deg, #059669, #047857);
    }
    
    .duration-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 600;
      margin: 2px;
    }
    
    .duration-badge.low { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
    .duration-badge.medium { background: rgba(251, 191, 36, 0.2); color: #fbbf24; }
    .duration-badge.high { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
    
    .loading-skeleton {
      background: linear-gradient(90deg, #374151 25%, #4b5563 50%, #374151 75%);
      background-size: 200% 100%;
      animation: loading 1.5s infinite;
    }
    
    @keyframes loading {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
  </style>
</head>
<body>
  <div class="flex h-screen overflow-hidden">
    <%- include('../partials/admin-sidebar') %>

    <div class="flex-1 ml-64 overflow-y-auto content-area flex flex-col">
      <%- include('../partials/admin-header', { pageTitle: 'Real-time FAL.AI Pricing' }) %>

      <main class="p-4 md:p-8 flex-1">
        <div class="max-w-7xl mx-auto">
          
          <!-- Header -->
          <div class="mb-8">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h1 class="text-3xl font-bold text-white mb-2">
                  <i class="fas fa-chart-line mr-3 text-blue-400"></i>
                  Real-time FAL.AI Pricing
                </h1>
                <p class="text-gray-400">Data langsung dari fal.ai API - Update otomatis</p>
              </div>
              
              <!-- Refresh Button -->
              <button 
                id="refreshBtn"
                onclick="refreshPricing()"
                class="refresh-btn px-6 py-3 text-white rounded-xl font-semibold shadow-lg"
              >
                <i class="fas fa-sync-alt mr-2"></i>
                Refresh Data
              </button>
            </div>
            
            <!-- Status Bar -->
            <div class="glass-strong rounded-xl p-4 border-l-4 border-green-500">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                  <div class="flex items-center gap-2">
                    <div class="w-3 h-3 bg-green-400 rounded-full sync-status"></div>
                    <span class="text-sm font-semibold text-green-400">LIVE DATA</span>
                  </div>
                  <div class="text-sm text-gray-400">
                    Last updated: <span id="lastUpdate">Loading...</span>
                  </div>
                </div>
                
                <div class="flex items-center gap-6 text-sm">
                  <div class="text-gray-400">
                    Total Models: <span id="totalModels" class="text-white font-semibold">-</span>
                  </div>
                  <div class="text-gray-400">
                    Video: <span id="videoCount" class="text-pink-400 font-semibold">-</span>
                  </div>
                  <div class="text-gray-400">
                    Image: <span id="imageCount" class="text-blue-400 font-semibold">-</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Filter Tabs -->
          <div class="flex gap-2 mb-6">
            <button onclick="filterModels('all')" class="filter-tab active" data-filter="all">
              <i class="fas fa-th mr-2"></i>All Models
            </button>
            <button onclick="filterModels('video')" class="filter-tab" data-filter="video">
              <i class="fas fa-video mr-2"></i>Video Models
            </button>
            <button onclick="filterModels('image')" class="filter-tab" data-filter="image">
              <i class="fas fa-image mr-2"></i>Image Models
            </button>
          </div>

          <!-- Models Grid -->
          <div id="modelsGrid" class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6">
            <!-- Loading State -->
            <div class="price-card glass-strong rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="model-icon loading-skeleton"></div>
                <div class="flex-1 space-y-3">
                  <div class="h-4 loading-skeleton rounded w-3/4"></div>
                  <div class="h-3 loading-skeleton rounded w-1/2"></div>
                  <div class="h-6 loading-skeleton rounded w-full"></div>
                </div>
              </div>
            </div>
            
            <!-- Repeat loading cards -->
            <div class="price-card glass-strong rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="model-icon loading-skeleton"></div>
                <div class="flex-1 space-y-3">
                  <div class="h-4 loading-skeleton rounded w-2/3"></div>
                  <div class="h-3 loading-skeleton rounded w-1/3"></div>
                  <div class="h-6 loading-skeleton rounded w-full"></div>
                </div>
              </div>
            </div>
            
            <div class="price-card glass-strong rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="model-icon loading-skeleton"></div>
                <div class="flex-1 space-y-3">
                  <div class="h-4 loading-skeleton rounded w-4/5"></div>
                  <div class="h-3 loading-skeleton rounded w-2/5"></div>
                  <div class="h-6 loading-skeleton rounded w-full"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Footer Info -->
          <div class="mt-8 glass-strong rounded-xl p-6 border-l-4 border-blue-500">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-blue-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-info-circle text-blue-400 text-xl"></i>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white mb-2">Tentang Data Ini</h3>
                <ul class="text-sm text-gray-300 space-y-1">
                  <li>• Data diambil langsung dari fal.ai API secara real-time</li>
                  <li>• Harga dalam USD - sesuai dengan yang ditagih fal.ai</li>
                  <li>• Video models menunjukkan harga per detik atau flat rate</li>
                  <li>• Image models umumnya flat rate per generation</li>
                  <li>• Data diperbarui otomatis setiap 5 menit</li>
                </ul>
              </div>
            </div>
          </div>

        </div>
      </main>
    </div>
  </div>

  <%- include('../partials/admin-scripts') %>
  <script src="/js/admin-pricing-realtime.js"></script>
  
  <style>
    .filter-tab {
      padding: 12px 24px;
      border-radius: 10px;
      background: rgba(55, 65, 81, 0.5);
      color: #9ca3af;
      border: 1px solid rgba(75, 85, 99, 0.3);
      font-weight: 500;
      transition: all 0.3s;
      cursor: pointer;
    }
    
    .filter-tab:hover {
      background: rgba(75, 85, 99, 0.8);
      color: #fff;
      border-color: rgba(107, 114, 128, 0.5);
    }
    
    .filter-tab.active {
      background: linear-gradient(135deg, #3b82f6, #1d4ed8);
      color: #fff;
      border-color: #3b82f6;
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }
  </style>
</body>
</html>
