  <%- include('../partials/admin-scripts') %>

  <script>
    const API_CONFIGS = <%- JSON.stringify(apiConfigs) %>;

    async function apiRequest(url, options = {}) {
      const response = await fetch(url, {
        ...options,
        headers: {
          'Content-Type': 'application/json',
          ...options.headers
        }
      });
      
      const data = await response.json();
      
      if (!response.ok) {
        throw new Error(data.message || 'Request failed');
      }
      
      return data;
    }

    function editApiConfig(serviceName) {
      const config = API_CONFIGS.find(c => c.service_name === serviceName);
      if (!config) return;
      
      document.getElementById('modal-service-name').textContent = serviceName;
      document.getElementById('edit-service_name').value = serviceName;
      
      // Show/hide fields based on service type
      const isTripay = serviceName === 'TRIPAY';
      const isGroq = serviceName === 'GROQ';
      const isGoogleOAuth = serviceName === 'GOOGLE_OAUTH';
      const isSendGrid = serviceName === 'SENDGRID';
      const isSuno = serviceName === 'SUNO';
      
      document.getElementById('tripay-fields').classList.toggle('hidden', !isTripay);
      document.getElementById('groq-fields').classList.toggle('hidden', !isGroq);
      document.getElementById('google-oauth-fields').classList.toggle('hidden', !isGoogleOAuth);
      document.getElementById('sendgrid-fields').classList.toggle('hidden', !isSendGrid);
      document.getElementById('suno-fields').classList.toggle('hidden', !isSuno);
      document.getElementById('generic-api-fields').classList.toggle('hidden', isTripay || isGroq || isGoogleOAuth || isSendGrid || isSuno);
      
      if (isTripay) {
        // Populate Tripay fields
        document.getElementById('edit-tripay-merchant-code').value = config.additional_config?.merchant_code || '';
        document.getElementById('edit-tripay-merchant-name').value = config.additional_config?.merchant_name || '';
        document.getElementById('edit-tripay-api-key').value = '';
        document.getElementById('edit-tripay-private-key').value = '';
        document.getElementById('edit-tripay-callback-url').value = config.additional_config?.callback_url || 'http://localhost:5005/api/payment/callback';
        document.getElementById('edit-tripay-endpoint').value = config.endpoint_url || 'https://tripay.co.id/api-sandbox';
      } else if (isGroq) {
        // Populate Groq fields
        document.getElementById('edit-groq-api-key').value = '';
        document.getElementById('edit-groq-model').value = config.additional_config?.default_model || 'llama-3.3-70b-versatile';
        document.getElementById('edit-groq-endpoint').value = config.endpoint_url || 'https://api.groq.com/openai/v1';
      } else if (isGoogleOAuth) {
        document.getElementById('edit-google-client-id').value = config.api_key || '';
        document.getElementById('edit-google-callback-url').value = config.endpoint_url || 'http://localhost:5005/auth/google/callback';
        document.getElementById('edit-google-client-secret').value = '';
        
        // Highlight callback URL field for first-time setup
        if (!config.api_key) {
          setTimeout(() => {
            document.getElementById('edit-google-callback-url').focus();
            document.getElementById('edit-google-callback-url').select();
          }, 300);
        }
      } else if (isSendGrid) {
        // Populate SendGrid fields
        document.getElementById('edit-sendgrid-api-key').value = '';
        document.getElementById('edit-sendgrid-email-from').value = config.additional_config?.email_from || 'noreply@pixelnest.com';
        document.getElementById('edit-sendgrid-email-from-name').value = config.additional_config?.email_from_name || 'PixelNest';
        document.getElementById('edit-sendgrid-endpoint').value = config.endpoint_url || 'https://api.sendgrid.com/v3';
      } else if (isSuno) {
        // Populate Suno fields
        document.getElementById('edit-suno-api-key').value = '';
        document.getElementById('edit-suno-endpoint').value = config.endpoint_url || 'https://api.sunoapi.org';
        document.getElementById('edit-suno-callback-url').value = config.additional_config?.callback_url || 'https://pixelnest.app/music/callback/suno';
      } else {
        document.getElementById('edit-api_key').value = '';
        document.getElementById('edit-endpoint_url').value = config.endpoint_url || '';
        document.getElementById('edit-rate_limit').value = config.rate_limit || '';
      }
      
      document.getElementById('edit-is_active').checked = config.is_active;
      
      document.getElementById('editModal').classList.remove('hidden');
      document.getElementById('editModal').classList.add('flex');
    }

    function closeEditModal() {
      document.getElementById('editModal').classList.add('hidden');
      document.getElementById('editModal').classList.remove('flex');
    }

    document.getElementById('editForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const serviceName = document.getElementById('edit-service_name').value;
      const isTripay = serviceName === 'TRIPAY';
      const isGroq = serviceName === 'GROQ';
      const isGoogleOAuth = serviceName === 'GOOGLE_OAUTH';
      const isSendGrid = serviceName === 'SENDGRID';
      const isSuno = serviceName === 'SUNO';
      
      const data = {
        is_active: document.getElementById('edit-is_active').checked
      };
      
      if (isTripay) {
        // Handle Tripay fields
        const merchantCode = document.getElementById('edit-tripay-merchant-code').value.trim();
        const merchantName = document.getElementById('edit-tripay-merchant-name').value.trim();
        const apiKey = document.getElementById('edit-tripay-api-key').value.trim();
        const privateKey = document.getElementById('edit-tripay-private-key').value.trim();
        const callbackUrl = document.getElementById('edit-tripay-callback-url').value.trim();
        const endpointUrl = document.getElementById('edit-tripay-endpoint').value;
        
        if (apiKey) data.api_key = apiKey;
        if (privateKey) data.api_secret = privateKey;
        if (endpointUrl) data.endpoint_url = endpointUrl;
        
        // Build additional_config object
        data.additional_config = {};
        if (merchantCode) data.additional_config.merchant_code = merchantCode;
        if (merchantName) data.additional_config.merchant_name = merchantName;
        if (callbackUrl) data.additional_config.callback_url = callbackUrl;
        
        // Validation
        const config = API_CONFIGS.find(c => c.service_name === serviceName);
        if (!merchantCode && !config.additional_config?.merchant_code) {
          showToast('Kode Merchant is required', 'error');
          return;
        }
        if (!apiKey && !config.api_key) {
          showToast('API Key is required', 'error');
          return;
        }
      } else if (isGroq) {
        // Handle Groq fields
        const apiKey = document.getElementById('edit-groq-api-key').value.trim();
        const defaultModel = document.getElementById('edit-groq-model').value.trim();
        const endpointUrl = document.getElementById('edit-groq-endpoint').value.trim();
        
        if (apiKey) data.api_key = apiKey;
        if (endpointUrl) data.endpoint_url = endpointUrl;
        
        // Build additional_config object
        data.additional_config = {};
        if (defaultModel) data.additional_config.default_model = defaultModel;
        
        // Validation
        const config = API_CONFIGS.find(c => c.service_name === serviceName);
        if (!apiKey && !config.api_key) {
          showToast('Groq API Key is required', 'error');
          return;
        }
      } else if (isGoogleOAuth) {
        const clientId = document.getElementById('edit-google-client-id').value.trim();
        const clientSecret = document.getElementById('edit-google-client-secret').value.trim();
        const callbackUrl = document.getElementById('edit-google-callback-url').value.trim();
        
        if (clientId) data.api_key = clientId;
        if (clientSecret) data.api_secret = clientSecret;
        if (callbackUrl) data.endpoint_url = callbackUrl;
        
        if (!clientId && !API_CONFIGS.find(c => c.service_name === serviceName).api_key) {
          showToast('Google Client ID is required', 'error');
          return;
        }
      } else if (isSendGrid) {
        // Handle SendGrid fields
        const apiKey = document.getElementById('edit-sendgrid-api-key').value.trim();
        const emailFrom = document.getElementById('edit-sendgrid-email-from').value.trim();
        const emailFromName = document.getElementById('edit-sendgrid-email-from-name').value.trim();
        const endpointUrl = document.getElementById('edit-sendgrid-endpoint').value.trim();
        
        if (apiKey) data.api_key = apiKey;
        if (endpointUrl) data.endpoint_url = endpointUrl;
        
        // Build additional_config object
        data.additional_config = {};
        if (emailFrom) data.additional_config.email_from = emailFrom;
        if (emailFromName) data.additional_config.email_from_name = emailFromName;
        
        // Validation
        const config = API_CONFIGS.find(c => c.service_name === serviceName);
        if (!emailFrom && !config.additional_config?.email_from) {
          showToast('Email From is required', 'error');
          return;
        }
      } else if (isSuno) {
        // Handle Suno fields
        const apiKey = document.getElementById('edit-suno-api-key').value.trim();
        const endpointUrl = document.getElementById('edit-suno-endpoint').value.trim();
        const callbackUrl = document.getElementById('edit-suno-callback-url').value.trim();
        
        if (apiKey) data.api_key = apiKey;
        if (endpointUrl) data.endpoint_url = endpointUrl;
        
        // Build additional_config object with callback_url
        const config = API_CONFIGS.find(c => c.service_name === serviceName);
        data.additional_config = {
          ...(config.additional_config || {}),  // Preserve existing config
          callback_url: callbackUrl || 'https://pixelnest.app/music/callback/suno'
        };
        
        // Validation
        if (!apiKey && !config.api_key) {
          showToast('Suno API Key is required', 'error');
          return;
        }
        if (!callbackUrl && !config.additional_config?.callback_url) {
          showToast('Callback URL is required', 'error');
          return;
        }
      } else {
        const apiKey = document.getElementById('edit-api_key').value.trim();
        const endpointUrl = document.getElementById('edit-endpoint_url').value.trim();
        const rateLimit = document.getElementById('edit-rate_limit').value;
        
        if (apiKey) data.api_key = apiKey;
        if (endpointUrl) data.endpoint_url = endpointUrl;
        if (rateLimit) data.rate_limit = parseInt(rateLimit);
      }

      // Debug log
      console.log('📤 Submitting Suno config:', data);
      if (isSuno && data.additional_config) {
        console.log('   Callback URL:', data.additional_config.callback_url);
      }
      
      try {
        showLoading();
        const result = await apiRequest('/admin/api-configs/' + serviceName, {
          method: 'PUT',
          body: JSON.stringify(data)
        });
        
        hideLoading();
        
        // Show success message
        showToast(serviceName + ' configuration updated successfully!', 'success');
        
        // Show warning if .env sync failed
        if (result.warning || !result.envSynced) {
          setTimeout(() => {
            showToast('⚠️  Database updated but .env may need manual sync', 'warning');
          }, 1500);
        }
        
        // Show sync status info
        if (result.syncStatus && !result.syncStatus.inSync) {
          setTimeout(() => {
            showToast('Restart server to apply changes: npm run dev', 'info');
          }, 3000);
        }
        
        setTimeout(() => location.reload(), 4000);
      } catch (error) {
        hideLoading();
        showToast(error.message, 'error');
      }
    });

    async function toggleApiStatus(serviceName, newStatus) {
      const statusText = newStatus ? 'enable' : 'disable';
      if (!confirm('Are you sure you want to ' + statusText + ' ' + serviceName + '?')) {
        return;
      }

      try {
        showLoading();
        await apiRequest('/admin/api-configs/' + serviceName, {
          method: 'PUT',
          body: JSON.stringify({ is_active: newStatus })
        });
        
        hideLoading();
        showToast(serviceName + ' ' + statusText + 'd successfully!', 'success');
        setTimeout(() => location.reload(), 500);
      } catch (error) {
        hideLoading();
        showToast(error.message, 'error');
      }
    }

    // Add New API Config functions
    function openAddModal() {
      document.getElementById('addModal').classList.remove('hidden');
      document.getElementById('addModal').classList.add('flex');
    }

    function closeAddModal() {
      document.getElementById('addModal').classList.add('hidden');
      document.getElementById('addModal').classList.remove('flex');
      document.getElementById('addForm').reset();
    }

    function toggleAddServiceFields(serviceName) {
      const isTripay = serviceName === 'TRIPAY';
      document.getElementById('add-tripay-fields').classList.toggle('hidden', !isTripay);
      document.getElementById('add-generic-fields').classList.toggle('hidden', isTripay || !serviceName);
    }

    // Handle Add Form submission
    document.getElementById('addForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const serviceName = document.getElementById('add-service_name').value;
      if (!serviceName) {
        showToast('Please select a service type', 'error');
        return;
      }

      const isTripay = serviceName === 'TRIPAY';
      const data = {
        service_name: serviceName,
        is_active: document.getElementById('add-is_active').checked
      };

      if (isTripay) {
        const merchantCode = document.getElementById('add-tripay-merchant-code').value.trim();
        const merchantName = document.getElementById('add-tripay-merchant-name').value.trim();
        const apiKey = document.getElementById('add-tripay-api-key').value.trim();
        const privateKey = document.getElementById('add-tripay-private-key').value.trim();
        const callbackUrl = document.getElementById('add-tripay-callback-url').value.trim();
        const endpointUrl = document.getElementById('add-tripay-endpoint').value;

        if (!merchantCode || !apiKey || !privateKey) {
          showToast('Please fill all required Tripay fields', 'error');
          return;
        }

        data.api_key = apiKey;
        data.api_secret = privateKey;
        data.endpoint_url = endpointUrl;
        data.additional_config = {
          merchant_code: merchantCode,
          merchant_name: merchantName,
          callback_url: callbackUrl || window.location.origin + '/api/payment/callback'
        };
      } else {
        const apiKey = document.getElementById('add-api_key').value.trim();
        const endpointUrl = document.getElementById('add-endpoint_url').value.trim();

        if (!apiKey) {
          showToast('API Key is required', 'error');
          return;
        }

        data.api_key = apiKey;
        data.endpoint_url = endpointUrl;
      }

      try {
        showLoading();
        const result = await apiRequest('/admin/api-configs', {
          method: 'POST',
          body: JSON.stringify(data)
        });
        
        hideLoading();
        showToast(serviceName + ' configuration added successfully!', 'success');
        closeAddModal();
        
        setTimeout(() => location.reload(), 1500);
      } catch (error) {
        hideLoading();
        showToast(error.message, 'error');
      }
    });

    // Close modal on ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeEditModal();
        closeAddModal();
      }
    });

    // Copy to clipboard function
    function copyToClipboard(text) {
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(() => {
          showToast('Callback URL copied to clipboard!', 'success');
        }).catch(err => {
          fallbackCopy(text);
        });
      } else {
        fallbackCopy(text);
      }
    }

    function fallbackCopy(text) {
      const textArea = document.createElement('textarea');
      textArea.value = text;
      textArea.style.position = 'fixed';
      textArea.style.left = '-999999px';
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand('copy');
        showToast('Callback URL copied to clipboard!', 'success');
      } catch (err) {
        showToast('Failed to copy URL', 'error');
      }
      document.body.removeChild(textArea);
    }

    // Copy callback URL from input field
    function copyCallbackFromInput() {
      const input = document.getElementById('edit-google-callback-url');
      const url = input.value.trim();
      if (!url) {
        showToast('Please enter a callback URL first', 'error');
        return;
      }
      copyToClipboard(url);
    }

    // Copy Tripay callback URL
    function copyTripayCallback() {
      const input = document.getElementById('edit-tripay-callback-url');
      const url = input.value.trim();
      if (!url) {
        showToast('Please enter a callback URL first', 'error');
        return;
      }
      copyToClipboard(url);
    }

    // Toggle API Key visibility
    function toggleApiKey(button) {
      const container = button.parentElement;
      const display = container.querySelector('.api-key-display');
      const icon = button.querySelector('i');
      
      const fullKey = display.getAttribute('data-key');
      const maskedKey = display.getAttribute('data-masked');
      const isHidden = icon.classList.contains('fa-eye');
      
      if (isHidden) {
        // Show full key
        display.textContent = fullKey;
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
        button.title = 'Hide';
        display.style.maxWidth = 'none';
        display.style.wordBreak = 'break-all';
      } else {
        // Hide key
        display.textContent = maskedKey;
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
        button.title = 'Show';
        display.style.maxWidth = '180px';
      }
    }

    // Toggle API Secret visibility
    function toggleApiSecret(button) {
      const container = button.parentElement;
      const display = container.querySelector('.api-secret-display');
      const icon = button.querySelector('i');
      
      const fullSecret = display.getAttribute('data-secret');
      const maskedSecret = display.getAttribute('data-masked');
      const isHidden = icon.classList.contains('fa-eye');
      
      if (isHidden) {
        // Show full secret
        display.textContent = fullSecret;
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
        button.title = 'Hide';
        display.style.wordBreak = 'break-all';
      } else {
        // Hide secret
        display.textContent = maskedSecret;
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
        button.title = 'Show';
      }
    }

    // Auto-hide all keys after 30 seconds if shown
    let autoHideTimers = [];
    
    document.addEventListener('click', function(e) {
      if (e.target.closest('button[onclick^="toggleApi"]')) {
        // Clear existing timers
        autoHideTimers.forEach(timer => clearTimeout(timer));
        autoHideTimers = [];
        
        // Set new timer to auto-hide after 30 seconds
        const timer = setTimeout(() => {
          document.querySelectorAll('.fa-eye-slash').forEach(icon => {
            const button = icon.closest('button');
            if (button && button.onclick) {
              button.click();
            }
          });
          showToast('API keys auto-hidden for security', 'info');
        }, 30000);
        
        autoHideTimers.push(timer);
      }
    });
  </script>
</body>
</html>
