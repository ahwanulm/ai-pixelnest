<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PixelNest Admin</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/favicon.png">
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%- include('../partials/admin-styles') %>
</head>
<body>
  <div class="flex h-screen overflow-hidden">
    <%- include('../partials/admin-sidebar') %>

    <div class="flex-1 ml-64 overflow-y-auto content-area flex flex-col">
      <%- include('../partials/admin-header', { pageTitle: title }) %>

      <main class="p-8 flex-1">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="text-gray-400">Configure API keys and settings for external services</p>
          </div>
          <button onclick="openAddModal()" class="px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white rounded-lg transition flex items-center">
            <i class="fas fa-plus mr-2"></i> Add New API Config
          </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <% apiConfigs.filter(config => config.service_name !== 'EMAIL').forEach(config => { %>
            <div class="glass-strong rounded-xl p-6">
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center space-x-3">
                  <div class="w-12 h-12 <%= config.service_name === 'TRIPAY' ? 'bg-yellow-500/20' : config.service_name === 'GROQ' ? 'bg-orange-500/20' : config.service_name === 'SUNO' ? 'bg-pink-500/20' : config.service_name === 'EMAIL' || config.service_name === 'SENDGRID' ? 'bg-blue-500/20' : 'bg-violet-500/20' %> rounded-lg flex items-center justify-center">
                    <i class="fas <%= config.service_name === 'TRIPAY' ? 'fa-credit-card' : config.service_name === 'GROQ' ? 'fa-wand-magic-sparkles' : config.service_name === 'SUNO' ? 'fa-music' : config.service_name === 'EMAIL' || config.service_name === 'SENDGRID' ? 'fa-envelope' : config.service_name === 'GOOGLE_OAUTH' ? 'fa-google' : config.service_name === 'OPENAI' ? 'fa-brain' : 'fa-plug' %> <%= config.service_name === 'TRIPAY' ? 'text-yellow-400' : config.service_name === 'GROQ' ? 'text-orange-400' : config.service_name === 'SUNO' ? 'text-pink-400' : config.service_name === 'EMAIL' || config.service_name === 'SENDGRID' ? 'text-blue-400' : 'text-violet-400' %> text-xl"></i>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-white"><%= config.service_name %></h3>
                    <p class="text-sm text-gray-400 truncate" style="max-width: 200px;"><%= config.endpoint_url %></p>
                  </div>
                </div>
                <div class="flex flex-col items-end space-y-1">
                  <span class="px-3 py-1 text-xs rounded-full <%= config.is_active ? 'badge-success' : 'badge-error' %>">
                    <%= config.is_active ? 'Active' : 'Inactive' %>
                  </span>
                  <% if (config.syncStatus && !config.syncStatus.inSync) { %>
                    <span class="px-2 py-1 text-xs rounded bg-amber-500/20 text-amber-300 border border-amber-500/30" title="<%= config.syncStatus.message %>">
                      <i class="fas fa-exclamation-triangle"></i> Out of Sync
                    </span>
                  <% } else if (config.syncStatus && config.syncStatus.inSync) { %>
                    <span class="px-2 py-1 text-xs rounded bg-green-500/20 text-green-300 border border-green-500/30" title="Database and .env are in sync">
                      <i class="fas fa-check-circle"></i> Synced
                    </span>
                  <% } %>
                </div>
              </div>

              <div class="space-y-2 mb-4">
                <% if (config.service_name === 'TRIPAY') { %>
                  <!-- TRIPAY Payment Gateway Fields -->
                  <div class="p-3 bg-white/5 rounded-lg space-y-3">
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Kode Merchant:</span>
                      <span class="text-white font-mono text-xs text-right">
                        <%= config.additional_config?.merchant_code || 'Not configured' %>
                      </span>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Nama Merchant:</span>
                      <span class="text-white font-mono text-xs text-right">
                        <%= config.additional_config?.merchant_name || 'Not configured' %>
                      </span>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">API Key:</span>
                      <div class="flex items-center gap-2 ml-2">
                        <span class="text-white font-mono text-xs text-right api-key-display" 
                              data-key="<%= config.api_key || '' %>" 
                              data-masked="<%= config.api_key ? config.api_key.substring(0, 15) + '...' : 'Not configured' %>"
                              style="max-width: 180px;">
                          <%= config.api_key ? config.api_key.substring(0, 15) + '...' : 'Not configured' %>
                        </span>
                        <% if (config.api_key) { %>
                          <button onclick="toggleApiKey(this)" 
                                  class="text-gray-400 hover:text-white text-xs transition"
                                  title="Show/Hide">
                            <i class="fas fa-eye"></i>
                          </button>
                        <% } %>
                      </div>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Private Key:</span>
                      <div class="flex items-center gap-2 ml-2">
                        <span class="text-white font-mono text-xs text-right api-secret-display" 
                              data-secret="<%= config.api_secret || '' %>" 
                              data-masked="••••••••••••••••">
                          <%= config.api_secret ? '••••••••••••••••' : 'Not configured' %>
                        </span>
                        <% if (config.api_secret) { %>
                          <button onclick="toggleApiSecret(this)" 
                                  class="text-gray-400 hover:text-white text-xs transition"
                                  title="Show/Hide">
                            <i class="fas fa-eye"></i>
                          </button>
                        <% } %>
                      </div>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="space-y-1">
                      <div class="flex items-center justify-between">
                        <span class="text-gray-400 text-xs font-medium">Callback URL:</span>
                        <button onclick="copyToClipboard('<%= config.additional_config?.callback_url || 'Not configured' %>')" 
                                class="text-violet-400 hover:text-violet-300 text-xs">
                          <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                      </div>
                      <div class="p-2 bg-yellow-500/10 border border-yellow-500/30 rounded">
                        <code class="text-yellow-300 text-xs break-all"><%= config.additional_config?.callback_url || 'http://localhost:5005/api/payment/callback' %></code>
                      </div>
                      <p class="text-xs text-gray-500 italic">
                        <i class="fas fa-info-circle mr-1"></i>Use this URL in Tripay Dashboard
                      </p>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Endpoint:</span>
                      <span class="text-white font-mono text-xs text-right">
                        <%= config.endpoint_url || 'Not configured' %>
                      </span>
                    </div>
                  </div>
                <% } else if (config.service_name === 'GOOGLE_OAUTH') { %>
                  <div class="p-3 bg-white/5 rounded-lg space-y-3">
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Client ID:</span>
                      <div class="flex items-center gap-2 ml-2">
                        <span class="text-white font-mono text-xs text-right break-all api-key-display" 
                              data-key="<%= config.api_key || '' %>" 
                              data-masked="<%= config.api_key ? config.api_key.substring(0, 20) + '...' : 'Not configured' %>"
                              style="max-width: 180px;">
                          <%= config.api_key ? config.api_key.substring(0, 20) + '...' : 'Not configured' %>
                        </span>
                        <% if (config.api_key) { %>
                          <button onclick="toggleApiKey(this)" 
                                  class="text-gray-400 hover:text-white text-xs transition"
                                  title="Show/Hide">
                            <i class="fas fa-eye"></i>
                          </button>
                        <% } %>
                      </div>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Client Secret:</span>
                      <div class="flex items-center gap-2 ml-2">
                        <span class="text-white font-mono text-xs text-right api-secret-display" 
                              data-secret="<%= config.api_secret || '' %>" 
                              data-masked="••••••••••••••••">
                          <%= config.api_secret ? '••••••••••••••••' : 'Not configured' %>
                        </span>
                        <% if (config.api_secret) { %>
                          <button onclick="toggleApiSecret(this)" 
                                  class="text-gray-400 hover:text-white text-xs transition"
                                  title="Show/Hide">
                            <i class="fas fa-eye"></i>
                          </button>
                        <% } %>
                      </div>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="space-y-1">
                      <div class="flex items-center justify-between">
                        <span class="text-gray-400 text-xs font-medium">Callback URL:</span>
                        <button onclick="copyToClipboard('<%= config.endpoint_url %>')" 
                                class="text-violet-400 hover:text-violet-300 text-xs">
                          <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                      </div>
                      <div class="p-2 bg-violet-500/10 border border-violet-500/30 rounded">
                        <code class="text-violet-300 text-xs break-all"><%= config.endpoint_url || 'http://localhost:5005/auth/google/callback' %></code>
                      </div>
                      <p class="text-xs text-gray-500 italic">
                        <i class="fas fa-info-circle mr-1"></i>Use this URL in Google Cloud Console
                      </p>
                    </div>
                  </div>
                <% } else if (config.service_name === 'GROQ') { %>
                  <!-- GROQ AI Service Fields -->
                  <div class="p-3 bg-white/5 rounded-lg space-y-3">
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">API Key:</span>
                      <div class="flex items-center gap-2 ml-2">
                        <span class="text-white font-mono text-xs text-right api-key-display" 
                              data-key="<%= config.api_key || '' %>" 
                              data-masked="<%= config.api_key ? config.api_key.substring(0, 15) + '...' : 'Not configured' %>"
                              style="max-width: 180px;">
                          <%= config.api_key ? config.api_key.substring(0, 15) + '...' : 'Not configured' %>
                        </span>
                        <% if (config.api_key) { %>
                          <button onclick="toggleApiKey(this)" 
                                  class="text-gray-400 hover:text-white text-xs transition"
                                  title="Show/Hide">
                            <i class="fas fa-eye"></i>
                          </button>
                        <% } %>
                      </div>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Model:</span>
                      <span class="text-white font-mono text-xs text-right">
                        <%= config.additional_config?.default_model || 'llama-3.3-70b-versatile' %>
                      </span>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Endpoint:</span>
                      <span class="text-white font-mono text-xs text-right">
                        <%= config.endpoint_url || 'Not configured' %>
                      </span>
                    </div>
                    <div class="mt-3 p-2 bg-orange-500/10 border border-orange-500/30 rounded">
                      <p class="text-xs text-orange-300">
                        <i class="fas fa-wand-magic-sparkles mr-1"></i>Used for intelligent prompt enhancement
                      </p>
                    </div>
                  </div>
                <% } else if (config.service_name === 'SUNO') { %>
                  <!-- SUNO AI Music Generation -->
                  <div class="p-3 bg-white/5 rounded-lg space-y-3">
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">API Key:</span>
                      <div class="flex items-center gap-2 ml-2">
                        <span class="text-white font-mono text-xs text-right api-key-display" 
                              data-key="<%= config.api_key || '' %>" 
                              data-masked="<%= config.api_key ? config.api_key.substring(0, 15) + '...' : 'Not configured' %>"
                              style="max-width: 180px;">
                          <%= config.api_key ? config.api_key.substring(0, 15) + '...' : 'Not configured' %>
                        </span>
                        <% if (config.api_key) { %>
                          <button onclick="toggleApiKey(this)" 
                                  class="text-gray-400 hover:text-white text-xs transition"
                                  title="Show/Hide">
                            <i class="fas fa-eye"></i>
                          </button>
                        <% } %>
                      </div>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Endpoint:</span>
                      <span class="text-white font-mono text-xs text-right">
                        <%= config.endpoint_url || 'Not configured' %>
                      </span>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Callback URL:</span>
                      <div class="flex items-center gap-2 ml-2">
                        <span class="text-white font-mono text-xs text-right" style="max-width: 180px; word-break: break-all;">
                          <%= config.additional_config?.callback_url || 'Not configured' %>
                        </span>
                        <% if (config.additional_config?.callback_url) { %>
                          <button onclick="copyToClipboard('<%= config.additional_config.callback_url %>')" 
                                  class="text-pink-400 hover:text-pink-300 text-xs transition"
                                  title="Copy">
                            <i class="fas fa-copy"></i>
                          </button>
                        <% } %>
                      </div>
                    </div>
                    <div class="mt-3 p-2 bg-pink-500/10 border border-pink-500/30 rounded">
                      <p class="text-xs text-pink-300">
                        <i class="fas fa-music mr-1"></i>Used for AI music generation via Suno API
                      </p>
                    </div>
                  </div>
                <% } else if (config.service_name === 'SENDGRID') { %>
                  <!-- SENDGRID Email Service Fields -->
                  <div class="p-3 bg-white/5 rounded-lg space-y-3">
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">API Key:</span>
                      <div class="flex items-center gap-2 ml-2">
                        <span class="text-white font-mono text-xs text-right api-key-display" 
                              data-key="<%= config.api_key || '' %>" 
                              data-masked="<%= config.api_key ? config.api_key.substring(0, 15) + '...' : 'Not configured' %>"
                              style="max-width: 180px;">
                          <%= config.api_key ? config.api_key.substring(0, 15) + '...' : 'Not configured' %>
                        </span>
                        <% if (config.api_key) { %>
                          <button onclick="toggleApiKey(this)" 
                                  class="text-gray-400 hover:text-white text-xs transition"
                                  title="Show/Hide">
                            <i class="fas fa-eye"></i>
                          </button>
                        <% } %>
                      </div>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Email From:</span>
                      <span class="text-white font-mono text-xs text-right">
                        <%= config.additional_config?.email_from || 'Not configured' %>
                      </span>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Sender Name:</span>
                      <span class="text-white font-mono text-xs text-right">
                        <%= config.additional_config?.email_from_name || 'Not configured' %>
                      </span>
                    </div>
                    <div class="h-px bg-white/10"></div>
                    <div class="flex items-start justify-between">
                      <span class="text-gray-400 text-xs font-medium">Endpoint:</span>
                      <span class="text-white font-mono text-xs text-right">
                        <%= config.endpoint_url || 'Not configured' %>
                      </span>
                    </div>
                    <div class="mt-3 p-2 bg-blue-500/10 border border-blue-500/30 rounded">
                      <p class="text-xs text-blue-300">
                        <i class="fas fa-info-circle mr-1"></i>Get your API key from 
                        <a href="https://app.sendgrid.com/settings/api_keys" target="_blank" class="underline hover:text-blue-200">
                          SendGrid Dashboard
                        </a>
                      </p>
                    </div>
                  </div>
                <% } else { %>
                  <div class="flex items-center justify-between text-sm p-2 bg-white/5 rounded">
                    <span class="text-gray-400">API Key:</span>
                    <div class="flex items-center gap-2">
                      <span class="text-white font-mono text-xs api-key-display" 
                            data-key="<%= config.api_key || '' %>" 
                            data-masked="••••••••">
                        <%= config.api_key ? '••••••••' : 'Not set' %>
                      </span>
                      <% if (config.api_key) { %>
                        <button onclick="toggleApiKey(this)" 
                                class="text-gray-400 hover:text-white text-xs transition"
                                title="Show/Hide">
                          <i class="fas fa-eye"></i>
                        </button>
                      <% } %>
                    </div>
                  </div>
                  <% if (config.rate_limit) { %>
                    <div class="flex items-center justify-between text-sm p-2 bg-white/5 rounded">
                      <span class="text-gray-400">Rate Limit:</span>
                      <span class="text-white font-medium"><%= config.rate_limit %> req/min</span>
                    </div>
                  <% } %>
                <% } %>
              </div>

              <div class="flex space-x-2">
                <button onclick="editApiConfig('<%= config.service_name %>')" class="flex-1 px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white rounded-lg transition">
                  <i class="fas fa-edit mr-2"></i> Configure
                </button>
                <button onclick="toggleApiStatus('<%= config.service_name %>', <%= !config.is_active %>)" 
                        class="flex-1 px-4 py-2 <%= config.is_active ? 'bg-red-600 hover:bg-red-700' : 'bg-green-600 hover:bg-green-700' %> text-white rounded-lg transition">
                  <i class="fas <%= config.is_active ? 'fa-ban' : 'fa-check' %> mr-2"></i> <%= config.is_active ? 'Disable' : 'Enable' %>
                </button>
              </div>
            </div>
          <% }); %>
        </div>
      </main>

      <%- include('../partials/admin-footer') %>
    </div>
  </div>

  <!-- Add New API Config Modal -->
  <div id="addModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50">
    <div class="glass-strong rounded-2xl p-8 max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
      <h3 class="text-2xl font-bold text-white mb-6">Add New API Configuration</h3>
      <form id="addForm" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">
            Service Name <span class="text-red-500">*</span>
          </label>
          <select id="add-service_name" name="service_name" required
                  onchange="toggleAddServiceFields(this.value)"
                  class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:border-violet-500">
            <option value="">-- Select Service --</option>
            <option value="TRIPAY">TRIPAY (Payment Gateway)</option>
            <option value="GROQ">GROQ (AI Prompt Enhancement)</option>
            <option value="OPENAI">OPENAI (AI Models)</option>
            <option value="REPLICATE">REPLICATE (AI Models)</option>
            <option value="CUSTOM">CUSTOM (Other Service)</option>
          </select>
        </div>

        <!-- Tripay Fields for Add -->
        <div id="add-tripay-fields" class="hidden space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">
              Kode Merchant <span class="text-red-500">*</span>
            </label>
            <input type="text" id="add-tripay-merchant-code" name="merchant_code"
                   class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:border-violet-500 font-mono text-sm"
                   placeholder="T41400">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">
              Nama Merchant
            </label>
            <input type="text" id="add-tripay-merchant-name" name="merchant_name"
                   class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:border-violet-500 text-sm"
                   placeholder="Merchant Sandbox">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">
              API Key <span class="text-red-500">*</span>
            </label>
            <input type="password" id="add-tripay-api-key" name="api_key"
                   class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:border-violet-500 font-mono text-sm"
                   placeholder="DEV-xxxxxxxxxxxxx">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">
              Private Key <span class="text-red-500">*</span>
            </label>
            <input type="password" id="add-tripay-private-key" name="api_secret"
                   class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:border-violet-500 font-mono text-sm"
                   placeholder="xxxxx-xxxxx-xxxxx">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">
              Callback URL <span class="text-red-500">*</span>
            </label>
            <input type="url" id="add-tripay-callback-url" name="callback_url"
                   class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:border-violet-500 font-mono text-sm"
                   placeholder="https://your-domain.com/api/payment/callback">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">
              Endpoint URL <span class="text-red-500">*</span>
            </label>
            <select id="add-tripay-endpoint" name="endpoint_url"
                    class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:border-violet-500 text-sm">
              <option value="https://tripay.co.id/api-sandbox">Sandbox (Testing)</option>
              <option value="https://tripay.co.id/api">Production (Live)</option>
            </select>
          </div>
        </div>

        <!-- Generic Fields for Add -->
        <div id="add-generic-fields" class="hidden space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">
              API Key <span class="text-red-500">*</span>
            </label>
            <input type="password" id="add-api_key" name="api_key"
                   class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:border-violet-500 font-mono text-sm"
                   placeholder="Enter API key">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Endpoint URL</label>
            <input type="url" id="add-endpoint_url" name="endpoint_url"
                   class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:border-violet-500 font-mono text-sm">
          </div>
        </div>

        <div class="flex items-center pt-4 border-t" style="border-color: rgba(255, 255, 255, 0.1);">
