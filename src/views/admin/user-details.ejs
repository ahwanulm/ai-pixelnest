<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PixelNest Admin</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/favicon.png">
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/js/theme-manager.js"></script>
  <%- include('../partials/admin-styles') %>
  <style>
    .generation-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1rem;
    }
    .generation-item {
      position: relative;
      background: rgba(255,255,255,0.03);
      border-radius: 12px;
      overflow: hidden;
      transition: all 0.3s;
      cursor: pointer;
    }
    .generation-item:hover {
      background: rgba(255,255,255,0.08);
      transform: translateY(-4px);
    }
    .generation-item img, .generation-item video {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }
    .generation-badge {
      position: absolute;
      top: 8px;
      right: 8px;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      backdrop-filter: blur(10px);
    }
    .badge-image { background: rgba(59, 130, 246, 0.8); color: white; }
    .badge-video { background: rgba(139, 92, 246, 0.8); color: white; }
    
    .modal {
      display: none;
      position: fixed;
      z-index: 9999;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.8);
      backdrop-filter: blur(5px);
    }
    .modal.active { display: flex; align-items: center; justify-content: center; }
    .modal-content {
      background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
      border-radius: 16px;
      max-width: 600px;
      width: 90%;
      max-height: 90vh;
      overflow-y: auto;
      padding: 2rem;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    
    .media-modal-content {
      max-width: 90vw;
      max-height: 90vh;
      padding: 0;
      overflow: visible;
    }
    .media-modal-content img,
    .media-modal-content video {
      max-width: 100%;
      max-height: 85vh;
      width: auto;
      height: auto;
      border-radius: 12px;
    }
    
    .tab-buttons {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      border-bottom: 2px solid rgba(139, 92, 246, 0.2);
    }
    .tab-button {
      padding: 0.75rem 1.5rem;
      background: transparent;
      border: none;
      color: #9ca3af;
      cursor: pointer;
      transition: all 0.3s;
      border-bottom: 3px solid transparent;
      font-weight: 500;
    }
    .tab-button.active {
      color: #8b5cf6;
      border-bottom-color: #8b5cf6;
    }
    .tab-content {
      display: none;
    }
    .tab-content.active {
      display: block;
    }
  </style>
</head>
<body>
  <div class="flex h-screen overflow-hidden">
    <%- include('../partials/admin-sidebar') %>

    <div class="flex-1 ml-64 overflow-y-auto content-area flex flex-col">
      <%- include('../partials/admin-header', { pageTitle: title }) %>

      <main class="p-8 flex-1">
        <a href="/admin/users" class="text-violet-400 hover:text-violet-300 mb-6 inline-block">
          <i class="fas fa-arrow-left mr-2"></i> Back to Users
        </a>

        <!-- User Info -->
        <div class="glass-strong rounded-xl p-6 mb-6">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-6">
              <img src="<%= userDetails.user.avatar_url || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(userDetails.user.name) %>" 
                   class="w-24 h-24 rounded-full ring-4 ring-violet-500" id="userAvatar">
              <div>
                <h2 class="text-2xl font-bold text-white" id="userName"><%= userDetails.user.name %></h2>
                <p class="text-gray-400" id="userEmail"><%= userDetails.user.email %></p>
                <div class="mt-2 space-x-2">
                  <span class="px-3 py-1 text-xs rounded-full <%= userDetails.user.role === 'admin' ? 'badge-info' : 'badge-success' %>" id="userRole">
                    <%= userDetails.user.role || 'user' %>
                  </span>
                  <span class="px-3 py-1 text-xs rounded-full <%= userDetails.user.is_active ? 'badge-success' : 'badge-error' %>" id="userStatus">
                    <%= userDetails.user.is_active ? 'Active' : 'Inactive' %>
                  </span>
                </div>
              </div>
            </div>
            
            <!-- Action Buttons -->
            <div class="flex gap-2">
              <button onclick="openEditUserModal()" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition">
                <i class="fas fa-edit mr-2"></i> Edit User
              </button>
              <button onclick="openEditCreditsModal()" class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition">
                <i class="fas fa-coins mr-2"></i> Edit Credits
              </button>
              <button onclick="deleteUser()" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition">
                <i class="fas fa-trash mr-2"></i> Delete
              </button>
            </div>
          </div>

          <div class="grid grid-cols-4 gap-4 mt-6">
            <div class="p-4 bg-blue-500/10 rounded-lg cursor-pointer" onclick="openEditCreditsModal()">
              <p class="text-sm text-gray-400">Credits</p>
              <p class="text-2xl font-bold text-blue-400" id="userCredits"><%= userDetails.user.credits || 0 %></p>
              <p class="text-xs text-blue-300 mt-1"><i class="fas fa-edit"></i> Click to edit</p>
            </div>
            <div class="p-4 bg-green-500/10 rounded-lg">
              <p class="text-sm text-gray-400">Generations</p>
              <p class="text-2xl font-bold text-green-400"><%= userDetails.generations.length %></p>
            </div>
            <div class="p-4 bg-purple-500/10 rounded-lg">
              <p class="text-sm text-gray-400">Joined</p>
              <p class="text-lg font-bold text-purple-400"><%= new Date(userDetails.user.created_at).toLocaleDateString() %></p>
            </div>
            <div class="p-4 bg-yellow-500/10 rounded-lg">
              <p class="text-sm text-gray-400">Last Login</p>
              <p class="text-lg font-bold text-yellow-400"><%= userDetails.user.last_login ? new Date(userDetails.user.last_login).toLocaleDateString() : 'Never' %></p>
            </div>
          </div>
        </div>

        <!-- Tabs Navigation -->
        <div class="glass-strong rounded-xl mb-6">
          <div class="tab-buttons">
            <button class="tab-button active" onclick="switchTab('generations')">
              <i class="fas fa-images mr-2"></i> Generated Content (<%= userDetails.generations.length %>)
            </button>
            <button class="tab-button" onclick="switchTab('activity')">
              <i class="fas fa-history mr-2"></i> Activity
            </button>
            <button class="tab-button" onclick="switchTab('credits')">
              <i class="fas fa-coins mr-2"></i> Credit History
            </button>
          </div>
        </div>

        <!-- Tab: Generated Content -->
        <div id="tab-generations" class="tab-content active">
          <div class="glass-strong rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-white">Generated Images & Videos</h3>
              <div class="flex gap-2">
                <button onclick="filterGenerations('all')" class="filter-btn px-3 py-1 bg-violet-600 text-white rounded text-sm active">
                  All
                </button>
                <button onclick="filterGenerations('image')" class="filter-btn px-3 py-1 bg-gray-700 text-white rounded text-sm">
                  Images
                </button>
                <button onclick="filterGenerations('video')" class="filter-btn px-3 py-1 bg-gray-700 text-white rounded text-sm">
                  Videos
                </button>
              </div>
            </div>
            
            <% if (userDetails.generations.length === 0) { %>
              <p class="text-gray-500 text-center py-12">No generations yet</p>
            <% } else { %>
              <div class="generation-grid" id="generationGrid">
                <% userDetails.generations.forEach(gen => { %>
                  <div class="generation-item" data-type="<%= gen.generation_type %>" onclick='viewGeneration(<%= JSON.stringify(gen) %>)'>
                    <% if (gen.generation_type === 'video') { %>
                      <video src="<%= gen.result_url %>" muted loop onmouseover="this.play()" onmouseout="this.pause()"></video>
                    <% } else { %>
                      <img src="<%= gen.result_url %>" alt="Generated <%= gen.generation_type %>">
                    <% } %>
                    <div class="generation-badge badge-<%= gen.generation_type %>">
                      <%= gen.generation_type %>
                    </div>
                    <div class="p-3">
                      <p class="text-xs text-gray-400 truncate"><%= gen.prompt %></p>
                      <div class="flex items-center justify-between mt-2">
                        <span class="text-xs text-violet-400"><%= gen.sub_type %></span>
                        <span class="text-xs text-blue-400"><%= gen.credits_cost %> credits</span>
                      </div>
                      <p class="text-xs text-gray-500 mt-1"><%= new Date(gen.created_at).toLocaleDateString() %></p>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Tab: Activity -->
        <div id="tab-activity" class="tab-content">
          <div class="glass-strong rounded-xl p-6">
            <h3 class="text-xl font-bold text-white mb-4">Recent Activity</h3>
            <div class="space-y-4">
              <% if (userDetails.activities.length === 0) { %>
                <p class="text-gray-500 text-center py-8">No activity</p>
              <% } else { %>
                <% userDetails.activities.slice(0, 20).forEach(activity => { %>
                  <div class="flex items-start space-x-4 p-4 rounded-lg hover:bg-white/5">
                    <div class="w-10 h-10 bg-violet-500/20 rounded-full flex items-center justify-center flex-shrink-0">
                      <i class="fas fa-circle text-violet-400 text-xs"></i>
                    </div>
                    <div class="flex-1">
                      <p class="text-sm font-medium text-white"><%= activity.activity_type %></p>
                      <p class="text-sm text-gray-400"><%= activity.description || '' %></p>
                      <p class="text-xs text-gray-500 mt-1"><%= new Date(activity.created_at).toLocaleString() %></p>
                    </div>
                  </div>
                <% }); %>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Tab: Credit History -->
        <div id="tab-credits" class="tab-content">
          <div class="glass-strong rounded-xl p-6">
            <h3 class="text-xl font-bold text-white mb-4">Credit Transaction History</h3>
            <div class="space-y-3">
              <% if (userDetails.creditHistory.length === 0) { %>
                <p class="text-gray-500 text-center py-8">No credit transactions</p>
              <% } else { %>
                <% userDetails.creditHistory.forEach(credit => { %>
                  <div class="flex items-center justify-between p-4 rounded-lg bg-white/5 hover:bg-white/10 transition">
                    <div>
                      <p class="text-sm font-medium text-white"><%= credit.description %></p>
                      <p class="text-xs text-gray-500"><%= new Date(credit.created_at).toLocaleString() %></p>
                    </div>
                    <div class="text-right">
                      <p class="text-lg font-bold <%= credit.amount > 0 ? 'text-green-400' : 'text-red-400' %>">
                        <%= credit.amount > 0 ? '+' : '' %><%= credit.amount %>
                      </p>
                      <p class="text-xs text-gray-400">Balance: <%= credit.balance_after %></p>
                    </div>
                  </div>
                <% }); %>
              <% } %>
            </div>
          </div>
        </div>
      </main>

      <%- include('../partials/admin-footer') %>
    </div>
  </div>

  <!-- Edit Credits Modal -->
  <div id="editCreditsModal" class="modal">
    <div class="modal-content">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-bold text-white">Edit User Credits</h3>
        <button onclick="closeModal('editCreditsModal')" class="text-gray-400 hover:text-white">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      
      <form onsubmit="updateCredits(event)">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-2">Current Credits</label>
          <input type="text" value="<%= userDetails.user.credits || 0 %>" readonly 
                 class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-white" />
        </div>
        
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-2">Amount to Add/Subtract</label>
          <input type="number" id="creditAmount" name="amount" required 
                 placeholder="Enter amount (use - for deduction)"
                 class="w-full px-4 py-2 bg-white/10 border border-white/20 rounded-lg text-white focus:border-violet-500 focus:outline-none" />
          <p class="text-xs text-gray-400 mt-1">Use positive number to add, negative to subtract</p>
        </div>
        
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-300 mb-2">Description</label>
          <textarea id="creditDescription" name="description" rows="3"
                    placeholder="Reason for credit adjustment..."
                    class="w-full px-4 py-2 bg-white/10 border border-white/20 rounded-lg text-white focus:border-violet-500 focus:outline-none"></textarea>
        </div>
        
        <div class="flex gap-3">
          <button type="submit" class="flex-1 px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white rounded-lg transition">
            <i class="fas fa-save mr-2"></i> Save Changes
          </button>
          <button type="button" onclick="closeModal('editCreditsModal')" 
                  class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg transition">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit User Modal -->
  <div id="editUserModal" class="modal">
    <div class="modal-content">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-bold text-white">Edit User Information</h3>
        <button onclick="closeModal('editUserModal')" class="text-gray-400 hover:text-white">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      
      <form onsubmit="updateUser(event)">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-2">Name</label>
          <input type="text" id="editName" name="name" value="<%= userDetails.user.name %>" required
                 class="w-full px-4 py-2 bg-white/10 border border-white/20 rounded-lg text-white focus:border-violet-500 focus:outline-none" />
        </div>
        
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-2">Email</label>
          <input type="email" id="editEmail" name="email" value="<%= userDetails.user.email %>" required
                 class="w-full px-4 py-2 bg-white/10 border border-white/20 rounded-lg text-white focus:border-violet-500 focus:outline-none" />
        </div>
        
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-2">Role</label>
          <select id="editRole" name="role" 
                  class="w-full px-4 py-2 bg-white/10 border border-white/20 rounded-lg text-white focus:border-violet-500 focus:outline-none">
            <option value="user" <%= userDetails.user.role === 'user' ? 'selected' : '' %>>User</option>
            <option value="admin" <%= userDetails.user.role === 'admin' ? 'selected' : '' %>>Admin</option>
          </select>
        </div>
        
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-2">Status</label>
          <select id="editStatus" name="is_active"
                  class="w-full px-4 py-2 bg-white/10 border border-white/20 rounded-lg text-white focus:border-violet-500 focus:outline-none">
            <option value="true" <%= userDetails.user.is_active ? 'selected' : '' %>>Active</option>
            <option value="false" <%= !userDetails.user.is_active ? 'selected' : '' %>>Inactive</option>
          </select>
        </div>

        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-300 mb-2">Phone</label>
          <input type="text" id="editPhone" name="phone" value="<%= userDetails.user.phone || '' %>"
                 class="w-full px-4 py-2 bg-white/10 border border-white/20 rounded-lg text-white focus:border-violet-500 focus:outline-none" />
        </div>
        
        <div class="flex gap-3">
          <button type="submit" class="flex-1 px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white rounded-lg transition">
            <i class="fas fa-save mr-2"></i> Save Changes
          </button>
          <button type="button" onclick="closeModal('editUserModal')" 
                  class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg transition">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- View Generation Modal -->
  <div id="viewGenerationModal" class="modal" onclick="closeModal('viewGenerationModal')">
    <div class="modal-content media-modal-content" onclick="event.stopPropagation()">
      <div id="generationMediaContainer"></div>
      <div class="p-4 bg-gradient-to-t from-black/80 to-transparent absolute bottom-0 left-0 right-0 rounded-b-xl">
        <p id="generationPrompt" class="text-white font-medium mb-2"></p>
        <div class="flex items-center justify-between text-sm">
          <span id="generationType" class="text-violet-300"></span>
          <span id="generationCost" class="text-blue-300"></span>
          <span id="generationDate" class="text-gray-400"></span>
        </div>
      </div>
      <button onclick="closeModal('viewGenerationModal')" 
              class="absolute top-4 right-4 w-10 h-10 bg-black/50 hover:bg-black/70 rounded-full flex items-center justify-center text-white transition">
        <i class="fas fa-times"></i>
      </button>
    </div>
  </div>

  <%- include('../partials/admin-scripts') %>
  
  <script>
    const userId = <%= userDetails.user.id %>;
    
    // Tab switching
    function switchTab(tabName) {
      document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
      
      event.target.classList.add('active');
      document.getElementById('tab-' + tabName).classList.add('active');
    }
    
    // Filter generations
    function filterGenerations(type) {
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.classList.remove('active', 'bg-violet-600');
        btn.classList.add('bg-gray-700');
      });
      event.target.classList.add('active', 'bg-violet-600');
      event.target.classList.remove('bg-gray-700');
      
      const items = document.querySelectorAll('.generation-item');
      items.forEach(item => {
        if (type === 'all' || item.dataset.type === type) {
          item.style.display = 'block';
        } else {
          item.style.display = 'none';
        }
      });
    }
    
    // View generation detail
    function viewGeneration(gen) {
      const modal = document.getElementById('viewGenerationModal');
      const container = document.getElementById('generationMediaContainer');
      
      if (gen.generation_type === 'video') {
        container.innerHTML = `<video src="${gen.result_url}" controls autoplay class="rounded-xl"></video>`;
      } else {
        container.innerHTML = `<img src="${gen.result_url}" alt="Generated image" class="rounded-xl">`;
      }
      
      document.getElementById('generationPrompt').textContent = gen.prompt;
      document.getElementById('generationType').innerHTML = `<i class="fas fa-tag mr-1"></i>${gen.sub_type}`;
      document.getElementById('generationCost').innerHTML = `<i class="fas fa-coins mr-1"></i>${gen.credits_cost} credits`;
      document.getElementById('generationDate').textContent = new Date(gen.created_at).toLocaleDateString();
      
      modal.classList.add('active');
    }
    
    // Modal functions
    function openEditCreditsModal() {
      document.getElementById('editCreditsModal').classList.add('active');
    }
    
    function openEditUserModal() {
      document.getElementById('editUserModal').classList.add('active');
    }
    
    function closeModal(modalId) {
      document.getElementById(modalId).classList.remove('active');
    }
    
    // Update credits
    async function updateCredits(e) {
      e.preventDefault();
      
      const amount = parseInt(document.getElementById('creditAmount').value);
      const description = document.getElementById('creditDescription').value || 'Admin credit adjustment';
      
      if (isNaN(amount) || amount === 0) {
        alert('Please enter a valid amount');
        return;
      }
      
      try {
        const response = await fetch(`/admin/users/${userId}/credits`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ amount, description })
        });
        
        const data = await response.json();
        
        if (data.success) {
          alert('Credits updated successfully!');
          location.reload();
        } else {
          alert('Error: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Failed to update credits');
      }
    }
    
    // Update user
    async function updateUser(e) {
      e.preventDefault();
      
      const formData = {
        name: document.getElementById('editName').value,
        email: document.getElementById('editEmail').value,
        role: document.getElementById('editRole').value,
        is_active: document.getElementById('editStatus').value === 'true',
        phone: document.getElementById('editPhone').value
      };
      
      try {
        const response = await fetch(`/admin/users/${userId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });
        
        const data = await response.json();
        
        if (data.success) {
          alert('User updated successfully!');
          location.reload();
        } else {
          alert('Error: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Failed to update user');
      }
    }
    
    // Delete user
    async function deleteUser() {
      if (!confirm('Are you sure you want to delete this user? This action cannot be undone!')) {
        return;
      }
      
      if (!confirm('WARNING: All user data including generations and credit history will be deleted. Continue?')) {
        return;
      }
      
      try {
        const response = await fetch(`/admin/users/${userId}`, {
          method: 'DELETE'
        });
        
        const data = await response.json();
        
        if (data.success) {
          alert('User deleted successfully');
          window.location.href = '/admin/users';
        } else {
          alert('Error: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Failed to delete user');
      }
    }
    
    // Close modal on ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal').forEach(modal => modal.classList.remove('active'));
      }
    });
  </script>
</body>
</html>
