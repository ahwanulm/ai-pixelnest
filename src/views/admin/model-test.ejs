<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PixelNest Admin</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/favicon.png">
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%- include('../partials/admin-styles') %>
</head>
<body>
  <div class="flex h-screen overflow-hidden">
    <%- include('../partials/admin-sidebar') %>

    <!-- Main Content -->
    <div class="flex-1 ml-64 overflow-y-auto content-area flex flex-col">
      <%- include('../partials/admin-header', { pageTitle: title }) %>

      <main class="p-4 md:p-8 flex-1">
        <!-- Page Header -->
        <div class="mb-6">
          <h1 class="text-2xl md:text-3xl font-bold text-white mb-2">🧪 Model Connection Test</h1>
          <p class="text-sm md:text-base text-gray-400">Test AI model connections without incurring generation costs</p>
        </div>

        <!-- API Status Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
          <!-- FAL.AI Status -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <p class="text-sm text-gray-400 font-medium">FAL.AI API</p>
                <h3 id="fal-status" class="text-xl font-bold text-gray-400 mt-1">Not Tested</h3>
                <p id="fal-message" class="text-xs text-gray-500 mt-1">Click test to check connection</p>
              </div>
              <div class="w-12 h-12 bg-purple-500/20 rounded-lg flex items-center justify-center">
                <i id="fal-icon" class="fas fa-question-circle text-purple-400 text-xl"></i>
              </div>
            </div>
            <button onclick="testFalConnection()" id="test-fal-btn" class="w-full px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition text-sm font-medium">
              <i class="fas fa-plug mr-2"></i>Test FAL.AI Connection
            </button>
          </div>

          <!-- Suno API Status -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <p class="text-sm text-gray-400 font-medium">Suno API</p>
                <h3 id="suno-status" class="text-xl font-bold text-gray-400 mt-1">Not Tested</h3>
                <p id="suno-message" class="text-xs text-gray-500 mt-1">Click test to check connection</p>
              </div>
              <div class="w-12 h-12 bg-pink-500/20 rounded-lg flex items-center justify-center">
                <i id="suno-icon" class="fas fa-question-circle text-pink-400 text-xl"></i>
              </div>
            </div>
            <button onclick="testSunoConnection()" id="test-suno-btn" class="w-full px-4 py-2 bg-pink-600 hover:bg-pink-700 text-white rounded-lg transition text-sm font-medium">
              <i class="fas fa-music mr-2"></i>Test Suno Connection
            </button>
          </div>

          <!-- Database Status -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <p class="text-sm text-gray-400 font-medium">Database</p>
                <h3 id="db-status" class="text-xl font-bold text-gray-400 mt-1">Not Tested</h3>
                <p id="db-message" class="text-xs text-gray-500 mt-1">Click test to check connection</p>
              </div>
              <div class="w-12 h-12 bg-green-500/20 rounded-lg flex items-center justify-center">
                <i id="db-icon" class="fas fa-question-circle text-green-400 text-xl"></i>
              </div>
            </div>
            <button onclick="testDbConnection()" id="test-db-btn" class="w-full px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition text-sm font-medium">
              <i class="fas fa-database mr-2"></i>Test Database
            </button>
          </div>
        </div>

        <!-- Test All Button -->
        <div class="mb-6">
          <button onclick="testAllConnections()" id="test-all-btn" class="px-6 py-3 bg-gradient-to-r from-blue-600 to-cyan-600 text-white rounded-lg hover:from-blue-700 hover:to-cyan-700 transition font-medium shadow-lg">
            <i class="fas fa-flask mr-2"></i>Test All Connections
          </button>
        </div>

        <!-- Model Testing Section -->
        <div class="glass-strong rounded-xl p-6 mb-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-white">
              <i class="fas fa-robot mr-2 text-purple-400"></i>Model Connection Test
            </h2>
            <div class="flex items-center gap-2">
              <span class="text-sm text-gray-400">Test without generating content</span>
              <i class="fas fa-info-circle text-cyan-400" title="Tests model availability and parameter validation without actual generation"></i>
            </div>
          </div>

          <!-- Model Selection -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Select Model to Test</label>
              <select id="test-model-select" class="w-full px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-purple-500 transition">
                <option value="">Select a model...</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Test Type</label>
              <select id="test-type-select" class="w-full px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-purple-500 transition">
                <option value="availability">Model Availability</option>
                <option value="parameters">Parameter Validation</option>
                <option value="dry-run">Dry Run (No Generation)</option>
              </select>
            </div>
          </div>

          <!-- Test Parameters (Optional) -->
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-300 mb-2">
              Test Prompt (Optional)
              <span class="text-xs text-gray-500">- For parameter validation only</span>
            </label>
            <input type="text" id="test-prompt" placeholder="a simple test prompt" class="w-full px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-purple-500 transition">
          </div>

          <!-- Test Button -->
          <button onclick="testModelConnection()" id="test-model-btn" class="px-6 py-3 bg-gradient-to-r from-purple-600 to-pink-600 text-white rounded-lg hover:from-purple-700 hover:to-pink-700 transition font-medium disabled:opacity-50 disabled:cursor-not-allowed">
            <i class="fas fa-play mr-2"></i>Test Selected Model
          </button>
        </div>

        <!-- Test Results -->
        <div class="glass-strong rounded-xl p-6">
          <h2 class="text-xl font-bold text-white mb-4">
            <i class="fas fa-chart-line mr-2 text-green-400"></i>Test Results
          </h2>
          
          <!-- Results Container -->
          <div id="test-results" class="space-y-4">
            <div class="text-center py-8 text-gray-400">
              <i class="fas fa-vial text-3xl mb-3"></i>
              <p>No tests performed yet</p>
              <p class="text-sm">Run connection tests to see results here</p>
            </div>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="mt-6 flex flex-wrap gap-3">
          <button onclick="clearResults()" class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition text-sm">
            <i class="fas fa-trash mr-2"></i>Clear Results
          </button>
          <button onclick="exportResults()" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition text-sm" disabled>
            <i class="fas fa-download mr-2"></i>Export Results
          </button>
          <button onclick="refreshModels()" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition text-sm">
            <i class="fas fa-sync mr-2"></i>Refresh Models
          </button>
        </div>

      </main>
    </div>
  </div>

  <!-- Test Progress Modal -->
  <div id="test-progress-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="glass-strong rounded-2xl max-w-md w-full p-6">
      <div class="text-center">
        <div class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
          <i class="fas fa-spinner fa-spin text-blue-400 text-2xl"></i>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Testing Connection</h3>
        <p id="progress-message" class="text-gray-400 mb-4">Initializing test...</p>
        <div class="w-full bg-gray-800 rounded-full h-2 mb-4">
          <div id="progress-bar" class="bg-blue-600 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
        <button onclick="cancelTest()" class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition text-sm">
          Cancel Test
        </button>
      </div>
    </div>
  </div>

  <%- include('../partials/admin-scripts') %>
  
  <script>
    // Global variables
    let testResults = [];
    let currentTest = null;

    // Initialize page
    document.addEventListener('DOMContentLoaded', function() {
      loadAvailableModels();
    });

    // Load available models for testing
    async function loadAvailableModels() {
      try {
        const response = await fetch('/admin/api/models');
        const data = await response.json();
        
        const select = document.getElementById('test-model-select');
        select.innerHTML = '<option value="">Select a model...</option>';
        
        if (data.success && data.models) {
          data.models.forEach(model => {
            const option = document.createElement('option');
            option.value = model.model_id;
            option.textContent = `${model.name} (${model.type})`;
            option.dataset.type = model.type;
            select.appendChild(option);
          });
        }
      } catch (error) {
        console.error('Error loading models:', error);
        showToast('Error loading models', 'error');
      }
    }

    // Test FAL.AI connection
    async function testFalConnection() {
      const btn = document.getElementById('test-fal-btn');
      const status = document.getElementById('fal-status');
      const message = document.getElementById('fal-message');
      const icon = document.getElementById('fal-icon');

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Testing...';
      
      try {
        const response = await fetch('/admin/api/test-fal-connection', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        
        const data = await response.json();
        
        if (data.connected) {
          status.textContent = 'Connected';
          status.className = 'text-xl font-bold text-green-400 mt-1';
          message.textContent = data.message || 'API connection successful';
          icon.className = 'fas fa-check-circle text-green-400 text-xl';
          
          addTestResult('FAL.AI Connection', 'success', data.message, {
            status: data.status,
            api_key_valid: data.api_key_valid
          });
        } else {
          status.textContent = 'Failed';
          status.className = 'text-xl font-bold text-red-400 mt-1';
          message.textContent = data.error || 'Connection failed';
          icon.className = 'fas fa-times-circle text-red-400 text-xl';
          
          addTestResult('FAL.AI Connection', 'error', data.error, data);
        }
      } catch (error) {
        status.textContent = 'Error';
        status.className = 'text-xl font-bold text-red-400 mt-1';
        message.textContent = 'Test failed: ' + error.message;
        icon.className = 'fas fa-exclamation-triangle text-red-400 text-xl';
        
        addTestResult('FAL.AI Connection', 'error', error.message);
      }
      
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-plug mr-2"></i>Test FAL.AI Connection';
    }

    // Test Suno connection
    async function testSunoConnection() {
      const btn = document.getElementById('test-suno-btn');
      const status = document.getElementById('suno-status');
      const message = document.getElementById('suno-message');
      const icon = document.getElementById('suno-icon');

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Testing...';
      
      try {
        const response = await fetch('/admin/api/test-suno-connection', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        
        const data = await response.json();
        
        if (data.connected) {
          status.textContent = 'Connected';
          status.className = 'text-xl font-bold text-green-400 mt-1';
          message.textContent = data.message || 'API connection successful';
          icon.className = 'fas fa-check-circle text-green-400 text-xl';
          
          addTestResult('Suno API Connection', 'success', data.message, data);
        } else {
          status.textContent = 'Failed';
          status.className = 'text-xl font-bold text-red-400 mt-1';
          message.textContent = data.error || 'Connection failed';
          icon.className = 'fas fa-times-circle text-red-400 text-xl';
          
          addTestResult('Suno API Connection', 'error', data.error, data);
        }
      } catch (error) {
        status.textContent = 'Error';
        status.className = 'text-xl font-bold text-red-400 mt-1';
        message.textContent = 'Test failed: ' + error.message;
        icon.className = 'fas fa-exclamation-triangle text-red-400 text-xl';
        
        addTestResult('Suno API Connection', 'error', error.message);
      }
      
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-music mr-2"></i>Test Suno Connection';
    }

    // Test database connection
    async function testDbConnection() {
      const btn = document.getElementById('test-db-btn');
      const status = document.getElementById('db-status');
      const message = document.getElementById('db-message');
      const icon = document.getElementById('db-icon');

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Testing...';
      
      try {
        const response = await fetch('/admin/api/test-db-connection', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        
        const data = await response.json();
        
        if (data.connected) {
          status.textContent = 'Connected';
          status.className = 'text-xl font-bold text-green-400 mt-1';
          message.textContent = data.message || 'Database connection successful';
          icon.className = 'fas fa-check-circle text-green-400 text-xl';
          
          addTestResult('Database Connection', 'success', data.message, {
            models_count: data.models_count,
            users_count: data.users_count
          });
        } else {
          status.textContent = 'Failed';
          status.className = 'text-xl font-bold text-red-400 mt-1';
          message.textContent = data.error || 'Connection failed';
          icon.className = 'fas fa-times-circle text-red-400 text-xl';
          
          addTestResult('Database Connection', 'error', data.error, data);
        }
      } catch (error) {
        status.textContent = 'Error';
        status.className = 'text-xl font-bold text-red-400 mt-1';
        message.textContent = 'Test failed: ' + error.message;
        icon.className = 'fas fa-exclamation-triangle text-red-400 text-xl';
        
        addTestResult('Database Connection', 'error', error.message);
      }
      
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-database mr-2"></i>Test Database';
    }

    // Test all connections
    async function testAllConnections() {
      const btn = document.getElementById('test-all-btn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Testing All...';
      
      try {
        await testDbConnection();
        await new Promise(resolve => setTimeout(resolve, 1000)); // Small delay
        
        await testFalConnection();
        await new Promise(resolve => setTimeout(resolve, 1000));
        
        await testSunoConnection();
        
        showToast('All connection tests completed', 'success');
      } catch (error) {
        showToast('Error during testing: ' + error.message, 'error');
      }
      
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-flask mr-2"></i>Test All Connections';
    }

    // Test specific model connection
    async function testModelConnection() {
      const modelSelect = document.getElementById('test-model-select');
      const testTypeSelect = document.getElementById('test-type-select');
      const promptInput = document.getElementById('test-prompt');
      const btn = document.getElementById('test-model-btn');

      if (!modelSelect.value) {
        showToast('Please select a model to test', 'warning');
        return;
      }

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Testing Model...';
      
      showProgressModal('Testing model connection...');
      
      try {
        const response = await fetch('/admin/api/test-model-connection', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            model_id: modelSelect.value,
            test_type: testTypeSelect.value,
            prompt: promptInput.value || 'test prompt'
          })
        });
        
        const data = await response.json();
        
        if (data.success) {
          addTestResult(
            `Model Test: ${modelSelect.selectedOptions[0].textContent}`,
            'success',
            data.message,
            {
              test_type: testTypeSelect.value,
              model_available: data.model_available,
              parameters_valid: data.parameters_valid,
              response_time: data.response_time
            }
          );
          showToast('Model test completed successfully', 'success');
        } else {
          addTestResult(
            `Model Test: ${modelSelect.selectedOptions[0].textContent}`,
            'error',
            data.error,
            data
          );
          showToast('Model test failed: ' + data.error, 'error');
        }
      } catch (error) {
        addTestResult(
          `Model Test: ${modelSelect.selectedOptions[0].textContent}`,
          'error',
          error.message
        );
        showToast('Model test error: ' + error.message, 'error');
      }
      
      hideProgressModal();
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-play mr-2"></i>Test Selected Model';
    }

    // Add test result
    function addTestResult(testName, status, message, details = {}) {
      const result = {
        id: Date.now(),
        timestamp: new Date().toISOString(),
        test: testName,
        status: status,
        message: message,
        details: details
      };
      
      testResults.unshift(result);
      renderTestResults();
      
      // Enable export button if we have results
      document.querySelector('button[onclick="exportResults()"]').disabled = false;
    }

    // Render test results
    function renderTestResults() {
      const container = document.getElementById('test-results');
      
      if (testResults.length === 0) {
        container.innerHTML = `
          <div class="text-center py-8 text-gray-400">
            <i class="fas fa-vial text-3xl mb-3"></i>
            <p>No tests performed yet</p>
            <p class="text-sm">Run connection tests to see results here</p>
          </div>
        `;
        return;
      }
      
      container.innerHTML = testResults.map(result => {
        const statusClass = result.status === 'success' ? 'text-green-400' : 'text-red-400';
        const statusIcon = result.status === 'success' ? 'fa-check-circle' : 'fa-times-circle';
        
        return `
          <div class="p-4 bg-gray-800/50 rounded-lg border border-gray-700">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <i class="fas ${statusIcon} ${statusClass}"></i>
                  <h3 class="font-semibold text-white">${result.test}</h3>
                  <span class="text-xs text-gray-500">${new Date(result.timestamp).toLocaleString()}</span>
                </div>
                <p class="text-sm text-gray-300 mb-2">${result.message}</p>
                ${Object.keys(result.details).length > 0 ? `
                  <details class="text-xs">
                    <summary class="cursor-pointer text-cyan-400 hover:text-cyan-300">Show Details</summary>
                    <pre class="mt-2 p-2 bg-gray-900 rounded text-gray-300 overflow-x-auto">${JSON.stringify(result.details, null, 2)}</pre>
                  </details>
                ` : ''}
              </div>
              <button onclick="removeTestResult(${result.id})" class="text-gray-500 hover:text-red-400 transition ml-2">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>
        `;
      }).join('');
    }

    // Remove test result
    function removeTestResult(id) {
      testResults = testResults.filter(result => result.id !== id);
      renderTestResults();
      
      if (testResults.length === 0) {
        document.querySelector('button[onclick="exportResults()"]').disabled = true;
      }
    }

    // Clear all results
    function clearResults() {
      if (testResults.length === 0) {
        showToast('No results to clear', 'info');
        return;
      }
      
      if (confirm('Are you sure you want to clear all test results?')) {
        testResults = [];
        renderTestResults();
        document.querySelector('button[onclick="exportResults()"]').disabled = true;
        showToast('Test results cleared', 'success');
      }
    }

    // Export results
    function exportResults() {
      if (testResults.length === 0) {
        showToast('No results to export', 'warning');
        return;
      }
      
      const data = {
        exported_at: new Date().toISOString(),
        test_count: testResults.length,
        results: testResults
      };
      
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      
      const a = document.createElement('a');
      a.href = url;
      a.download = `model-test-results-${new Date().toISOString().split('T')[0]}.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      
      URL.revokeObjectURL(url);
      showToast('Results exported successfully', 'success');
    }

    // Refresh models
    async function refreshModels() {
      const btn = event.target;
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Refreshing...';
      
      try {
        await loadAvailableModels();
        showToast('Models refreshed successfully', 'success');
      } catch (error) {
        showToast('Error refreshing models: ' + error.message, 'error');
      }
      
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-sync mr-2"></i>Refresh Models';
    }

    // Show progress modal
    function showProgressModal(message) {
      document.getElementById('progress-message').textContent = message;
      document.getElementById('test-progress-modal').classList.remove('hidden');
      
      // Simulate progress
      let progress = 0;
      const interval = setInterval(() => {
        progress += 10;
        document.getElementById('progress-bar').style.width = progress + '%';
        
        if (progress >= 90) {
          clearInterval(interval);
        }
      }, 200);
      
      currentTest = { interval };
    }

    // Hide progress modal
    function hideProgressModal() {
      if (currentTest && currentTest.interval) {
        clearInterval(currentTest.interval);
      }
      document.getElementById('progress-bar').style.width = '100%';
      setTimeout(() => {
        document.getElementById('test-progress-modal').classList.add('hidden');
        document.getElementById('progress-bar').style.width = '0%';
      }, 500);
      currentTest = null;
    }

    // Cancel test
    function cancelTest() {
      if (currentTest && currentTest.interval) {
        clearInterval(currentTest.interval);
      }
      hideProgressModal();
      showToast('Test cancelled', 'warning');
    }

    // Show toast notification
    function showToast(message, type = 'info') {
      // Create toast element if it doesn't exist
      let toastContainer = document.getElementById('toast-container');
      if (!toastContainer) {
        toastContainer = document.createElement('div');
        toastContainer.id = 'toast-container';
        toastContainer.className = 'fixed top-4 right-4 z-50 space-y-2';
        document.body.appendChild(toastContainer);
      }
      
      const toast = document.createElement('div');
      const colorClass = {
        success: 'bg-green-600',
        error: 'bg-red-600', 
        warning: 'bg-yellow-600',
        info: 'bg-blue-600'
      }[type] || 'bg-blue-600';
      
      toast.className = `${colorClass} text-white px-4 py-3 rounded-lg shadow-lg transform translate-x-full transition-transform duration-300`;
      toast.innerHTML = `
        <div class="flex items-center gap-2">
          <i class="fas fa-${type === 'success' ? 'check' : type === 'error' ? 'times' : type === 'warning' ? 'exclamation-triangle' : 'info-circle'}"></i>
          <span>${message}</span>
        </div>
      `;
      
      toastContainer.appendChild(toast);
      
      // Animate in
      setTimeout(() => {
        toast.classList.remove('translate-x-full');
      }, 100);
      
      // Remove after delay
      setTimeout(() => {
        toast.classList.add('translate-x-full');
        setTimeout(() => {
          toastContainer.removeChild(toast);
        }, 300);
      }, 3000);
    }
  </script>
</body>
</html>
