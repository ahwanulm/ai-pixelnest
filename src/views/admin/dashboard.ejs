<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PixelNest Admin</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/favicon.png">
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%- include('../partials/admin-styles') %>
</head>
<body>
  <div class="flex h-screen overflow-hidden">
    <%- include('../partials/admin-sidebar') %>

    <!-- Main Content -->
    <div class="flex-1 ml-64 overflow-y-auto content-area flex flex-col">
      <%- include('../partials/admin-header', { pageTitle: title }) %>

      <!-- Page Content -->
      <main class="p-8 flex-1">
        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <!-- Total Users -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Total Users</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.totalUsers || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-blue-500/20 flex items-center justify-center">
                <i class="fas fa-users text-blue-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              <span class="text-green-400 font-semibold">+<%= (stats.newUsersThisMonth || 0).toLocaleString() %></span> this month
            </p>
          </div>

          <!-- Active Users -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Active Users</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.activeUsers || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-green-500/20 flex items-center justify-center">
                <i class="fas fa-user-check text-green-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              Last 30 days
            </p>
          </div>

          <!-- Total Credits -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Total Credits</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.totalCredits || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-yellow-500/20 flex items-center justify-center">
                <i class="fas fa-coins text-yellow-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              Distributed to users
            </p>
          </div>

          <!-- Total Generations -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">AI Generations</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.totalGenerations || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-purple-500/20 flex items-center justify-center">
                <i class="fas fa-magic text-purple-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              <span class="text-green-400 font-semibold">+<%= (stats.generationsThisMonth || 0).toLocaleString() %></span> this month
            </p>
          </div>
        </div>

        <!-- Financial Stats -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <!-- Total Revenue -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Total Revenue</p>
                <h3 class="text-3xl font-bold text-white mt-2">Rp <%= (stats.totalRevenue || 0).toLocaleString('id-ID') %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-emerald-500/20 flex items-center justify-center">
                <i class="fas fa-money-bill-wave text-emerald-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              <span class="text-green-400 font-semibold">Rp <%= (stats.revenueThisMonth || 0).toLocaleString('id-ID') %></span> this month
            </p>
          </div>

          <!-- Total Transactions -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Total Transactions</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.totalTransactions || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-indigo-500/20 flex items-center justify-center">
                <i class="fas fa-receipt text-indigo-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              <span class="text-blue-400 font-semibold">+<%= (stats.transactionsThisMonth || 0).toLocaleString() %></span> this month
            </p>
          </div>

          <!-- Pending Payments -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Pending Payments</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.pendingPaymentsCount || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-amber-500/20 flex items-center justify-center">
                <i class="fas fa-clock text-amber-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              Rp <%= (stats.pendingPaymentsAmount || 0).toLocaleString('id-ID') %>
              <% if (stats.activePendingPaymentsCount !== undefined && stats.activePendingPaymentsCount < (stats.pendingPaymentsCount || 0)) { %>
                <span class="text-amber-400">(<%= (stats.activePendingPaymentsCount || 0) %> aktif)</span>
              <% } %>
            </p>
          </div>

          <!-- Payment Success Rate -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Payment Success Rate</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.paymentSuccessRate || 0) %>%</h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-teal-500/20 flex items-center justify-center">
                <i class="fas fa-chart-line text-teal-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              Paid vs Total
            </p>
          </div>
        </div>

        <!-- Today's Activity Stats -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <!-- Generations Today -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Generations Today</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.generationsToday || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-pink-500/20 flex items-center justify-center">
                <i class="fas fa-sparkles text-pink-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              Last 24 hours
            </p>
          </div>

          <!-- Credit Transactions Today -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Credit Transactions</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.creditTransactionsToday || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-cyan-500/20 flex items-center justify-center">
                <i class="fas fa-exchange-alt text-cyan-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              <span class="text-green-400 font-semibold">+<%= (stats.creditsAddedToday || 0).toLocaleString() %></span> credits today
            </p>
          </div>

          <!-- Average Credits -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Avg Credits/User</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.averageCreditsPerUser || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-orange-500/20 flex items-center justify-center">
                <i class="fas fa-chart-bar text-orange-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              Average distribution
            </p>
          </div>

          <!-- Active Subscriptions -->
          <div class="stat-card rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm font-medium">Active Subscriptions</p>
                <h3 class="text-3xl font-bold text-white mt-2"><%= (stats.activeSubscriptions || 0).toLocaleString() %></h3>
              </div>
              <div class="w-14 h-14 rounded-xl bg-rose-500/20 flex items-center justify-center">
                <i class="fas fa-crown text-rose-400 text-2xl"></i>
              </div>
            </div>
            <p class="text-sm text-gray-400 mt-4">
              Premium users
            </p>
          </div>
        </div>

        <!-- Recent Activity & Quick Actions -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Recent Activity -->
          <div class="lg:col-span-2 glass-strong rounded-xl p-6">
            <div class="flex items-center justify-between mb-6">
              <h3 class="text-xl font-bold text-white">Recent Activity</h3>
              <a href="/admin/activity-logs" class="text-violet-400 hover:text-violet-300 text-sm font-medium transition">
                View All <i class="fas fa-arrow-right ml-1"></i>
              </a>
            </div>
            
            <div class="space-y-4">
              <% if (!stats.recentActivities || stats.recentActivities.length === 0) { %>
                <p class="text-gray-500 text-center py-8">No recent activity</p>
              <% } else { %>
                <% stats.recentActivities.forEach(activity => { %>
                  <div class="flex items-start space-x-4 p-4 rounded-lg hover:bg-white/5 transition">
                    <div class="flex-shrink-0">
                      <div class="w-10 h-10 bg-violet-500/20 rounded-full flex items-center justify-center">
                        <i class="fas fa-user text-violet-400"></i>
                      </div>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-white">
                        <%= activity.user_name || 'Unknown User' %>
                      </p>
                      <p class="text-sm text-gray-400 truncate">
                        <%= activity.description %>
                      </p>
                      <p class="text-xs text-gray-500 mt-1">
                        <i class="far fa-clock"></i> <%= new Date(activity.created_at).toLocaleString() %>
                      </p>
                    </div>
                  </div>
                <% }); %>
              <% } %>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="glass-strong rounded-xl p-6">
            <h3 class="text-xl font-bold text-white mb-6">Quick Actions</h3>
            
            <div class="space-y-3">
              <a href="/admin/users" class="block p-4 bg-blue-500/10 hover:bg-blue-500/20 border border-blue-500/20 rounded-lg transition">
                <div class="flex items-center space-x-3">
                  <i class="fas fa-users text-blue-400 text-xl"></i>
                  <span class="font-medium text-white">Manage Users</span>
                </div>
              </a>
              
              <a href="/admin/promo-codes" class="block p-4 bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 rounded-lg transition">
                <div class="flex items-center space-x-3">
                  <i class="fas fa-ticket-alt text-green-400 text-xl"></i>
                  <span class="font-medium text-white">Create Promo Code</span>
                </div>
              </a>
              
              <a href="/admin/notifications" class="block p-4 bg-purple-500/10 hover:bg-purple-500/20 border border-purple-500/20 rounded-lg transition">
                <div class="flex items-center space-x-3">
                  <i class="fas fa-bell text-purple-400 text-xl"></i>
                  <span class="font-medium text-white">Send Notification</span>
                </div>
              </a>
              
              <a href="/admin/api-configs" class="block p-4 bg-yellow-500/10 hover:bg-yellow-500/20 border border-yellow-500/20 rounded-lg transition">
                <div class="flex items-center space-x-3">
                  <i class="fas fa-cog text-yellow-400 text-xl"></i>
                  <span class="font-medium text-white">API Settings</span>
                </div>
              </a>
            </div>

            <hr class="my-6" style="border-color: rgba(255, 255, 255, 0.1);">

            <h4 class="text-sm font-semibold text-gray-400 mb-3">Quick Stats</h4>
            <div class="space-y-3">
              <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
                <span class="text-sm text-gray-400">Active Promo Codes</span>
                <span class="text-lg font-bold text-white"><%= (stats.activePromoCodes || 0) %></span>
              </div>
              <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
                <span class="text-sm text-gray-400">Active Subscriptions</span>
                <span class="text-lg font-bold text-white"><%= (stats.activeSubscriptions || 0) %></span>
              </div>
              <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
                <span class="text-sm text-gray-400">Today's Generations</span>
                <span class="text-lg font-bold text-white"><%= (stats.generationsToday || 0) %></span>
              </div>
              <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
                <span class="text-sm text-gray-400">Payment Success Rate</span>
                <span class="text-lg font-bold text-white"><%= (stats.paymentSuccessRate || 0) %>%</span>
              </div>
            </div>
          </div>
        </div>
      </main>

      <%- include('../partials/admin-footer') %>
    </div>
  </div>

  <%- include('../partials/admin-scripts') %>
</body>
</html>
