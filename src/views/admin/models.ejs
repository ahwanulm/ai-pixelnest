          </div>
          <button onclick="closeSunoPricingModal()" class="text-gray-400 hover:text-white transition p-2">
            <i class="fas fa-times text-xl"></i>
          </button>
        </div>
      </div>

      <!-- Content (Scrollable) -->
      <div class="p-4 md:p-6 overflow-y-auto flex-1">
        <div id="suno-models-list" class="space-y-3">
          <!-- Models will be loaded here by JavaScript -->
        </div>
      </div>

      <!-- Footer (Always Visible - Sticky) -->
      <div class="p-4 md:p-6 border-t border-gray-700 bg-gray-800/50 flex-shrink-0">
        <div class="flex flex-col sm:flex-row gap-3">
          <button 
            onclick="saveSunoModelsWithPricing()" 
            class="flex-1 px-6 py-3 bg-gradient-to-r from-pink-600 to-purple-600 text-white rounded-lg hover:from-pink-700 hover:to-purple-700 transition font-medium shadow-lg shadow-pink-500/20"
          >
            <i class="fas fa-save mr-2"></i>
            Save All Models with Custom Pricing
          </button>
          <button 
            onclick="closeSunoPricingModal()" 
            class="px-6 py-3 bg-gray-700 text-white rounded-lg hover:bg-gray-600 transition font-medium"
          >
            Cancel
          </button>
        </div>
        <p class="text-xs text-gray-400 mt-3 text-center">
          <i class="fas fa-info-circle mr-1"></i>
          Tip: Recommended pricing 0.5 credits (IDR 1,000) untuk semua model music generation
        </p>
      </div>
    </div>
  </div>

  <!-- Browse FAL.AI Models Modal -->
  <div id="browse-fal-modal" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-gray-900 border border-gray-700 rounded-2xl w-full max-w-6xl max-h-[90vh] overflow-hidden">
      <!-- Header -->
      <div class="p-4 md:p-6 border-b border-gray-700 bg-gradient-to-r from-blue-900/50 to-cyan-900/50">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-xl md:text-2xl font-bold text-white mb-2">Browse FAL.AI Models</h3>
            <p class="text-gray-300 text-sm md:text-base">Real-time search and import from fal.ai • <span class="text-green-400">Live Pricing</span></p>
          </div>
          <button onclick="closeBrowseModal()" class="text-gray-400 hover:text-white transition p-2">
            <i class="fas fa-times text-xl"></i>
          </button>
        </div>

        <!-- Search and Filters -->
        <div class="flex flex-col md:flex-row gap-4 mt-4">
          <div class="flex-1 relative">
            <input 
              type="text" 
              id="fal-search" 
              placeholder="Search models (e.g., flux, kling, runway, sora...)" 
              class="w-full pl-10 pr-4 py-3 bg-gray-800/50 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
              oninput="searchFalModels()"
            >
            <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
          </div>
          <div class="flex gap-2">
            <button onclick="filterFalModels('all')" class="fal-filter-btn active px-4 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm font-medium" data-type="all">
              <i class="fas fa-th-large mr-1"></i> All
            </button>
            <button onclick="filterFalModels('video')" class="fal-filter-btn px-4 py-3 bg-gray-700 text-gray-300 rounded-lg hover:bg-gray-600 transition text-sm font-medium" data-type="video">
              <i class="fas fa-video mr-1"></i> Video
            </button>
            <button onclick="filterFalModels('image')" class="fal-filter-btn px-4 py-3 bg-gray-700 text-gray-300 rounded-lg hover:bg-gray-600 transition text-sm font-medium" data-type="image">
              <i class="fas fa-image mr-1"></i> Image
            </button>
          </div>
        </div>

        <!-- Stats Bar -->
        <div class="flex items-center justify-between mt-4 p-3 bg-gray-800/50 rounded-lg">
          <div class="flex items-center gap-6 text-sm flex-wrap">
            <span class="text-gray-400">
              <i class="fas fa-database mr-2"></i>Found: <span id="fal-search-count" class="text-white font-bold">-</span>
            </span>
            <span class="text-gray-400">
              <i class="fas fa-sync mr-2"></i>Last Updated: <span id="fal-last-sync" class="text-green-400">Live</span>
            </span>
            <span id="fal-api-status" class="text-gray-400">
              <i class="fas fa-circle-notch fa-spin mr-2"></i>Checking API...
            </span>
          </div>
          <div class="flex items-center gap-2">
            <button onclick="testFalConnection()" class="px-3 py-1 bg-purple-600 hover:bg-purple-700 text-white rounded text-xs transition">
              <i class="fas fa-plug mr-1"></i> Test API
            </button>
            <button onclick="refreshFalModels()" class="px-3 py-1 bg-blue-600 hover:bg-blue-700 text-white rounded text-xs transition">
              <i class="fas fa-refresh mr-1"></i> Refresh
            </button>
          </div>
        </div>
        
        <!-- Source Selector & Actions -->
        <div class="mt-3 flex items-center justify-between gap-3">
          <!-- Source Toggle -->
          <div class="flex items-center gap-2 bg-gray-800 rounded-lg p-1">
            <button onclick="switchModelSource('curated')" id="source-curated" class="px-3 py-1.5 rounded text-sm font-medium transition bg-blue-600 text-white">
              <i class="fas fa-star mr-1"></i> Curated (100+)
            </button>
            <button onclick="switchModelSource('all')" id="source-all" class="px-3 py-1.5 rounded text-sm font-medium transition text-gray-400 hover:text-white">
              <i class="fas fa-globe mr-1"></i> All Models
            </button>
          </div>
          
          <!-- Sync Pricing Button -->
          <button onclick="syncPricingFromFal()" class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white rounded text-sm transition">
            <i class="fas fa-dollar-sign mr-1"></i> Sync Pricing
          </button>
        </div>
        
        <!-- Info Note -->
        <div class="mt-3 p-3 bg-blue-900/20 border border-blue-500/30 rounded-lg">
          <div class="flex items-start gap-2">
            <i class="fas fa-info-circle text-blue-400 mt-0.5"></i>
            <div class="text-xs text-gray-300" id="source-info">
              <strong class="text-blue-400">Curated:</strong> 100+ verified models with accurate pricing. 
              <strong class="text-green-400">All:</strong> Includes scraped models from fal.ai (may have estimated pricing).
            </div>
          </div>
        </div>
      </div>

      <!-- Models Grid -->
      <div class="p-4 md:p-6 max-h-[60vh] overflow-y-auto">
        <div id="fal-models-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <!-- Models will be loaded here -->
          <div class="col-span-full text-center py-8 text-gray-400" id="fal-loading">
            <i class="fas fa-spinner fa-spin text-2xl mb-2"></i>
            <p>Connecting to FAL.AI...</p>
          </div>
        </div>
      </div>

      <div class="p-4 md:p-6 border-t border-gray-700 bg-gray-900/50">
        <div class="flex items-center justify-between text-sm">
          <div class="text-gray-400">
            <i class="fas fa-info-circle mr-2"></i>
            <span class="text-yellow-400 font-bold">New Formula:</span> IDR 1,000 = 2 Credits • 
            Click <strong class="text-white">"Import"</strong> to add model
          </div>
          <button onclick="closeBrowseModal()" class="px-4 py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-600 transition">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/admin-scripts') %>

  <script src="/js/admin-models.js?v=20251029-pricing-fix"></script>
</body>
</html>

