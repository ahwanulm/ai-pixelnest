<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PixelNest Admin</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/favicon.png">
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%- include('../partials/admin-styles') %>
</head>
<body>
  <div class="flex h-screen overflow-hidden">
    <%- include('../partials/admin-sidebar') %>

    <!-- Main Content -->
    <div class="flex-1 ml-64 overflow-y-auto content-area flex flex-col">
      <%- include('../partials/admin-header', { pageTitle: title }) %>

      <main class="p-4 md:p-8 flex-1">
        <!-- Page Header -->
        <div class="mb-6">
          <h1 class="text-2xl md:text-3xl font-bold text-white mb-2">🤖 AI Models Management</h1>
          <p class="text-sm md:text-base text-gray-400">Manage available AI models for image and video generation</p>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-4 mb-6">
          <!-- Total Models -->
          <div class="stat-card rounded-xl p-4 md:p-6">
            <div class="flex items-center justify-between mb-2">
              <div>
                <p class="text-xs md:text-sm text-gray-400 font-medium">Total Models</p>
                <h3 id="total-models" class="text-xl md:text-2xl font-bold text-white mt-1">0</h3>
              </div>
              <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-robot text-blue-400 text-lg md:text-xl"></i>
              </div>
            </div>
          </div>

          <!-- Image Models -->
          <div class="stat-card rounded-xl p-4 md:p-6">
            <div class="flex items-center justify-between mb-2">
              <div>
                <p class="text-xs md:text-sm text-gray-400 font-medium">Image</p>
                <h3 id="image-models" class="text-xl md:text-2xl font-bold text-white mt-1">0</h3>
              </div>
              <div class="w-10 h-10 md:w-12 md:h-12 bg-purple-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-image text-purple-400 text-lg md:text-xl"></i>
              </div>
            </div>
          </div>

          <!-- Video Models -->
          <div class="stat-card rounded-xl p-4 md:p-6">
            <div class="flex items-center justify-between mb-2">
              <div>
                <p class="text-xs md:text-sm text-gray-400 font-medium">Video</p>
                <h3 id="video-models" class="text-xl md:text-2xl font-bold text-white mt-1">0</h3>
              </div>
              <div class="w-10 h-10 md:w-12 md:h-12 bg-pink-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-video text-pink-400 text-lg md:text-xl"></i>
              </div>
            </div>
          </div>

          <!-- Audio Models -->
          <div class="stat-card rounded-xl p-4 md:p-6">
            <div class="flex items-center justify-between mb-2">
              <div>
                <p class="text-xs md:text-sm text-gray-400 font-medium">Audio</p>
                <h3 id="audio-models" class="text-xl md:text-2xl font-bold text-white mt-1">0</h3>
              </div>
              <div class="w-10 h-10 md:w-12 md:h-12 bg-cyan-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-music text-cyan-400 text-lg md:text-xl"></i>
              </div>
            </div>
          </div>

          <!-- Trending -->
          <div class="stat-card rounded-xl p-4 md:p-6">
            <div class="flex items-center justify-between mb-2">
              <div>
                <p class="text-xs md:text-sm text-gray-400 font-medium">Trending</p>
                <h3 id="trending-models" class="text-xl md:text-2xl font-bold text-white mt-1">0</h3>
              </div>
              <div class="w-10 h-10 md:w-12 md:h-12 bg-green-500/20 rounded-lg flex items-center justify-center">
                <i class="fas fa-fire text-green-400 text-lg md:text-xl"></i>
              </div>
            </div>
          </div>
        </div>

        <!-- Controls -->
        <div class="glass-strong rounded-xl p-4 md:p-6 mb-6">
          <div class="flex flex-col lg:flex-row gap-4">
            <!-- Search -->
            <div class="flex-1">
              <div class="relative">
                <input 
                  type="text" 
                  id="search-models" 
                  placeholder="Search models..."
                  class="w-full px-4 py-2.5 md:py-3 pl-10 md:pl-12 bg-gray-800/50 border border-gray-700 rounded-lg text-sm md:text-base text-white placeholder-gray-500 focus:outline-none focus:border-purple-500 transition"
                >
                <i class="fas fa-search absolute left-3 md:left-4 top-3 md:top-4 text-gray-500 text-sm md:text-base"></i>
              </div>
            </div>

            <!-- Filters & Actions -->
            <div class="flex flex-wrap gap-2 md:gap-3">
              <select id="filter-type" class="flex-1 sm:flex-none px-3 md:px-4 py-2.5 md:py-3 bg-gray-800/50 border border-gray-700 rounded-lg text-sm md:text-base text-white focus:outline-none focus:border-purple-500 transition">
                <option value="">All Types</option>
                <option value="image">Image</option>
                <option value="video">Video</option>
                <option value="audio">Audio</option>
              </select>

              <select id="filter-status" class="flex-1 sm:flex-none px-3 md:px-4 py-2.5 md:py-3 bg-gray-800/50 border border-gray-700 rounded-lg text-sm md:text-base text-white focus:outline-none focus:border-purple-500 transition">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="trending">Trending</option>
                <option value="viral">Viral</option>
              </select>

              <button onclick="syncFalModels()" class="w-full sm:w-auto px-4 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-green-600 to-emerald-600 text-white text-sm md:text-base rounded-lg hover:from-green-700 hover:to-emerald-700 transition flex items-center justify-center gap-2 font-medium">
                <i class="fas fa-sync"></i>
                <span>Sync FAL.AI</span>
              </button>
              
    <button onclick="openSunoPricingModal()" class="w-full sm:w-auto px-4 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-pink-600 to-purple-600 text-white text-sm md:text-base rounded-lg hover:from-pink-700 hover:to-purple-700 transition flex items-center justify-center gap-2 font-medium" title="Add all Suno AI music models with custom pricing">
      <i class="fas fa-music"></i>
      <span class="hidden sm:inline">Add Suno Models</span>
      <span class="sm:hidden">Suno</span>
    </button>
              
              <button onclick="verifyFalPricing()" class="w-full sm:w-auto px-4 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-green-600 to-emerald-600 text-white text-sm md:text-base rounded-lg hover:from-green-700 hover:to-emerald-700 transition flex items-center justify-center gap-2 font-medium" title="Verify FAL.AI pricing accuracy">
                <i class="fas fa-sync"></i>
                <span class="hidden sm:inline">Verify FAL Pricing</span>
                <span class="sm:hidden">Verify</span>
              </button>
              
              <button onclick="verifyPricing()" class="w-full sm:w-auto px-4 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-yellow-600 to-orange-600 text-white text-sm md:text-base rounded-lg hover:from-yellow-700 hover:to-orange-700 transition flex items-center justify-center gap-2 font-medium">
                <i class="fas fa-exclamation-triangle"></i>
                <span class="hidden sm:inline">Fix Pricing</span>
                <span class="sm:hidden">Fix</span>
              </button>
              
              <button onclick="refreshAllPricing()" class="w-full sm:w-auto px-4 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-purple-600 to-pink-600 text-white text-sm md:text-base rounded-lg hover:from-purple-700 hover:to-pink-700 transition flex items-center justify-center gap-2 font-medium">
                <i class="fas fa-refresh"></i>
                <span class="hidden sm:inline">Refresh</span>
                <span class="sm:hidden">Refresh</span>
              </button>

              <button onclick="openBrowseModal()" class="w-full sm:w-auto px-4 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-blue-600 to-cyan-600 text-white text-sm md:text-base rounded-lg hover:from-blue-700 hover:to-cyan-700 transition flex items-center justify-center gap-2 font-medium">
                <i class="fas fa-search"></i>
                <span class="hidden sm:inline">Browse fal.ai</span>
                <span class="sm:hidden">Browse</span>
              </button>

              <button onclick="openAddModal()" class="w-full sm:w-auto px-4 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-purple-600 to-pink-600 text-white text-sm md:text-base rounded-lg hover:from-purple-700 hover:to-pink-700 transition flex items-center justify-center gap-2 font-medium">
                <i class="fas fa-plus"></i>
                <span>Add Manual</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Bulk Actions Bar -->
        <div id="bulk-actions-bar" class="glass-strong rounded-xl p-4 mb-4 hidden">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex items-center gap-3">
              <span id="selected-count" class="text-sm text-gray-300 font-medium">0 models selected</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <button 
                onclick="activateSelected()" 
                class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm rounded-lg transition flex items-center gap-2"
              >
                <i class="fas fa-check-circle"></i>
                <span>Activate Selected</span>
              </button>
              <button 
                onclick="deactivateSelected()" 
                class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm rounded-lg transition flex items-center gap-2"
              >
                <i class="fas fa-times-circle"></i>
                <span>Deactivate Selected</span>
              </button>
              <button 
                onclick="syncSelectedPrices()" 
                class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm rounded-lg transition flex items-center gap-2"
              >
                <i class="fas fa-sync"></i>
                <span>Sync Prices</span>
              </button>
              <button 
                onclick="deleteSelectedModels()" 
                class="px-4 py-2 bg-red-700 hover:bg-red-800 text-white text-sm rounded-lg transition flex items-center gap-2"
              >
                <i class="fas fa-trash"></i>
                <span>Delete Selected</span>
              </button>
              <button 
                onclick="clearSelection()" 
                class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white text-sm rounded-lg transition"
              >
                Clear
              </button>
            </div>
          </div>
        </div>

        <!-- Models Table -->
        <div class="glass-strong rounded-xl overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full min-w-[640px]">
              <thead class="bg-gray-800/50">
                <tr>
                  <th class="px-3 md:px-4 py-3 md:py-4 text-left">
                    <input 
                      type="checkbox" 
                      id="select-all-checkbox" 
                      onchange="toggleSelectAll(this)"
                      class="w-4 h-4 rounded border-gray-600 bg-gray-700 text-purple-600 focus:ring-purple-500 focus:ring-offset-gray-800 cursor-pointer"
                      title="Select All"
                    >
                  </th>
                  <th class="px-3 md:px-6 py-3 md:py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Model</th>
                  <th class="px-3 md:px-6 py-3 md:py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider hidden sm:table-cell">Type</th>
                  <th class="px-3 md:px-6 py-3 md:py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider hidden lg:table-cell">Category</th>
                  <th class="px-3 md:px-6 py-3 md:py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider hidden md:table-cell">Status</th>
                  <th class="px-3 md:px-6 py-3 md:py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">FAL Price</th>
                  <th class="px-3 md:px-6 py-3 md:py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Credits</th>
                  <th class="px-3 md:px-6 py-3 md:py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody id="models-table-body" class="divide-y divide-gray-700/50">
                <!-- Models will be loaded here -->
                <tr>
                  <td colspan="8" class="px-3 md:px-6 py-8 text-center text-gray-400">
                    <i class="fas fa-spinner fa-spin text-xl md:text-2xl mb-2"></i>
                    <p class="text-sm md:text-base">Loading models...</p>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Pagination -->
        <div id="pagination" class="mt-6 flex flex-wrap justify-center gap-2">
          <!-- Pagination buttons will be added here -->
        </div>
      </main>
    </div>
  </div>

  <!-- Add/Edit Model Modal -->
  <div id="model-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4 overflow-y-auto">
    <div class="glass-strong rounded-2xl max-w-2xl w-full my-8">
      <div class="p-4 md:p-6 border-b border-gray-700">
        <div class="flex items-center justify-between">
          <h3 id="modal-title" class="text-xl md:text-2xl font-bold text-white">Add New Model</h3>
          <button onclick="closeModal()" class="text-gray-400 hover:text-white transition">
            <i class="fas fa-times text-lg md:text-xl"></i>
          </button>
        </div>
      </div>

      <form id="model-form" class="p-4 md:p-6 space-y-4 max-h-[calc(90vh-100px)] overflow-y-auto">
        <input type="hidden" id="model-edit-id">

        <!-- Model ID & Name -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1">Model ID <span class="text-red-400">*</span></label>
            <input 
              type="text" 
              id="model-id" 
              required
              placeholder="fal-ai/flux-pro"
              class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white placeholder-gray-500 text-sm focus:outline-none focus:border-purple-500"
            >
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1">Model Name <span class="text-red-400">*</span></label>
            <input 
              type="text" 
              id="model-name" 
              required
              placeholder="FLUX Pro"
              class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white placeholder-gray-500 text-sm focus:outline-none focus:border-purple-500"
            >
          </div>
        </div>

        <!-- Provider & Description -->
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1">Provider</label>
            <input 
              type="text" 
              id="model-provider" 
              placeholder="Black Forest Labs"
              class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white placeholder-gray-500 text-sm focus:outline-none focus:border-purple-500"
            >
          </div>
          <div class="col-span-2">
            <label class="block text-xs font-semibold text-gray-300 mb-1">Description</label>
            <input 
              type="text" 
              id="model-description" 
              placeholder="Brief description..."
              class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white placeholder-gray-500 text-sm focus:outline-none focus:border-purple-500"
            >
          </div>
        </div>

        <!-- Type, Category, Speed & Quality (Compact Grid) -->
        <div class="grid grid-cols-4 gap-3">
          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1">Type <span class="text-red-400">*</span></label>
            <select 
              id="model-type" 
              required
              onchange="updateCategoryOptions()"
              class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-purple-500"
            >
              <option value="">Select</option>
              <option value="image">Image</option>
              <option value="video">Video</option>
              <option value="audio">Audio</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1">Category <span class="text-red-400">*</span></label>
            <select 
              id="model-category" 
              required
              class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-purple-500"
            >
              <option value="">Select</option>
              <!-- Image Categories -->
              <option value="Text-to-Image" data-type="image">Text-to-Image</option>
              <option value="Image Editing" data-type="image">Image Editing</option>
              <option value="Upscaling" data-type="image">Upscaling</option>
              <option value="Background Removal" data-type="image">Background Removal</option>
              <option value="Face Enhancement" data-type="image">Face Enhancement</option>
              <option value="Style Transfer" data-type="image">Style Transfer</option>
              <option value="Text-to-3D" data-type="image">Text-to-3D</option>
              <option value="Image-to-3D" data-type="image">Image-to-3D</option>
              
              <!-- Video Categories -->
              <option value="Text-to-Video" data-type="video">Text-to-Video</option>
              <option value="Image-to-Video" data-type="video">Image-to-Video</option>
              <option value="Video Editing" data-type="video">Video Editing</option>
              <option value="Video Enhancement" data-type="video">Video Enhancement</option>
              <option value="Video Upscaling" data-type="video">Video Upscaling</option>
              <option value="Animation" data-type="video">Animation</option>
              <option value="Video Effects" data-type="video">Video Effects</option>
              
              <!-- Audio Categories -->
              <option value="Text-to-Speech" data-type="audio">Text-to-Speech</option>
              <option value="Audio Generation" data-type="audio">Audio Generation</option>
              <option value="Music Generation" data-type="audio">Music Generation</option>
              <option value="Voice Cloning" data-type="audio">Voice Cloning</option>
              <option value="Audio Enhancement" data-type="audio">Audio Enhancement</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1">Speed</label>
            <select 
              id="model-speed" 
              class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-purple-500"
            >
              <option value="">Select</option>
              <option value="ultra-fast">Ultra Fast</option>
              <option value="very-fast">Very Fast</option>
              <option value="fast">Fast</option>
              <option value="medium">Medium</option>
              <option value="slow">Slow</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-semibold text-gray-300 mb-1">Quality</label>
            <select 
              id="model-quality" 
              class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-purple-500"
            >
              <option value="">Select</option>
              <option value="excellent">Excellent</option>
              <option value="very-good">Very Good</option>
              <option value="good">Good</option>
              <option value="fair">Fair</option>
            </select>
          </div>
        </div>

        <!-- Duration Configuration (for Video Models) -->
        <div id="duration-config-section" class="space-y-3 p-4 bg-gradient-to-r from-blue-900/20 to-purple-900/20 rounded-lg border border-blue-500/30">
          <div class="flex items-center gap-2">
            <i class="fas fa-clock text-blue-400"></i>
            <label class="text-sm font-semibold text-blue-300">⏱️ Duration Configuration</label>
            <span class="text-xs text-gray-400">(Video models only)</span>
          </div>
          
          <div class="grid grid-cols-2 gap-3">
            <!-- Available Durations -->
            <div>
              <label class="block text-xs text-gray-400 mb-1">Available Durations <i class="fas fa-info-circle text-cyan-400" title="Comma-separated: 5,10 or 4s,6s,8s"></i></label>
              <input 
                type="text" 
                id="available-durations" 
                placeholder="5,10 or 4s,6s,8s"
                class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white placeholder-gray-500 text-sm focus:outline-none focus:border-blue-500"
              >
              <p class="text-xs text-gray-500 mt-1">
                Examples:<br>
                • Kling: <code class="text-green-400">5,10</code><br>
                • Veo3: <code class="text-green-400">4s,6s,8s</code><br>
                • Runway: <code class="text-green-400">5,10</code>
              </p>
            </div>
            
            <!-- Price Per Second -->
            <div>
              <label class="block text-xs text-gray-400 mb-1">Price Per Second ($)</label>
              <input 
                type="number" 
                id="price-per-second-input" 
                step="0.0001"
                placeholder="0.0100"
                oninput="autoCalculateCredits()"
                class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white placeholder-gray-500 text-sm focus:outline-none focus:border-blue-500"
              >
              <p class="text-xs text-gray-500 mt-1">
                Used for per-second pricing calculation
              </p>
            </div>
          </div>
          
          <!-- Duration Preview -->
          <div class="p-3 bg-gray-800/30 rounded-lg">
            <p class="text-xs font-semibold text-cyan-400 mb-2">💡 Duration Preview:</p>
            <div id="duration-preview" class="text-xs text-gray-300">
              Enter durations above to see preview...
            </div>
          </div>
          
          <!-- Duration Type -->
          <div>
            <label class="block text-xs text-gray-400 mb-1">Duration Format <i class="fas fa-info-circle text-cyan-400" title="How duration is sent to API"></i></label>
            <select 
              id="duration-format-type" 
              class="w-full px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-blue-500"
            >
              <option value="number">Number (e.g., Veo: 4, 6, 8)</option>
              <option value="string">String (e.g., Kling: "5", "10")</option>
            </select>
            <p class="text-xs text-gray-500 mt-1">
              <strong>Number:</strong> Google Veo models (4, 6, 8)<br>
              <strong>String:</strong> Kling models ("5", "10", "15")
            </p>
          </div>
        </div>

        <!-- Advanced Model Configuration -->
        <div class="space-y-3 p-4 bg-gradient-to-r from-purple-900/20 to-pink-900/20 rounded-lg border border-purple-500/30">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <i class="fas fa-cog text-purple-400"></i>
              <label class="text-sm font-semibold text-purple-300">⚙️ Advanced Configuration</label>
            </div>
            <button type="button" onclick="loadModelTemplate()" class="px-3 py-1.5 bg-purple-600 hover:bg-purple-700 text-white text-xs rounded transition">
              <i class="fas fa-download mr-1"></i> Load Template
            </button>
          </div>
          
          <div class="grid grid-cols-2 gap-3">
            <!-- Parameter Style -->
            <div>
