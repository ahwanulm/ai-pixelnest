<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Blog PixelNest - Artikel, tips, dan insights tentang AI video generation, strategi content marketing, dan teknologi AI terkini.">
    <title><%= title %></title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    <script src="/js/theme-manager.js"></script>
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Hero Section -->
        <section class="relative py-12 overflow-hidden">
            <!-- Background Effects -->
            <div class="absolute inset-0 opacity-20">
                <div class="absolute top-20 left-10 w-72 h-72 bg-violet-600/30 rounded-full blur-3xl animate-pulse"></div>
                <div class="absolute bottom-20 right-10 w-96 h-96 bg-fuchsia-600/30 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
            </div>

            <div class="section-container relative z-10">
                <div class="text-center max-w-4xl mx-auto mb-12">
                    <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6 text-violet-400 animate-fade-in">
                        Blog & Insights
                    </span>
                    <h1 class="text-5xl md:text-7xl font-black mb-6 tracking-tight animate-slide-up">
                        Belajar Lebih Dalam tentang AI Video
                    </h1>
                    <p class="text-lg md:text-xl text-gray-400 font-light animate-slide-up" style="animation-delay: 0.1s;">
                        Artikel terbaru tentang strategi, tips, fakta menarik,<br class="hidden md:block">
                        dan teknologi AI video generation
                    </p>
                </div>
            </div>
        </section>

        <!-- Blog Posts Grid -->
        <section class="section-container py-12">
            <% if (posts && posts.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
                    <% posts.forEach(function(post) { %>
                        <article class="glass rounded-2xl overflow-hidden hover:glass-strong transition-all duration-300 group">
                            <!-- Category Badge -->
                            <% if (post.category) { %>
                                <div class="p-6 pb-4">
                                    <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full <%= 
                                        post.category.includes('Strategi') ? 'bg-violet-500/10 text-violet-400 border border-violet-500/20' :
                                        post.category.includes('Teknologi') ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20' :
                                        post.category.includes('Fakta') ? 'bg-green-500/10 text-green-400 border border-green-500/20' :
                                        post.category.includes('Tutorial') ? 'bg-orange-500/10 text-orange-400 border border-orange-500/20' :
                                        post.category.includes('Tren') ? 'bg-pink-500/10 text-pink-400 border border-pink-500/20' :
                                        post.category.includes('Case') ? 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20' :
                                        'bg-purple-500/10 text-purple-400 border border-purple-500/20'
                                    %>">
                                        <%= post.category %>
                                    </span>
                                </div>
                            <% } %>
                            
                            <!-- Content -->
                            <div class="px-6 pb-6">
                                <h3 class="text-xl font-bold mb-3 leading-tight group-hover:text-violet-400 transition-colors">
                                    <a href="/blog/<%= post.slug %>"><%= post.title %></a>
                                </h3>
                                
                                <% if (post.excerpt) { %>
                                    <p class="text-sm text-gray-400 leading-relaxed mb-4 line-clamp-3">
                                        <%= post.excerpt %>
                                    </p>
                                <% } %>
                                
                                <!-- Meta Info -->
                                <div class="flex items-center justify-between text-xs text-gray-500 mb-4">
                                    <div class="flex items-center gap-4">
                                        <% if (post.author) { %>
                                            <span class="flex items-center gap-1">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                                </svg>
                                                <%= post.author %>
                                            </span>
                                        <% } %>
                                        <span class="flex items-center gap-1">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                            </svg>
                                            <%= post.views || 0 %> views
                                        </span>
                                    </div>
                                </div>
                                
                                <!-- Read More Link -->
                                <a href="/blog/<%= post.slug %>" class="inline-flex items-center gap-2 text-sm font-semibold text-violet-400 hover:text-violet-300 transition-colors group">
                                    Baca Selengkapnya
                                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                                    </svg>
                                </a>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="text-center max-w-md mx-auto glass rounded-2xl p-12">
                    <svg class="w-16 h-16 mx-auto mb-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                    <h3 class="text-xl font-bold mb-2">Belum Ada Artikel</h3>
                    <p class="text-gray-400">Artikel blog akan segera hadir. Stay tuned!</p>
                </div>
            <% } %>
        </section>

        <!-- CTA Section -->
        <section class="section-container py-12">
            <div class="relative overflow-hidden rounded-3xl max-w-4xl mx-auto">
                <div class="absolute inset-0 holographic opacity-20"></div>
                <div class="absolute inset-0 glass"></div>
                
                <div class="relative z-10 text-center py-16 px-8">
                    <h2 class="text-3xl md:text-5xl font-black mb-4 tracking-tight">
                        Siap Membuat Video AI?
                    </h2>
                    <p class="text-lg text-gray-400 mb-8 max-w-2xl mx-auto">
                        Terapkan tips dan strategi dari artikel di atas dengan PixelNest
                    </p>
                    <a href="/contact" class="btn-primary text-base inline-block px-10 py-4">
                        Mulai Gratis Sekarang
                    </a>
                </div>
            </div>
        </section>
    </main>
    
    <%- include('partials/footer') %>
    
    <script src="/js/main.js"></script>
</body>
</html>

