<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="PixelNest Workflow Automation - Streamline your business processes">
    <title>Workflow Automation - PixelNest</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Hero Section -->
        <section class="relative py-20 overflow-hidden">
            <div class="section-container relative z-10">
                <div class="text-center mb-16">
                    <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6 text-blue-400">
                        Automation
                    </span>
                    <h1 class="text-5xl md:text-6xl font-black mb-6 tracking-tight">
                        Workflow Automation
                    </h1>
                    <p class="text-lg text-gray-400 font-light max-w-2xl mx-auto">
                        Automate repetitive tasks and streamline your business processes with intelligent automation solutions.
                    </p>
                </div>

                <!-- Benefits -->
                <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
                    <div class="glass rounded-2xl p-8 text-center">
                        <div class="text-5xl mb-4">⚡</div>
                        <h3 class="text-2xl font-bold mb-3 gradient-text">Save Time</h3>
                        <p class="text-gray-300">Automate tasks that take hours and complete them in seconds. Free up your team for strategic work.</p>
                    </div>
                    <div class="glass rounded-2xl p-8 text-center">
                        <div class="text-5xl mb-4">🎯</div>
                        <h3 class="text-2xl font-bold mb-3 gradient-text">Reduce Errors</h3>
                        <p class="text-gray-300">Eliminate human errors with consistent, reliable automated processes that work perfectly every time.</p>
                    </div>
                    <div class="glass rounded-2xl p-8 text-center">
                        <div class="text-5xl mb-4">📈</div>
                        <h3 class="text-2xl font-bold mb-3 gradient-text">Scale Easily</h3>
                        <p class="text-gray-300">Handle increased workload without hiring more staff. Automation scales with your business growth.</p>
                    </div>
                </div>

                <!-- What We Automate -->
                <div class="max-w-6xl mx-auto mb-16">
                    <h2 class="text-3xl font-black text-center mb-12 tracking-tight">What We Automate</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="glass rounded-2xl p-6">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 text-violet-400">Email Processing</h3>
                                    <p class="text-gray-300 text-sm">Automatically sort, categorize, and respond to emails. Extract data and trigger actions based on email content.</p>
                                </div>
                            </div>
                        </div>

                        <div class="glass rounded-2xl p-6">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 text-fuchsia-400">Document Management</h3>
                                    <p class="text-gray-300 text-sm">Automate document generation, processing, and filing. Extract information from PDFs and images automatically.</p>
                                </div>
                            </div>
                        </div>

                        <div class="glass rounded-2xl p-6">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-cyan-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 text-blue-400">Financial Processes</h3>
                                    <p class="text-gray-300 text-sm">Automate invoicing, expense tracking, payment reminders, and reconciliation. Keep finances organized effortlessly.</p>
                                </div>
                            </div>
                        </div>

                        <div class="glass rounded-2xl p-6">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-violet-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 text-purple-400">Customer Management</h3>
                                    <p class="text-gray-300 text-sm">Automate customer onboarding, follow-ups, and support ticketing. Enhance customer experience with rapid responses.</p>
                                </div>
                            </div>
                        </div>

                        <div class="glass rounded-2xl p-6">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 bg-gradient-to-br from-pink-600 to-red-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 text-pink-400">Data Collection</h3>
                                    <p class="text-gray-300 text-sm">Automatically gather data from multiple sources, clean it, and organize it for analysis and reporting.</p>
                                </div>
                            </div>
                        </div>

                        <div class="glass rounded-2xl p-6">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 bg-gradient-to-br from-cyan-600 to-blue-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 text-cyan-400">Scheduling & Reminders</h3>
                                    <p class="text-gray-300 text-sm">Automate appointment booking, meeting scheduling, and send automated reminders to reduce no-shows.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- How It Works -->
                <div class="max-w-4xl mx-auto mb-16">
                    <h2 class="text-3xl font-black text-center mb-12 tracking-tight">How It Works</h2>
                    <div class="space-y-6">
                        <div class="glass rounded-2xl p-8">
                            <div class="flex items-start gap-6">
                                <div class="w-12 h-12 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-xl flex items-center justify-center flex-shrink-0 text-xl font-black">1</div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 gradient-text">Consultation</h3>
                                    <p class="text-gray-300">We analyze your current workflows and identify automation opportunities that will have the biggest impact on your business.</p>
                                </div>
                            </div>
                        </div>

                        <div class="glass rounded-2xl p-8">
                            <div class="flex items-start gap-6">
                                <div class="w-12 h-12 bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded-xl flex items-center justify-center flex-shrink-0 text-xl font-black">2</div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 gradient-text">Design</h3>
                                    <p class="text-gray-300">Our team designs custom automation workflows tailored to your specific needs, processes, and existing tools.</p>
                                </div>
                            </div>
                        </div>

                        <div class="glass rounded-2xl p-8">
                            <div class="flex items-start gap-6">
                                <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-cyan-600 rounded-xl flex items-center justify-center flex-shrink-0 text-xl font-black">3</div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 gradient-text">Implementation</h3>
                                    <p class="text-gray-300">We build and deploy your automation system, integrate it with your existing tools, and ensure everything works seamlessly.</p>
                                </div>
                            </div>
                        </div>

                        <div class="glass rounded-2xl p-8">
                            <div class="flex items-start gap-6">
                                <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-violet-600 rounded-xl flex items-center justify-center flex-shrink-0 text-xl font-black">4</div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2 gradient-text">Support & Optimization</h3>
                                    <p class="text-gray-300">We provide ongoing support and continuously optimize your automations for better performance and new opportunities.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Results -->
                <div class="max-w-6xl mx-auto mb-16">
                    <div class="glass rounded-2xl p-12">
                        <h2 class="text-3xl font-black text-center mb-12 tracking-tight">Expected Results</h2>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
                            <div>
                                <div class="text-4xl font-black gradient-text mb-2">70%</div>
                                <div class="text-sm text-gray-400">Time Saved</div>
                            </div>
                            <div>
                                <div class="text-4xl font-black gradient-text mb-2">95%</div>
                                <div class="text-sm text-gray-400">Fewer Errors</div>
                            </div>
                            <div>
                                <div class="text-4xl font-black gradient-text mb-2">3x</div>
                                <div class="text-sm text-gray-400">Productivity</div>
                            </div>
                            <div>
                                <div class="text-4xl font-black gradient-text mb-2">24/7</div>
                                <div class="text-sm text-gray-400">Operations</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CTA -->
                <div class="max-w-4xl mx-auto">
                    <div class="glass-strong rounded-2xl p-12 text-center">
                        <h2 class="text-3xl font-black mb-4 tracking-tight">Ready to Automate Your Workflows?</h2>
                        <p class="text-gray-300 mb-8">Let's discuss how automation can transform your business</p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="/contact-page" class="btn-primary px-8 py-3">Schedule Consultation</a>
                            <a href="/case-studies" class="btn-outline px-8 py-3">View Case Studies</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>

