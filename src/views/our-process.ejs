<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="PixelNest Process - How we deliver AI-powered solutions">
    <title>Our Process - PixelNest</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    <script src="/js/theme-manager.js"></script>
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Hero Section -->
        <section class="relative py-20 overflow-hidden">
            <div class="section-container relative z-10">
                <div class="text-center mb-16">
                    <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6 text-violet-400">
                        How It Works
                    </span>
                    <h1 class="text-5xl md:text-6xl font-black mb-6 tracking-tight">
                        Our Process
                    </h1>
                    <p class="text-lg text-gray-400 font-light max-w-2xl mx-auto">
                        From concept to creation in four simple steps
                    </p>
                </div>

                <!-- Process Steps -->
                <div class="max-w-5xl mx-auto space-y-12 mb-16">
                    <!-- Step 1 -->
                    <div class="glass rounded-2xl p-8 md:p-12 hover:glass-strong transition-all duration-300">
                        <div class="flex flex-col md:flex-row gap-8 items-start">
                            <div class="flex-shrink-0">
                                <div class="w-16 h-16 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-2xl flex items-center justify-center text-2xl font-black">
                                    01
                                </div>
                            </div>
                            <div class="flex-1">
                                <h2 class="text-3xl font-bold mb-4 gradient-text">Discovery & Planning</h2>
                                <p class="text-gray-300 mb-4 leading-relaxed">
                                    We start by understanding your vision. What do you want to create? What's your goal? Whether you're generating a single image or planning a full campaign, we help you define your requirements and choose the right AI models.
                                </p>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="glass-strong rounded-lg p-4">
                                        <h3 class="font-bold text-violet-400 mb-2">For Individuals</h3>
                                        <p class="text-sm text-gray-400">Choose your creation type, select AI model, and set your preferences through our intuitive dashboard.</p>
                                    </div>
                                    <div class="glass-strong rounded-lg p-4">
                                        <h3 class="font-bold text-fuchsia-400 mb-2">For Enterprises</h3>
                                        <p class="text-sm text-gray-400">Consultation call to understand scale, requirements, and custom integration needs.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2 -->
                    <div class="glass rounded-2xl p-8 md:p-12 hover:glass-strong transition-all duration-300">
                        <div class="flex flex-col md:flex-row gap-8 items-start">
                            <div class="flex-shrink-0">
                                <div class="w-16 h-16 bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded-2xl flex items-center justify-center text-2xl font-black">
                                    02
                                </div>
                            </div>
                            <div class="flex-1">
                                <h2 class="text-3xl font-bold mb-4 gradient-text">Configuration & Setup</h2>
                                <p class="text-gray-300 mb-4 leading-relaxed">
                                    Configure your generation parameters. Write detailed prompts, adjust settings like resolution, aspect ratio, duration, and style. Our smart suggestions help you get the best results from our AI models.
                                </p>
                                <div class="space-y-3">
                                    <div class="flex items-start gap-3">
                                        <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <div>
                                            <p class="text-white font-semibold">Smart Prompt Engineering</p>
                                            <p class="text-sm text-gray-400">AI-powered suggestions to improve your prompts</p>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <div>
                                            <p class="text-white font-semibold">Parameter Optimization</p>
                                            <p class="text-sm text-gray-400">Automatic settings adjustment for best quality</p>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3">
                                        <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <div>
                                            <p class="text-white font-semibold">Cost Estimation</p>
                                            <p class="text-sm text-gray-400">Know exactly how many credits each generation will use</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Step 3 -->
                    <div class="glass rounded-2xl p-8 md:p-12 hover:glass-strong transition-all duration-300">
                        <div class="flex flex-col md:flex-row gap-8 items-start">
                            <div class="flex-shrink-0">
                                <div class="w-16 h-16 bg-gradient-to-br from-blue-600 to-cyan-600 rounded-2xl flex items-center justify-center text-2xl font-black">
                                    03
                                </div>
                            </div>
                            <div class="flex-1">
                                <h2 class="text-3xl font-bold mb-4 gradient-text">AI Generation</h2>
                                <p class="text-gray-300 mb-4 leading-relaxed">
                                    Our powerful AI models spring into action. Watch in real-time as your content is generated. We use cutting-edge models from leading AI providers, optimized for speed and quality. Most images complete in under 30 seconds, videos in 1-5 minutes.
                                </p>
                                <div class="glass-strong rounded-lg p-4">
                                    <div class="flex items-center gap-3 mb-3">
                                        <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
                                        <span class="text-sm font-mono font-semibold uppercase tracking-wider text-gray-400">Real-time Status</span>
                                    </div>
                                    <p class="text-sm text-gray-400">Track your generation progress with live updates. Receive notifications when your content is ready to download.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Step 4 -->
                    <div class="glass rounded-2xl p-8 md:p-12 hover:glass-strong transition-all duration-300">
                        <div class="flex flex-col md:flex-row gap-8 items-start">
                            <div class="flex-shrink-0">
                                <div class="w-16 h-16 bg-gradient-to-br from-purple-600 to-violet-600 rounded-2xl flex items-center justify-center text-2xl font-black">
                                    04
                                </div>
                            </div>
                            <div class="flex-1">
                                <h2 class="text-3xl font-bold mb-4 gradient-text">Review & Refine</h2>
                                <p class="text-gray-300 mb-4 leading-relaxed">
                                    Review your generated content, download in high quality, and iterate if needed. All your creations are saved in your gallery for easy access. Not satisfied? Adjust your parameters and regenerate until you achieve the perfect result.
                                </p>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                    <div class="glass-strong rounded-lg p-4 text-center">
                                        <div class="text-2xl mb-2">💾</div>
                                        <p class="text-sm font-semibold text-white mb-1">Download</p>
                                        <p class="text-xs text-gray-400">High-quality files ready to use</p>
                                    </div>
                                    <div class="glass-strong rounded-lg p-4 text-center">
                                        <div class="text-2xl mb-2">🔄</div>
                                        <p class="text-sm font-semibold text-white mb-1">Iterate</p>
                                        <p class="text-xs text-gray-400">Refine until perfect</p>
                                    </div>
                                    <div class="glass-strong rounded-lg p-4 text-center">
                                        <div class="text-2xl mb-2">📤</div>
                                        <p class="text-sm font-semibold text-white mb-1">Share</p>
                                        <p class="text-xs text-gray-400">Export to any platform</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Why Our Process Works -->
                <div class="max-w-4xl mx-auto mb-16">
                    <h2 class="text-3xl font-black text-center mb-12 tracking-tight">Why Our Process Works</h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="glass rounded-2xl p-6 text-center">
                            <div class="text-4xl mb-4">⚡</div>
                            <h3 class="text-lg font-bold mb-3 text-violet-400">Fast & Efficient</h3>
                            <p class="text-gray-300 text-sm">Optimized workflow reduces generation time by up to 90% compared to traditional methods.</p>
                        </div>

                        <div class="glass rounded-2xl p-6 text-center">
                            <div class="text-4xl mb-4">🎯</div>
                            <h3 class="text-lg font-bold mb-3 text-fuchsia-400">Consistent Quality</h3>
                            <p class="text-gray-300 text-sm">Proven process ensures reliable, high-quality results every single time.</p>
                        </div>

                        <div class="glass rounded-2xl p-6 text-center">
                            <div class="text-4xl mb-4">📈</div>
                            <h3 class="text-lg font-bold mb-3 text-blue-400">Scalable</h3>
                            <p class="text-gray-300 text-sm">From one image to thousands of videos, our process scales with your needs.</p>
                        </div>
                    </div>
                </div>

                <!-- CTA -->
                <div class="max-w-4xl mx-auto">
                    <div class="glass-strong rounded-2xl p-12 text-center">
                        <h2 class="text-3xl font-black mb-4 tracking-tight">Ready to Get Started?</h2>
                        <p class="text-gray-300 mb-8">Experience our streamlined process today</p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="/auth/register" class="btn-primary px-8 py-3">Start Creating Free</a>
                            <a href="/documentation" class="btn-outline px-8 py-3">View Documentation</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>

