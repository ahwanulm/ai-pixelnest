<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="PixelNest - AI Video Generation Platform. Create stunning videos with AI in seconds.">
    <title><%= title %></title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Hero Section -->
        <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
            
            <div class="section-container relative z-10">
                <div class="text-center max-w-6xl mx-auto">
                    <!-- Badge -->
                    <div class="inline-flex items-center space-x-3 glass px-6 py-3 rounded-full mb-8 animate-fade-in group hover:glass-strong transition-all duration-300">
                        <img src="/assets/img/logo/logo.png" alt="PixelNest" class="h-6 w-auto group-hover:scale-110 transition-transform">
                        <span class="text-xs font-bold uppercase tracking-[0.2em] font-mono">AI VIDEO GENERATION</span>
                    </div>
                    
                    <!-- Main Heading -->
                    <h1 class="text-7xl md:text-8xl lg:text-9xl font-black mb-6 leading-[0.9] animate-slide-up tracking-tight">
                        Create Videos with AI in Seconds
                    </h1>
                    
                    <!-- Subtitle -->
                    <p class="text-lg md:text-xl text-gray-400 mb-12 max-w-2xl mx-auto animate-slide-up font-light leading-relaxed" style="animation-delay: 0.1s;">
                        Transform ideas into stunning videos instantly.<br class="hidden md:block">
                        No editing skills. Just <span class="text-violet-400 font-semibold">pure AI magic</span>.
                    </p>
                    
                    <!-- CTA Buttons -->
                    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-20 animate-slide-up" style="animation-delay: 0.2s;">
                        <a href="/contact" class="group btn-primary text-base px-10 py-4">
                            <span class="flex items-center gap-2 justify-center">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M8 5v14l11-7z"/>
                                </svg>
                                Start Creating Free
                            </span>
                        </a>
                        <a href="#features" class="btn-outline text-base px-10 py-4">
                            See Features
                        </a>
                    </div>
                    
                    <!-- Video Showcase -->
                    <div class="relative max-w-5xl mx-auto animate-scale-in" style="animation-delay: 0.3s;">
                        <div class="video-frame aspect-video bg-gradient-to-br from-gray-900 to-black relative group cursor-pointer film-strip">
                            <div class="absolute inset-0 flex items-center justify-center">
                                <div class="relative">
                                    <button class="play-button relative w-20 h-20 bg-gradient-to-r from-violet-600 to-fuchsia-600 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                        <svg class="w-10 h-10 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M8 5v14l11-7z"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            
                            <div class="absolute inset-0 grid grid-cols-3 gap-1 p-4 opacity-20 group-hover:opacity-30 transition-opacity">
                                <div class="bg-gradient-to-br from-violet-600 to-purple-600 rounded"></div>
                                <div class="bg-gradient-to-br from-purple-600 to-fuchsia-600 rounded"></div>
                                <div class="bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded"></div>
                                <div class="bg-gradient-to-br from-blue-600 to-violet-600 rounded"></div>
                                <div class="bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded"></div>
                                <div class="bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded"></div>
                                <div class="bg-gradient-to-br from-purple-600 to-violet-600 rounded"></div>
                                <div class="bg-gradient-to-br from-violet-600 to-blue-600 rounded"></div>
                                <div class="bg-gradient-to-br from-fuchsia-600 to-purple-600 rounded"></div>
                            </div>
                            
                            <div class="absolute top-4 left-4 flex items-center gap-2 glass px-3 py-1.5 rounded-full">
                                <div class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></div>
                                <span class="text-[10px] font-mono font-semibold uppercase tracking-wider">AI GENERATING</span>
                            </div>
                        </div>
                        
                        <!-- Stats -->
                        <div class="absolute -bottom-6 left-1/2 transform -translate-x-1/2 w-full max-w-2xl">
                            <div class="glass rounded-xl p-4 backdrop-blur-xl">
                                <div class="grid grid-cols-3 gap-6 text-center">
                                    <div>
                                        <div class="text-2xl font-black gradient-text mb-0.5">2.5M+</div>
                                        <div class="text-[10px] text-gray-500 uppercase tracking-wider font-mono">Videos</div>
                                    </div>
                                    <div>
                                        <div class="text-2xl font-black gradient-text mb-0.5">30s</div>
                                        <div class="text-[10px] text-gray-500 uppercase tracking-wider font-mono">Generation</div>
                                    </div>
                                    <div>
                                        <div class="text-2xl font-black gradient-text mb-0.5">4K</div>
                                        <div class="text-[10px] text-gray-500 uppercase tracking-wider font-mono">Quality</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- AI Models Preview Section -->
        <section class="section-container py-20">
            <div class="text-center mb-16">
                <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6 text-blue-400">
                    AI Models
                </span>
                <h2 class="text-4xl md:text-5xl font-black mb-4 tracking-tight">
                    Powered by Leading AI
                </h2>
                <p class="text-lg text-gray-400 max-w-2xl mx-auto font-light">
                    Choose from the best AI models for your video generation needs
                </p>
            </div>

            <!-- Featured Models Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
                <!-- Model 1: Veo 2 -->
                <div class="glass rounded-2xl p-6 hover:glass-strong transition-all duration-300 group">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-12 h-12 bg-blue-600/20 border border-blue-500/30 rounded-xl flex items-center justify-center text-blue-400 font-bold text-xl flex-shrink-0">
                            G
                        </div>
                        <div>
                            <h3 class="font-bold text-lg">Veo 2</h3>
                            <p class="text-xs text-gray-500">Google DeepMind</p>
                        </div>
                    </div>
                    <div class="flex gap-2 mb-3">
                        <span class="text-xs font-semibold px-3 py-1 bg-blue-500/10 text-blue-400 rounded-full">VIDEO</span>
                        <span class="text-xs font-semibold px-3 py-1 bg-white/5 text-gray-400 rounded-full">4K Ultra HD</span>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Photorealistic video generation with precise motion control
                    </p>
                </div>

                <!-- Model 2: Sora 2 -->
                <div class="glass rounded-2xl p-6 hover:glass-strong transition-all duration-300 group">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-12 h-12 bg-green-600/20 border border-green-500/30 rounded-xl flex items-center justify-center text-green-400 font-bold text-xl flex-shrink-0">
                            O
                        </div>
                        <div>
                            <h3 class="font-bold text-lg">Sora 2</h3>
                            <p class="text-xs text-gray-500">OpenAI</p>
                        </div>
                    </div>
                    <div class="flex gap-2 mb-3">
                        <span class="text-xs font-semibold px-3 py-1 bg-blue-500/10 text-blue-400 rounded-full">VIDEO</span>
                        <span class="text-xs font-semibold px-3 py-1 bg-white/5 text-gray-400 rounded-full">60 seconds</span>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Text-to-video AI creating realistic and imaginative scenes
                    </p>
                </div>

                <!-- Model 3: Imagen 3 -->
                <div class="glass rounded-2xl p-6 hover:glass-strong transition-all duration-300 group">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-12 h-12 bg-indigo-600/20 border border-indigo-500/30 rounded-xl flex items-center justify-center text-indigo-400 font-bold text-xl flex-shrink-0">
                            G
                        </div>
                        <div>
                            <h3 class="font-bold text-lg">Imagen 3</h3>
                            <p class="text-xs text-gray-500">Google</p>
                        </div>
                    </div>
                    <div class="flex gap-2 mb-3">
                        <span class="text-xs font-semibold px-3 py-1 bg-purple-500/10 text-purple-400 rounded-full">IMAGE</span>
                        <span class="text-xs font-semibold px-3 py-1 bg-white/5 text-gray-400 rounded-full">8K Quality</span>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        High-quality image generation with prompt understanding
                    </p>
                </div>

                <!-- Model 4: DALL-E 4 -->
                <div class="glass rounded-2xl p-6 hover:glass-strong transition-all duration-300 group">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-12 h-12 bg-teal-600/20 border border-teal-500/30 rounded-xl flex items-center justify-center text-teal-400 font-bold text-xl flex-shrink-0">
                            O
                        </div>
                        <div>
                            <h3 class="font-bold text-lg">DALL-E 4</h3>
                            <p class="text-xs text-gray-500">OpenAI</p>
                        </div>
                    </div>
                    <div class="flex gap-2 mb-3">
                        <span class="text-xs font-semibold px-3 py-1 bg-purple-500/10 text-purple-400 rounded-full">IMAGE</span>
                        <span class="text-xs font-semibold px-3 py-1 bg-white/5 text-gray-400 rounded-full">Versatile</span>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Create realistic images from natural language descriptions
                    </p>
                </div>

                <!-- Model 5: GPT-4 Turbo -->
                <div class="glass rounded-2xl p-6 hover:glass-strong transition-all duration-300 group">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-12 h-12 bg-gradient-to-br from-emerald-600 to-green-600 rounded-xl flex items-center justify-center text-white font-bold text-xl flex-shrink-0">
                            O
                        </div>
                        <div>
                            <h3 class="font-bold text-lg">GPT-4 Turbo</h3>
                            <p class="text-xs text-gray-500">OpenAI</p>
                        </div>
                    </div>
                    <div class="flex gap-2 mb-3">
                        <span class="text-xs font-semibold px-3 py-1 bg-green-500/10 text-green-400 rounded-full">LANGUAGE</span>
                        <span class="text-xs font-semibold px-3 py-1 bg-white/5 text-gray-400 rounded-full">128K Context</span>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Most capable GPT model with superior performance
                    </p>
                </div>

                <!-- Model 6: Claude 3.5 -->
                <div class="glass rounded-2xl p-6 hover:glass-strong transition-all duration-300 group">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-12 h-12 bg-gradient-to-br from-orange-600 to-amber-600 rounded-xl flex items-center justify-center text-white font-bold text-xl flex-shrink-0">
                            A
                        </div>
                        <div>
                            <h3 class="font-bold text-lg">Claude 3.5 Sonnet</h3>
                            <p class="text-xs text-gray-500">Anthropic</p>
                        </div>
                    </div>
                    <div class="flex gap-2 mb-3">
                        <span class="text-xs font-semibold px-3 py-1 bg-green-500/10 text-green-400 rounded-full">LANGUAGE</span>
                        <span class="text-xs font-semibold px-3 py-1 bg-white/5 text-gray-400 rounded-full">200K Context</span>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Advanced AI with excellent reasoning capabilities
                    </p>
                </div>
            </div>

            <!-- CTA to Services Page -->
            <div class="text-center">
                <a href="/services" class="inline-flex items-center gap-2 btn-outline px-8 py-3">
                    <span>Explore All 50+ Models</span>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                </a>
            </div>
        </section>

        <!-- Features Section - Compact Design -->
        <section id="features" class="section-container py-32">
            <div class="text-center mb-20">
                <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6">
                    Features
                </span>
                <h2 class="text-5xl md:text-6xl font-black mb-4 tracking-tight">
                    Everything You Need
                </h2>
                <p class="text-lg text-gray-400 max-w-2xl mx-auto font-light">
                    Professional AI-powered tools for video creation
                </p>
            </div>
            
            <!-- Compact Grid -->
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-12 max-w-6xl mx-auto">
                <!-- Feature 1 -->
                <div class="feature-compact">
                    <div class="icon-wrapper bg-gradient-to-br from-violet-600 to-purple-600">
                        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                    </div>
                    <h3>Text to Video</h3>
                    <p>Describe your vision, AI creates it</p>
                </div>

                <!-- Feature 2 -->
                <div class="feature-compact">
                    <div class="icon-wrapper bg-gradient-to-br from-fuchsia-600 to-pink-600">
                        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
                        </svg>
                    </div>
                    <h3>AI Voice</h3>
                    <p>50+ ultra-realistic voices</p>
                </div>

                <!-- Feature 3 -->
                <div class="feature-compact">
                    <div class="icon-wrapper bg-gradient-to-br from-blue-600 to-cyan-600">
                        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <h3>Auto-Edit</h3>
                    <p>Smart cuts & transitions</p>
                </div>

                <!-- Feature 4 -->
                <div class="feature-compact">
                    <div class="icon-wrapper bg-gradient-to-br from-green-600 to-emerald-600">
                        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                    </div>
                    <h3>Stock Library</h3>
                    <p>Millions of assets</p>
                </div>

                <!-- Feature 5 -->
                <div class="feature-compact">
                    <div class="icon-wrapper bg-gradient-to-br from-orange-600 to-red-600">
                        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                        </svg>
                    </div>
                    <h3>4K Export</h3>
                    <p>Ultra HD quality</p>
                </div>

                <!-- Feature 6 -->
                <div class="feature-compact">
                    <div class="icon-wrapper bg-gradient-to-br from-purple-600 to-indigo-600">
                        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                    </div>
                    <h3>Collaborate</h3>
                    <p>Real-time teamwork</p>
                </div>
            </div>
        </section>

        <!-- How It Works - Compact -->
        <section class="section-container py-20">
            <div class="text-center mb-16">
              
                <h2 class="text-4xl md:text-5xl font-black mb-4 tracking-tight">
                    Three Simple Steps
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 max-w-5xl mx-auto">
                <!-- Step 1 -->
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-violet-600 to-purple-600 rounded-2xl mb-6 text-2xl font-black">
                        1
                    </div>
                    <h3 class="text-xl font-bold mb-3">Describe Your Video</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Type what you want. AI understands your vision.
                    </p>
                </div>

                <!-- Step 2 -->
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded-2xl mb-6 text-2xl font-black">
                        2
                    </div>
                    <h3 class="text-xl font-bold mb-3">AI Generates</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Watch AI create your video in real-time.
                    </p>
                </div>

                <!-- Step 3 -->
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-blue-600 to-cyan-600 rounded-2xl mb-6 text-2xl font-black">
                        3
                    </div>
                    <h3 class="text-xl font-bold mb-3">Download & Share</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        Get your video in 4K. Share everywhere.
                    </p>
                </div>
            </div>
        </section>

        <!-- Testimonials - Compact -->
        <section class="section-container py-20">
            <div class="text-center mb-16">
                <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6">
                    Reviews
                </span>
                <h2 class="text-4xl md:text-5xl font-black mb-4 tracking-tight">
                    Loved by Creators
                </h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
                <% if (testimonials && testimonials.length > 0) { %>
                    <% testimonials.slice(0, 3).forEach(function(testimonial) { %>
                        <div class="glass rounded-2xl p-6 hover:glass-strong transition-all duration-300">
                            <div class="flex gap-1 mb-3">
                                <% for(let i = 0; i < 5; i++) { %>
                                    <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                                <% } %>
                            </div>
                            <p class="text-sm text-gray-300 mb-4 leading-relaxed">
                                "<%= testimonial.testimonial %>"
                            </p>
                            <div>
                                <div class="text-sm font-semibold"><%= testimonial.name %></div>
                                <div class="text-xs text-gray-500"><%= testimonial.position %></div>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="section-container py-20">
            <div class="relative overflow-hidden rounded-3xl">
                <div class="absolute inset-0 holographic opacity-20"></div>
                <div class="absolute inset-0 glass"></div>
                
                <div class="relative z-10 text-center py-24 px-8">
                    <div class="w-20 h-20 bg-gradient-to-r from-violet-600 to-fuchsia-600 rounded-2xl flex items-center justify-center mx-auto mb-8 play-button">
                        <svg class="w-10 h-10 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M8 5v14l11-7z"/>
                        </svg>
                    </div>
                    <h2 class="text-4xl md:text-6xl font-black mb-6 tracking-tight">
                        Ready to Create?
                    </h2>
                    <p class="text-lg text-gray-400 mb-8 max-w-2xl mx-auto font-light">
                        Join thousands making stunning AI videos
                    </p>
                    <a href="/contact" class="btn-primary text-base inline-block px-10 py-4">
                        Start Free Today
                    </a>
                    <p class="text-xs text-gray-600 mt-6 font-mono">No credit card • 3 free videos</p>
                </div>
            </div>
        </section>
    </main>
    
    <%- include('partials/footer') %>
    
    <script src="/js/main.js"></script>
</body>
</html>
