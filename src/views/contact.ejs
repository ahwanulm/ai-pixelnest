<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    <script src="/js/theme-manager.js"></script>
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Page Header -->
        <section class="section-container pt-32 pb-16 text-center">
            <div class="max-w-4xl mx-auto">
                <span class="inline-block px-6 py-2 glass rounded-full text-sm font-semibold uppercase tracking-wider mb-6">
                    Contact Us
                </span>
                <h1 class="text-6xl md:text-7xl font-black mb-6">
                    Get In <span class="gradient-text">Touch</span>
                </h1>
                <p class="text-xl text-gray-400">
                    Let's discuss how we can help automate and grow your business
                </p>
            </div>
        </section>

        <!-- Contact Section -->
        <section class="section-container">
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 max-w-6xl mx-auto">
                <!-- Contact Form -->
                <div class="lg:col-span-3">
                    <div class="card">
                        <h2 class="text-3xl font-bold mb-6">Send us a message</h2>
                        
                        <% if (errors && errors.length > 0) { %>
                            <div class="glass-strong border-2 border-red-500 rounded-xl p-4 mb-6">
                                <% errors.forEach(function(error) { %>
                                    <p class="text-red-400"><%= error.msg %></p>
                                <% }); %>
                            </div>
                        <% } %>

                        <form action="/contact" method="POST" class="space-y-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold mb-2">Full Name *</label>
                                <input 
                                    type="text" 
                                    id="name" 
                                    name="name" 
                                    class="input-field" 
                                    value="<%= formData.name || '' %>"
                                    placeholder="John Doe"
                                    required
                                >
                            </div>

                            <div>
                                <label for="email" class="block text-sm font-semibold mb-2">Email Address *</label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email" 
                                    class="input-field" 
                                    value="<%= formData.email || '' %>"
                                    placeholder="john@company.com"
                                    required
                                >
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label for="phone" class="block text-sm font-semibold mb-2">Phone Number</label>
                                    <input 
                                        type="tel" 
                                        id="phone" 
                                        name="phone" 
                                        class="input-field" 
                                        value="<%= formData.phone || '' %>"
                                        placeholder="+1 (234) 567-890"
                                    >
                                </div>

                                <div>
                                    <label for="company" class="block text-sm font-semibold mb-2">Company Name</label>
                                    <input 
                                        type="text" 
                                        id="company" 
                                        name="company" 
                                        class="input-field" 
                                        value="<%= formData.company || '' %>"
                                        placeholder="Your Company"
                                    >
                                </div>
                            </div>

                            <div>
                                <label for="message" class="block text-sm font-semibold mb-2">Your Message *</label>
                                <textarea 
                                    id="message" 
                                    name="message" 
                                    class="input-field resize-none" 
                                    rows="6" 
                                    placeholder="Tell us about your project..."
                                    required
                                ><%= formData.message || '' %></textarea>
                            </div>

                            <button type="submit" class="btn-primary w-full">
                                Send Message →
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Contact Info -->
                <div class="lg:col-span-2 space-y-6">
                    <div class="card">
                        <h3 class="text-2xl font-bold mb-6">Contact Information</h3>
                        <p class="text-gray-400 mb-6">
                            Reach out to us anytime. We're here to help you automate smarter.
                        </p>

                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 glass rounded-xl flex items-center justify-center flex-shrink-0">
                                    <span class="text-2xl">📧</span>
                                </div>
                                <div>
                                    <h4 class="font-semibold mb-1">Email</h4>
                                    <a href="mailto:hello@pixelnest.ai" class="text-violet-400 hover:text-violet-300">
                                        admin@pixelnest.pro
                                    </a>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 glass rounded-xl flex items-center justify-center flex-shrink-0">
                                    <span class="text-2xl">📞</span>
                                </div>
                                <div>
                                    <h4 class="font-semibold mb-1">Phone</h4>
                                    <a href="tel:+1234567890" class="text-violet-400 hover:text-violet-300">
                                        +62 87875506478
                                    </a>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 glass rounded-xl flex items-center justify-center flex-shrink-0">
                                    <span class="text-2xl">📍</span>
                                </div>
                                <div>
                                    <h4 class="font-semibold mb-1">Office</h4>
                                    <p class="text-gray-400">
                                        Pringgasela, Lombok TImur<br>
                                        Nusa Tenggara Barat, 83665
                                    </p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 glass rounded-xl flex items-center justify-center flex-shrink-0">
                                    <span class="text-2xl">⏰</span>
                                </div>
                                <div>
                                    <h4 class="font-semibold mb-1">Buka di Jam Kerja</h4>
                                    <p class="text-gray-400">
                                        Minggu - Sabtu: 9:00 AM - 6:00 PM PST<br>
                                        Weekend: Libur
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <h4 class="font-semibold mb-4">Follow Us</h4>
                        <div class="flex gap-3">
                            <a href="#" class="w-12 h-12 glass rounded-xl flex items-center justify-center hover:glass-strong hover:text-violet-400 transition-all duration-300">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
                                </svg>
                            </a>
                            <a href="#" class="w-12 h-12 glass rounded-xl flex items-center justify-center hover:glass-strong hover:text-violet-400 transition-all duration-300">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
                                    <circle cx="4" cy="4" r="2"/>
                                </svg>
                            </a>
                            <a href="#" class="w-12 h-12 glass rounded-xl flex items-center justify-center hover:glass-strong hover:text-violet-400 transition-all duration-300">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    
    <%- include('partials/footer') %>
    
    <script src="/js/main.js"></script>
</body>
</html>
