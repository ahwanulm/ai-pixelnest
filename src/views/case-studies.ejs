<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="PixelNest Case Studies - Success stories from our clients">
    <title>Case Studies - PixelNest</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Hero Section -->
        <section class="relative py-20 overflow-hidden">
            <div class="section-container relative z-10">
                <div class="text-center mb-16">
                    <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6 text-violet-400">
                        Success Stories
                    </span>
                    <h1 class="text-5xl md:text-6xl font-black mb-6 tracking-tight">
                        Case Studies
                    </h1>
                    <p class="text-lg text-gray-400 font-light max-w-2xl mx-auto">
                        See how businesses are transforming their content creation with PixelNest
                    </p>
                </div>

                <!-- Case Studies Grid -->
                <div class="max-w-6xl mx-auto space-y-12">
                    <!-- Case Study 1 -->
                    <div class="glass rounded-2xl overflow-hidden">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8">
                            <div>
                                <span class="inline-block px-3 py-1 glass-strong rounded-full text-xs font-mono font-semibold uppercase tracking-wider mb-4 text-violet-400">E-Commerce</span>
                                <h2 class="text-3xl font-black mb-4 tracking-tight">Fashion Brand Scales Product Photography</h2>
                                <p class="text-gray-300 mb-6">A leading Indonesian fashion brand reduced product photography costs by 80% while increasing output by 300%.</p>
                                
                                <div class="space-y-4 mb-6">
                                    <div>
                                        <h3 class="text-sm font-bold text-violet-400 mb-2">Challenge</h3>
                                        <p class="text-gray-300">Manual photoshoots were expensive and time-consuming, limiting their ability to showcase new collections quickly.</p>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-bold text-fuchsia-400 mb-2">Solution</h3>
                                        <p class="text-gray-300">Used PixelNest's AI image generation to create product variations, lifestyle shots, and marketing materials instantly.</p>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-bold text-blue-400 mb-2">Results</h3>
                                        <ul class="list-disc list-inside text-gray-300 space-y-1 ml-2">
                                            <li>80% cost reduction</li>
                                            <li>300% increase in content output</li>
                                            <li>2-week faster time-to-market</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center justify-center">
                                <div class="glass-strong rounded-xl p-8 text-center">
                                    <div class="text-5xl font-black gradient-text mb-2">80%</div>
                                    <div class="text-sm text-gray-400">Cost Reduction</div>
                                    <div class="text-5xl font-black gradient-text mt-6 mb-2">300%</div>
                                    <div class="text-sm text-gray-400">Output Increase</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Case Study 2 -->
                    <div class="glass rounded-2xl overflow-hidden">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8">
                            <div>
                                <span class="inline-block px-3 py-1 glass-strong rounded-full text-xs font-mono font-semibold uppercase tracking-wider mb-4 text-fuchsia-400">Marketing Agency</span>
                                <h2 class="text-3xl font-black mb-4 tracking-tight">Agency Delivers 10x More Concepts</h2>
                                <p class="text-gray-300 mb-6">A creative agency in Jakarta transformed their concept presentation process with AI-generated video mockups.</p>
                                
                                <div class="space-y-4 mb-6">
                                    <div>
                                        <h3 class="text-sm font-bold text-violet-400 mb-2">Challenge</h3>
                                        <p class="text-gray-300">Creating video concept mockups took days, limiting the number of options they could present to clients.</p>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-bold text-fuchsia-400 mb-2">Solution</h3>
                                        <p class="text-gray-300">Leveraged PixelNest's video generation to create multiple concept variations in minutes instead of days.</p>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-bold text-blue-400 mb-2">Results</h3>
                                        <ul class="list-disc list-inside text-gray-300 space-y-1 ml-2">
                                            <li>10x more concepts per pitch</li>
                                            <li>50% higher client approval rate</li>
                                            <li>60% reduction in revision cycles</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center justify-center">
                                <div class="glass-strong rounded-xl p-8 text-center">
                                    <div class="text-5xl font-black gradient-text mb-2">10x</div>
                                    <div class="text-sm text-gray-400">More Concepts</div>
                                    <div class="text-5xl font-black gradient-text mt-6 mb-2">50%</div>
                                    <div class="text-sm text-gray-400">Higher Approval</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Case Study 3 -->
                    <div class="glass rounded-2xl overflow-hidden">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8">
                            <div>
                                <span class="inline-block px-3 py-1 glass-strong rounded-full text-xs font-mono font-semibold uppercase tracking-wider mb-4 text-blue-400">Education</span>
                                <h2 class="text-3xl font-black mb-4 tracking-tight">EdTech Startup Creates Engaging Content</h2>
                                <p class="text-gray-300 mb-6">An online learning platform increased student engagement by 200% with AI-generated educational videos.</p>
                                
                                <div class="space-y-4 mb-6">
                                    <div>
                                        <h3 class="text-sm font-bold text-violet-400 mb-2">Challenge</h3>
                                        <p class="text-gray-300">Limited budget for video production made it difficult to create engaging visual content for all courses.</p>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-bold text-fuchsia-400 mb-2">Solution</h3>
                                        <p class="text-gray-300">Used PixelNest to generate custom visual content, animations, and explainer videos for curriculum.</p>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-bold text-blue-400 mb-2">Results</h3>
                                        <ul class="list-disc list-inside text-gray-300 space-y-1 ml-2">
                                            <li>200% increase in engagement</li>
                                            <li>90% faster content creation</li>
                                            <li>40% improvement in completion rates</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center justify-center">
                                <div class="glass-strong rounded-xl p-8 text-center">
                                    <div class="text-5xl font-black gradient-text mb-2">200%</div>
                                    <div class="text-sm text-gray-400">More Engagement</div>
                                    <div class="text-5xl font-black gradient-text mt-6 mb-2">90%</div>
                                    <div class="text-sm text-gray-400">Faster Creation</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Case Study 4 -->
                    <div class="glass rounded-2xl overflow-hidden">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8">
                            <div>
                                <span class="inline-block px-3 py-1 glass-strong rounded-full text-xs font-mono font-semibold uppercase tracking-wider mb-4 text-purple-400">Real Estate</span>
                                <h2 class="text-3xl font-black mb-4 tracking-tight">Property Developer Visualizes Projects</h2>
                                <p class="text-gray-300 mb-6">A property developer in Bali accelerated sales with AI-generated property visualizations and lifestyle imagery.</p>
                                
                                <div class="space-y-4 mb-6">
                                    <div>
                                        <h3 class="text-sm font-bold text-violet-400 mb-2">Challenge</h3>
                                        <p class="text-gray-300">Traditional 3D rendering was too slow and expensive for rapid iterations and marketing campaigns.</p>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-bold text-fuchsia-400 mb-2">Solution</h3>
                                        <p class="text-gray-300">Generated photorealistic property visualizations, interior designs, and lifestyle scenes with PixelNest.</p>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-bold text-blue-400 mb-2">Results</h3>
                                        <ul class="list-disc list-inside text-gray-300 space-y-1 ml-2">
                                            <li>70% faster visualization delivery</li>
                                            <li>45% increase in pre-sales</li>
                                            <li>85% reduction in rendering costs</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center justify-center">
                                <div class="glass-strong rounded-xl p-8 text-center">
                                    <div class="text-5xl font-black gradient-text mb-2">45%</div>
                                    <div class="text-sm text-gray-400">More Pre-Sales</div>
                                    <div class="text-5xl font-black gradient-text mt-6 mb-2">85%</div>
                                    <div class="text-sm text-gray-400">Cost Reduction</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CTA Section -->
                <div class="max-w-4xl mx-auto mt-16">
                    <div class="glass-strong rounded-2xl p-12 text-center">
                        <h2 class="text-3xl font-black mb-4 tracking-tight">Ready to Create Your Success Story?</h2>
                        <p class="text-gray-300 mb-8">Join hundreds of businesses transforming their content creation with AI</p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="/auth/register" class="btn-primary px-8 py-3">Start Free Trial</a>
                            <a href="/contact" class="btn-outline px-8 py-3">Talk to Sales</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>

