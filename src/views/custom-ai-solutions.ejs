<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="PixelNest Custom AI Solutions - Tailored AI for your business">
    <title>Custom AI Solutions - PixelNest</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Hero Section -->
        <section class="relative py-20 overflow-hidden">
            <div class="section-container relative z-10">
                <div class="text-center mb-16">
                    <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6 text-purple-400">
                        Enterprise
                    </span>
                    <h1 class="text-5xl md:text-6xl font-black mb-6 tracking-tight">
                        Custom AI Solutions
                    </h1>
                    <p class="text-lg text-gray-400 font-light max-w-2xl mx-auto">
                        Bespoke AI solutions designed specifically for your unique business challenges and goals.
                    </p>
                </div>

                <!-- Overview -->
                <div class="max-w-4xl mx-auto mb-16">
                    <div class="glass rounded-2xl p-8 md:p-12">
                        <h2 class="text-3xl font-bold mb-6 gradient-text">Why Custom AI?</h2>
                        <p class="text-gray-300 mb-6 leading-relaxed">
                            Off-the-shelf AI solutions can't always address your specific business needs. Our custom AI solutions are built from the ground up to solve your unique challenges, integrate with your existing systems, and deliver measurable results.
                        </p>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div class="glass-strong rounded-lg p-6 text-center">
                                <div class="text-3xl mb-3">🎯</div>
                                <h3 class="font-bold mb-2 text-violet-400">Tailored</h3>
                                <p class="text-sm text-gray-400">Built specifically for your business</p>
                            </div>
                            <div class="glass-strong rounded-lg p-6 text-center">
                                <div class="text-3xl mb-3">🔗</div>
                                <h3 class="font-bold mb-2 text-fuchsia-400">Integrated</h3>
                                <p class="text-sm text-gray-400">Works with your existing tools</p>
                            </div>
                            <div class="glass-strong rounded-lg p-6 text-center">
                                <div class="text-3xl mb-3">📈</div>
                                <h3 class="font-bold mb-2 text-blue-400">Scalable</h3>
                                <p class="text-sm text-gray-400">Grows with your business</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- What We Build -->
                <div class="max-w-6xl mx-auto mb-16">
                    <h2 class="text-3xl font-black text-center mb-12 tracking-tight">What We Build</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-violet-400">Machine Learning Models</h3>
                            <p class="text-gray-300 mb-4">Custom ML models trained on your data for prediction, classification, recommendation, and pattern recognition.</p>
                            <ul class="space-y-2 text-sm text-gray-400">
                                <li>• Predictive analytics</li>
                                <li>• Image & video recognition</li>
                                <li>• Natural language processing</li>
                                <li>• Anomaly detection</li>
                            </ul>
                        </div>

                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-fuchsia-400">Intelligent Chatbots</h3>
                            <p class="text-gray-300 mb-4">AI-powered conversational interfaces that understand context and provide intelligent responses.</p>
                            <ul class="space-y-2 text-sm text-gray-400">
                                <li>• Customer support automation</li>
                                <li>• Lead qualification</li>
                                <li>• Internal knowledge base</li>
                                <li>• Multi-language support</li>
                            </ul>
                        </div>

                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-cyan-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-blue-400">Data Analytics Platforms</h3>
                            <p class="text-gray-300 mb-4">Custom analytics solutions that turn your data into actionable insights with AI-powered analysis.</p>
                            <ul class="space-y-2 text-sm text-gray-400">
                                <li>• Real-time dashboards</li>
                                <li>• Automated reporting</li>
                                <li>• Trend analysis</li>
                                <li>• Business intelligence</li>
                            </ul>
                        </div>

                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-violet-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-purple-400">Computer Vision Systems</h3>
                            <p class="text-gray-300 mb-4">AI systems that can see, understand, and analyze visual content from images and videos.</p>
                            <ul class="space-y-2 text-sm text-gray-400">
                                <li>• Object detection & tracking</li>
                                <li>• Quality control automation</li>
                                <li>• Facial recognition</li>
                                <li>• Document processing</li>
                            </ul>
                        </div>

                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-pink-600 to-red-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-pink-400">API Development</h3>
                            <p class="text-gray-300 mb-4">Custom APIs that connect your systems and enable AI capabilities across your applications.</p>
                            <ul class="space-y-2 text-sm text-gray-400">
                                <li>• RESTful & GraphQL APIs</li>
                                <li>• Webhook integrations</li>
                                <li>• Third-party connections</li>
                                <li>• Real-time data sync</li>
                            </ul>
                        </div>

                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-cyan-600 to-blue-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-cyan-400">Process Optimization</h3>
                            <p class="text-gray-300 mb-4">AI-driven analysis and optimization of your business processes for maximum efficiency.</p>
                            <ul class="space-y-2 text-sm text-gray-400">
                                <li>• Workflow analysis</li>
                                <li>• Resource allocation</li>
                                <li>• Performance optimization</li>
                                <li>• Cost reduction strategies</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Development Process -->
                <div class="max-w-4xl mx-auto mb-16">
                    <h2 class="text-3xl font-black text-center mb-12 tracking-tight">Our Development Process</h2>
                    <div class="space-y-4">
                        <div class="glass rounded-xl p-6 flex items-start gap-6">
                            <div class="w-10 h-10 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-lg flex items-center justify-center flex-shrink-0 font-bold">1</div>
                            <div>
                                <h3 class="font-bold text-lg mb-2 text-violet-400">Discovery & Planning</h3>
                                <p class="text-gray-300 text-sm">Deep dive into your business, challenges, and goals. Define scope, requirements, and success metrics.</p>
                            </div>
                        </div>

                        <div class="glass rounded-xl p-6 flex items-start gap-6">
                            <div class="w-10 h-10 bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded-lg flex items-center justify-center flex-shrink-0 font-bold">2</div>
                            <div>
                                <h3 class="font-bold text-lg mb-2 text-fuchsia-400">Data Preparation</h3>
                                <p class="text-gray-300 text-sm">Collect, clean, and prepare your data. Ensure data quality and privacy compliance.</p>
                            </div>
                        </div>

                        <div class="glass rounded-xl p-6 flex items-start gap-6">
                            <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-cyan-600 rounded-lg flex items-center justify-center flex-shrink-0 font-bold">3</div>
                            <div>
                                <h3 class="font-bold text-lg mb-2 text-blue-400">Model Development</h3>
                                <p class="text-gray-300 text-sm">Build and train custom AI models. Test multiple approaches and optimize for best performance.</p>
                            </div>
                        </div>

                        <div class="glass rounded-xl p-6 flex items-start gap-6">
                            <div class="w-10 h-10 bg-gradient-to-br from-purple-600 to-violet-600 rounded-lg flex items-center justify-center flex-shrink-0 font-bold">4</div>
                            <div>
                                <h3 class="font-bold text-lg mb-2 text-purple-400">Integration & Deployment</h3>
                                <p class="text-gray-300 text-sm">Deploy the solution into your environment. Integrate with your existing systems and tools.</p>
                            </div>
                        </div>

                        <div class="glass rounded-xl p-6 flex items-start gap-6">
                            <div class="w-10 h-10 bg-gradient-to-br from-pink-600 to-red-600 rounded-lg flex items-center justify-center flex-shrink-0 font-bold">5</div>
                            <div>
                                <h3 class="font-bold text-lg mb-2 text-pink-400">Monitoring & Support</h3>
                                <p class="text-gray-300 text-sm">Continuous monitoring, maintenance, and optimization. Dedicated support team available 24/7.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Why Choose Us -->
                <div class="max-w-6xl mx-auto mb-16">
                    <div class="glass rounded-2xl p-12">
                        <h2 class="text-3xl font-black text-center mb-12 tracking-tight">Why Choose PixelNest</h2>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                            <div class="text-center">
                                <div class="text-4xl mb-4">🎓</div>
                                <h3 class="font-bold mb-2 text-violet-400">Expert Team</h3>
                                <p class="text-sm text-gray-400">AI specialists with years of experience in machine learning and software development</p>
                            </div>
                            <div class="text-center">
                                <div class="text-4xl mb-4">🔒</div>
                                <h3 class="font-bold mb-2 text-fuchsia-400">Data Security</h3>
                                <p class="text-sm text-gray-400">Bank-level security and full GDPR compliance to protect your sensitive data</p>
                            </div>
                            <div class="text-center">
                                <div class="text-4xl mb-4">💰</div>
                                <h3 class="font-bold mb-2 text-blue-400">ROI Focused</h3>
                                <p class="text-sm text-gray-400">Solutions designed to deliver measurable business value and positive ROI</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CTA -->
                <div class="max-w-4xl mx-auto">
                    <div class="glass-strong rounded-2xl p-12 text-center">
                        <h2 class="text-3xl font-black mb-4 tracking-tight">Ready to Build Your Custom AI Solution?</h2>
                        <p class="text-gray-300 mb-8">Let's discuss your project and create something amazing together</p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="/contact-page" class="btn-primary px-8 py-3">Start a Project</a>
                            <a href="/case-studies" class="btn-outline px-8 py-3">View Case Studies</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>

