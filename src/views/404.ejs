<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - PixelNest</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    
    <style>
        /* Background Override - No Purple */
        .particle-bg {
            background-image: 
                radial-gradient(circle at 20% 50%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(6, 182, 212, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 40% 20%, rgba(16, 185, 129, 0.08) 0%, transparent 50%);
        }
        
        .video-grid-bg {
            background-image: 
                linear-gradient(rgba(59, 130, 246, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(59, 130, 246, 0.03) 1px, transparent 1px);
        }
        
        /* Error Container */
        .error-container {
            position: relative;
            z-index: 10;
            text-align: center;
            animation: fadeInUp 0.8s ease-out;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* 404 Number */
        .error-404 {
            font-size: 12rem;
            font-weight: 900;
            line-height: 1;
            background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 50%, #10b981 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: glowPulse 3s ease-in-out infinite;
            position: relative;
            letter-spacing: -0.05em;
        }
        
        @keyframes glowPulse {
            0%, 100% { 
                filter: drop-shadow(0 0 20px rgba(59, 130, 246, 0.5));
            }
            50% { 
                filter: drop-shadow(0 0 40px rgba(6, 182, 212, 0.8));
            }
        }
        
        /* Floating Icons */
        .floating-icon {
            position: fixed;
            font-size: 3rem;
            opacity: 0.08;
            animation: float 6s ease-in-out infinite;
            pointer-events: none;
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(10deg); }
        }
        
        .icon-1 { top: 10%; left: 10%; animation-delay: 0s; }
        .icon-2 { top: 20%; right: 15%; animation-delay: 1s; }
        .icon-3 { bottom: 15%; left: 15%; animation-delay: 2s; }
        .icon-4 { bottom: 20%; right: 10%; animation-delay: 1.5s; }
        
        @media (max-width: 768px) {
            .error-404 {
                font-size: 6rem;
            }
            .floating-icon {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center relative overflow-hidden text-white">
    <!-- Background Elements -->
    <div class="particle-bg fixed inset-0"></div>
    <div class="video-grid-bg fixed inset-0"></div>
    
    <!-- Floating Icons -->
    <div class="floating-icon icon-1">🔍</div>
    <div class="floating-icon icon-2">🎯</div>
    <div class="floating-icon icon-3">🚀</div>
    <div class="floating-icon icon-4">⚡</div>
    
    <!-- Error Container -->
    <div class="error-container max-w-4xl mx-auto px-6 py-12">
        <!-- Logo -->
        <div class="mb-8 animate-fade-in">
            <a href="/" class="inline-flex items-center gap-3 group">
                <img src="/assets/img/logo/logo.png" alt="PixelNest Logo" class="h-12 w-auto transform group-hover:scale-110 transition-transform duration-300">
                <span class="text-2xl font-bold text-white">PixelNest</span>
            </a>
        </div>
        
        <!-- 404 Number -->
        <h1 class="error-404 mb-8">404</h1>
        
        <!-- Error Message -->
        <div class="glass rounded-2xl p-8 md:p-12 mb-8 max-w-2xl mx-auto">
            <h2 class="text-4xl md:text-5xl font-black mb-4 tracking-tight text-white">Page Not Found</h2>
            <p class="text-xl text-gray-300 mb-6 leading-relaxed">
                <%= message || "Oops! The page you're looking for seems to have vanished into the digital void." %>
            </p>
            <p class="text-gray-400 text-base">
                The page might have been removed, had its name changed, or is temporarily unavailable.
            </p>
        </div>
        
        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
            <a href="/" class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-cyan-600 text-white px-8 py-4 rounded-xl font-semibold hover:shadow-lg hover:shadow-blue-500/50 hover:scale-105 active:scale-95 transition-all duration-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                Back to Home
            </a>
            <a href="/contact-page" class="inline-flex items-center gap-2 border-2 border-blue-500/50 text-white px-8 py-4 rounded-xl font-semibold hover:border-blue-500 hover:bg-blue-500/10 transition-all duration-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                </svg>
                Contact Support
            </a>
        </div>
        
        <!-- Quick Links -->
        <div class="glass rounded-xl p-6 max-w-2xl mx-auto">
            <p class="text-sm text-gray-300 mb-4 font-mono uppercase tracking-wider">You might be looking for:</p>
            <div class="flex flex-wrap gap-3 justify-center">
                <a href="/auth/dashboard" class="text-sm text-blue-400 hover:text-blue-300 transition-colors font-medium">Dashboard</a>
                <span class="text-gray-500">•</span>
                <a href="/pricing-page" class="text-sm text-blue-400 hover:text-blue-300 transition-colors font-medium">Pricing</a>
                <span class="text-gray-500">•</span>
                <a href="/documentation" class="text-sm text-blue-400 hover:text-blue-300 transition-colors font-medium">Documentation</a>
                <span class="text-gray-500">•</span>
                <a href="/faq" class="text-sm text-blue-400 hover:text-blue-300 transition-colors font-medium">FAQ</a>
            </div>
        </div>
        
        <!-- Footer Note -->
        <p class="text-gray-400 text-sm mt-8 font-mono">
            Error Code: 404 | Page Not Found
        </p>
    </div>
</body>
</html>
