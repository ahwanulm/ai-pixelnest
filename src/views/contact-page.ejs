<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Contact PixelNest - Get in touch with our team">
    <title>Contact Us - PixelNest</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    <script src="/js/theme-manager.js"></script>
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Hero Section -->
        <section class="relative py-20 overflow-hidden">
            <div class="section-container relative z-10">
                <div class="text-center mb-16">
                    <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6 text-violet-400">
                        Get In Touch
                    </span>
                    <h1 class="text-5xl md:text-6xl font-black mb-6 tracking-tight">
                        Contact Us
                    </h1>
                    <p class="text-lg text-gray-400 font-light max-w-2xl mx-auto">
                        Have questions? We'd love to hear from you.
                    </p>
                </div>

                <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <!-- Contact Form -->
                    <div class="glass rounded-2xl p-8">
                        <h2 class="text-2xl font-bold mb-6 gradient-text">Send us a Message</h2>
                        <form class="space-y-4">
                            <div>
                                <label class="block text-sm font-semibold mb-2 text-gray-300">Name</label>
                                <input type="text" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 transition-colors" placeholder="Your name" required>
                            </div>

                            <div>
                                <label class="block text-sm font-semibold mb-2 text-gray-300">Email</label>
                                <input type="email" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 transition-colors" placeholder="your.email@example.com" required>
                            </div>

                            <div>
                                <label class="block text-sm font-semibold mb-2 text-gray-300">Subject</label>
                                <select class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-violet-500 transition-colors" required>
                                    <option value="">Select a subject</option>
                                    <option value="general">General Inquiry</option>
                                    <option value="support">Technical Support</option>
                                    <option value="billing">Billing Question</option>
                                    <option value="partnership">Partnership Opportunity</option>
                                    <option value="feedback">Feedback</option>
                                </select>
                            </div>

                            <div>
                                <label class="block text-sm font-semibold mb-2 text-gray-300">Message</label>
                                <textarea rows="5" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 transition-colors resize-none" placeholder="Tell us how we can help..." required></textarea>
                            </div>

                            <button type="submit" class="w-full btn-primary py-3">
                                Send Message
                            </button>
                        </form>
                    </div>

                    <!-- Contact Information -->
                    <div class="space-y-6">
                        <!-- Office Address -->
                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-violet-400">Office Address</h3>
                            <p class="text-gray-300 leading-relaxed">
                                Jln Pendidikan Pringgasela<br>
                                Lombok Timur<br>
                                Nusa Tenggara Barat, 83665<br>
                                Indonesia
                            </p>
                        </div>

                        <!-- Email -->
                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-fuchsia-400">Email Us</h3>
                            <div class="space-y-2 text-gray-300">
                                <p><strong class="text-white">General:</strong> <a href="mailto:hello@pixelnest.id" class="text-violet-400 hover:text-violet-300">hello@pixelnest.id</a></p>
                                <p><strong class="text-white">Support:</strong> <a href="mailto:support@pixelnest.id" class="text-violet-400 hover:text-violet-300">support@pixelnest.id</a></p>
                                <p><strong class="text-white">Sales:</strong> <a href="mailto:sales@pixelnest.id" class="text-violet-400 hover:text-violet-300">sales@pixelnest.id</a></p>
                            </div>
                        </div>

                        <!-- Business Hours -->
                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-cyan-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-blue-400">Business Hours</h3>
                            <div class="space-y-2 text-gray-300">
                                <p><strong class="text-white">Monday - Friday:</strong> 9:00 AM - 6:00 PM</p>
                                <p><strong class="text-white">Saturday:</strong> 10:00 AM - 4:00 PM</p>
                                <p><strong class="text-white">Sunday:</strong> Closed</p>
                                <p class="text-sm text-gray-400 mt-3">WIB (Western Indonesia Time)</p>
                            </div>
                        </div>

                        <!-- Social Media -->
                        <div class="glass rounded-2xl p-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-violet-600 rounded-xl flex items-center justify-center mb-4">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path>
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-purple-400">Follow Us</h3>
                            <div class="flex gap-3">
                                <a href="#" class="w-10 h-10 glass-strong rounded-lg flex items-center justify-center hover:bg-violet-600 transition-colors">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"></path>
                                    </svg>
                                </a>
                                <a href="#" class="w-10 h-10 glass-strong rounded-lg flex items-center justify-center hover:bg-violet-600 transition-colors">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path>
                                    </svg>
                                </a>
                                <a href="#" class="w-10 h-10 glass-strong rounded-lg flex items-center justify-center hover:bg-violet-600 transition-colors">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Help -->
                <div class="max-w-6xl mx-auto mt-12">
                    <div class="glass-strong rounded-2xl p-8">
                        <h2 class="text-2xl font-bold mb-6 text-center gradient-text">Quick Help</h2>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <a href="/faq" class="glass rounded-xl p-6 hover:glass-strong transition-all duration-300 text-center group">
                                <div class="text-3xl mb-3">❓</div>
                                <h3 class="font-bold mb-2 group-hover:text-violet-400 transition-colors">FAQ</h3>
                                <p class="text-sm text-gray-400">Find answers to common questions</p>
                            </a>
                            <a href="/documentation" class="glass rounded-xl p-6 hover:glass-strong transition-all duration-300 text-center group">
                                <div class="text-3xl mb-3">📚</div>
                                <h3 class="font-bold mb-2 group-hover:text-violet-400 transition-colors">Documentation</h3>
                                <p class="text-sm text-gray-400">Learn how to use PixelNest</p>
                            </a>
                            <a href="/auth/register" class="glass rounded-xl p-6 hover:glass-strong transition-all duration-300 text-center group">
                                <div class="text-3xl mb-3">🚀</div>
                                <h3 class="font-bold mb-2 group-hover:text-violet-400 transition-colors">Get Started</h3>
                                <p class="text-sm text-gray-400">Create your account now</p>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>

