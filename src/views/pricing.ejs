<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    <script src="/js/theme-manager.js"></script>
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Page Header -->
        <section class="section-container pt-32 pb-16 text-center">
            <div class="max-w-4xl mx-auto">
                <span class="inline-block px-6 py-2 glass rounded-full text-sm font-semibold uppercase tracking-wider mb-6">
                    Pricing
                </span>
                <h1 class="text-6xl md:text-7xl font-black mb-6">
                    Flexible Plans for <span class="gradient-text">Everyone</span>
                </h1>
                <p class="text-xl text-gray-400">
                    Choose a plan that fits your goals and scale as you grow
                </p>
            </div>
        </section>

        <!-- Pricing Toggle -->
        <section class="section-container py-8">
            <div class="flex justify-center gap-4">
                <button class="toggle-btn px-8 py-3 glass rounded-xl font-semibold active transition-all duration-300 hover:glass-strong" data-period="monthly">
                    Monthly
                </button>
                <button class="toggle-btn px-8 py-3 glass rounded-xl font-semibold transition-all duration-300 hover:glass-strong" data-period="yearly">
                    Yearly
                    <span class="ml-2 bg-green-500 text-white text-xs px-2 py-1 rounded-full">Save 20%</span>
                </button>
            </div>
        </section>

        <!-- Pricing Cards -->
        <section class="section-container">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
                <% if (pricingPlans && pricingPlans.length > 0) { %>
                    <% pricingPlans.forEach(function(plan) { %>
                        <div class="card <%= plan.is_popular ? 'ring-2 ring-violet-500 glow scale-105' : '' %> relative hover:scale-105 transition-transform duration-300">
                            <% if (plan.is_popular) { %>
                                <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
                                    <span class="bg-gradient-to-r from-violet-600 to-purple-600 px-6 py-2 rounded-full text-sm font-bold">
                                        🔥 Popular
                                    </span>
                                </div>
                            <% } %>
                            
                            <h3 class="text-2xl font-bold mb-6"><%= plan.name %></h3>
                            
                            <div class="mb-8">
                                <% if (plan.price > 0) { %>
                                    <span class="text-6xl font-black gradient-text price-value" data-monthly="<%= plan.price %>" data-yearly="<%= Math.round(plan.price * 12 * 0.8 / 12) %>">
                                        $<%= plan.price %>
                                    </span>
                                    <span class="text-gray-400 text-lg">/month</span>
                                <% } else { %>
                                    <span class="text-6xl font-black gradient-text">Custom</span>
                                <% } %>
                            </div>
                            
                            <ul class="space-y-4 mb-8">
                                <% if (plan.features && Array.isArray(plan.features)) { %>
                                    <% plan.features.forEach(function(feature) { %>
                                        <li class="flex items-start gap-3">
                                            <svg class="w-5 h-5 text-green-400 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                            </svg>
                                            <span class="text-gray-300"><%= feature %></span>
                                        </li>
                                    <% }); %>
                                <% } %>
                            </ul>
                            
                            <a href="/contact?plan=<%= plan.name.toLowerCase() %>" class="<%= plan.is_popular ? 'btn-primary' : 'btn-outline' %> w-full text-center block">
                                Get Started
                            </a>
                        </div>
                    <% }); %>
                <% } %>
            </div>
            
            <p class="text-center mt-12 text-gray-400 flex items-center justify-center gap-2">
                <span class="text-2xl">💚</span>
                <span>We donate 2% of your membership to pediatric wellbeing</span>
            </p>
        </section>

        <!-- FAQ Section -->
        <section class="section-container">
            <div class="text-center mb-16">
                <span class="inline-block px-6 py-2 glass rounded-full text-sm font-semibold uppercase tracking-wider mb-4">
                    FAQ's
                </span>
                <h2 class="text-5xl md:text-6xl font-black mb-6">
                    Frequently Asked <span class="gradient-text">Questions</span>
                </h2>
                <p class="text-xl text-gray-400 max-w-2xl mx-auto">
                    Find quick answers to the most common support questions
                </p>
            </div>

            <div class="max-w-3xl mx-auto space-y-4">
                <div class="faq-item glass rounded-2xl overflow-hidden">
                    <button class="faq-question w-full flex justify-between items-center p-6 text-left hover:glass-strong transition-all duration-300">
                        <span class="font-semibold text-lg">What types of processes can you automate?</span>
                        <svg class="w-6 h-6 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
                        <p class="p-6 pt-0 text-gray-400 leading-relaxed">
                            We specialize in automating repetitive workflows across operations, marketing, sales, and customer support using AI and custom logic.
                        </p>
                    </div>
                </div>

                <div class="faq-item glass rounded-2xl overflow-hidden">
                    <button class="faq-question w-full flex justify-between items-center p-6 text-left hover:glass-strong transition-all duration-300">
                        <span class="font-semibold text-lg">Do I need technical knowledge to use your service?</span>
                        <svg class="w-6 h-6 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
                        <p class="p-6 pt-0 text-gray-400 leading-relaxed">
                            Not at all. Our team handles the setup, integration, and optimization. You just focus on your goals — we'll automate the rest.
                        </p>
                    </div>
                </div>

                <div class="faq-item glass rounded-2xl overflow-hidden">
                    <button class="faq-question w-full flex justify-between items-center p-6 text-left hover:glass-strong transition-all duration-300">
                        <span class="font-semibold text-lg">Can you integrate with our existing tools?</span>
                        <svg class="w-6 h-6 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
                        <p class="p-6 pt-0 text-gray-400 leading-relaxed">
                            Yes! We support integrations with CRMs, project management tools, communication apps, and more — tailored to your stack.
                        </p>
                    </div>
                </div>

                <div class="faq-item glass rounded-2xl overflow-hidden">
                    <button class="faq-question w-full flex justify-between items-center p-6 text-left hover:glass-strong transition-all duration-300">
                        <span class="font-semibold text-lg">How long does implementation take?</span>
                        <svg class="w-6 h-6 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
                        <p class="p-6 pt-0 text-gray-400 leading-relaxed">
                            Most clients see their first automation live within 1–2 weeks, depending on complexity and the number of workflows.
                        </p>
                    </div>
                </div>

                <div class="faq-item glass rounded-2xl overflow-hidden">
                    <button class="faq-question w-full flex justify-between items-center p-6 text-left hover:glass-strong transition-all duration-300">
                        <span class="font-semibold text-lg">Is your AI secure and compliant?</span>
                        <svg class="w-6 h-6 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
                        <p class="p-6 pt-0 text-gray-400 leading-relaxed">
                            Absolutely. We use enterprise-grade security practices and ensure compliance with major data privacy standards like GDPR.
                        </p>
                    </div>
                </div>
            </div>

            <div class="text-center mt-12">
                <p class="text-gray-400 mb-6">Still have questions? Feel free to get in touch with us today!</p>
                <a href="/contact" class="btn-outline inline-block">
                    Ask A Question
                </a>
            </div>
        </section>
    </main>
    
    <%- include('partials/footer') %>
    
    <script src="/js/main.js"></script>
    <script src="/js/pricing.js"></script>
</body>
</html>
