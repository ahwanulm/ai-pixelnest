<!-- Modern Mobile Bottom Navigation with Center FAB -->
<% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
<div id="mobile-navbar" class="lg:hidden fixed bottom-0 left-0 right-0 z-[10004]">
    <!-- Background -->
    <div class="absolute inset-0 bg-zinc-950/95 backdrop-blur-2xl border-t border-white/10"></div>
    
    <!-- Navigation Container -->
    <div class="relative max-w-md mx-auto px-3 py-1.5">
        <div class="flex items-center justify-between relative">
            
            <!-- Processing - Shows results container on dashboard -->
            <button type="button" id="mobile-processing-btn" class="nav-item relative">
                <div class="nav-icon-wrapper">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                </div>
                <!-- Results Count Badge -->
                <span id="mobile-processing-badge" class="absolute -top-1 -right-1 min-w-[18px] h-[18px] bg-gradient-to-r from-blue-600 to-cyan-600 text-white text-xs font-bold rounded-full flex items-center justify-center border-2 border-zinc-950 hidden">
                    0
                </span>
            </button>
            
            <!-- Explore -->
            <a href="/explore" class="nav-item <%= typeof currentPath !== 'undefined' && currentPath === '/explore' ? 'active' : '' %>">
                <div class="nav-icon-wrapper">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
            </a>
            
            <!-- Center FAB - Create Button -->
            <a href="/dashboard" class="fab-button <%= typeof currentPath !== 'undefined' && currentPath === '/dashboard' ? 'active' : '' %>">
                <div class="fab-circle">
                    <div class="fab-inner">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                        </svg>
                    </div>
                </div>
            </a>
            
            <!-- Billing -->
            <a href="/billing" class="nav-item <%= typeof currentPath !== 'undefined' && currentPath === '/billing' ? 'active' : '' %>">
                <div class="nav-icon-wrapper">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                    </svg>
                </div>
            </a>
            
            <!-- Profile -->
            <div class="relative">
                <button id="profile-menu-btn" class="nav-item <%= typeof currentPath !== 'undefined' && (currentPath === '/profile' || currentPath === '/usage' || currentPath === '/referral/dashboard') ? 'active' : '' %>">
                    <div class="nav-icon-wrapper">
                        <% if (typeof user !== 'undefined' && user && user.avatar_url) { %>
                            <img src="<%= user.avatar_url %>" alt="<%= user.name %>" class="w-8 h-8 rounded-full object-cover ring-2 ring-violet-500/40 transition-all">
                        <% } else if (typeof user !== 'undefined' && user) { %>
                            <div class="w-8 h-8 bg-gradient-to-br from-violet-500 to-fuchsia-600 rounded-full flex items-center justify-center text-xs font-bold ring-2 ring-violet-500/40 transition-all">
                                <%= user.name.charAt(0).toUpperCase() %>
                            </div>
                        <% } else { %>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        <% } %>
                    </div>
                </button>
                
                <!-- Profile Submenu - Aligned Left -->
                <div id="profile-submenu" class="hidden absolute bottom-full right-0 mb-2 w-64 bg-zinc-900/98 backdrop-blur-2xl border border-white/10 rounded-2xl shadow-2xl overflow-hidden">
                    <!-- Header with Gradient -->
                    <div class="px-4 py-3 bg-gradient-to-br from-violet-600/20 via-fuchsia-600/20 to-violet-600/10">
                        <div class="flex items-center gap-3">
                            <% if (typeof user !== 'undefined' && user && user.avatar_url) { %>
                                <img src="<%= user.avatar_url %>" alt="<%= user.name %>" class="w-10 h-10 rounded-full ring-2 ring-violet-500/40 object-cover">
                            <% } else if (typeof user !== 'undefined' && user) { %>
                                <div class="w-10 h-10 bg-gradient-to-br from-violet-500 to-fuchsia-600 rounded-full flex items-center justify-center text-sm font-bold ring-2 ring-violet-500/40">
                                    <%= user.name.charAt(0).toUpperCase() %>
                                </div>
                            <% } %>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-bold text-white truncate"><%= typeof user !== 'undefined' && user ? user.name : 'Guest' %></p>
                                <div class="flex items-center gap-1.5 mt-1">
                                    <div class="flex items-center gap-1 bg-yellow-500/20 px-2 py-0.5 rounded-full">
                                        <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                                        </svg>
                                        <span class="text-xs font-mono font-bold text-yellow-400"><%= typeof user !== 'undefined' && user ? (user.credits || 0).toFixed(1) : '0.0' %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Menu Items -->
                    <div class="py-2">
                        <a href="/profile" class="menu-item">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                            <span>My Profile</span>
                        </a>
                        
                        <a href="/billing" class="menu-item">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                            </svg>
                            <span>Billing</span>
                        </a>
                        
                        <a href="/usage" class="menu-item">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                            </svg>
                            <span>Usage Stats</span>
                        </a>
                        
                        <a href="/referral/dashboard" class="menu-item group">
                            <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                            </svg>
                            <span>Referral Program</span>
                            <div class="ml-auto w-2 h-2 bg-yellow-400 rounded-full animate-pulse"></div>
                        </a>
                        
                        <a href="/feature-request" class="menu-item">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                            </svg>
                            <span>Request Fitur/Model</span>
                        </a>
                        
                        <div class="h-px bg-white/10 my-2 mx-3"></div>
                        
                        <a href="/logout" class="menu-item text-red-400 hover:text-red-300 hover:bg-red-500/10">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                            </svg>
                            <span>Logout</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<% } %>

<style>
/* Mobile Navbar Container */
#mobile-navbar {
    padding-bottom: env(safe-area-inset-bottom, 0);
}

/* Regular Nav Items */
.nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    background: transparent;
    border: none;
    text-decoration: none;
}

.nav-icon-wrapper {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: transparent;
    transition: all 0.3s ease;
    color: #9ca3af;
}

.nav-item:active .nav-icon-wrapper {
    transform: scale(0.9);
    background: rgba(255, 255, 255, 0.1);
}

.nav-item.active .nav-icon-wrapper {
    background: rgba(255, 255, 255, 0.15);
    color: #ffffff;
    box-shadow: 0 0 20px rgba(255, 255, 255, 0.2);
}

/* Center FAB Button */
.fab-button {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin-top: -1.25rem;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.fab-circle {
    position: relative;
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #8b5cf6 0%, #d946ef 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 
        0 6px 12px rgba(139, 92, 246, 0.4),
        0 3px 6px rgba(219, 39, 119, 0.3),
        0 0 0 4px rgba(0, 0, 0, 0.95),
        0 0 0 8px rgba(139, 92, 246, 0.15);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.fab-button:active {
    transform: scale(0.92);
}

.fab-button:active .fab-circle {
    box-shadow: 
        0 4px 8px rgba(139, 92, 246, 0.5),
        0 2px 4px rgba(219, 39, 119, 0.4),
        0 0 0 4px rgba(0, 0, 0, 0.95),
        0 0 0 8px rgba(139, 92, 246, 0.15);
}

.fab-inner {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #a78bfa 0%, #ec4899 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s ease;
}

.fab-button.active .fab-circle {
    background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
    box-shadow: 
        0 12px 24px rgba(255, 255, 255, 0.3),
        0 6px 12px rgba(255, 255, 255, 0.2),
        0 0 0 4px rgba(0, 0, 0, 0.95),
        0 0 0 8px rgba(255, 255, 255, 0.2);
    animation: pulse-fab 2s ease-in-out infinite;
}

.fab-button.active .fab-inner {
    background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
}

.fab-button.active svg {
    color: #8b5cf6;
}

@keyframes pulse-fab {
    0%, 100% {
        box-shadow: 
            0 12px 24px rgba(255, 255, 255, 0.3),
            0 6px 12px rgba(255, 255, 255, 0.2),
            0 0 0 4px rgba(0, 0, 0, 0.95),
            0 0 0 8px rgba(255, 255, 255, 0.2);
    }
    50% {
        box-shadow: 
            0 16px 32px rgba(255, 255, 255, 0.4),
            0 8px 16px rgba(255, 255, 255, 0.3),
            0 0 0 4px rgba(0, 0, 0, 0.95),
            0 0 0 8px rgba(255, 255, 255, 0.3);
    }
}

/* Profile Menu Items */
.menu-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: #d1d5db;
    transition: all 0.2s ease;
    cursor: pointer;
}

.menu-item:hover {
    background: rgba(255, 255, 255, 0.05);
    color: white;
}

/* Submenu Animation */
#profile-submenu {
    animation: slideUpFade 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes slideUpFade {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Responsive Adjustments */
@media (max-width: 380px) {
    .nav-icon-wrapper {
        width: 36px;
        height: 36px;
    }
    
    .fab-circle {
        width: 52px;
        height: 52px;
    }
    
    .fab-inner {
        width: 46px;
        height: 46px;
    }
    
    .fab-inner svg {
        width: 1.25rem;
        height: 1.25rem;
    }
    
    #profile-submenu {
        width: 240px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
        // Mobile Processing Button - Opens results overlay
        const mobileProcessingBtn = document.getElementById('mobile-processing-btn');
        if (mobileProcessingBtn) {
            mobileProcessingBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                // Check if we're on dashboard
                if (window.location.pathname === '/dashboard') {
                    // Already on dashboard, open mobile results view directly
                    // Use setTimeout to ensure DOM is ready and functions are available
                    setTimeout(function() {
                        if (typeof window.openMobileResults === 'function') {
                            window.openMobileResults();
                            
                            // Force sync results after a small delay to ensure data is loaded
                            setTimeout(function() {
                                if (typeof window.syncResultsToMobile === 'function') {
                                    window.syncResultsToMobile();
                                    console.log('✅ Results synced to mobile view');
                                }
                            }, 100);
                        } else {
                            console.warn('⚠️ openMobileResults function not available yet');
                        }
                    }, 50);
                } else {
                    // Not on dashboard, set flag and redirect
                    localStorage.setItem('openMobileResults', 'true');
                    window.location.href = '/dashboard';
                }
            });
        }
        
        // Auto-open results if flag is set (from other pages)
        if (window.location.pathname === '/dashboard') {
            const shouldOpenResults = localStorage.getItem('openMobileResults');
            if (shouldOpenResults === 'true') {
                // Clear flag immediately
                localStorage.removeItem('openMobileResults');
                
                // IMMEDIATELY hide dashboard and show loading
                const mainContent = document.querySelector('main');
                const mobileResultsView = document.getElementById('mobile-results-view');
                
                if (mainContent) {
                    mainContent.style.opacity = '0';
                    mainContent.style.pointerEvents = 'none';
                }
                
                // Immediately show the overlay container
                if (mobileResultsView) {
                    mobileResultsView.style.display = 'flex';
                    mobileResultsView.classList.remove('hidden');
                }
                
                // Wait for function to be available, then properly open
                const checkAndOpen = setInterval(function() {
                    if (typeof window.openMobileResults === 'function' && mobileResultsView) {
                        clearInterval(checkAndOpen);
                        
                        // Function available, now sync results
                        window.openMobileResults();
                        
                        // Make sure main content stays hidden
                        if (mainContent) {
                            mainContent.style.display = 'none';
                        }
                    }
                }, 50); // Check every 50ms for faster response
                
                // Timeout after 3 seconds
                setTimeout(function() {
                    clearInterval(checkAndOpen);
                    // If failed, restore dashboard
                    if (mainContent && mainContent.style.opacity === '0') {
                        mainContent.style.opacity = '1';
                        mainContent.style.pointerEvents = 'auto';
                        mainContent.style.display = 'block';
                    }
                }, 3000);
            }
        }
        
        // Profile menu toggle
        const profileMenuBtn = document.getElementById('profile-menu-btn');
        const profileSubmenu = document.getElementById('profile-submenu');
    
    if (profileMenuBtn && profileSubmenu) {
        profileMenuBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const isHidden = profileSubmenu.classList.contains('hidden');
            profileSubmenu.classList.toggle('hidden');
            
            // Haptic feedback
            if ('vibrate' in navigator) {
                navigator.vibrate(isHidden ? 10 : 5);
            }
        });
        
        // Close when clicking outside
        document.addEventListener('click', function(event) {
            if (!profileMenuBtn.contains(event.target) && !profileSubmenu.contains(event.target)) {
                profileSubmenu.classList.add('hidden');
            }
        });
        
        // Close on window resize
        window.addEventListener('resize', function() {
            if (window.innerWidth >= 1024) {
                profileSubmenu.classList.add('hidden');
            }
        });
    }
    
    // Handle Process button for mobile results view
    const processBtn = document.querySelector('a[href="/dashboard#results"]');
    if (processBtn) {
        processBtn.addEventListener('click', function(e) {
            if (window.innerWidth < 1024) {
                e.preventDefault();
                const mobileResultsView = document.getElementById('mobile-results-view');
                if (mobileResultsView) {
                    mobileResultsView.classList.remove('hidden');
                    mobileResultsView.classList.add('flex');
                    document.body.style.overflow = 'hidden';
                    
                    if (typeof syncResultsToMobile === 'function') {
                        syncResultsToMobile();
                    }
                }
            }
        });
    }
    
    // Touch feedback for all interactive elements
    const touchElements = document.querySelectorAll('.nav-item, .fab-button, .menu-item');
    touchElements.forEach(element => {
        element.addEventListener('touchstart', function() {
            if ('vibrate' in navigator) {
                navigator.vibrate(5);
            }
        }, { passive: true });
    });
});
</script>
