<header class="glass-strong sticky top-0 z-30">
  <div class="flex items-center justify-between px-8 py-4">
    <div class="flex items-center space-x-4">
      <!-- Mobile Menu Button -->
      <button id="mobileMenuToggle" class="lg:hidden text-white hover:text-violet-400 transition">
        <i class="fas fa-bars text-xl"></i>
      </button>
      
      <h2 class="text-2xl font-bold text-white"><%= typeof pageTitle !== 'undefined' ? pageTitle : (typeof title !== 'undefined' ? title : 'Admin Panel') %></h2>
    </div>
    
    <div class="flex items-center space-x-4">
      <!-- User Info -->
      <div class="hidden md:block text-right">
        <p class="text-sm font-semibold text-white"><%= user.name %></p>
        <p class="text-xs text-violet-400">Admin</p>
      </div>
      
      <!-- Avatar -->
      <img src="<%= user.avatar_url || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=8b5cf6&color=fff' %>" 
           alt="<%= user.name %>" 
           class="w-10 h-10 rounded-full ring-2 ring-violet-500">
    </div>
  </div>
</header>
