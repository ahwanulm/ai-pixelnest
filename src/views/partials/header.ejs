                                let showName = true;
                                
                                // If it's an email address, extract the part before @
                                if (displayName.includes('@')) {
                                    const emailParts = displayName.split('@');
                                    if (emailParts[0].length <= 12) {
                                        displayName = emailParts[0];
                                    } else {
                                        // Too long, just show initials
                                        displayName = emailParts[0].charAt(0).toUpperCase();
                                        if (emailParts[0].length > 1) {
                                            displayName += emailParts[0].charAt(1).toUpperCase();
                                        }
                                    }
                                } else if (displayName.length > 15) {
                                    // Truncate long names
                                    displayName = displayName.substring(0, 12) + '...';
