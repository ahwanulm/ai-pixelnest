<script>
// Toggle mobile submenu
function toggleMobileSubmenu(button) {
    const submenu = button.nextElementSibling;
    const allSubmenus = document.querySelectorAll('.mobile-submenu');
    const allTriggers = document.querySelectorAll('.mobile-submenu-trigger');
    
    // Close all other submenus
    allSubmenus.forEach(menu => {
        if (menu !== submenu) {
            menu.classList.remove('open');
        }
    });
    
    allTriggers.forEach(trigger => {
        if (trigger !== button) {
            trigger.classList.remove('active');
        }
    });
    
    // Toggle current submenu
    button.classList.toggle('active');
    submenu.classList.toggle('open');
}

// Mobile menu toggle with hamburger animation
document.addEventListener('DOMContentLoaded', function() {
    const navbarToggle = document.getElementById('navbarToggle');
    const navbarMenu = document.getElementById('navbarMenu');
    
    console.log('Navbar Toggle:', navbarToggle);
    console.log('Navbar Menu:', navbarMenu);
    
    if (navbarToggle && navbarMenu) {
        // Make absolutely sure it's clickable
        navbarToggle.style.pointerEvents = 'auto';
        navbarToggle.style.touchAction = 'manipulation';
        navbarToggle.style.zIndex = '10000';
        navbarToggle.style.position = 'relative';
        
        // Simple toggle function
        const toggleMenu = function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            console.log('Toggle clicked!');
            
            navbarMenu.classList.toggle('hidden');
            navbarToggle.classList.toggle('active');
            
            // Close all submenus when closing main menu
            if (navbarMenu.classList.contains('hidden')) {
                document.querySelectorAll('.mobile-submenu').forEach(menu => {
                    menu.classList.remove('open');
                });
                document.querySelectorAll('.mobile-submenu-trigger').forEach(trigger => {
                    trigger.classList.remove('active');
                });
            }
        };
        
        // Multiple event listeners to catch any interaction
        navbarToggle.addEventListener('touchstart', function(e) {
            console.log('Touch start detected');
        }, { passive: true });
        
        navbarToggle.addEventListener('touchend', function(e) {
            console.log('Touch end detected');
            toggleMenu(e);
        }, { passive: false });
        
        navbarToggle.addEventListener('click', function(e) {
            console.log('Click detected');
            toggleMenu(e);
        }, false);
        
        // Add visual feedback for debugging
        navbarToggle.addEventListener('mousedown', function() {
            console.log('Mouse down');
            this.style.transform = 'scale(0.95)';
        });
        
        navbarToggle.addEventListener('mouseup', function() {
            console.log('Mouse up');
            this.style.transform = 'scale(1)';
        });
    } else {
        console.error('Navbar toggle or menu not found!');
    }
    
    // Header scroll effect
    const header = document.getElementById('main-header');
    let lastScroll = 0;
    
    window.addEventListener('scroll', function() {
        const currentScroll = window.pageYOffset;
        
        if (currentScroll > 50) {
            header.classList.add('scrolled');
        } else {
            header.classList.remove('scrolled');
        }
        
        lastScroll = currentScroll;
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', function(e) {
        if (navbarMenu && !navbarMenu.classList.contains('hidden')) {
            if (!navbarToggle.contains(e.target) && !navbarMenu.contains(e.target)) {
                navbarMenu.classList.add('hidden');
                navbarToggle.classList.remove('active');
            }
        }
    });
});
</script>
