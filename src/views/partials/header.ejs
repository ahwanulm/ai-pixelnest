<!-- Modern Header Styles -->
<style>
/* Header Scroll Effect */
#main-header {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

#main-header.scrolled {
    backdrop-filter: blur(20px);
}

/* Navigation Links - Modern Pill Style */
.nav-link {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(209, 213, 219, 1);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
}

.nav-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(219, 39, 119, 0.1));
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 0.75rem;
}

.nav-link:hover::before {
    opacity: 1;
}

.nav-link:hover {
    color: rgba(255, 255, 255, 1);
    transform: translateY(-1px);
}

.nav-link.active {
    color: rgba(255, 255, 255, 1);
    font-weight: 600;
}

.nav-link.active::before {
    opacity: 1;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(219, 39, 119, 0.2));
}

.nav-link-text {
    position: relative;
    z-index: 1;
}

.nav-link-indicator {
    position: absolute;
    bottom: 0.25rem;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 1.5rem;
    height: 2px;
    background: linear-gradient(90deg, rgba(139, 92, 246, 1), rgba(219, 39, 119, 1));
    border-radius: 2px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.nav-link.active .nav-link-indicator,
.nav-link:hover .nav-link-indicator {
    transform: translateX(-50%) scaleX(1);
}

/* User Dropdown Button */
.user-dropdown-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    transition: all 0.2s ease;
    cursor: pointer;
    max-width: 200px;
    overflow: hidden;
}

.user-dropdown-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(139, 92, 246, 0.3);
}

/* Dropdown Menu */
.dropdown-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    width: 13rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 50;
}

.group:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}

.dropdown-menu-inner {
    background: rgba(24, 24, 27, 0.95);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    padding: 0.5rem;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.2);
}

.dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    color: rgba(209, 213, 219, 1);
    transition: all 0.15s ease;
    cursor: pointer;
}

.dropdown-item:hover {
    color: rgba(255, 255, 255, 1);
    background: rgba(255, 255, 255, 0.05);
}

.dropdown-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
}

.dropdown-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 0.5rem 0;
}

/* Mega Dropdown Menu */
.mega-dropdown {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) translateY(-10px);
    top: calc(100% + 0.25rem);
    min-width: 280px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    z-index: 100;
    pointer-events: none;
}

/* Add padding area to prevent dropdown from closing */
.mega-dropdown::before {
    content: '';
    position: absolute;
    top: -16px;
    left: 0;
    right: 0;
    height: 20px;
    background: transparent;
}

.group:hover .mega-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
    transition-delay: 0.1s;
}

.mega-dropdown-inner {
    background: rgba(24, 24, 27, 0.98);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    padding: 0.5rem;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    overflow: hidden;
}

.mega-dropdown-item {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 0.875rem;
    border-radius: 0.75rem;
    transition: all 0.2s ease;
    cursor: pointer;
    position: relative;
    overflow: hidden;
}

.mega-dropdown-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(219, 39, 119, 0.08));
    opacity: 0;
    transition: opacity 0.2s ease;
}

.mega-dropdown-item:hover::before {
    opacity: 1;
}

.mega-dropdown-item:hover {
    background: rgba(255, 255, 255, 0.03);
    transform: translateX(4px);
}

.mega-item-icon {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(139, 92, 246, 0.1);
    border-radius: 0.75rem;
    transition: all 0.2s ease;
    color: rgba(167, 139, 250, 1);
}

.mega-dropdown-item:hover .mega-item-icon {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(219, 39, 119, 0.2));
    transform: scale(1.1);
}

.mega-item-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: 0.125rem;
    position: relative;
    z-index: 1;
}

.mega-item-desc {
    font-size: 0.75rem;
    color: rgba(156, 163, 175, 1);
    line-height: 1.4;
    position: relative;
    z-index: 1;
}

/* Modern Buttons */
.modern-btn-outline,
.modern-btn-primary {
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 0.75rem;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.modern-btn-outline {
    color: rgba(209, 213, 219, 1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
}

.modern-btn-outline:hover {
    color: rgba(255, 255, 255, 1);
    border-color: rgba(139, 92, 246, 0.5);
    background: rgba(139, 92, 246, 0.1);
    transform: translateY(-1px);
}

.modern-btn-primary {
    color: rgba(255, 255, 255, 1);
    background: linear-gradient(135deg, rgba(139, 92, 246, 1), rgba(219, 39, 119, 1));
    border: none;
    box-shadow: 0 4px 6px -1px rgba(139, 92, 246, 0.3);
}

.modern-btn-primary:hover {
    box-shadow: 0 10px 15px -3px rgba(139, 92, 246, 0.4);
    transform: translateY(-2px);
}

/* Mobile Menu Button with Hamburger */
.mobile-menu-btn {
    display: flex;
    flex-direction: column;
