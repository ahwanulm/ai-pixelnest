<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Extend Music - PixelNest</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css?v=<%= appVersion %>
    <script src="/js/theme-manager.js"></script>">
  
  <style>
    body {
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      min-height: 100vh;
    }
    
    .glass {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .glass-strong {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.15);
    }
    
    .gradient-cyan {
      background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);
    }
    
    @keyframes pulse-glow {
      0%, 100% {
        box-shadow: 0 0 20px rgba(6, 182, 212, 0.5);
      }
      50% {
        box-shadow: 0 0 40px rgba(6, 182, 212, 0.8);
      }
    }
    
    .generating {
      animation: pulse-glow 2s ease-in-out infinite;
    }
  </style>
</head>
<body class="text-white">
  
  <%- include('../partials/header') %>
  
  <div class="container mx-auto px-4 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full gradient-cyan mb-6">
        <i class="fas fa-forward text-4xl text-white"></i>
      </div>
      <h1 class="text-5xl font-bold mb-4">
        <span class="gradient-text">Extend Your Music</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Continue and extend your music tracks with AI - make them longer and more complete
      </p>
      
      <!-- Navigation Tabs -->
      <div class="flex justify-center gap-4 mt-8">
        <a href="/music" class="px-6 py-3 glass rounded-lg hover:bg-white/10 transition">
          <i class="fas fa-music mr-2"></i>Music Generation
        </a>
        <a href="/music/lyrics" class="px-6 py-3 glass rounded-lg hover:bg-white/10 transition">
          <i class="fas fa-pen-fancy mr-2"></i>Lyrics Generation
        </a>
        <a href="/music/extend" class="px-6 py-3 gradient-cyan rounded-lg font-bold">
          <i class="fas fa-forward mr-2"></i>Extend Music
        </a>
      </div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <!-- Extension Form -->
      <div class="lg:col-span-2">
        <div class="glass-strong rounded-2xl p-8">
          <h2 class="text-2xl font-bold mb-6 flex items-center">
            <i class="fas fa-wand-magic-sparkles text-cyan-400 mr-3"></i>
            Extend Music Track
          </h2>
          
          <form id="extendForm" class="space-y-6">
            <!-- Audio ID Input -->
            <div>
              <label for="audio_id" class="block text-sm font-medium mb-2">
                <i class="fas fa-hashtag mr-2 text-cyan-400"></i>
                Audio ID / Track ID *
              </label>
              <input
                type="text"
                id="audio_id"
                name="audio_id"
                class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-cyan-500 focus:outline-none text-white placeholder-gray-400 font-mono"
                placeholder="Enter the audio ID from your generated music"
                required
              >
              <p class="text-xs text-gray-400 mt-1">Find this ID in your music generation results or history</p>
            </div>
            
            <!-- Continuation Prompt -->
            <div>
              <label for="prompt" class="block text-sm font-medium mb-2">
                <i class="fas fa-align-left mr-2 text-purple-400"></i>
                Continuation Description (Optional)
              </label>
              <textarea
                id="prompt"
                name="prompt"
                rows="4"
                class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-purple-500 focus:outline-none text-white placeholder-gray-400"
                placeholder="Describe how you want the music to continue... (e.g., 'continue with more energy', 'add a guitar solo', 'slow down to an emotional ending')"
              ></textarea>
              <p class="text-xs text-gray-400 mt-1">Leave empty to auto-continue in the same style</p>
            </div>
            
            <!-- Continue At (Timestamp) -->
            <div>
              <label for="continue_at" class="block text-sm font-medium mb-2">
                <i class="fas fa-clock mr-2 text-blue-400"></i>
                Continue From (seconds)
              </label>
              <input
                type="number"
                id="continue_at"
                name="continue_at"
                min="0"
                step="1"
                class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-blue-500 focus:outline-none text-white placeholder-gray-400"
                placeholder="e.g., 60 (leave empty for auto)"
              >
              <p class="text-xs text-gray-400 mt-1">Specify the timestamp (in seconds) to continue from</p>
            </div>
            
            <!-- Submit Button -->
            <button
              type="submit"
              id="extendBtn"
              class="w-full py-4 gradient-cyan rounded-lg font-bold text-lg hover:shadow-lg hover:shadow-cyan-500/50 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <i class="fas fa-forward mr-2"></i>
              <span id="btnText">Extend Music</span>
            </button>
            
            <p class="text-xs text-gray-400 text-center">
              <i class="fas fa-coins mr-1 text-yellow-400"></i>
              Extension cost: <span class="text-yellow-400 font-bold">30 credits</span>
              <br>
              <span class="text-gray-500">Your balance: <span id="userCredits" class="text-yellow-400 font-bold"><%= user.credits %> credits</span></span>
            </p>
          </form>
        </div>
        
        <!-- How to Find Audio ID -->
        <div class="glass-strong rounded-2xl p-6 mt-6">
          <h3 class="text-lg font-bold mb-4 flex items-center">
            <i class="fas fa-question-circle text-blue-400 mr-2"></i>
            How to Find Audio ID?
          </h3>
          <ol class="space-y-3 text-sm text-gray-300">
            <li class="flex items-start">
              <span class="text-cyan-400 font-bold mr-3">1.</span>
              <span>Go to your <a href="/gallery" class="text-cyan-400 hover:underline">Gallery</a> or <a href="/dashboard" class="text-cyan-400 hover:underline">Dashboard</a></span>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-400 font-bold mr-3">2.</span>
              <span>Find the music track you want to extend</span>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-400 font-bold mr-3">3.</span>
              <span>Click on "Details" or "Info" button</span>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-400 font-bold mr-3">4.</span>
              <span>Copy the Audio ID shown in the details</span>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-400 font-bold mr-3">5.</span>
              <span>Paste it in the form above</span>
            </li>
          </ol>
        </div>
      </div>
      
      <!-- Info Sidebar -->
      <div class="space-y-6">
        <!-- Extension Info -->
        <div class="glass-strong rounded-2xl p-6">
          <h3 class="text-lg font-bold mb-4 flex items-center">
            <i class="fas fa-info-circle text-cyan-400 mr-2"></i>
            About Extension
          </h3>
          <div class="space-y-4 text-sm text-gray-300">
            <p>
              <i class="fas fa-check-circle text-green-400 mr-2"></i>
              <strong>Seamless Continuation:</strong> AI continues your music naturally
            </p>
            <p>
              <i class="fas fa-check-circle text-green-400 mr-2"></i>
              <strong>Maintain Style:</strong> Keeps the same genre and feel
            </p>
            <p>
              <i class="fas fa-check-circle text-green-400 mr-2"></i>
              <strong>Flexible Length:</strong> Extend as much as you need
            </p>
            <p>
              <i class="fas fa-check-circle text-green-400 mr-2"></i>
              <strong>Custom Direction:</strong> Guide where the music goes
            </p>
          </div>
        </div>
        
        <!-- Tips -->
        <div class="glass-strong rounded-2xl p-6">
          <h3 class="text-lg font-bold mb-4 flex items-center">
            <i class="fas fa-lightbulb text-yellow-400 mr-2"></i>
            Extension Tips
          </h3>
          <ul class="space-y-3 text-sm text-gray-300">
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Use continuation prompts to guide the direction</span>
            </li>
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Leave prompt empty for natural continuation</span>
            </li>
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Specify timestamp for precise control</span>
            </li>
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Can extend multiple times for longer tracks</span>
            </li>
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Works best with high-quality original tracks</span>
            </li>
          </ul>
        </div>
        
        <!-- Examples -->
        <div class="glass-strong rounded-2xl p-6">
          <h3 class="text-lg font-bold mb-4 flex items-center">
            <i class="fas fa-fire text-orange-400 mr-2"></i>
            Example Prompts
          </h3>
          <div class="space-y-2 text-xs">
            <div class="p-2 glass rounded">
              <span class="text-gray-400">"Add an epic guitar solo"</span>
            </div>
            <div class="p-2 glass rounded">
              <span class="text-gray-400">"Slow down to emotional ending"</span>
            </div>
            <div class="p-2 glass rounded">
              <span class="text-gray-400">"Build up energy for finale"</span>
            </div>
            <div class="p-2 glass rounded">
              <span class="text-gray-400">"Continue with same vibe"</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Results Section -->
    <div id="resultsSection" class="mt-12 hidden">
      <h2 class="text-3xl font-bold mb-6 text-center">
        <i class="fas fa-music text-cyan-400 mr-3"></i>
        Extended Music
      </h2>
      <div id="extendResults" class="max-w-4xl mx-auto">
        <!-- Results will be inserted here -->
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  
  <script>
    const extendForm = document.getElementById('extendForm');
    const extendBtn = document.getElementById('extendBtn');
    const btnText = document.getElementById('btnText');
    const resultsSection = document.getElementById('resultsSection');
    const extendResults = document.getElementById('extendResults');
    const userCreditsEl = document.getElementById('userCredits');
    
    extendForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = {
        audio_id: document.getElementById('audio_id').value.trim(),
        prompt: document.getElementById('prompt').value.trim(),
        continue_at: document.getElementById('continue_at').value
      };
      
      if (!formData.audio_id) {
        showNotification('Please enter an Audio ID', 'error');
        return;
      }
      
      // Disable button and show loading
      extendBtn.disabled = true;
      extendBtn.classList.add('generating');
      btnText.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Extending...';
      
      try {
        const response = await fetch('/music/extend', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(formData)
        });
        
        const data = await response.json();
        
        if (data.success) {
          showNotification('Music extension started successfully!', 'success');
          
          // Update credits
          if (data.remainingCredits !== undefined) {
            userCreditsEl.textContent = data.remainingCredits + ' credits';
          }
          
          // Display results
          displayResults(data.data, formData);
          
          // Reset form
          extendForm.reset();
        } else {
          showNotification(data.message || 'Failed to extend music', 'error');
        }
      } catch (error) {
        console.error('Error:', error);
        showNotification('An error occurred. Please try again.', 'error');
      } finally {
        extendBtn.disabled = false;
        extendBtn.classList.remove('generating');
        btnText.innerHTML = '<i class="fas fa-forward mr-2"></i>Extend Music';
      }
    });
    
    function displayResults(data, formData) {
      resultsSection.classList.remove('hidden');
      
      extendResults.innerHTML = `
        <div class="glass-strong rounded-xl p-8">
          <div class="text-center mb-6">
            <i class="fas fa-check-circle text-green-400 text-5xl mb-4"></i>
            <h3 class="text-2xl font-bold mb-2">Extension Started!</h3>
            <p class="text-gray-400">Your music is being extended. This may take a few moments.</p>
          </div>
          <div class="p-4 glass rounded-lg mb-4">
            <p class="text-sm text-gray-400 mb-2"><strong>Original Audio ID:</strong></p>
            <p class="font-mono text-cyan-400">${formData.audio_id}</p>
          </div>
          ${formData.prompt ? `
            <div class="p-4 glass rounded-lg mb-4">
              <p class="text-sm text-gray-400 mb-2"><strong>Continuation:</strong></p>
              <p class="text-white">${formData.prompt}</p>
            </div>
          ` : ''}
          <div class="text-center mt-6">
            <a href="/gallery" class="inline-block px-6 py-3 gradient-cyan rounded-lg font-bold hover:shadow-lg transition">
              <i class="fas fa-images mr-2"></i>Check Gallery for Results
            </a>
          </div>
        </div>
      `;
      
      resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    function showNotification(message, type = 'info') {
      const notification = document.createElement('div');
      notification.className = `fixed top-4 right-4 px-6 py-4 rounded-lg shadow-lg z-50 ${
        type === 'success' ? 'bg-green-500' :
        type === 'error' ? 'bg-red-500' :
        type === 'warning' ? 'bg-yellow-500' :
        'bg-blue-500'
      } text-white font-medium`;
      notification.innerHTML = `
        <i class="fas ${
          type === 'success' ? 'fa-check-circle' :
          type === 'error' ? 'fa-exclamation-circle' :
          type === 'warning' ? 'fa-exclamation-triangle' :
          'fa-info-circle'
        } mr-2"></i>
        ${message}
      `;
      
      document.body.appendChild(notification);
      
      setTimeout(() => {
        notification.remove();
      }, 5000);
    }
  </script>
</body>
</html>

