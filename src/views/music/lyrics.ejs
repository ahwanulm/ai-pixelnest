<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Lyrics Generation - PixelNest</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css?v=<%= appVersion %>">
  
  <style>
    body {
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      min-height: 100vh;
    }
    
    .glass {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .glass-strong {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.15);
    }
    
    .gradient-purple {
      background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
    }
    
    .lyrics-output {
      white-space: pre-wrap;
      font-family: 'Courier New', monospace;
      line-height: 1.8;
    }
    
    @keyframes pulse-glow {
      0%, 100% {
        box-shadow: 0 0 20px rgba(139, 92, 246, 0.5);
      }
      50% {
        box-shadow: 0 0 40px rgba(139, 92, 246, 0.8);
      }
    }
    
    .generating {
      animation: pulse-glow 2s ease-in-out infinite;
    }
  </style>
</head>
<body class="text-white">
  
  <%- include('../partials/header') %>
  
  <div class="container mx-auto px-4 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full gradient-purple mb-6">
        <i class="fas fa-pen-fancy text-4xl text-white"></i>
      </div>
      <h1 class="text-5xl font-bold mb-4">
        <span class="gradient-text">AI Lyrics Generation</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Generate creative song lyrics using AI - perfect for songwriting inspiration
      </p>
      
      <!-- Navigation Tabs -->
      <div class="flex justify-center gap-4 mt-8">
        <a href="/music" class="px-6 py-3 glass rounded-lg hover:bg-white/10 transition">
          <i class="fas fa-music mr-2"></i>Music Generation
        </a>
        <a href="/music/lyrics" class="px-6 py-3 gradient-purple rounded-lg font-bold">
          <i class="fas fa-pen-fancy mr-2"></i>Lyrics Generation
        </a>
        <a href="/music/extend" class="px-6 py-3 glass rounded-lg hover:bg-white/10 transition">
          <i class="fas fa-forward mr-2"></i>Extend Music
        </a>
      </div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <!-- Generation Form -->
      <div class="lg:col-span-2">
        <div class="glass-strong rounded-2xl p-8">
          <h2 class="text-2xl font-bold mb-6 flex items-center">
            <i class="fas fa-wand-magic-sparkles text-purple-400 mr-3"></i>
            Generate Lyrics
          </h2>
          
          <form id="lyricsForm" class="space-y-6">
            <!-- Prompt -->
            <div>
              <label for="prompt" class="block text-sm font-medium mb-2">
                <i class="fas fa-align-left mr-2 text-purple-400"></i>
                Song Theme / Description *
              </label>
              <textarea
                id="prompt"
                name="prompt"
                rows="4"
                class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-purple-500 focus:outline-none text-white placeholder-gray-400"
                placeholder="Describe what the song is about... (e.g., 'love song about summer romance', 'rock anthem about overcoming challenges')"
                required
              ></textarea>
              <p class="text-xs text-gray-400 mt-1">Be specific about theme, emotion, and style!</p>
            </div>
            
            <!-- Genre & Mood -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="genre" class="block text-sm font-medium mb-2">
                  <i class="fas fa-guitar mr-2 text-pink-400"></i>
                  Genre (Optional)
                </label>
                <input
                  type="text"
                  id="genre"
                  name="genre"
                  class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-pink-500 focus:outline-none text-white placeholder-gray-400"
                  placeholder="Pop, Rock, Hip Hop, etc."
                >
              </div>
              
              <div>
                <label for="mood" class="block text-sm font-medium mb-2">
                  <i class="fas fa-heart mr-2 text-red-400"></i>
                  Mood (Optional)
                </label>
                <input
                  type="text"
                  id="mood"
                  name="mood"
                  class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-red-500 focus:outline-none text-white placeholder-gray-400"
                  placeholder="Happy, Sad, Energetic, etc."
                >
              </div>
            </div>
            
            <!-- Submit Button -->
            <button
              type="submit"
              id="generateBtn"
              class="w-full py-4 gradient-purple rounded-lg font-bold text-lg hover:shadow-lg hover:shadow-purple-500/50 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <i class="fas fa-pen-fancy mr-2"></i>
              <span id="btnText">Generate Lyrics</span>
            </button>
            
            <p class="text-xs text-gray-400 text-center">
              <i class="fas fa-info-circle mr-1"></i>
              Lyrics generation is FREE - no credits required!
            </p>
          </form>
        </div>
      </div>
      
      <!-- Info Sidebar -->
      <div class="space-y-6">
        <!-- Tips -->
        <div class="glass-strong rounded-2xl p-6">
          <h3 class="text-lg font-bold mb-4 flex items-center">
            <i class="fas fa-lightbulb text-yellow-400 mr-2"></i>
            Tips for Best Lyrics
          </h3>
          <ul class="space-y-3 text-sm text-gray-300">
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Be specific about the story or message</span>
            </li>
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Mention the genre and mood</span>
            </li>
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Include emotional tone</span>
            </li>
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Describe the target audience</span>
            </li>
            <li class="flex items-start">
              <i class="fas fa-check text-green-400 mr-2 mt-1"></i>
              <span>Use generated lyrics as inspiration</span>
            </li>
          </ul>
        </div>
        
        <!-- Examples -->
        <div class="glass-strong rounded-2xl p-6">
          <h3 class="text-lg font-bold mb-4 flex items-center">
            <i class="fas fa-fire text-orange-400 mr-2"></i>
            Example Prompts
          </h3>
          <div class="space-y-3 text-sm">
            <div class="p-3 glass rounded-lg cursor-pointer hover:bg-white/10 transition" onclick="fillExample('love song about summer romance at the beach, nostalgic and bittersweet')">
              <i class="fas fa-heart text-pink-400 mr-2"></i>
              <span class="text-gray-300">Summer romance ballad</span>
            </div>
            <div class="p-3 glass rounded-lg cursor-pointer hover:bg-white/10 transition" onclick="fillExample('powerful rock anthem about overcoming adversity and never giving up')">
              <i class="fas fa-bolt text-yellow-400 mr-2"></i>
              <span class="text-gray-300">Motivational rock song</span>
            </div>
            <div class="p-3 glass rounded-lg cursor-pointer hover:bg-white/10 transition" onclick="fillExample('hip hop track about success and staying humble, confident yet introspective')">
              <i class="fas fa-microphone text-purple-400 mr-2"></i>
              <span class="text-gray-300">Hip hop about success</span>
            </div>
            <div class="p-3 glass rounded-lg cursor-pointer hover:bg-white/10 transition" onclick="fillExample('melancholic indie pop about lost friendship and moving on')">
              <i class="fas fa-cloud-rain text-blue-400 mr-2"></i>
              <span class="text-gray-300">Sad indie pop</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Generated Lyrics Section -->
    <div id="resultsSection" class="mt-12 hidden">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-6 text-center">
          <i class="fas fa-file-lines text-purple-400 mr-3"></i>
          Generated Lyrics
        </h2>
        <div class="glass-strong rounded-2xl p-8">
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold" id="lyricsTitle">Your Song Lyrics</h3>
            <div class="flex gap-2">
              <button onclick="copyLyrics()" class="px-4 py-2 glass rounded-lg hover:bg-white/10 transition">
                <i class="fas fa-copy mr-2"></i>Copy
              </button>
              <button onclick="downloadLyrics()" class="px-4 py-2 glass rounded-lg hover:bg-white/10 transition">
                <i class="fas fa-download mr-2"></i>Download
              </button>
              <button onclick="createMusicFromLyrics()" class="px-4 py-2 gradient-purple rounded-lg hover:shadow-lg transition">
                <i class="fas fa-music mr-2"></i>Create Music
              </button>
            </div>
          </div>
          <div id="lyricsOutput" class="lyrics-output text-gray-100 p-6 glass rounded-lg min-h-[300px]">
            <!-- Lyrics will appear here -->
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  
  <script>
    const lyricsForm = document.getElementById('lyricsForm');
    const generateBtn = document.getElementById('generateBtn');
    const btnText = document.getElementById('btnText');
    const resultsSection = document.getElementById('resultsSection');
    const lyricsOutput = document.getElementById('lyricsOutput');
    
    let currentLyrics = '';
    let currentPrompt = '';
    
    lyricsForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Get form data
      const prompt = document.getElementById('prompt').value.trim();
      const genre = document.getElementById('genre').value.trim();
      const mood = document.getElementById('mood').value.trim();
      
      if (!prompt) {
        showNotification('Please enter a song theme or description', 'error');
        return;
      }
      
      // Build full prompt
      let fullPrompt = prompt;
      if (genre) fullPrompt += `, genre: ${genre}`;
      if (mood) fullPrompt += `, mood: ${mood}`;
      
      currentPrompt = fullPrompt;
      
      // Disable button and show loading
      generateBtn.disabled = true;
      generateBtn.classList.add('generating');
      btnText.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Generating...';
      
      try {
        const response = await fetch('/music/generate-lyrics', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ prompt: fullPrompt })
        });
        
        const data = await response.json();
        
        if (data.success) {
          showNotification('Lyrics generated successfully!', 'success');
          displayLyrics(data.data);
        } else {
          showNotification(data.message || 'Failed to generate lyrics', 'error');
        }
      } catch (error) {
        console.error('Error:', error);
        showNotification('An error occurred. Please try again.', 'error');
      } finally {
        generateBtn.disabled = false;
        generateBtn.classList.remove('generating');
        btnText.innerHTML = '<i class="fas fa-pen-fancy mr-2"></i>Generate Lyrics';
      }
    });
    
    function displayLyrics(data) {
      resultsSection.classList.remove('hidden');
      
      // Extract lyrics from response
      let lyrics = '';
      if (data.text) {
        lyrics = data.text;
      } else if (data.data && data.data.text) {
        lyrics = data.data.text;
      } else if (typeof data === 'string') {
        lyrics = data;
      } else {
        lyrics = JSON.stringify(data, null, 2);
      }
      
      currentLyrics = lyrics;
      lyricsOutput.textContent = lyrics;
      
      // Scroll to results
      resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    function copyLyrics() {
      navigator.clipboard.writeText(currentLyrics);
      showNotification('Lyrics copied to clipboard!', 'success');
    }
    
    function downloadLyrics() {
      const blob = new Blob([currentLyrics], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'lyrics.txt';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      showNotification('Lyrics downloaded!', 'success');
    }
    
    function createMusicFromLyrics() {
      // Store lyrics in session storage and redirect to music generation
      sessionStorage.setItem('generatedLyrics', currentLyrics);
      sessionStorage.setItem('lyricsPrompt', currentPrompt);
      window.location.href = '/music?fromLyrics=true';
    }
    
    function fillExample(text) {
      document.getElementById('prompt').value = text;
      document.getElementById('prompt').focus();
    }
    
    function showNotification(message, type = 'info') {
      const notification = document.createElement('div');
      notification.className = `fixed top-4 right-4 px-6 py-4 rounded-lg shadow-lg z-50 ${
        type === 'success' ? 'bg-green-500' :
        type === 'error' ? 'bg-red-500' :
        type === 'warning' ? 'bg-yellow-500' :
        'bg-blue-500'
      } text-white font-medium`;
      notification.innerHTML = `
        <i class="fas ${
          type === 'success' ? 'fa-check-circle' :
          type === 'error' ? 'fa-exclamation-circle' :
          type === 'warning' ? 'fa-exclamation-triangle' :
          'fa-info-circle'
        } mr-2"></i>
        ${message}
      `;
      
      document.body.appendChild(notification);
      
      setTimeout(() => {
        notification.remove();
      }, 5000);
    }
  </script>
</body>
</html>

