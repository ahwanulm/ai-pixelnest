  </div>
  
  <%- include('../partials/footer') %>
  
  <!-- Edit Pricing Modal (Admin Only) -->
  <% if (user && user.role === 'admin') { %>
  <div id="editPricingModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/70 p-4">
    <div class="bg-gray-900 rounded-xl max-w-md w-full p-6 border border-white/10">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-xl font-bold text-white">Edit Model Pricing</h3>
        <button onclick="closeEditPricing()" class="text-gray-400 hover:text-white">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-2 text-gray-300">Model</label>
          <input type="text" id="editModelName" class="w-full px-4 py-2 glass rounded-lg border border-white/10 text-white" readonly>
          <input type="hidden" id="editModelId">
        </div>
        
        <div>
          <label class="block text-sm font-medium mb-2 text-gray-300">
            <i class="fas fa-coins text-yellow-400 mr-2"></i>
            Credits Cost
          </label>
                  <input 
                    type="number" 
                    id="editModelCost" 
                    min="0" 
                    step="0.1"
                    class="w-full px-4 py-2 glass rounded-lg border border-white/10 text-white focus:border-yellow-500 focus:outline-none"
                  >
                  <p class="text-xs text-gray-400 mt-1">
                    Example: 0.5 = IDR 1,000 • 1 = IDR 2,000 • 2 = IDR 4,000
                  </p>
        </div>
        
                <div class="flex gap-2">
                  <button 
                    onclick="closeEditPricing()" 
                    class="flex-1 px-4 py-2 glass rounded-lg hover:bg-white/10 transition"
                  >
                    Cancel
                  </button>
                  <button 
                    onclick="savePricing()" 
                    class="flex-1 px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded-lg transition"
                  >
                    <i class="fas fa-save mr-2"></i>Save & Reload
                  </button>
                </div>
                <p class="text-xs text-gray-400 mt-2 text-center">
                  <i class="fas fa-info-circle mr-1"></i>
                  Page will reload to show updated pricing
                </p>
      </div>
    </div>
  </div>
  <% } %>

  <script>
    console.log('🎵 Music generation script loaded');
    
    const musicForm = document.getElementById('musicForm');
    const generateBtn = document.getElementById('generateBtn');
    const btnText = document.getElementById('btnText');
    const resultsSection = document.getElementById('resultsSection');
    const musicResults = document.getElementById('musicResults');
    const userCreditsEl = document.getElementById('userCredits');
    
    console.log('📋 Element check:', {
      musicForm: !!musicForm,
      generateBtn: !!generateBtn,
      resultsSection: !!resultsSection,
      musicResults: !!musicResults
    });
    
    // Update model info display
    function updateModelInfo() {
      const select = document.getElementById('model');
      const option = select.options[select.selectedIndex];
      const modelInfo = document.getElementById('modelInfo');
      
      if (option) {
        document.getElementById('modelName').textContent = option.dataset.name || option.text;
        document.getElementById('modelDescription').textContent = option.dataset.description || '';
        document.getElementById('modelCost').textContent = option.dataset.cost || '0';
        document.getElementById('modelQuality').textContent = (option.dataset.quality || 'good').toUpperCase();
        document.getElementById('modelDuration').textContent = option.dataset.duration === 'null' ? 'Varies' : option.dataset.duration + 's';
        modelInfo.classList.remove('hidden');
      }
    }
    
    // Admin: Edit pricing modal
    <% if (user && user.role === 'admin') { %>
    function openEditPricing() {
      const select = document.getElementById('model');
      const option = select.options[select.selectedIndex];
      
      // Get model data from select option or from database
      const modelName = option.dataset.name || option.text;
      const modelCost = option.dataset.cost || 0;
      const modelValue = option.value;
      
      // Find model ID from sunoModels data
      <% if (sunoModels && sunoModels.length > 0) { %>
      const sunoModelsData = <%- JSON.stringify(sunoModels) %>;
      const modelData = sunoModelsData.find(m => {
        const version = m.metadata?.version || m.model_id.replace('suno-', '');
        return version === modelValue;
      });
      
      if (modelData) {
        document.getElementById('editModelId').value = modelData.id;
        document.getElementById('editModelName').value = modelData.name;
        document.getElementById('editModelCost').value = modelData.cost;
        document.getElementById('editPricingModal').classList.remove('hidden');
        document.getElementById('editPricingModal').classList.add('flex');
      }
      <% } %>
    }
    
    function closeEditPricing() {
      document.getElementById('editPricingModal').classList.add('hidden');
      document.getElementById('editPricingModal').classList.remove('flex');
    }
    
    async function savePricing() {
      const modelId = document.getElementById('editModelId').value;
      const newCost = parseFloat(document.getElementById('editModelCost').value);
      
      if (!modelId || isNaN(newCost)) {
        showNotification('Invalid data', 'error');
        return;
      }
      
      try {
        const response = await fetch(`/admin/api/models/${modelId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ cost: newCost })
        });
        
        const data = await response.json();
        
        if (data.success) {
          showNotification('Pricing updated successfully! Reloading page...', 'success');
          closeEditPricing();
          
          // Reload page to get fresh data from database
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          showNotification(data.message || 'Failed to update pricing', 'error');
        }
      } catch (error) {
        console.error('Error:', error);
        showNotification('Error updating pricing', 'error');
      }
    }
    <% } %>
    
    // Toggle Advanced Options
    function toggleAdvanced() {
      const options = document.getElementById('advancedOptions');
      const toggle = document.getElementById('advancedToggle');
      const vocalGenderSection = document.getElementById('vocalGenderSection');
      const isHidden = options.classList.contains('hidden');
      
      if (isHidden) {
        options.classList.remove('hidden');
        toggle.innerHTML = '<i class="fas fa-chevron-up mr-1"></i>Hide';
        
        // Debug: check if vocal gender section is visible
        console.log('🔍 Advanced Options opened');
        console.log('   vocalGenderSection exists:', !!vocalGenderSection);
        console.log('   vocalGenderSection display:', vocalGenderSection ? window.getComputedStyle(vocalGenderSection).display : 'N/A');
        console.log('   vocalGenderSection visibility:', vocalGenderSection ? window.getComputedStyle(vocalGenderSection).visibility : 'N/A');
      } else {
        options.classList.add('hidden');
        toggle.innerHTML = '<i class="fas fa-chevron-down mr-1"></i>Show';
        console.log('🔍 Advanced Options closed');
      }
    }
    
    // Switch Generation Mode
    function switchMode(mode) {
      const descMode = document.getElementById('descriptionMode');
      const custMode = document.getElementById('customMode');
      const descBtn = document.getElementById('modeDescription');
      const custBtn = document.getElementById('modeCustom');
      
      if (mode === 'description') {
        // Show description, hide custom
        descMode.classList.remove('hidden');
        custMode.classList.add('hidden');
        descBtn.classList.add('active');
        custBtn.classList.remove('active');
        
        // Clear custom fields
        document.getElementById('lyrics').value = '';
        document.getElementById('style').value = '';
      } else {
        // Show custom, hide description
        descMode.classList.add('hidden');
        custMode.classList.remove('hidden');
        descBtn.classList.remove('active');
        custBtn.classList.add('active');
        
        // Clear description field
        document.getElementById('description').value = '';
      }
    }
    
    // Select Vocal Gender
    function selectVocalGender(gender) {
      // Check if instrumental mode is enabled
      const isInstrumental = document.getElementById('make_instrumental').value === 'true';
      
      if (isInstrumental) {
        // Don't allow selection in instrumental mode
        return;
      }
      
      // Remove active from all buttons
      document.querySelectorAll('.vocal-gender-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      
      // Add active to selected button
      const selectedBtn = document.querySelector(`.vocal-gender-btn[data-gender="${gender}"]`);
      if (selectedBtn) {
        selectedBtn.classList.add('active');
      }
      
      // Update hidden input
      document.getElementById('vocal_gender').value = gender;
      
      console.log('🎤 Vocal gender selected:', gender || 'auto');
    }
    
    // Update vocal gender state when track type changes
    function updateVocalGenderState() {
      const isInstrumental = document.getElementById('make_instrumental').value === 'true';
      const vocalGenderButtons = document.querySelectorAll('.vocal-gender-btn');
      
      vocalGenderButtons.forEach(btn => {
        if (isInstrumental) {
          btn.style.opacity = '0.5';
          btn.style.pointerEvents = 'none';
          btn.style.cursor = 'not-allowed';
        } else {
          btn.style.opacity = '1';
          btn.style.pointerEvents = 'auto';
          btn.style.cursor = 'pointer';
        }
      });
      
      // Reset to auto if instrumental
      if (isInstrumental) {
        selectVocalGender('');
      }
    }
    
    // Set Genre (replaces current style)
    function setGenre(genre) {
      const styleInput = document.getElementById('style');
      styleInput.value = genre;
      
      // Visual feedback
      event.target.style.transform = 'scale(1.1)';
      setTimeout(() => {
        event.target.style.transform = '';
      }, 200);
      
      console.log('🎸 Genre set:', genre);
    }
    
    // Add Mood (appends to current style)
    function addMood(mood) {
      const styleInput = document.getElementById('style');
      let currentStyle = styleInput.value.trim();
      
      // Check if mood already exists
      if (currentStyle.toLowerCase().includes(mood.toLowerCase())) {
        console.log('ℹ️ Mood already added:', mood);
        return;
      }
      
      // Append mood
      if (currentStyle) {
        styleInput.value = currentStyle + ', ' + mood;
      } else {
        styleInput.value = mood;
      }
      
      // Visual feedback
      event.target.style.transform = 'scale(1.1)';
      setTimeout(() => {
        event.target.style.transform = '';
      }, 200);
      
      console.log('🎭 Mood added:', mood);
    }
    
    // Update Weirdness label
    function updateWeirdnessLabel(value) {
      const label = document.getElementById('weirdnessValue');
      const val = parseFloat(value);
      
      if (val <= 0.3) {
        label.textContent = `(${val} - Conventional)`;
        label.className = 'text-xs text-yellow-300 ml-2';
      } else if (val <= 0.6) {
        label.textContent = `(${val} - Creative)`;
        label.className = 'text-xs text-orange-300 ml-2';
      } else {
        label.textContent = `(${val} - Wild!)`;
        label.className = 'text-xs text-red-300 ml-2';
      }
    }
    
    // Update Style Weight label
    function updateStyleWeightLabel(value) {
      const label = document.getElementById('styleWeightValue');
      const val = parseFloat(value);
      
      if (val <= 0.4) {
        label.textContent = `(${val} - Flexible)`;
        label.className = 'text-xs text-blue-300 ml-2';
      } else if (val <= 0.7) {
        label.textContent = `(${val} - Balanced)`;
        label.className = 'text-xs text-indigo-300 ml-2';
      } else {
        label.textContent = `(${val} - Strict)`;
        label.className = 'text-xs text-purple-300 ml-2';
      }
    }
    
    // Initialize on page load
    document.addEventListener('DOMContentLoaded', () => {
      updateModelInfo();
      selectVocalGender(''); // Default to auto
      updateVocalGenderState(); // Check initial instrumental state
      updateWeirdnessLabel(0.5); // Default weirdness
      updateStyleWeightLabel(0.7); // Default style weight
    });
    
    musicForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Determine generation mode
      const isCustomMode = !document.getElementById('customMode').classList.contains('hidden');
      const isInstrumental = document.getElementById('make_instrumental').value === 'true';
      
      // Base form data
      const formData = {
        model: document.getElementById('model').value,
        make_instrumental: isInstrumental,
        title: document.getElementById('title').value.trim(),
        custom_mode: isCustomMode,
        weirdness: parseFloat(document.getElementById('weirdness').value),
        style_weight: parseFloat(document.getElementById('style_weight').value)
      };
      
      // Add mode-specific fields
      if (isCustomMode) {
        // Custom Mode: lyrics + style
        const lyrics = document.getElementById('lyrics').value.trim();
        const style = document.getElementById('style').value.trim();
        
        if (!lyrics) {
          showNotification('Please enter song lyrics', 'error');
          return;
        }
        if (!style) {
          showNotification('Please enter music style', 'error');
          return;
        }
        
        formData.prompt = lyrics; // Suno uses 'prompt' for lyrics in custom mode
        formData.tags = style;     // Suno uses 'tags' for style/genre
      } else {
        // Description Mode: AI generates lyrics
        const description = document.getElementById('description').value.trim();
        
        if (!description) {
          showNotification('Please enter a music description', 'error');
          return;
        }
        
        formData.prompt = description;
        formData.tags = '';  // Empty tags, AI will decide
      }
      
      // Add vocal gender only if not instrumental
      if (!isInstrumental) {
        const vocalGender = document.getElementById('vocal_gender').value;
        console.log('🎤 Frontend - Vocal Gender Value:', vocalGender || '(empty - auto)');
        if (vocalGender) {
          formData.vocal_gender = vocalGender;
          console.log('   ✅ Added to formData:', vocalGender);
        } else {
          console.log('   ℹ️  Empty - will use auto detection');
        }
      } else {
        console.log('🎤 Frontend - Instrumental mode, skipping vocal gender');
      }
      
      // Disable button and show loading
      generateBtn.disabled = true;
      generateBtn.classList.add('generating');
      btnText.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Generating...';
      
      // ✨ Show loading card IMMEDIATELY (before fetch)
      console.log('🎬 Calling displayProcessingState() BEFORE fetch');
      displayProcessingState('temp', formData);
      console.log('✅ displayProcessingState() called');
      
      try {
        const response = await fetch('/music/generate', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(formData)
        });
        
        const data = await response.json();
        
        if (data.success) {
          showNotification('Music generation started! Waiting for results...', 'success');
          
          // Update credits display
          if (data.remainingCredits !== undefined) {
            userCreditsEl.textContent = data.remainingCredits + ' credits';
          }
          
          // Update loading card with real generation ID (already showing)
          // displayProcessingState(data.generationId, formData); // Already shown above
          
          // Start SSE to listen for completion
          listenForCompletion(data.generationId, formData);
          
          // Reset form
          musicForm.reset();
        } else {
          showNotification(data.message || 'Failed to generate music', 'error');
          
          // Hide loading card on error
          const resultsSection = document.getElementById('resultsSection');
          const musicResults = document.getElementById('musicResults');
          if (resultsSection) {
            resultsSection.classList.add('hidden');
            resultsSection.style.display = 'none';
          }
          if (musicResults) musicResults.innerHTML = '';
          
          generateBtn.disabled = false;
          generateBtn.classList.remove('generating');
          btnText.innerHTML = '<i class="fas fa-music mr-2"></i>Generate Music';
        }
      } catch (error) {
        console.error('Error:', error);
        showNotification('An error occurred. Please try again.', 'error');
        
        // Hide loading card on error
        const resultsSection = document.getElementById('resultsSection');
        const musicResults = document.getElementById('musicResults');
        if (resultsSection) {
          resultsSection.classList.add('hidden');
          resultsSection.style.display = 'none';
        }
        if (musicResults) musicResults.innerHTML = '';
        
        generateBtn.disabled = false;
        generateBtn.classList.remove('generating');
        btnText.innerHTML = '<i class="fas fa-music mr-2"></i>Generate Music';
      }
    });
    
    function displayMusicResults(data, formData) {
      // ✨ Get fresh references
      const resultsSection = document.getElementById('resultsSection');
      const musicResults = document.getElementById('musicResults');
      
      if (!resultsSection || !musicResults) {
        console.error('❌ Results elements not found!');
        return;
      }
      
      resultsSection.classList.remove('hidden');
      resultsSection.style.display = 'block'; // ✨ Force show
      
      // Clear previous results
      musicResults.innerHTML = '';
      
      // Check if data has tracks
      if (data.data && data.data.length > 0) {
        const totalTracks = data.data.length;
        console.log(`🎵 Displaying ${totalTracks} track(s)`);
        
        data.data.forEach((track, index) => {
          const musicCard = createMusicCard(track, formData, index, totalTracks);
          musicResults.innerHTML += musicCard;
        });
        
        // Show success notification with track count
        if (totalTracks > 1) {
          showNotification(`Successfully generated ${totalTracks} tracks!`, 'success');
        }
      } else {
        musicResults.innerHTML = `
          <div class="col-span-full glass-strong rounded-xl p-8 text-center">
            <i class="fas fa-clock text-4xl text-yellow-400 mb-4"></i>
            <p class="text-xl font-bold mb-2">Music is being generated...</p>
            <p class="text-gray-400">This may take a few moments. Check your dashboard for completed generations.</p>
          </div>
        `;
      }
      
      // Scroll to results
      resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    function createMusicCard(track, formData, index, totalTracks = 1) {
      const title = track.title || formData.title || `Generated Track ${index + 1}`;
      const audioUrl = track.audio_url || track.video_url;
      const imageUrl = track.image_url || track.image_large_url || '/images/music-placeholder.jpg';
      const duration = track.duration ? `${Math.floor(track.duration / 60)}:${(track.duration % 60).toString().padStart(2, '0')}` : '';
      
      return `
        <div class="glass-strong rounded-xl p-6 music-card animate-fade-in" style="animation-delay: ${index * 0.1}s">
          ${totalTracks > 1 ? `
            <div class="inline-block px-3 py-1 bg-purple-500/20 text-purple-300 rounded-full text-xs font-semibold mb-3">
              <i class="fas fa-music mr-1"></i>
              Track ${index + 1} of ${totalTracks}
            </div>
          ` : ''}
          <div class="aspect-square rounded-lg overflow-hidden mb-4 relative group">
            <img src="${imageUrl}" alt="${title}" class="w-full h-full object-cover transition-transform group-hover:scale-110" onerror="this.src='/images/music-placeholder.jpg'">
            ${duration ? `
              <div class="absolute bottom-2 right-2 bg-black/70 px-2 py-1 rounded text-xs">
                <i class="fas fa-clock mr-1"></i>${duration}
              </div>
            ` : ''}
          </div>
          <h3 class="text-lg font-bold mb-2">${title}</h3>
          <p class="text-sm text-gray-400 mb-4 line-clamp-2">${formData.prompt || 'AI Generated Music'}</p>
          ${audioUrl ? `
            <audio controls class="w-full mb-4">
              <source src="${audioUrl}" type="audio/mpeg">
              Your browser does not support the audio element.
            </audio>
            <div class="flex gap-2">
              <a href="${audioUrl}" download class="flex-1 text-center py-2 glass rounded-lg hover:bg-white/10 transition">
                <i class="fas fa-download mr-2"></i>Download
              </a>
              <button onclick="shareMusic('${audioUrl}')" class="flex-1 py-2 glass rounded-lg hover:bg-white/10 transition">
                <i class="fas fa-share mr-2"></i>Share
              </button>
            </div>
          ` : `
            <div class="py-4 text-center text-yellow-400">
              <i class="fas fa-spinner fa-spin mr-2"></i>Processing...
            </div>
          `}
        </div>
      `;
    }
    
    function shareMusic(url) {
      if (navigator.share) {
        navigator.share({
          title: 'Check out this AI-generated music!',
          url: url
        }).catch(err => console.log('Error sharing:', err));
      } else {
        navigator.clipboard.writeText(url);
        showNotification('Link copied to clipboard!', 'success');
      }
    }
    
    function showNotification(message, type = 'info') {
      // Create notification element
      const notification = document.createElement('div');
      notification.className = `fixed top-4 right-4 px-6 py-4 rounded-lg shadow-lg z-50 ${
        type === 'success' ? 'bg-green-500' :
        type === 'error' ? 'bg-red-500' :
        type === 'warning' ? 'bg-yellow-500' :
        'bg-blue-500'
      } text-white font-medium`;
      notification.innerHTML = `
        <i class="fas ${
          type === 'success' ? 'fa-check-circle' :
          type === 'error' ? 'fa-exclamation-circle' :
          type === 'warning' ? 'fa-exclamation-triangle' :
          'fa-info-circle'
        } mr-2"></i>
        ${message}
      `;
      
      document.body.appendChild(notification);
      
      // Remove after 5 seconds
      setTimeout(() => {
        notification.remove();
      }, 5000);
    }
    
    // ========== SSE REAL-TIME UPDATES ==========
    let eventSource = null;
    
    function displayProcessingState(generationId, formData) {
      // ✨ Get fresh references (in case elements weren't ready initially)
      const resultsSection = document.getElementById('resultsSection');
      const musicResults = document.getElementById('musicResults');
      
      if (!resultsSection || !musicResults) {
        console.error('❌ Results elements not found!');
        return;
      }
      
      console.log('✅ Showing loading card in results section');
      resultsSection.classList.remove('hidden');
      resultsSection.style.display = 'block'; // ✨ Force show
      musicResults.innerHTML = `
        <div id="loading-card-${generationId}" class="col-span-full glass-strong rounded-xl p-8 text-center">
          <div class="animate-pulse mb-4">
            <i class="fas fa-music text-6xl text-blue-400"></i>
          </div>
          <p class="text-xl font-bold mb-2">Generating your music...</p>
          <p class="text-gray-400 mb-2" id="progress-status-${generationId}">Initializing...</p>
          <div class="w-full bg-gray-700 rounded-full h-2 overflow-hidden mb-2">
            <div id="progress-bar-${generationId}" class="h-full bg-gradient-to-r from-blue-500 to-purple-500 transition-all duration-500" style="width: 0%"></div>
          </div>
          <p class="text-xs text-gray-500" id="progress-percent-${generationId}">0%</p>
        </div>
      `;
      resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    // Update progress for a specific generation
    function updateProgress(generationId, progress, status) {
      const progressBar = document.getElementById(`progress-bar-${generationId}`);
      const progressPercent = document.getElementById(`progress-percent-${generationId}`);
      const progressStatus = document.getElementById(`progress-status-${generationId}`);
      
      if (progressBar) {
        progressBar.style.width = `${progress}%`;
      }
      if (progressPercent) {
        progressPercent.textContent = `${progress}%`;
      }
      if (progressStatus && status) {
        progressStatus.textContent = status;
      }
      
      console.log(`📊 Progress updated: ${progress}% - ${status || ''}`);
    }
    
    function listenForCompletion(generationId, formData) {
      console.log('📡 Starting SSE listener for generation:', generationId);
      
      // Close existing connection if any
      if (eventSource) {
        console.log('🔄 Closing previous SSE connection');
        eventSource.close();
        eventSource = null;
      }
      
      // Set initial progress
      updateProgress(generationId, 10, 'Queued...');
      
      // Connect to SSE endpoint
      console.log('🔗 Connecting to SSE: /api/sse/generation-updates');
      eventSource = new EventSource('/api/sse/generation-updates');
      
      eventSource.addEventListener('message', (event) => {
        const data = JSON.parse(event.data);
        if (data.type === 'connected') {
          console.log('✅ SSE connected');
        }
      });
      
      // ✨ Listen for progress updates
      eventSource.addEventListener('job-progress', (event) => {
        const data = JSON.parse(event.data);
        console.log('📊 Progress update:', data);
        
        // Check if this is our job
        if (data.generationId === generationId) {
          const progress = data.progress || 0;
          const status = data.status || 'Processing...';
          
          // Update progress bar
          updateProgress(generationId, progress, status);
        }
      });
      
      eventSource.addEventListener('job-completed', async (event) => {
        const data = JSON.parse(event.data);
        console.log('✅ Job completed via SSE:', data);
        
        // Check if this is our job
        if (data.generationId === generationId) {
          console.log('🎵 Our music generation completed!');
          
          // Update progress to 100%
          updateProgress(generationId, 100, 'Completed!');
          
          // Fetch the completed generation data
          try {
            const response = await fetch(`/api/generations/${generationId}`);
            const genData = await response.json();
            
            if (genData.success) {
              // Display the music results
              const tracks = genData.generation.metadata?.all_tracks || 
                            genData.generation.result_data?.all_tracks || 
                            [genData.generation];
              
              displayMusicResults({ data: tracks }, formData);
              showNotification('Music generated successfully!', 'success');
            }
          } catch (error) {
            console.error('Error fetching generation:', error);
            showNotification('Music completed but failed to load. Please refresh.', 'warning');
          }
          
          // Re-enable button
          generateBtn.disabled = false;
          generateBtn.classList.remove('generating');
          btnText.innerHTML = '<i class="fas fa-music mr-2"></i>Generate Music';
          
          // Close SSE
          if (eventSource) {
            console.log('🔒 Closing SSE connection (job completed)');
            eventSource.close();
            eventSource = null;
          }
        }
      });
      
      eventSource.addEventListener('job-failed', (event) => {
        const data = JSON.parse(event.data);
        
        if (data.generationId === generationId) {
          console.error('❌ Music generation failed:', data.error);
          showNotification(data.error || 'Music generation failed', 'error');
          
          // Re-enable button
          generateBtn.disabled = false;
          generateBtn.classList.remove('generating');
          btnText.innerHTML = '<i class="fas fa-music mr-2"></i>Generate Music';
          
          // Get fresh references
          const resultsSection = document.getElementById('resultsSection');
          const musicResults = document.getElementById('musicResults');
          
          // Show error state
          if (musicResults) {
            musicResults.innerHTML = `
              <div class="col-span-full glass-strong rounded-xl p-8 text-center">
                <i class="fas fa-exclamation-circle text-6xl text-red-400 mb-4"></i>
                <p class="text-xl font-bold mb-2">Generation Failed</p>
                <p class="text-gray-400">${data.error || 'Unknown error occurred'}</p>
              </div>
            `;
          }
          
          // Close SSE
          if (eventSource) {
            console.log('🔒 Closing SSE connection (job failed)');
            eventSource.close();
            eventSource = null;
          }
        }
      });
      
      eventSource.onerror = (error) => {
        console.error('❌ SSE connection error:', error);
        // Auto-reconnect handled by browser
      };
      
      // Cleanup on page unload
      window.addEventListener('beforeunload', () => {
        if (eventSource) {
          console.log('🧹 Cleaning up SSE on page unload');
          eventSource.close();
          eventSource = null;
        }
      });
      
      // Fallback: Check status via polling after 90 seconds
      setTimeout(async () => {
        if (eventSource) {
          console.log('⏰ SSE timeout, checking status via API...');
          try {
            const response = await fetch(`/api/generations/${generationId}`);
            const data = await response.json();
            
            if (data.success && data.generation.status === 'completed') {
              const tracks = data.generation.metadata?.all_tracks || 
                            data.generation.result_data?.all_tracks || 
                            [data.generation];
              displayMusicResults({ data: tracks }, formData);
              showNotification('Music generated successfully!', 'success');
              
              // Re-enable button
              generateBtn.disabled = false;
              generateBtn.classList.remove('generating');
              btnText.innerHTML = '<i class="fas fa-music mr-2"></i>Generate Music';
            }
          } catch (error) {
            console.error('Fallback check error:', error);
          }
          
          // Close SSE
          if (eventSource) {
            eventSource.close();
            eventSource = null;
          }
        }
      }, 90000); // 90 seconds
    }
  </script>
</body>
</html>

