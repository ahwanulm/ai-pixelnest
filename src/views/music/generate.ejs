<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PixelNest</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css?v=<%= appVersion %>
    <script src="/js/theme-manager.js"></script>">
  
  <style>
    body {
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      min-height: 100vh;
    }
    
    .glass {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .glass-strong {
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.15);
    }
    
    .gradient-pink {
      background: linear-gradient(135deg, #ec4899 0%, #8b5cf6 100%);
    }
    
    .gradient-purple {
      background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
    }
    
    /* Vocal Gender Buttons */
    .vocal-gender-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 16px 12px;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
      backdrop-filter: blur(10px);
      border: 2px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      transition: all 0.3s ease;
      cursor: pointer;
      color: rgb(156 163 175);
      min-height: 110px;
    }
    
    .vocal-gender-btn:hover {
      border-color: rgba(236, 72, 153, 0.6);
      background: linear-gradient(135deg, rgba(236, 72, 153, 0.1) 0%, rgba(236, 72, 153, 0.05) 100%);
      color: white;
      transform: translateY(-4px);
      box-shadow: 0 8px 16px rgba(236, 72, 153, 0.2);
    }
    
    .vocal-gender-btn.active {
      border-color: rgb(236, 72, 153);
      background: linear-gradient(135deg, rgba(236, 72, 153, 0.25) 0%, rgba(236, 72, 153, 0.15) 100%);
      color: rgb(244, 114, 182);
      box-shadow: 0 4px 12px rgba(236, 72, 153, 0.3);
    }
    
    .vocal-gender-btn i {
      color: currentColor;
    }
    
    .vocal-gender-btn.active i {
      color: rgb(236, 72, 153);
    }
    
    /* Tempo Buttons */
    .tempo-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 12px 8px;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
      backdrop-filter: blur(10px);
      border: 2px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      transition: all 0.3s ease;
      cursor: pointer;
      color: rgb(156 163 175);
      min-height: 100px;
    }
    
    .tempo-btn:hover {
      border-color: rgba(251, 146, 60, 0.6);
      background: linear-gradient(135deg, rgba(251, 146, 60, 0.1) 0%, rgba(251, 146, 60, 0.05) 100%);
      color: white;
      transform: translateY(-4px);
      box-shadow: 0 8px 16px rgba(251, 146, 60, 0.2);
    }
    
    .tempo-btn.active {
      border-color: rgb(251, 146, 60);
      background: linear-gradient(135deg, rgba(251, 146, 60, 0.25) 0%, rgba(251, 146, 60, 0.15) 100%);
      color: rgb(251, 146, 60);
      box-shadow: 0 4px 12px rgba(251, 146, 60, 0.3);
    }
    
    .tempo-btn i {
      color: currentColor;
    }
    
    .tempo-btn.active i {
      color: rgb(251, 146, 60);
    }
    
    /* Mode Toggle Buttons */
    .mode-btn {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: rgb(156 163 175);
    }
    
    .mode-btn:hover {
      border-color: rgba(236, 72, 153, 0.5);
      color: white;
    }
    
    .mode-btn.active {
      background: linear-gradient(135deg, #ec4899 0%, #8b5cf6 100%);
      border-color: rgb(236, 72, 153);
      color: white;
    }
    
    /* Range Sliders */
    .slider-gradient::-webkit-slider-thumb {
      appearance: none;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
      cursor: pointer;
      box-shadow: 0 0 10px rgba(251, 191, 36, 0.5);
      transition: all 0.3s ease;
    }
    
    .slider-gradient::-webkit-slider-thumb:hover {
      transform: scale(1.2);
      box-shadow: 0 0 15px rgba(251, 191, 36, 0.8);
    }
    
    .slider-gradient::-moz-range-thumb {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
      cursor: pointer;
      border: none;
      box-shadow: 0 0 10px rgba(251, 191, 36, 0.5);
    }
    
    .slider-gradient-indigo::-webkit-slider-thumb {
      appearance: none;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: linear-gradient(135deg, #818cf8 0%, #6366f1 100%);
      cursor: pointer;
      box-shadow: 0 0 10px rgba(129, 140, 248, 0.5);
      transition: all 0.3s ease;
    }
    
    .slider-gradient-indigo::-webkit-slider-thumb:hover {
      transform: scale(1.2);
      box-shadow: 0 0 15px rgba(129, 140, 248, 0.8);
    }
    
    .slider-gradient-indigo::-moz-range-thumb {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: linear-gradient(135deg, #818cf8 0%, #6366f1 100%);
      cursor: pointer;
      border: none;
      box-shadow: 0 0 10px rgba(129, 140, 248, 0.5);
    }
    
    .music-card {
      transition: all 0.3s ease;
    }
    
    .music-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 40px rgba(236, 72, 153, 0.3);
    }
    
    @keyframes pulse-glow {
      0%, 100% {
        box-shadow: 0 0 20px rgba(236, 72, 153, 0.5);
      }
      50% {
        box-shadow: 0 0 40px rgba(236, 72, 153, 0.8);
      }
    }
    
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .generating {
      animation: pulse-glow 2s ease-in-out infinite;
    }
    
    .animate-fade-in {
      animation: fadeIn 0.5s ease-out forwards;
      opacity: 0;
    }
    
    /* Genre and Mood Preset Buttons */
    .genre-preset-btn,
    .mood-preset-btn {
      padding: 6px 12px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 6px;
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.8);
      cursor: pointer;
      transition: all 0.2s ease;
    }
    
    .genre-preset-btn:hover,
    .mood-preset-btn:hover {
      background: rgba(147, 51, 234, 0.2);
      border-color: rgba(147, 51, 234, 0.5);
      color: white;
      transform: translateY(-2px);
    }
    
    .genre-preset-btn:active,
    .mood-preset-btn:active {
      transform: scale(0.95);
    }
  </style>
</head>
<body class="text-white">
  
  <%- include('../partials/header') %>
  
  <div class="container mx-auto px-4 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full gradient-pink mb-6">
        <i class="fas fa-music text-4xl text-white"></i>
      </div>
      <h1 class="text-5xl font-bold mb-4">
        <span class="gradient-text">AI Music Generation</span>
        <span class="text-xs ml-4 px-3 py-1 bg-green-500 text-white rounded-full">v2.0 UPDATED</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Create unique music tracks from text descriptions using Suno AI
      </p>
      
      <% if (!sunoAvailable) { %>
        <div class="mt-6 p-4 bg-yellow-500/20 border border-yellow-500/30 rounded-lg max-w-2xl mx-auto">
          <i class="fas fa-exclamation-triangle text-yellow-400 mr-2"></i>
          <span class="text-yellow-200">Music generation service is currently not available. Please contact administrator.</span>
        </div>
      <% } %>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <!-- Generation Form -->
      <div class="lg:col-span-2">
        <div class="glass-strong rounded-2xl p-8">
          <h2 class="text-2xl font-bold mb-6 flex items-center">
            <i class="fas fa-wand-magic-sparkles text-pink-400 mr-3"></i>
            Generate Music
          </h2>
          
          <form id="musicForm" class="space-y-6">
            <!-- Generation Mode Toggle -->
            <div class="flex items-center justify-between p-4 glass-strong rounded-lg">
              <div>
                <h4 class="font-medium text-white">Generation Mode</h4>
                <p class="text-xs text-gray-400 mt-1">Choose how to create your music</p>
              </div>
              <div class="flex gap-2">
                <button
                  type="button"
                  id="modeDescription"
                  onclick="switchMode('description')"
                  class="mode-btn active px-4 py-2 rounded-lg transition"
                >
                  <i class="fas fa-magic mr-2"></i>Description
                </button>
                <button
                  type="button"
                  id="modeCustom"
                  onclick="switchMode('custom')"
                  class="mode-btn px-4 py-2 rounded-lg transition"
                >
                  <i class="fas fa-pen mr-2"></i>Custom Lyrics
                </button>
              </div>
            </div>
            
            <!-- Description Mode (AI generates lyrics) -->
            <div id="descriptionMode" class="space-y-4">
              <div>
                <label for="description" class="block text-sm font-medium mb-2">
                  <i class="fas fa-lightbulb mr-2 text-pink-400"></i>
                  Music Description *
                </label>
                <textarea
                  id="description"
                  name="description"
                  rows="3"
                  class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-pink-500 focus:outline-none text-white placeholder-gray-400"
                  placeholder="Describe your song... (e.g., 'A happy pop song about summer love with upbeat melody')"
                  <%= !sunoAvailable ? 'disabled' : '' %>
                ></textarea>
                <p class="text-xs text-gray-400 mt-1">
                  <i class="fas fa-info-circle mr-1"></i>
                  AI will generate lyrics based on your description
                </p>
              </div>
            </div>
            
            <!-- Custom Mode (User provides lyrics + style) -->
            <div id="customMode" class="hidden space-y-4">
              <div>
                <label for="lyrics" class="block text-sm font-medium mb-2">
                  <i class="fas fa-file-alt mr-2 text-pink-400"></i>
                  Song Lyrics *
                </label>
                <textarea
                  id="lyrics"
                  name="lyrics"
                  rows="6"
                  class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-pink-500 focus:outline-none text-white placeholder-gray-400 font-mono text-sm"
                  placeholder="[Verse 1]&#10;Your lyrics here...&#10;&#10;[Chorus]&#10;More lyrics...&#10;&#10;[Verse 2]&#10;..."
                  <%= !sunoAvailable ? 'disabled' : '' %>
                ></textarea>
                <p class="text-xs text-gray-400 mt-1">
                  <i class="fas fa-info-circle mr-1"></i>
                  Include structure tags like [Verse], [Chorus], [Bridge], etc.
                </p>
              </div>
              
              <div>
                <label for="style" class="block text-sm font-medium mb-2">
                  <i class="fas fa-palette mr-2 text-purple-400"></i>
                  Music Style *
                </label>
                <input
                  type="text"
                  id="style"
                  name="style"
                  class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-purple-500 focus:outline-none text-white placeholder-gray-400"
                  placeholder="e.g., pop, rock ballad, electronic dance, acoustic folk"
                  <%= !sunoAvailable ? 'disabled' : '' %>
                >
                <p class="text-xs text-gray-400 mt-1">
                  <i class="fas fa-info-circle mr-1"></i>
                  Define the genre and style of your music
                </p>
                
                <!-- Genre Presets (Quick Select) -->
                <div class="mt-3">
                  <p class="text-xs text-gray-400 mb-2">Quick Genre Presets:</p>
                  <div class="flex flex-wrap gap-2">
                    <button type="button" onclick="setGenre('pop')" class="genre-preset-btn">Pop</button>
                    <button type="button" onclick="setGenre('rock')" class="genre-preset-btn">Rock</button>
                    <button type="button" onclick="setGenre('hip hop')" class="genre-preset-btn">Hip Hop</button>
                    <button type="button" onclick="setGenre('electronic')" class="genre-preset-btn">Electronic</button>
                    <button type="button" onclick="setGenre('jazz')" class="genre-preset-btn">Jazz</button>
                    <button type="button" onclick="setGenre('classical')" class="genre-preset-btn">Classical</button>
                    <button type="button" onclick="setGenre('country')" class="genre-preset-btn">Country</button>
                    <button type="button" onclick="setGenre('r&b')" class="genre-preset-btn">R&B</button>
                  </div>
                </div>
                
                <!-- Mood Presets (Quick Select) -->
                <div class="mt-3">
                  <p class="text-xs text-gray-400 mb-2">Mood Presets:</p>
                  <div class="flex flex-wrap gap-2">
                    <button type="button" onclick="addMood('upbeat')" class="mood-preset-btn">😊 Upbeat</button>
                    <button type="button" onclick="addMood('sad')" class="mood-preset-btn">😢 Sad</button>
                    <button type="button" onclick="addMood('energetic')" class="mood-preset-btn">⚡ Energetic</button>
                    <button type="button" onclick="addMood('calm')" class="mood-preset-btn">😌 Calm</button>
                    <button type="button" onclick="addMood('romantic')" class="mood-preset-btn">💕 Romantic</button>
                    <button type="button" onclick="addMood('aggressive')" class="mood-preset-btn">🔥 Aggressive</button>
                    <button type="button" onclick="addMood('melancholic')" class="mood-preset-btn">🌧️ Melancholic</button>
                    <button type="button" onclick="addMood('happy')" class="mood-preset-btn">😄 Happy</button>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Model Selection -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="model" class="block text-sm font-medium mb-2">
                  <i class="fas fa-microchip mr-2 text-purple-400"></i>
                  AI Model
                  <% if (user && user.role === 'admin') { %>
                    <a href="/admin/models?filter_provider=SUNO" class="ml-2 text-xs text-blue-400 hover:text-blue-300" target="_blank" title="Manage models in admin panel">
                      <i class="fas fa-cog"></i> Manage
                    </a>
                  <% } %>
                </label>
                <select
                  id="model"
                  name="model"
                  class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-purple-500 focus:outline-none text-white"
                  <%= !sunoAvailable ? 'disabled' : '' %>
                  onchange="updateModelInfo()"
                >
                  <% if (sunoModels && sunoModels.length > 0) { %>
                    <% sunoModels.forEach((model, index) => { %>
                      <option 
                        value="<%= model.metadata?.version || model.model_id.replace('suno-', '') %>" 
                        data-cost="<%= model.cost %>"
                        data-duration="<%= model.max_duration || 'Varies' %>"
                        data-quality="<%= model.quality %>"
                        data-name="<%= model.name %>"
                        data-description="<%= model.description %>"
                        <%= index === 0 ? 'selected' : '' %>
                      >
                        <%= model.name %> - <%= model.cost %> credits (≈ IDR <%= (model.cost * 2000).toLocaleString('id-ID') %>)
                        <% if (model.trending) { %> 🔥<% } %>
                      </option>
                    <% }); %>
                  <% } else { %>
                    <!-- Fallback if no models in database -->
                    <option value="v5" data-cost="0.5" selected>V5 - Latest (0.5 credits / IDR 1,000)</option>
                    <option value="v4_5PLUS" data-cost="0.5">V4.5 PLUS - Richer Tones (0.5 credits / IDR 1,000)</option>
                    <option value="v4_5" data-cost="0.5">V4.5 - Smart Prompts (0.5 credits / IDR 1,000)</option>
                    <option value="v4" data-cost="0.5">V4 - Improved Vocals (0.5 credits / IDR 1,000)</option>
                    <option value="v3_5" data-cost="0.5">V3.5 - Better Structure (0.5 credits / IDR 1,000)</option>
                  <% } %>
                </select>
                
                <!-- Model Info Display -->
                <div id="modelInfo" class="mt-2 p-3 glass rounded-lg text-xs hidden">
                  <div class="flex justify-between items-start mb-2">
                    <div>
                      <strong class="text-white" id="modelName"></strong>
                      <p class="text-gray-400 mt-1" id="modelDescription"></p>
                    </div>
                    <% if (user && user.role === 'admin') { %>
                      <button 
                        onclick="openEditPricing()" 
                        class="px-2 py-1 bg-blue-500/20 hover:bg-blue-500/30 rounded text-blue-300 text-xs"
                        title="Edit pricing"
                      >
                        <i class="fas fa-edit"></i>
                      </button>
                    <% } %>
                  </div>
                  <div class="grid grid-cols-3 gap-2 text-center">
                    <div class="p-2 bg-white/5 rounded">
                      <div class="text-yellow-400 font-bold" id="modelCost"></div>
                      <div class="text-gray-500">Credits</div>
                    </div>
                    <div class="p-2 bg-white/5 rounded">
                      <div class="text-purple-400 font-bold" id="modelQuality"></div>
                      <div class="text-gray-500">Quality</div>
                    </div>
                    <div class="p-2 bg-white/5 rounded">
                      <div class="text-cyan-400 font-bold" id="modelDuration"></div>
                      <div class="text-gray-500">Max Length</div>
                    </div>
                  </div>
                </div>
              </div>
              
              <div>
                <label for="make_instrumental" class="block text-sm font-medium mb-2">
                  <i class="fas fa-guitar mr-2 text-blue-400"></i>
                  Track Type
                </label>
                <select
                  id="make_instrumental"
                  name="make_instrumental"
                  class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-blue-500 focus:outline-none text-white"
                  <%= !sunoAvailable ? 'disabled' : '' %>
                  onchange="updateVocalGenderState()"
                >
                  <option value="false" selected>With Vocals</option>
                  <option value="true">Instrumental Only</option>
                </select>
              </div>
            </div>
            
            <!-- Advanced Options -->
            <div class="glass-strong rounded-xl p-4 space-y-4">
              <div class="flex items-center justify-between">
                <h4 class="text-sm font-bold text-white flex items-center">
                  <i class="fas fa-sliders-h mr-2 text-purple-400"></i>
                  Advanced Options
                  <span class="ml-2 text-xs px-2 py-0.5 bg-pink-500 text-white rounded">VOCAL GENDER INSIDE ⭐</span>
                </h4>
                <button 
                  type="button" 
                  onclick="toggleAdvanced()" 
                  class="text-xs text-blue-400 hover:text-blue-300"
                  id="advancedToggle"
                >
                  <i class="fas fa-chevron-down mr-1"></i>
                  Show
                </button>
              </div>
              
              <div id="advancedOptions" class="hidden space-y-4">
                <!-- Vocal Gender Selection -->
                <div id="vocalGenderSection" class="p-4 bg-pink-500/5 border border-pink-500/20 rounded-lg">
                  <label class="block text-sm font-medium mb-3">
                    <i class="fas fa-microphone mr-2 text-pink-400"></i>
                    Vocal Gender
                    <span class="text-xs text-gray-400 ml-2">(Auto-detected if not set)</span>
                  </label>
                  <div class="grid grid-cols-3 gap-3">
                    <button
                      type="button"
                      onclick="selectVocalGender('')"
                      class="vocal-gender-btn active"
                      data-gender=""
                    >
                      <i class="fas fa-robot text-2xl mb-2"></i>
                      <span class="text-sm font-medium">Auto</span>
                      <span class="text-xs text-gray-400">AI Decides</span>
                    </button>
                    <button
                      type="button"
                      onclick="selectVocalGender('m')"
                      class="vocal-gender-btn"
                      data-gender="m"
                    >
                      <i class="fas fa-mars text-2xl mb-2"></i>
                      <span class="text-sm font-medium">Male</span>
                      <span class="text-xs text-gray-400">♂️ Voice</span>
                    </button>
                    <button
                      type="button"
                      onclick="selectVocalGender('f')"
                      class="vocal-gender-btn"
                      data-gender="f"
                    >
                      <i class="fas fa-venus text-2xl mb-2"></i>
                      <span class="text-sm font-medium">Female</span>
                      <span class="text-xs text-gray-400">♀️ Voice</span>
                    </button>
                  </div>
                  <input type="hidden" id="vocal_gender" name="vocal_gender" value="">
                  <p class="text-xs text-gray-400 mt-2">
                    <i class="fas fa-info-circle mr-1"></i>
                    Disabled automatically for instrumental tracks
                  </p>
                </div>
                
                <!-- Song Title (Optional) -->
                <div>
                  <label for="title" class="block text-sm font-medium mb-2">
                    <i class="fas fa-heading mr-2 text-cyan-400"></i>
                    Song Title
                    <span class="text-xs text-gray-400 ml-2">(Optional)</span>
                  </label>
                  <input
                    type="text"
                    id="title"
                    name="title"
                    class="w-full px-4 py-3 glass rounded-lg border border-white/10 focus:border-cyan-500 focus:outline-none text-white placeholder-gray-400"
                    placeholder="My Amazing Song"
                    <%= !sunoAvailable ? 'disabled' : '' %>
                  >
                </div>
                
                <!-- Weirdness Slider -->
                <div>
                  <label for="weirdness" class="block text-sm font-medium mb-2">
                    <i class="fas fa-sparkles mr-2 text-yellow-400"></i>
                    Weirdness
                    <span class="text-xs text-gray-400 ml-2" id="weirdnessValue">(0.5 - Balanced)</span>
                  </label>
                  <input 
                    type="range" 
                    id="weirdness" 
                    name="weirdness" 
                    min="0" 
                    max="1" 
                    step="0.1" 
                    value="0.5"
                    class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer slider-gradient"
                    oninput="updateWeirdnessLabel(this.value)"
                    <%= !sunoAvailable ? 'disabled' : '' %>
                  >
                  <div class="flex justify-between text-xs text-gray-500 mt-1">
                    <span>🎯 Conventional</span>
                    <span>🎨 Experimental</span>
                  </div>
                  <p class="text-xs text-gray-400 mt-2">
                    <span class="font-semibold text-yellow-300">0-0.3:</span> Predictable · 
                    <span class="font-semibold text-orange-300">0.4-0.6:</span> Creative · 
                    <span class="font-semibold text-red-300">0.7-1.0:</span> Wild
                  </p>
                </div>
                
                <!-- Style Weight Slider -->
                <div>
