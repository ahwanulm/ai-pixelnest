<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="PixelNest Documentation - Learn how to use our platform">
    <title>Documentation - PixelNest</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="text-white">
    <%- include('partials/header') %>
    
    <main class="mt-20">
        <!-- Hero Section -->
        <section class="relative py-20 overflow-hidden">
            <div class="section-container relative z-10">
                <div class="text-center mb-16">
                    <span class="inline-block px-4 py-1.5 glass rounded-full text-xs font-mono font-semibold uppercase tracking-[0.2em] mb-6 text-violet-400">
                        Documentation
                    </span>
                    <h1 class="text-5xl md:text-6xl font-black mb-6 tracking-tight">
                        Getting Started
                    </h1>
                    <p class="text-lg text-gray-400 font-light max-w-2xl mx-auto">
                        Everything you need to know to create amazing content with AI
                    </p>
                </div>

                <!-- Quick Start Guide -->
                <div class="max-w-4xl mx-auto mb-16">
                    <div class="glass rounded-2xl p-8 mb-8">
                        <h2 class="text-3xl font-bold mb-6 gradient-text">Quick Start Guide</h2>
                        
                        <div class="space-y-6">
                            <div class="flex gap-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-lg flex items-center justify-center font-bold">1</div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2">Create an Account</h3>
                                    <p class="text-gray-300">Sign up with your email or Google account. It's free and takes less than a minute.</p>
                                </div>
                            </div>

                            <div class="flex gap-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-lg flex items-center justify-center font-bold">2</div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2">Purchase Credits</h3>
                                    <p class="text-gray-300">Add credits to your account to start creating. Credits never expire.</p>
                                </div>
                            </div>

                            <div class="flex gap-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-lg flex items-center justify-center font-bold">3</div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2">Choose Your Model</h3>
                                    <p class="text-gray-300">Select from our library of AI models based on your needs - image or video generation.</p>
                                </div>
                            </div>

                            <div class="flex gap-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-lg flex items-center justify-center font-bold">4</div>
                                <div>
                                    <h3 class="text-xl font-bold mb-2">Generate & Download</h3>
                                    <p class="text-gray-300">Enter your prompt, adjust settings, and generate. Download your creation in seconds.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Features Documentation -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-6xl mx-auto mb-16">
                    <div class="glass rounded-2xl p-6">
                        <div class="w-12 h-12 bg-gradient-to-br from-violet-600 to-purple-600 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <h3 class="text-xl font-bold mb-3">Image Generation</h3>
                        <p class="text-gray-300 mb-4">Create stunning images from text descriptions. Supports text-to-image, image editing, upscaling, and background removal.</p>
                        <ul class="space-y-2 text-sm text-gray-400">
                            <li>• Multiple aspect ratios</li>
                            <li>• Advanced customization</li>
                            <li>• High-resolution output</li>
                        </ul>
                    </div>

                    <div class="glass rounded-2xl p-6">
                        <div class="w-12 h-12 bg-gradient-to-br from-fuchsia-600 to-pink-600 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <h3 class="text-xl font-bold mb-3">Video Generation</h3>
                        <p class="text-gray-300 mb-4">Generate professional videos with AI. Support for text-to-video, image-to-video, and video extensions.</p>
                        <ul class="space-y-2 text-sm text-gray-400">
                            <li>• Variable duration options</li>
                            <li>• 4K quality support</li>
                            <li>• Cinematic effects</li>
                        </ul>
                    </div>

                    <div class="glass rounded-2xl p-6">
                        <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-cyan-600 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                            </svg>
                        </div>
                        <h3 class="text-xl font-bold mb-3">Gallery Management</h3>
                        <p class="text-gray-300 mb-4">Organize and manage all your creations in one place. Easy search, filter, and download options.</p>
                        <ul class="space-y-2 text-sm text-gray-400">
                            <li>• Real-time sync</li>
                            <li>• Cloud storage</li>
                            <li>• Easy sharing</li>
                        </ul>
                    </div>

                    <div class="glass rounded-2xl p-6">
                        <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-violet-600 rounded-xl flex items-center justify-center mb-4">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <h3 class="text-xl font-bold mb-3">Credit System</h3>
                        <p class="text-gray-300 mb-4">Transparent pricing with no hidden fees. Only pay for what you use with our credit-based system.</p>
                        <ul class="space-y-2 text-sm text-gray-400">
                            <li>• Credits never expire</li>
                            <li>• Clear pricing</li>
                            <li>• Volume discounts</li>
                        </ul>
                    </div>
                </div>

                <!-- API Documentation -->
                <div class="max-w-4xl mx-auto">
                    <div class="glass rounded-2xl p-8">
                        <h2 class="text-3xl font-bold mb-6 gradient-text">Best Practices</h2>
                        
                        <div class="space-y-6">
                            <div>
                                <h3 class="text-xl font-bold mb-3 text-violet-400">Writing Effective Prompts</h3>
                                <ul class="list-disc list-inside text-gray-300 space-y-2 ml-4">
                                    <li>Be specific and descriptive</li>
                                    <li>Include style, mood, and composition details</li>
                                    <li>Use clear, concise language</li>
                                    <li>Experiment with different variations</li>
                                </ul>
                            </div>

                            <div>
                                <h3 class="text-xl font-bold mb-3 text-fuchsia-400">Optimizing Results</h3>
                                <ul class="list-disc list-inside text-gray-300 space-y-2 ml-4">
                                    <li>Choose the right AI model for your use case</li>
                                    <li>Adjust parameters based on desired output</li>
                                    <li>Use reference images when available</li>
                                    <li>Iterate and refine your prompts</li>
                                </ul>
                            </div>

                            <div>
                                <h3 class="text-xl font-bold mb-3 text-blue-400">Managing Credits</h3>
                                <ul class="list-disc list-inside text-gray-300 space-y-2 ml-4">
                                    <li>Monitor your credit balance regularly</li>
                                    <li>Start with lower quality for testing</li>
                                    <li>Use preview features when available</li>
                                    <li>Take advantage of volume pricing</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>

