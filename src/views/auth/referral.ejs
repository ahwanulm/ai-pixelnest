<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PixelNest AI</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/favicon.png">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="/css/mobile-navbar.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/js/theme-manager.js"></script>
  
  <style>
    body {
      background: #0a0a0a;
      min-height: 100vh;
      font-family: 'Space Grotesk', sans-serif;
    }
    
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 30px
    }
    
    .stat-card {
      background: rgba(24, 24, 27, 0.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 15px;
      padding: 25px;
      transition: all 0.3s ease;
      border-left: 3px solid;
    }
    
    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    
    .stat-card.earnings { border-left-color: #10b981; }
    .stat-card.referrals { border-left-color: #8b5cf6; }
    .stat-card.pending { border-left-color: #fbbf24; }
    .stat-card.paid { border-left-color: #06b6d4; }
    
    .stat-icon {
      font-size: 2rem;
      margin-bottom: 10px;
      opacity: 0.8;
    }
    
    .stat-card.earnings .stat-icon { color: #10b981; }
    .stat-card.referrals .stat-icon { color: #8b5cf6; }
    .stat-card.pending .stat-icon { color: #fbbf24; }
    .stat-card.paid .stat-icon { color: #06b6d4; }
    
    .stat-value {
      font-size: 1.8rem;
      font-weight: 700;
      color: white;
      margin-bottom: 5px;
    }
    
    .stat-label {
      color: #9ca3af;
      font-size: 0.85rem;
    }
    
    .content-card {
      background: rgba(24, 24, 27, 0.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 15px;
      padding: 30px;
      margin-bottom: 30px;
    }
    
    .content-card h3 {
      color: white;
      font-weight: 700;
      margin-bottom: 20px;
      font-size: 1.3rem;
    }
    
    .referral-link-card {
      background: rgba(24, 24, 27, 0.8);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(139, 92, 246, 0.3);
      border-radius: 15px;
      padding: 30px;
      margin-bottom: 30px;
      color: white;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
      position: relative;
      overflow: hidden;
    }
    
    .referral-link-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #8b5cf6, #7c3aed, #8b5cf6);
      background-size: 200% 100%;
      animation: shimmer 3s linear infinite;
    }
    
    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
    
    .link-input-group {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }
    
    .link-input {
      flex: 1;
      padding: 12px 20px;
      border-radius: 10px;
      border: 1px solid rgba(139, 92, 246, 0.3);
      font-size: 0.95rem;
      background: rgba(0, 0, 0, 0.4);
      color: white;
      backdrop-filter: blur(10px);
    }
    
    .link-input::placeholder {
      color: rgba(255,255,255,0.4);
    }
    
    .link-input:focus {
      outline: none;
      border-color: #8b5cf6;
      box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
    }
    
    .btn-copy {
      padding: 12px 30px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    
    .btn-copy:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(139, 92, 246, 0.4);
    }
    
    .share-buttons {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    
    .share-btn {
      padding: 10px 20px;
      border-radius: 10px;
      border: 1px solid rgba(139, 92, 246, 0.3);
      background: rgba(139, 92, 246, 0.1);
      color: #d1d5db;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 0.9rem;
    }
    
    .share-btn:hover {
      background: rgba(139, 92, 246, 0.2);
      border-color: #8b5cf6;
      color: white;
      transform: translateY(-2px);
    }
    
    .form-label {
      font-weight: 600;
      color: white;
      margin-bottom: 8px;
      display: block;
    }
    
    .form-control, .form-select {
      width: 100%;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.1);
      padding: 10px 15px;
      background: rgba(0,0,0,0.3);
      color: white;
    }
    
    .form-control:focus, .form-select:focus {
      border-color: #8b5cf6;
      outline: none;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
      border: none;
      border-radius: 10px;
      padding: 12px 30px;
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(139, 92, 246, 0.3);
    }
    
    .btn-primary:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    
    .table {
      width: 100%;
      border-collapse: collapse;
    }
    
    .table th {
      background: rgba(139, 92, 246, 0.1);
      color: white;
      font-weight: 600;
      padding: 12px;
      text-align: left;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    
    .table td {
      padding: 12px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      color: #d1d5db;
    }
    
    .table tr:hover td {
      background: rgba(255,255,255,0.03);
    }
    
    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-weight: 500;
      font-size: 0.85rem;
    }
    
    .badge.bg-success {
      background: rgba(16, 185, 129, 0.2);
      color: #10b981;
      border: 1px solid rgba(16, 185, 129, 0.3);
    }
    
    .badge.bg-info {
      background: rgba(6, 182, 212, 0.2);
      color: #06b6d4;
      border: 1px solid rgba(6, 182, 212, 0.3);
    }
    
    .badge.bg-warning {
      background: rgba(251, 191, 36, 0.2);
      color: #fbbf24;
      border: 1px solid rgba(251, 191, 36, 0.3);
    }
    
    .badge.bg-danger {
      background: rgba(239, 68, 68, 0.2);
      color: #ef4444;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }
    
    .badge.bg-primary {
      background: rgba(139, 92, 246, 0.2);
      color: #8b5cf6;
      border: 1px solid rgba(139, 92, 246, 0.3);
    }
    
    .alert {
      border-radius: 10px;
      padding: 15px 20px;
      margin-bottom: 20px;
      border: 1px solid;
    }
    
    .alert-success {
      background: rgba(16, 185, 129, 0.1);
      border-color: rgba(16, 185, 129, 0.3);
      color: #10b981;
    }
    
    .alert-warning {
      background: rgba(251, 191, 36, 0.1);
      border-color: rgba(251, 191, 36, 0.3);
      color: #fbbf24;
    }
    
    .empty-state {
      text-align: center;
      padding: 50px 20px;
      color: #6b7280;
    }
    
    .empty-state i {
      font-size: 4rem;
      margin-bottom: 20px;
      opacity: 0.3;
    }
  </style>
</head>
<body class="bg-zinc-950 text-white">
  <!-- Mobile Header -->
  <%- include('../partials/mobile-header') %>
  
  <!-- Top Navigation Bar (Same as Billing) - Hidden on Mobile -->
  <div class="hidden lg:block border-b border-white/10 bg-zinc-950/50 backdrop-blur-xl sticky top-0 z-50">
    <div class="px-4 md:px-8 py-4 flex items-center justify-between">
      <!-- Logo & Title -->
      <div class="flex items-center gap-2 md:gap-4">
        <a href="/dashboard" class="flex items-center gap-2 md:gap-3">
          <img src="/assets/img/logo/logo.png" alt="PixelNest Logo" class="h-8 md:h-10 w-auto">
          <span class="font-black text-base md:text-lg">PIXELNEST</span>
        </a>
        <span class="text-gray-600 hidden md:inline">/</span>
        <h2 class="text-xs md:text-sm font-semibold text-gray-400 hidden md:block">Referral Program</h2>
      </div>
      
      <!-- Navigation Links - Desktop -->
      <div class="hidden lg:flex items-center gap-6">
        <a href="/dashboard" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
          <span class="relative z-10">Dashboard</span>
          <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/tutorial" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
          <span class="relative z-10">Tutorial</span>
          <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/billing" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
          <span class="relative z-10">Billing</span>
          <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/gallery" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
          <span class="relative z-10">Gallery</span>
          <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
        </a>
      </div>
      
      <!-- User Menu - Mobile & Desktop -->
      <div class="flex items-center gap-4">
        <!-- Credits Display -->
        <div class="hidden md:flex items-center gap-2 px-3 py-1.5 bg-yellow-500/10 border border-yellow-500/20 rounded-lg">
          <i class="fas fa-coins text-yellow-400 text-sm"></i>
          <span class="text-yellow-400 font-semibold text-sm"><%= user.credits || 0 %></span>
        </div>
        
        <!-- User Avatar Dropdown -->
        <div class="relative">
          <button id="profile-btn" class="flex items-center gap-2 hover:opacity-80 transition">
            <% if (user.avatar_url) { %>
              <img src="<%= user.avatar_url %>" alt="<%= user.name %>" class="w-8 h-8 md:w-10 md:h-10 rounded-full ring-2 ring-violet-500">
            <% } else { %>
              <div class="w-8 h-8 md:w-10 md:h-10 rounded-full bg-gradient-to-br from-violet-600 to-fuchsia-600 flex items-center justify-center text-white font-bold text-sm ring-2 ring-violet-500">
                <%= user.name.charAt(0).toUpperCase() %>
              </div>
            <% } %>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          
          <!-- Dropdown Menu -->
                    <div id="profile-dropdown" class="hidden absolute right-0 mt-2 w-56 bg-zinc-900 border border-white/10 rounded-lg shadow-xl overflow-hidden z-[10000]">
            <div class="px-4 py-3 border-b border-white/10">
              <p class="text-sm font-semibold text-white"><%= user.name %></p>
              <p class="text-xs text-gray-400 truncate"><%= user.email %></p>
            </div>
            <div class="py-2">
              <a href="/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                Profile
              </a>
              <a href="/feature-request" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Request Model AI
              </a>
              <a href="/usage" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
                Usage
              </a>
              <a href="/billing" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                </svg>
                Billing
              </a>
              <a href="/referral/dashboard" class="flex items-center gap-3 px-4 py-2 text-sm text-white bg-white/5 transition-colors group">
                <svg class="w-4 h-4 text-yellow-400 group-hover:text-yellow-300 transition-colors" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                </svg>
                Referral Program
              </a>
            </div>
            <% if (user.role === 'admin') { %>
              <div class="border-t border-white/10">
                <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2 text-sm text-violet-400 hover:bg-violet-500/10 hover:text-violet-300 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  Admin Panel
                </a>
              </div>
            <% } %>
            <div class="border-t border-white/10">
              <a href="/logout" class="flex items-center gap-3 px-4 py-2 text-sm text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Logout
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 md:px-6 pt-20 lg:pt-8 py-8 pb-24">
    
    <!-- System Inactive Alert -->
    <% if (typeof systemInactive !== 'undefined' && systemInactive) { %>
      <div class="mb-6 p-6 bg-red-500/10 border border-red-500/30 rounded-xl">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0">
            <i class="fas fa-exclamation-triangle text-red-400 text-3xl"></i>
          </div>
          <div>
            <h3 class="text-xl font-bold text-red-400 mb-2">Sistem Referral Sedang Nonaktif</h3>
            <p class="text-gray-300 mb-3">
              Program referral saat ini sedang dalam status nonaktif. Fitur-fitur referral tidak dapat digunakan sementara waktu.
            </p>
            <p class="text-gray-400 text-sm">
              Jika Anda memiliki pertanyaan, silakan hubungi admin atau support kami.
            </p>
          </div>
        </div>
      </div>
    <% } %>
    
    <!-- Statistics -->
    <div class="stats-grid">
      <div class="stat-card earnings">
        <div class="stat-icon"><i class="fas fa-wallet"></i></div>
        <div class="stat-value">Rp <%= stats.availableForPayout.toLocaleString('id-ID') %></div>
        <div class="stat-label">Saldo Tersedia</div>
      </div>
      
      <div class="stat-card referrals">
        <div class="stat-icon"><i class="fas fa-users"></i></div>
        <div class="stat-value"><%= stats.totalReferrals %></div>
        <div class="stat-label">Total Referral</div>
      </div>
      
      <div class="stat-card pending">
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
        <div class="stat-value">Rp <%= stats.pendingPayout.toLocaleString('id-ID') %></div>
        <div class="stat-label">Payout Pending</div>
      </div>
      
      <div class="stat-card paid">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-value">Rp <%= stats.totalPaidOut.toLocaleString('id-ID') %></div>
        <div class="stat-label">Total Dibayarkan</div>
      </div>
    </div>
    
    <!-- Referral Link Card -->
    <% if (!systemInactive) { %>
    <div class="referral-link-card">
      <h3 class="text-xl font-bold mb-4">
        <i class="fas fa-link"></i> Link Referral Anda
      </h3>
      <div class="link-input-group">
        <input type="text" class="link-input" id="referralLink" value="<%= referralLink %>" readonly>
        <button class="btn-copy" onclick="copyLink()">
          <i class="fas fa-copy"></i> Copy Link
        </button>
      </div>
      <p class="text-gray-300 mb-3 text-sm">
        <i class="fas fa-info-circle"></i> 
        Bagikan link ini ke teman Anda. Anda akan mendapat:
      </p>
      <ul class="text-gray-300 text-sm mb-5 pl-5 space-y-1">
        <li>💸 <%= settings.commission_per_purchase %>% komisi dari setiap pembelian/top-up yang mereka lakukan</li>
        <li>💡 <strong>Note:</strong> Komisi hanya dari <strong>pembelian</strong>, bukan dari pendaftaran</li>
      </ul>
      <div class="share-buttons">
        <button class="share-btn" onclick="shareWhatsApp()">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </button>
        <button class="share-btn" onclick="shareTelegram()">
          <i class="fab fa-telegram"></i> Telegram
        </button>
        <button class="share-btn" onclick="shareTwitter()">
          <i class="fab fa-twitter"></i> Twitter
        </button>
        <button class="share-btn" onclick="shareFacebook()">
          <i class="fab fa-facebook"></i> Facebook
        </button>
      </div>
    </div>
    <% } %>
    
    <!-- Request Payout -->
    <% if (!systemInactive) { %>
    <div class="content-card">
      <h3><i class="fas fa-money-check-alt"></i> Request Payout</h3>
      
      <% if (stats.availableForPayout >= settings.minimum_payout) { %>
        <div class="alert alert-success">
          <i class="fas fa-check-circle"></i>
          Saldo Anda sudah mencukupi untuk melakukan payout! Minimum payout: Rp <%= settings.minimum_payout.toLocaleString('id-ID') %>
        </div>
      <% } else { %>
        <div class="alert alert-warning">
          <i class="fas fa-exclamation-triangle"></i>
          Saldo Anda belum mencukupi. Minimum payout: Rp <%= settings.minimum_payout.toLocaleString('id-ID') %>
        </div>
      <% } %>
      
      <form id="payoutForm" style="margin-top: 20px;" onsubmit="handlePayoutRequest(event)">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 20px;">
          <div>
            <label class="form-label">Jumlah Payout (Rp)</label>
            <input type="number" class="form-control" name="amount" 
                   min="<%= settings.minimum_payout %>" 
                   max="<%= stats.availableForPayout %>" 
                   value="<%= stats.availableForPayout %>"
                   required>
            <small style="color: #6b7280; font-size: 0.85rem;">
              Min: Rp <%= settings.minimum_payout.toLocaleString('id-ID') %> | 
              Max: Rp <%= stats.availableForPayout.toLocaleString('id-ID') %>
            </small>
          </div>
          
          <div>
            <label class="form-label">Metode Pembayaran</label>
            <select class="form-select" name="payment_method" required>
              <option value="">Pilih metode...</option>
              <option value="bank_transfer">Transfer Bank</option>
              <option value="gopay">GoPay</option>
              <option value="ovo">OVO</option>
              <option value="dana">DANA</option>
            </select>
          </div>
        </div>
        
        <div id="paymentDetails"></div>
        
        <button type="submit" class="btn-primary" 
                <%= stats.availableForPayout < settings.minimum_payout ? 'disabled' : '' %>>
          <i class="fas fa-paper-plane"></i> Request Payout
        </button>
        
        <p style="margin-top: 15px; color: #6b7280; font-size: 0.85rem;">
          <i class="fas fa-info-circle"></i> 
          Catatan: Anda dapat melakukan request payout maksimal 1x dalam <%= settings.payout_cooldown_days %> hari.
          Proses payout membutuhkan waktu 1-3 hari kerja.
        </p>
      </form>
    </div>
    <% } %>
    
    <!-- Payout History -->
    <div class="content-card">
      <h3><i class="fas fa-history"></i> Riwayat Payout</h3>
      
      <% if (payoutRequests && payoutRequests.length > 0) { %>
        <div style="overflow-x: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>Tanggal</th>
                <th>Jumlah</th>
                <th>Metode</th>
                <th>Status</th>
                <th>Keterangan</th>
              </tr>
            </thead>
            <tbody>
              <% payoutRequests.forEach(payout => { %>
                <tr>
                  <td><%= new Date(payout.created_at).toLocaleDateString('id-ID') %></td>
                  <td>Rp <%= payout.amount.toLocaleString('id-ID') %></td>
                  <td><%= payout.payment_method %></td>
                  <td>
                    <% if (payout.status === 'completed') { %>
                      <span class="badge bg-success">Selesai</span>
                    <% } else if (payout.status === 'processing') { %>
                      <span class="badge bg-info">Diproses</span>
                    <% } else if (payout.status === 'pending') { %>
                      <span class="badge bg-warning">Pending</span>
                    <% } else if (payout.status === 'rejected') { %>
                      <span class="badge bg-danger">Ditolak</span>
                    <% } %>
                  </td>
                  <td><%= payout.admin_notes || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-inbox"></i>
          <p>Belum ada riwayat payout</p>
        </div>
      <% } %>
    </div>
    
    <!-- Referred Users -->
    <% if (!systemInactive) { %>
    <div class="content-card">
      <h3><i class="fas fa-users"></i> User yang Anda Referensikan</h3>
      
      <% if (referredUsers && referredUsers.length > 0) { %>
        <div style="overflow-x: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>Nama</th>
                <th>Email</th>
                <th>Purchases Eligible</th>
                <th>Tanggal Daftar</th>
              </tr>
            </thead>
            <tbody>
              <% referredUsers.forEach(user => { %>
                <tr>
                  <td>
                    <% if (user.avatar_url) { %>
                      <img src="<%= user.avatar_url %>" alt="Avatar" 
                           style="width: 30px; height: 30px; border-radius: 50%; display: inline-block; margin-right: 10px; vertical-align: middle;">
                    <% } %>
                    <%= user.name %>
                  </td>
                  <td><%= user.email %></td>
                  <td>
                    <% if (user.purchase_count >= 2) { %>
                      <span class="badge" style="background: #ef4444;">2/2 (Max)</span>
                    <% } else if (user.purchase_count === 1) { %>
                      <span class="badge" style="background: #f59e0b;">1/2</span>
                    <% } else { %>
                      <span class="badge" style="background: #6b7280;">0/2</span>
                    <% } %>
                  </td>
                  <td><%= new Date(user.created_at).toLocaleDateString('id-ID') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-user-plus"></i>
          <p>Belum ada user yang mendaftar melalui referral Anda</p>
        </div>
      <% } %>
    </div>
    <% } %>
    
    <!-- Recent Transactions -->
    <% if (!systemInactive) { %>
    <div class="content-card">
      <h3><i class="fas fa-list"></i> Transaksi Terbaru</h3>
      
      <% if (transactions && transactions.length > 0) { %>
        <div style="overflow-x: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>Tanggal</th>
                <th>Tipe</th>
                <th>Deskripsi</th>
                <th>Jumlah</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.forEach(tx => { %>
                <tr>
                  <td><%= new Date(tx.created_at).toLocaleDateString('id-ID') %></td>
                  <td>
                    <% if (tx.transaction_type === 'purchase_commission') { %>
                      <span class="badge bg-primary">Komisi Pembelian</span>
                    <% } else { %>
                      <span class="badge bg-secondary"><%= tx.transaction_type %></span>
                    <% } %>
                  </td>
                  <td><%= tx.description %></td>
                  <td style="color: #10b981; font-weight: 600;">+Rp <%= tx.amount.toLocaleString('id-ID') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-receipt"></i>
          <p>Belum ada transaksi</p>
        </div>
      <% } %>
    </div>
    <% } %>
  </div>
  
  <script>
    const systemInactive = <%= typeof systemInactive !== 'undefined' ? systemInactive : false %>;
    
    // Profile Dropdown Toggle
    const profileBtn = document.getElementById('profile-btn');
    const profileDropdown = document.getElementById('profile-dropdown');
    
    if (profileBtn && profileDropdown) {
      profileBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        profileDropdown.classList.toggle('hidden');
      });
      
      // Close dropdown when clicking outside
      document.addEventListener('click', function(e) {
        if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
          profileDropdown.classList.add('hidden');
        }
      });
    }
  </script>
  
  <script>
    // Copy referral link
    function copyLink() {
      if (systemInactive) {
        alert('❌ Sistem referral sedang nonaktif.');
        return;
      }
      
      const linkInput = document.getElementById('referralLink');
      linkInput.select();
      document.execCommand('copy');
      
      const btn = event.target.closest('.btn-copy');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
      setTimeout(() => {
        btn.innerHTML = originalText;
      }, 2000);
    }
    
    // Share functions
    function shareWhatsApp() {
      if (systemInactive) {
        alert('❌ Sistem referral sedang nonaktif.');
        return;
      }
      
      const text = `Halo! Yuk join PixelNest AI untuk buat gambar & video dengan AI. Daftar pakai link ini: <%= referralLink %>`;
      window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank');
    }
    
    function shareTelegram() {
      if (systemInactive) {
        alert('❌ Sistem referral sedang nonaktif.');
        return;
      }
      
      const text = `Yuk join PixelNest AI! <%= referralLink %>`;
      window.open(`https://t.me/share/url?url=${encodeURIComponent('<%= referralLink %>')}&text=${encodeURIComponent(text)}`, '_blank');
    }
    
    function shareTwitter() {
      if (systemInactive) {
        alert('❌ Sistem referral sedang nonaktif.');
        return;
      }
      
      const text = `Join PixelNest AI dan buat gambar/video dengan AI! <%= referralLink %>`;
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`, '_blank');
    }
    
    function shareFacebook() {
      if (systemInactive) {
        alert('❌ Sistem referral sedang nonaktif.');
        return;
      }
      
      window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('<%= referralLink %>')}`, '_blank');
    }
    
    // Payment method details
    document.querySelector('select[name="payment_method"]').addEventListener('change', function() {
      const method = this.value;
      const detailsDiv = document.getElementById('paymentDetails');
      
      if (!method) {
        detailsDiv.innerHTML = '';
        return;
      }
      
      let html = '<div style="margin-bottom: 20px;">';
      
      if (method === 'bank_transfer') {
        html += `
          <label class="form-label">Nama Bank</label>
          <input type="text" class="form-control" name="bank_name" placeholder="Contoh: BCA" required style="margin-bottom: 15px;">
          <label class="form-label">Nomor Rekening</label>
          <input type="text" class="form-control" name="account_number" placeholder="1234567890" required style="margin-bottom: 15px;">
          <label class="form-label">Nama Pemilik Rekening</label>
          <input type="text" class="form-control" name="account_name" placeholder="Nama lengkap sesuai rekening" required>
        `;
      } else {
        html += `
          <label class="form-label">Nomor ${method.toUpperCase()}</label>
          <input type="text" class="form-control" name="account_number" placeholder="08xxxxxxxxxx" required style="margin-bottom: 15px;">
          <label class="form-label">Nama Pemilik Akun</label>
          <input type="text" class="form-control" name="account_name" placeholder="Nama lengkap" required>
        `;
      }
      
      html += '</div>';
      detailsDiv.innerHTML = html;
    });
    
    // Handle payout request
    async function handlePayoutRequest(e) {
      e.preventDefault();
      
      const form = e.target;
      const formData = new FormData(form);
      const method = formData.get('payment_method');
      
      const paymentDetails = {};
      if (method === 'bank_transfer') {
        paymentDetails.bank_name = formData.get('bank_name');
        paymentDetails.account_number = formData.get('account_number');
        paymentDetails.account_name = formData.get('account_name');
      } else {
        paymentDetails.account_number = formData.get('account_number');
        paymentDetails.account_name = formData.get('account_name');
      }
      
      try {
        const response = await fetch('/referral/payout/request', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            amount: parseFloat(formData.get('amount')),
            payment_method: method,
            payment_details: paymentDetails
          })
        });
        
        const data = await response.json();
        
        if (data.success) {
          alert('✅ Request payout berhasil dikirim! Kami akan memproses dalam 1-3 hari kerja.');
          window.location.reload();
        } else {
          alert('❌ ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('❌ Terjadi kesalahan. Silakan coba lagi.');
      }
    }
  </script>

  <!-- Mobile Navigation Bar -->
  <%- include('../partials/mobile-navbar') %>
</body>
</html>
