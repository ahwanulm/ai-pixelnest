<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="/css/generation-styles.css">
    <link rel="stylesheet" href="/css/mobile-navbar.css">
</head>
<body class="text-white">
    <!-- Mobile Header -->
    <%- include('../partials/mobile-header') %>
    
    <!-- Responsive Layout -->
    <div class="flex h-screen pt-14 lg:pt-0">
        <!-- Left Sidebar - Navigation (Hidden on mobile) -->
        <aside class="hidden lg:flex lg:w-96 bg-zinc-950 border-r border-white/10 flex-col h-screen overflow-hidden">
            <!-- Header -->
            <div class="p-6 border-b border-white/10">
                <!-- Logo -->
                <div class="flex items-center mb-6">
                    <a href="/" class="flex items-center gap-3">
                        <img src="/assets/img/logo/logo.png" alt="PixelNest Logo" class="h-10 w-auto">
                        <span class="font-black text-lg">PIXELNEST</span>
                    </a>
                </div>
                
                <!-- Navigation Title -->
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Gallery</h2>
            </div>

            <!-- Scrollable Content -->
            <div class="flex-1 overflow-y-auto p-6 space-y-6">
                <!-- Stats -->
                <div class="space-y-3">
                    <div class="glass-strong rounded-xl p-4">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm text-gray-400">Total Generations</span>
                            <i class="fas fa-magic text-violet-400"></i>
                        </div>
                        <p class="text-3xl font-black gradient-text"><%= stats.total %></p>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-3">
                        <div class="glass rounded-xl p-4">
                            <div class="flex items-center gap-2 mb-2">
                                <i class="fas fa-image text-blue-400 text-xs"></i>
                                <span class="text-xs text-gray-400">Images</span>
                            </div>
                            <p class="text-2xl font-bold text-blue-400"><%= stats.images %></p>
                        </div>
                        
                        <div class="glass rounded-xl p-4">
                            <div class="flex items-center gap-2 mb-2">
                                <i class="fas fa-video text-fuchsia-400 text-xs"></i>
                                <span class="text-xs text-gray-400">Videos</span>
                            </div>
                            <p class="text-2xl font-bold text-fuchsia-400"><%= stats.videos %></p>
                        </div>
                    </div>
                </div>

                
            </div>
        </aside>

        <!-- Main Content Area (Full width on mobile) -->
        <main class="flex-1 w-full bg-zinc-900 flex flex-col overflow-hidden">
            <!-- Top Bar (Responsive) -->
            <div class="border-b border-white/10 bg-zinc-950/50 backdrop-blur-xl relative z-40">
                <div class="px-4 lg:px-8 py-3 lg:py-4 flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <h2 class="text-sm font-semibold text-gray-400"><%= stats.total %> generations</h2>
                    </div>
                    <div class="hidden lg:flex items-center gap-6">
                        <a href="/dashboard" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
                            <span class="relative z-10">Dashboard</span>
                            <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
                        </a>
                        <a href="/explore" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
                            <span class="relative z-10">Explore</span>
                            <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
                        </a>
                        <a href="/tutorial" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
                            <span class="relative z-10">Tutorial</span>
                            <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
                        </a>
                        <a href="/billing" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
                            <span class="relative z-10">Billing</span>
                            <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
                        </a>
                        <a href="/gallery" class="relative text-sm text-white font-semibold transition-all duration-300 group">
                            <span class="relative z-10">Gallery</span>
                            <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-100 transition-opacity duration-300"></span>
                            <span class="absolute bottom-0 left-0 w-full h-0.5 bg-white transition-all duration-300"></span>
                        </a>
                        
                        <!-- Credits Display with Top-up Button -->
                        <div class="flex items-center gap-2">
                            <div class="relative px-3 py-1.5 bg-yellow-500/10 border border-yellow-500/20 rounded-lg group hover:border-yellow-500/40 transition-all duration-300 hover:scale-105 cursor-default">
                                <span class="absolute inset-0 bg-yellow-500/5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                                <div class="flex items-center gap-2 relative z-10">
                                    <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                                    </svg>
                                    <span class="text-sm font-bold text-yellow-400 font-mono"><%= (user.credits || 0).toFixed(1) %></span>
                                </div>
                            </div>
                            
                            <!-- Top-up Button -->
                            <a href="/billing" class="relative group flex items-center justify-center w-8 h-8 bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-lg hover:from-yellow-400 hover:to-yellow-500 transition-all duration-300 hover:scale-110 hover:rotate-90 shadow-lg shadow-yellow-500/20 hover:shadow-yellow-500/40" title="Top Up Credits">
                                <span class="absolute inset-0 bg-white/20 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                                <svg class="w-5 h-5 text-white relative z-10 font-bold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                                </svg>
                            </a>
                        </div>
                        
                        <!-- Profile Dropdown -->
                        <div class="relative z-[100]">
                            <button id="profile-btn" class="flex items-center gap-2 hover:opacity-80 transition-opacity relative z-[100] cursor-pointer">
                                <% if (user && user.avatar_url) { %>
                                    <img src="<%= user.avatar_url %>" alt="<%= user.name %>" class="w-8 h-8 rounded-full border-2 border-violet-500">
                                <% } else if (user) { %>
                                    <div class="w-8 h-8 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-full flex items-center justify-center text-xs font-bold">
                                        <%= user.name.charAt(0).toUpperCase() %>
                                    </div>
                                <% } %>
                                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                </svg>
                            </button>
                            
                            <!-- Dropdown Menu -->
                            <div id="profile-dropdown" class="hidden absolute right-0 mt-2 w-56 bg-zinc-900 border border-white/10 rounded-lg shadow-xl overflow-hidden z-[10000]">
                                <div class="px-4 py-3 border-b border-white/10">
                                    <p class="text-sm font-semibold text-white"><%= user.name %></p>
                                    <p class="text-xs text-gray-400 truncate"><%= user.email %></p>
                                </div>
                                <div class="py-2">
                                    <a href="/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                        </svg>
                                        Profile
                                    </a>
                                    <a href="/feature-request" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                        Request Model AI
                                    </a>
                                    <a href="/usage" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                                        </svg>
                                        Usage
                                    </a>
                                    <a href="/billing" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                                        </svg>
                                        Billing
                                    </a>
                                    <a href="/referral/dashboard" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors group">
                                        <svg class="w-4 h-4 text-yellow-400 group-hover:text-yellow-300 transition-colors" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                                        </svg>
                                        Referral Program
                                    </a>
                                </div>
                                <% if (user.role === 'admin') { %>
                                    <div class="border-t border-white/10">
                                        <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2 text-sm text-violet-400 hover:bg-violet-500/10 hover:text-violet-300 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            </svg>
                                            Admin Panel
                                        </a>
                                    </div>
                                <% } %>
                                <div class="border-t border-white/10">
                                    <a href="/logout" class="flex items-center gap-3 px-4 py-2 text-sm text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                        </svg>
                                        Logout
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Gallery Content Wrapper -->
            <div class="flex-1 overflow-y-auto p-8">
                <% if (Object.keys(groupedGenerations).length === 0) { %>
                    <!-- Empty State -->
                    <div class="flex flex-col items-center justify-center py-20 text-center">
                        <div class="w-24 h-24 bg-white/5 rounded-full flex items-center justify-center mb-6">
                            <i class="fas fa-images text-4xl text-gray-600"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2">No Generations Yet</h3>
                        <p class="text-gray-400 mb-6">Start creating amazing images and videos with AI</p>
                        <a href="/dashboard" class="btn-primary px-6 py-3">
                            <i class="fas fa-plus-circle mr-2"></i>
                            Create Your First Generation
                        </a>
                    </div>
                <% } else { %>
                    <!-- Gallery Grid by Date -->
                    <% Object.keys(groupedGenerations).forEach(date => { %>
                        <div class="mb-12">
                            <!-- Date Header -->
                            <div class="sticky top-20 z-10 bg-zinc-950/90 backdrop-blur-sm border-b border-white/10 pb-3 mb-6">
                                <h2 class="text-lg font-bold text-gray-300">
                                    <i class="fas fa-calendar text-violet-400 mr-2"></i>
                                    <%= date %>
                                </h2>
                            </div>
                            
                            <!-- Grid -->
                            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                                <% groupedGenerations[date].forEach(item => { %>
                                    <div class="generation-card glass rounded-xl overflow-hidden hover:glass-strong transition-all duration-300 group cursor-pointer"
                                         onclick="openModal('<%= item.id %>', '<%= item.type %>', '<%= item.url %>', `<%= item.prompt.replace(/`/g, '\\`').replace(/'/g, "\\'") %>`, '<%= item.subType %>', <%= item.cost %>)">
                                        
                                        <!-- Media Container -->
                                        <div class="aspect-square relative overflow-hidden bg-zinc-900">
                                            <% if (item.type === 'video') { %>
                                                <video 
                                                    class="w-full h-full object-cover"
                                                    loop
                                                    muted
                                                    onmouseover="this.play()"
                                                    onmouseout="this.pause(); this.currentTime=0"
                                                    preload="metadata">
                                                    <source src="<%= item.url %>" type="video/mp4">
                                                </video>
                                                <div class="absolute top-2 right-2 bg-black/70 px-2 py-1 rounded-full text-xs font-semibold flex items-center gap-1">
                                                    <i class="fas fa-video text-fuchsia-400"></i>
                                                    VIDEO
                                                </div>
                                            <% } else { %>
                                                <img 
                                                    src="<%= item.url %>" 
                                                    alt="<%= item.prompt %>"
                                                    class="w-full h-full object-cover"
                                                    loading="lazy">
                                                <div class="absolute top-2 right-2 bg-black/70 px-2 py-1 rounded-full text-xs font-semibold flex items-center gap-1">
                                                    <i class="fas fa-image text-blue-400"></i>
                                                    IMAGE
                                                </div>
                                            <% } %>
                                            
                                            <!-- Overlay -->
                                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/0 to-black/0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4">
                                                <p class="text-xs font-medium line-clamp-2 mb-2"><%= item.prompt %></p>
                                                <div class="flex items-center justify-between text-xs text-gray-400">
                                                    <span><%= item.subType.replace(/-/g, ' ') %></span>
                                                    <span><%= item.cost %> credits</span>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Info -->
                                        <div class="p-3">
                                            <p class="text-sm text-gray-400 line-clamp-2 leading-tight">
                                                <%= item.prompt %>
                                            </p>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
        </main>
    </div>

    <!-- Modal for Full View -->
    <div id="mediaModal" class="fixed inset-0 bg-black/90 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4" onclick="closeModal(event)">
        <div class="relative max-w-6xl w-full max-h-[90vh] bg-zinc-900 rounded-2xl overflow-hidden" onclick="event.stopPropagation()">
            <button onclick="closeModal()" class="absolute top-4 right-4 z-10 w-10 h-10 bg-black/50 hover:bg-black/70 rounded-full flex items-center justify-center transition-colors">
                <i class="fas fa-times text-xl"></i>
            </button>
            
            <div class="grid grid-cols-1 lg:grid-cols-3 h-full">
                <!-- Media Side -->
                <div class="lg:col-span-2 bg-black flex items-center justify-center p-8">
                    <div id="modalMediaContainer" class="max-w-full max-h-full"></div>
                </div>
                
                <!-- Info Side -->
                <div class="lg:col-span-1 p-6 space-y-4 overflow-y-auto">
                    <div>
                        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-2">Prompt</h3>
                        <p id="modalPrompt" class="text-white leading-relaxed"></p>
                    </div>
                    
                    <div>
                        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-2">Type</h3>
                        <span id="modalType" class="inline-block px-3 py-1 bg-white/10 rounded-full text-sm"></span>
                    </div>
                    
                    <div>
                        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-2">Cost</h3>
                        <p id="modalCost" class="text-yellow-400 font-bold"></p>
                    </div>
                    
                    <div class="pt-4 border-t border-white/10">
                        <a id="modalDownload" href="#" download class="btn-primary w-full text-center block">
                            <i class="fas fa-download mr-2"></i>
                            Download
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openModal(id, type, url, prompt, subType, cost) {
            const modal = document.getElementById('mediaModal');
            const container = document.getElementById('modalMediaContainer');
            
            // Clear previous content
            container.innerHTML = '';
            
            // Create media element
            if (type === 'video') {
                const video = document.createElement('video');
                video.src = url;
                video.controls = true;
                video.autoplay = true;
                video.loop = true;
                video.className = 'max-w-full max-h-[70vh] rounded-lg';
                container.appendChild(video);
            } else {
                const img = document.createElement('img');
                img.src = url;
                img.alt = prompt;
                img.className = 'max-w-full max-h-[70vh] rounded-lg';
                container.appendChild(img);
            }
            
            // Update info
            document.getElementById('modalPrompt').textContent = prompt;
            document.getElementById('modalType').textContent = subType.replace(/-/g, ' ');
            document.getElementById('modalCost').textContent = `${cost} credits`;
            document.getElementById('modalDownload').href = url;
            
            // Show modal
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
        
        function closeModal(event) {
            if (!event || event.target.id === 'mediaModal') {
                const modal = document.getElementById('mediaModal');
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
                
                // Stop video if playing
                const video = document.querySelector('#modalMediaContainer video');
                if (video) {
                    video.pause();
                }
            }
        }
        
        // Close on ESC key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeModal();
            }
        });
        
        // Profile Dropdown Toggle
        const profileBtn = document.getElementById('profile-btn');
        const profileDropdown = document.getElementById('profile-dropdown');
        
        if (profileBtn && profileDropdown) {
            profileBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                
                if (profileDropdown.classList.contains('hidden')) {
                    // Show dropdown
                    profileDropdown.classList.remove('hidden');
                    profileDropdown.style.display = 'block';
                    profileDropdown.style.opacity = '1';
                    profileDropdown.style.visibility = 'visible';
                    profileDropdown.style.pointerEvents = 'auto';
                } else {
                    // Hide dropdown
                    profileDropdown.classList.add('hidden');
                    profileDropdown.style.display = 'none';
                }
            });
            
            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
                    profileDropdown.classList.add('hidden');
                    profileDropdown.style.display = 'none';
                }
            });
        }
    </script>

    <!-- Mobile Navigation Bar -->
    <%- include('../partials/mobile-navbar') %>
</body>
</html>
