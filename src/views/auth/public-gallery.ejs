    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-24 lg:pb-8">
        <!-- Smart Search & Filter Bar (Compact) - NOT sticky on mobile -->
        <div class="glass-strong rounded-xl p-3 lg:p-4 mb-6 lg:sticky lg:top-[72px] z-40">
            <form action="/explore" method="GET">
                <!-- Main Filters Row -->
                <div class="flex flex-col lg:flex-row gap-2 mb-3">
                    <!-- Smart Search with Autocomplete -->
                    <div class="flex-1">
                        <div class="relative">
                            <i class="fas fa-search absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                            <input 
                                type="text" 
                                name="search" 
                                value="<%= filters.search %>"
                                placeholder="Search by prompt, model, or creator..."
                                class="w-full pl-10 pr-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-sm placeholder-gray-500 focus:border-violet-500/50 focus:ring-1 focus:ring-violet-500/20 transition-all">
                        </div>
                    </div>
                    
                    <!-- Type Filter (Compact) -->
                    <select 
                        name="type" 
                        class="px-2.5 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-xs focus:border-violet-500/50 focus:ring-1 focus:ring-violet-500/20 transition-all cursor-pointer">
                        <option value="all" <%= filters.type === 'all' ? 'selected' : '' %>>All Types</option>
                        <option value="image" <%= filters.type === 'image' ? 'selected' : '' %>>Images</option>
                        <option value="video" <%= filters.type === 'video' ? 'selected' : '' %>>Videos</option>
                    </select>
                    
                    <!-- Sort Filter (Compact) -->
                    <select 
                        name="sort" 
                        class="px-2.5 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-xs focus:border-violet-500/50 focus:ring-1 focus:ring-violet-500/20 transition-all cursor-pointer">
                        <option value="recent" <%= filters.sort === 'recent' ? 'selected' : '' %>>Recent</option>
                        <option value="popular" <%= filters.sort === 'popular' ? 'selected' : '' %>>Popular</option>
                        <option value="trending" <%= filters.sort === 'trending' ? 'selected' : '' %>>Trending</option>
                        <option value="mostViewed" <%= filters.sort === 'mostViewed' ? 'selected' : '' %>>Most Viewed</option>
                        <option value="mostLiked" <%= filters.sort === 'mostLiked' ? 'selected' : '' %>>Most Liked</option>
                    </select>
                    
                    <!-- Advanced Filters Toggle -->
                    <button 
                        type="button"
                        onclick="document.getElementById('advanced-filters').classList.toggle('hidden')"
                        class="px-3 py-2 bg-white/5 border border-white/10 hover:border-violet-500/50 rounded-lg text-white text-xs font-medium transition-all">
                        <i class="fas fa-sliders-h mr-1.5"></i>
                        <span class="hidden sm:inline">More</span>
                    </button>
                    
                    <!-- Submit Button -->
                    <button 
                        type="submit" 
                        class="px-4 py-2 bg-gradient-to-r from-violet-600 to-fuchsia-600 hover:from-violet-500 hover:to-fuchsia-500 rounded-lg font-semibold text-xs transition-all hover:scale-105 shadow-lg">
                        <i class="fas fa-search mr-1.5"></i> Search
                    </button>
                </div>
                
                
                <!-- Advanced Filters (Collapsible) -->
                <div id="advanced-filters" class="hidden pt-3 border-t border-white/10 space-y-2">
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
                        <!-- Model Filter -->
                        <div>
                            <label class="block text-[10px] text-gray-400 mb-1">Model</label>
                            <select name="model" class="w-full px-2 py-1.5 text-xs bg-white/5 border border-white/10 rounded-lg text-white focus:border-violet-500/50 transition-all cursor-pointer">
                                <option value="" <%= !filters.model ? 'selected' : '' %>>All Models</option>
                                <option value="flux" <%= filters.model === 'flux' ? 'selected' : '' %>>FLUX</option>
                                <option value="kling" <%= filters.model === 'kling' ? 'selected' : '' %>>Kling AI</option>
                                <option value="runway" <%= filters.model === 'runway' ? 'selected' : '' %>>Runway</option>
                                <option value="stable-diffusion" <%= filters.model === 'stable-diffusion' ? 'selected' : '' %>>Stable Diffusion</option>
                                <option value="midjourney" <%= filters.model === 'midjourney' ? 'selected' : '' %>>Midjourney</option>
                            </select>
                        </div>
                        
                        <!-- Aspect Ratio Filter -->
                        <div>
                            <label class="block text-[10px] text-gray-400 mb-1">Aspect Ratio</label>
                            <select name="aspectRatio" class="w-full px-2 py-1.5 text-xs bg-white/5 border border-white/10 rounded-lg text-white focus:border-violet-500/50 transition-all cursor-pointer">
                                <option value="" <%= !filters.aspectRatio ? 'selected' : '' %>>All Ratios</option>
                                <option value="1:1" <%= filters.aspectRatio === '1:1' ? 'selected' : '' %>>1:1 Square</option>
                                <option value="16:9" <%= filters.aspectRatio === '16:9' ? 'selected' : '' %>>16:9 Landscape</option>
                                <option value="9:16" <%= filters.aspectRatio === '9:16' ? 'selected' : '' %>>9:16 Portrait</option>
                                <option value="4:3" <%= filters.aspectRatio === '4:3' ? 'selected' : '' %>>4:3 Classic</option>
                                <option value="3:4" <%= filters.aspectRatio === '3:4' ? 'selected' : '' %>>3:4 Portrait</option>
                            </select>
                        </div>
                        
                        <!-- Quality Filter -->
                        <div>
                            <label class="block text-[10px] text-gray-400 mb-1">Min Views</label>
                            <select name="minViews" class="w-full px-2 py-1.5 text-xs bg-white/5 border border-white/10 rounded-lg text-white focus:border-violet-500/50 transition-all cursor-pointer">
                                <option value="0" <%= filters.minViews == 0 ? 'selected' : '' %>>Any</option>
                                <option value="10" <%= filters.minViews == 10 ? 'selected' : '' %>>10+ views</option>
                                <option value="50" <%= filters.minViews == 50 ? 'selected' : '' %>>50+ views</option>
                                <option value="100" <%= filters.minViews == 100 ? 'selected' : '' %>>100+ views</option>
                                <option value="500" <%= filters.minViews == 500 ? 'selected' : '' %>>500+ views</option>
                            </select>
                        </div>
                        
                        <!-- Creator Filter -->
                        <div>
                            <label class="block text-[10px] text-gray-400 mb-1">Creator</label>
                            <select name="creatorType" class="w-full px-2 py-1.5 text-xs bg-white/5 border border-white/10 rounded-lg text-white focus:border-violet-500/50 transition-all cursor-pointer">
                                <option value="" <%= !filters.creatorType ? 'selected' : '' %>>All Creators</option>
                                <option value="named" <%= filters.creatorType === 'named' ? 'selected' : '' %>>Named Only</option>
                                <option value="anonymous" <%= filters.creatorType === 'anonymous' ? 'selected' : '' %>>Anonymous Only</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Reset Filters -->
                    <div class="flex justify-end">
                        <a href="/explore" class="px-3 py-1.5 text-xs text-gray-400 hover:text-white transition-colors">
                            <i class="fas fa-times mr-1"></i> Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- Recommendations Section -->
        <% if (recommendations && recommendations.length > 0) { %>
        <section class="mb-12">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold">
                    <i class="fas fa-sparkles text-yellow-400 mr-2"></i>
                    <% if (user) { %>
                        Recommended for You
                    <% } else { %>
                        Trending Now
                    <% } %>
                </h2>
            </div>
            
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                <% recommendations.forEach(item => { %>
                    <div class="generation-card glass rounded-xl overflow-hidden hover-lift cursor-pointer group"
                         onclick="openDetailModal('<%= item.id %>')">
                        <div class="relative aspect-square overflow-hidden bg-zinc-900">
                            <% if (item.type === 'video') { %>
                                <video 
                                    src="<%= item.url %>" 
                                    class="w-full h-full object-cover"
                                    loop
                                    muted
                                    onmouseover="this.play()"
                                    onmouseout="this.pause(); this.currentTime=0">
                                </video>
                                <div class="absolute top-2 left-2 bg-black/70 px-2 py-1 rounded-full text-xs">
                                    <i class="fas fa-video text-fuchsia-400"></i>
                                </div>
                            <% } else { %>
                                <img 
                                    src="<%= item.url %>" 
                                    alt="<%= item.prompt %>"
                                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                    loading="lazy">
                                <div class="absolute top-2 left-2 bg-black/70 px-2 py-1 rounded-full text-xs">
                                    <i class="fas fa-image text-blue-400"></i>
                                </div>
                            <% } %>
                            
                            <!-- Overlay -->
                            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/0 to-black/0 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                <div class="absolute bottom-2 left-2 right-2">
                                    <p class="text-xs line-clamp-2 mb-2"><%= item.prompt %></p>
                                    <div class="flex items-center justify-between text-xs text-gray-400">
                                        <span><i class="fas fa-heart mr-1"></i> <%= item.likes || 0 %></span>
                                        <span><i class="fas fa-eye mr-1"></i> <%= item.views || 0 %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>
        <% } %>
        
        <!-- Main Gallery -->
        <section>
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold">
                    <i class="fas fa-th mr-2"></i>
                    Explore Gallery
                </h2>
                <p class="text-gray-400">
                    <%= pagination.totalItems.toLocaleString() %> results
                </p>
            </div>
            
            <% if (generations.length === 0) { %>
                <!-- Empty State -->
                <div class="text-center py-20">
                    <div class="w-24 h-24 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="fas fa-image text-5xl text-gray-600"></i>
                    </div>
                    <h3 class="text-2xl font-bold mb-2">No results found</h3>
                    <p class="text-gray-400 mb-6">Try adjusting your filters or search terms</p>
                    <a href="/explore" class="inline-block px-6 py-3 bg-violet-600 hover:bg-violet-700 rounded-xl font-semibold transition-colors">
                        <i class="fas fa-redo mr-2"></i> Reset Filters
                    </a>
                </div>
            <% } else { %>
                <!-- Uniform Grid -->
                <div class="gallery-grid">
                    <% generations.forEach(item => { %>
                        <div class="gallery-item cursor-pointer"
                             onclick="openDetailModal('<%= item.id %>')">
                            <!-- Media -->
                            <% if (item.type === 'video') { %>
                                <video 
                                    src="<%= item.url %>" 
                                    loop
                                    muted
                                    playsinline
                                    onmouseover="this.play()"
                                    onmouseout="this.pause(); this.currentTime=0">
                                </video>
                                <!-- Video Badge -->
                                <div class="video-badge">
                                    <i class="fas fa-play text-fuchsia-400"></i>
                                    <span class="text-white">VIDEO</span>
                                </div>
                            <% } else { %>
                                <img 
                                    src="<%= item.url %>" 
                                    alt="<%= item.prompt %>"
                                    loading="lazy">
                            <% } %>
                            
                            <!-- Metadata Bar (Always Visible - Extra Compact) -->
                            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black via-black/95 to-transparent px-2 py-1.5 pb-1.5">
                                <!-- Model & Tech Info -->
                                <div class="flex items-center gap-1.5 mb-1.5 flex-wrap">
                                    <% if (item.sub_type) { %>
                                        <span class="px-1.5 py-0.5 bg-violet-500/20 border border-violet-500/30 rounded text-[9px] font-semibold text-violet-300 uppercase tracking-wide">
                                            <%= item.sub_type.replace(/_/g, ' ').substring(0, 12) %>
                                        </span>
                                    <% } %>
                                    <% if (item.width && item.height) { %>
                                        <span class="px-1.5 py-0.5 bg-blue-500/20 border border-blue-500/30 rounded text-[9px] font-semibold text-blue-300">
                                            <%= item.width %>×<%= item.height %>
                                        </span>
                                    <% } %>
                                    <% if (item.duration) { %>
                                        <span class="px-1.5 py-0.5 bg-fuchsia-500/20 border border-fuchsia-500/30 rounded text-[9px] font-semibold text-fuchsia-300">
                                            <%= item.duration %>s
                                        </span>
                                    <% } %>
                                </div>
                                
                                <!-- Creator & Stats Row (Compact & Clear) -->
                                <div class="flex items-center justify-between text-xs">
                                    <div class="flex items-center gap-1.5 min-w-0">
                                        <% if (item.is_anonymous) { %>
                                            <div class="w-4 h-4 min-w-[16px] max-w-[16px] min-h-[16px] max-h-[16px] bg-gray-700 rounded-full flex items-center justify-center flex-shrink-0">
                                                <i class="fas fa-user-secret text-[8px]"></i>
                                            </div>
                                            <span class="text-gray-300 text-[10px]">Anon</span>
                                        <% } else { %>
                                            <% if (item.creator_avatar) { %>
                                                <img src="<%= item.creator_avatar %>" alt="<%= item.display_name || item.creator_name %>" class="w-4 h-4 min-w-[16px] max-w-[16px] min-h-[16px] max-h-[16px] rounded-full flex-shrink-0 object-cover">
                                            <% } else { %>
                                                <div class="w-4 h-4 min-w-[16px] max-w-[16px] min-h-[16px] max-h-[16px] bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-full flex items-center justify-center text-[8px] font-bold flex-shrink-0">
                                                    <%= (item.display_name || item.creator_name || 'U').charAt(0).toUpperCase() %>
                                                </div>
                                            <% } %>
                                            <span class="text-gray-300 text-[10px] truncate max-w-[70px]"><%= (item.display_name || item.creator_name || '').substring(0, 10) %></span>
                                        <% } %>
                                    </div>
                                    
                                    <div class="flex items-center gap-2 text-gray-400">
                                        <span class="flex items-center gap-0.5">
                                            <i class="fas fa-eye text-[8px]"></i>
                                            <span class="text-[9px]"><%= item.views || 0 %></span>
                                        </span>
                                        <span class="flex items-center gap-0.5">
                                            <i class="fas fa-heart text-[8px]"></i>
                                            <span class="text-[9px]"><%= item.like_count || 0 %></span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Hover Overlay (Simplified) -->
                            <div class="gallery-overlay">
                                <!-- Prompt (Full visibility on hover) -->
                                <div class="mb-2">
                                    <p class="text-xs text-white line-clamp-3 leading-relaxed">
                                        <%= item.prompt %>
                                    </p>
                                </div>
                                
                                <!-- Quick Actions -->
                                <% if (user) { %>
                                <div class="flex gap-2">
                                    <button 
                                        onclick="event.stopPropagation(); handleLike('<%= item.id %>')"
                                        class="flex-1 py-2 bg-black/70 backdrop-blur-sm hover:bg-red-500/70 rounded-lg flex items-center justify-center gap-1.5 transition-colors <%= item.user_liked ? 'text-red-400' : 'text-white' %>"
                                        data-generation-id="<%= item.id %>"
                                        data-liked="<%= item.user_liked ? 'true' : 'false' %>">
                                        <i class="fas fa-heart text-sm"></i>
                                        <span class="text-xs font-semibold">Like</span>
                                    </button>
                                    <button 
                                        onclick="event.stopPropagation(); handleBookmark('<%= item.id %>')"
                                        class="flex-1 py-2 bg-black/70 backdrop-blur-sm hover:bg-yellow-500/70 rounded-lg flex items-center justify-center gap-1.5 transition-colors <%= item.user_bookmarked ? 'text-yellow-400' : 'text-white' %>"
                                        data-generation-id="<%= item.id %>"
                                        data-bookmarked="<%= item.user_bookmarked ? 'true' : 'false' %>">
                                        <i class="fas fa-bookmark text-sm"></i>
                                        <span class="text-xs font-semibold">Save</span>
                                    </button>
                                </div>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                </div>
                
                <!-- Pagination -->
                <% if (pagination.totalPages > 1) { %>
                <div class="mt-12 flex items-center justify-center gap-2">
                    <% if (pagination.currentPage > 1) { %>
                        <a href="?page=<%= pagination.currentPage - 1 %>&type=<%= filters.type %>&sort=<%= filters.sort %>&search=<%= filters.search %>" 
                           class="px-4 py-2 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    <% } %>
                    
                    <% 
                    const maxPages = 7;
                    let startPage = Math.max(1, pagination.currentPage - Math.floor(maxPages / 2));
                    let endPage = Math.min(pagination.totalPages, startPage + maxPages - 1);
                    startPage = Math.max(1, endPage - maxPages + 1);
                    
                    for (let i = startPage; i <= endPage; i++) { %>
                        <a href="?page=<%= i %>&type=<%= filters.type %>&sort=<%= filters.sort %>&search=<%= filters.search %>" 
                           class="px-4 py-2 <%= i === pagination.currentPage ? 'bg-gradient-to-r from-violet-600 to-fuchsia-600' : 'bg-white/5 hover:bg-white/10' %> rounded-lg transition-colors font-semibold">
                            <%= i %>
                        </a>
                    <% } %>
                    
                    <% if (pagination.currentPage < pagination.totalPages) { %>
                        <a href="?page=<%= pagination.currentPage + 1 %>&type=<%= filters.type %>&sort=<%= filters.sort %>&search=<%= filters.search %>" 
                           class="px-4 py-2 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
                <% } %>
            <% } %>
        </section>
    </main>
    
    <!-- Detail Modal (to be implemented in JS) -->
    <div id="detail-modal" class="hidden fixed inset-0 bg-black/90 backdrop-blur-sm z-[10020] flex items-center justify-center p-4" onclick="if(event.target === this) closeDetailModal()">
        <!-- Modal content will be loaded dynamically -->
    </div>
    
    <!-- Scripts -->
    <script src="/js/public-gallery.js?v=<%= appVersion %>"></script>
    
    <script>
        // Profile Dropdown Toggle
        const profileBtn = document.getElementById('profile-btn-header');
        const profileDropdown = document.getElementById('profile-dropdown-header');
        
        if (profileBtn && profileDropdown) {
            profileBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                
                if (profileDropdown.classList.contains('hidden')) {
                    // Show dropdown
                    profileDropdown.classList.remove('hidden');
                    profileDropdown.style.display = 'block';
                    profileDropdown.style.opacity = '1';
                    profileDropdown.style.visibility = 'visible';
                    profileDropdown.style.pointerEvents = 'auto';
                } else {
                    // Hide dropdown
                    profileDropdown.classList.add('hidden');
                    profileDropdown.style.display = 'none';
                }
            });
            
            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
                    profileDropdown.classList.add('hidden');
                    profileDropdown.style.display = 'none';
                }
            });
        }
    </script>
    
    <% if (user) { %>
        <!-- Mobile Navigation Bar -->
        <%- include('../partials/mobile-navbar') %>
    <% } %>
</body>
</html>

