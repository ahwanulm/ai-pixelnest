                        <i class="fas fa-image text-blue-400 text-xs"></i>
                        <span class="text-gray-400 text-xs"><span class="text-white font-bold"><%= stats.images.toLocaleString() %></span> Images</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i class="fas fa-video text-fuchsia-400 text-xs"></i>
                        <span class="text-gray-400 text-xs"><span class="text-white font-bold"><%= stats.videos.toLocaleString() %></span> Videos</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i class="fas fa-users text-emerald-400 text-xs"></i>
                        <span class="text-gray-400 text-xs"><span class="text-white font-bold"><%= stats.total_creators.toLocaleString() %></span> Creators</span>
                    </div>
