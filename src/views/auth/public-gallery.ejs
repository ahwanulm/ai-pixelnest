                        <i class="fas fa-eye text-violet-400 text-xs"></i>
                        <span class="text-gray-400 text-xs"><span class="text-white font-bold"><%= stats.total_views.toLocaleString() %></span> Views</span>
                    </div>
                </div>
            </div>
