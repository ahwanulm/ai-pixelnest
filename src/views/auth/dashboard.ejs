            document.getElementById('paymentInstructionsStep').innerHTML = html;
        }

        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                alert('✅ Kode pembayaran berhasil dicopy!');
            }).catch(() => {
                alert('Gagal copy. Silakan copy manual.');
            });
        }

        // Load credit price on page load
        loadCreditPrice();
    </script>
    
