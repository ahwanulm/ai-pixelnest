                        <!-- 200 Credits -->
                        <button onclick="selectCredits(200)" class="credit-btn group relative px-2 py-3 bg-white/5 hover:bg-white/10 border-2 border-white/10 hover:border-yellow-500 rounded-lg transition-all duration-300 hover:scale-105">
                            <div class="flex flex-col items-center gap-1">
                                <span class="text-xl font-bold text-white">200</span>
                                <span class="text-[10px] text-gray-400">Credits</span>
                                <span class="text-xs font-semibold text-yellow-400" id="price-200">Rp 400K</span>
                            </div>
                            <div class="absolute inset-0 bg-gradient-to-br from-yellow-500/0 to-yellow-600/0 group-hover:from-yellow-500/10 group-hover:to-yellow-600/10 rounded-lg transition-all duration-300"></div>
                        </button>
                        
                        <!-- Custom Amount Button -->
                        <button onclick="focusCustomInput()" class="credit-btn group relative px-2 py-3 bg-gradient-to-br from-blue-500/10 to-cyan-500/10 hover:bg-white/10 border-2 border-blue-500/30 hover:border-blue-500 rounded-lg transition-all duration-300 hover:scale-105">
                            <div class="flex flex-col items-center gap-1">
                                <span class="text-xl font-bold text-white">+</span>
                                <span class="text-[10px] text-gray-400">Custom</span>
                                <span class="text-xs font-semibold text-blue-400">Lainnya</span>
                            </div>
                            <div class="absolute inset-0 bg-gradient-to-br from-blue-500/0 to-cyan-500/0 group-hover:from-blue-500/10 group-hover:to-cyan-500/10 rounded-lg transition-all duration-300"></div>
                        </button>
                    </div>
                </div>

                <!-- Custom Input -->
                <div>
                    <label class="block text-xs font-medium text-gray-300 mb-1.5">Atau Masukkan Jumlah Custom</label>
                    <div class="relative">
                        <input 
                            type="number" 
                            id="customCredits" 
                            min="1"
                            step="1"
                            placeholder="Minimal 1 credit"
                            class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-sm placeholder-gray-500 focus:border-yellow-500 focus:outline-none focus:ring-1 focus:ring-yellow-500/20 transition-all"
                            oninput="calculatePrice()"
                        >
                        <div class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 text-xs font-medium">
                            Credits
                        </div>
                    </div>
                </div>

                <!-- Promo Code Input (Compact) -->
                <div class="bg-white/5 border border-white/10 rounded-lg p-2.5">
                    <div class="flex items-center gap-1.5 mb-1.5">
                        <i class="fas fa-tag text-blue-400 text-xs"></i>
                        <label class="text-xs font-medium text-gray-300">Punya Kode Promo?</label>
                    </div>
                    <div class="flex gap-2">
                        <input 
                            type="text" 
                            id="promoCode" 
                            placeholder="Kode promo"
                            class="flex-1 px-2 py-1.5 bg-white/5 border border-white/10 rounded text-white text-xs placeholder-gray-500 focus:border-blue-500 focus:outline-none uppercase"
                            oninput="this.value = this.value.toUpperCase()"
                        >
                        <button 
                            id="applyPromoBtn"
                            onclick="applyPromoCode()" 
                            class="px-3 py-1.5 bg-blue-500 hover:bg-blue-600 text-white text-xs rounded transition-all font-medium whitespace-nowrap disabled:opacity-50"
                        >
                            Terapkan
                        </button>
                    </div>
                    <div id="promoMessage" class="mt-1.5 text-xs hidden"></div>
                </div>

                <!-- Price Summary -->
                <div id="priceSummary" class="p-3 bg-gradient-to-r from-blue-500/10 to-cyan-600/10 border border-blue-500/20 rounded-lg hidden">
                    <div class="space-y-1.5">
                        <div class="flex justify-between text-xs">
                            <span class="text-gray-400">Jumlah Credits:</span>
                            <span class="text-white font-semibold" id="summaryCredits">0</span>
                        </div>
                        <div class="flex justify-between text-xs">
                            <span class="text-gray-400">Harga per Credit:</span>
                            <span class="text-white font-semibold" id="summaryPricePerCredit">Rp 2.000</span>
                        </div>
                        <div class="h-px bg-white/10 my-1.5"></div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-300 font-medium text-sm">Total Pembayaran:</span>
                            <span class="text-xl font-bold text-yellow-400" id="summaryTotal">Rp 0</span>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="flex gap-2 pt-3 border-t border-white/10">
                    <button 
                        onclick="closeTopUpModal()" 
                        class="flex-1 px-3 py-2 bg-white/5 hover:bg-white/10 border border-white/10 text-white text-sm rounded-lg transition-all duration-300 font-medium"
                    >
                        Batal
                    </button>
                    <button 
                        id="proceedPaymentBtn"
                        onclick="showPaymentMethodsStep()" 
                        class="flex-1 px-3 py-2 bg-gradient-to-r from-yellow-500 to-yellow-600 hover:from-yellow-400 hover:to-yellow-500 text-black text-sm rounded-lg transition-all duration-300 font-bold shadow-lg shadow-yellow-500/20 hover:shadow-yellow-500/40 disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled
                    >
                        Lanjutkan
                    </button>
                </div>
            </div>

            <!-- Modal Body - Step 2: Payment Methods -->
            <div id="paymentMethodsStep" class="p-4 sm:p-6 space-y-4 sm:space-y-6 hidden">
                <!-- Summary Box -->
                <div class="relative overflow-hidden rounded-xl border border-yellow-500/30 bg-gradient-to-r from-yellow-500/10 via-yellow-600/10 to-orange-500/10 p-5">
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-yellow-500/5 to-transparent animate-shimmer"></div>
                    <div class="relative z-10">
                        <p class="text-xs font-semibold text-yellow-400 mb-3 flex items-center gap-2">
                            <i class="fas fa-shopping-cart"></i>
                            RINGKASAN PEMBAYARAN
                        </p>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="p-3 bg-black/20 rounded-lg">
                                <p class="text-xs text-gray-400 mb-1">Credits</p>
                                <p class="text-2xl font-bold text-yellow-400 font-mono" id="selectedCreditsDisplay">0</p>
                            </div>
                            <div class="p-3 bg-black/20 rounded-lg">
                                <p class="text-xs text-gray-400 mb-1">Total Bayar</p>
                                <p class="text-2xl font-bold text-white" id="selectedAmountDisplay">Rp 0</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Payment Methods Header -->
                <div class="border-t border-white/10 pt-4">
                    <h3 class="text-base font-bold text-white mb-1 flex items-center gap-2">
                        <i class="fas fa-credit-card text-yellow-400"></i>
                        Pilih Metode Pembayaran
                    </h3>
                    <p class="text-xs text-gray-400 mb-4">Pilih metode pembayaran yang Anda inginkan</p>
                    
                    <div id="paymentChannelsContainer" class="space-y-4">
                        <!-- Loading -->
                        <div class="text-center py-12">
                            <div class="w-12 h-12 border-4 border-white/10 border-t-yellow-500 rounded-full animate-spin mx-auto mb-4"></div>
                            <p class="text-gray-300 text-sm font-medium">Memuat metode pembayaran...</p>
                            <p class="text-gray-500 text-xs mt-1">Mohon tunggu sebentar</p>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="flex gap-3 pt-6 border-t border-white/10">
                    <button 
                        onclick="showCreditsStep()" 
                        class="flex-1 px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl transition-all duration-300 font-medium"
                    >
                        <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                        Kembali
                    </button>
                    <button 
                        id="confirmPaymentBtn"
                        onclick="createPayment()" 
                        class="flex-1 px-4 py-3 bg-gradient-to-r from-yellow-500 to-yellow-600 hover:from-yellow-400 hover:to-yellow-500 text-black rounded-xl transition-all duration-300 font-bold shadow-lg shadow-yellow-500/20 hover:shadow-yellow-500/40 disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled
                    >
                        <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Konfirmasi Pembayaran
                    </button>
                </div>
            </div>

            <!-- Modal Body - Step 3: Payment Instructions -->
            <div id="paymentInstructionsStep" class="p-4 sm:p-6 space-y-4 sm:space-y-6 hidden">
                <!-- Will be filled dynamically -->
            </div>
        </div>
    </div>

    <!-- Loading Card Animations -->
    <link rel="stylesheet" href="/css/loading-card-animation.css?v=<%= appVersion %>">
    <link rel="stylesheet" href="/css/auto-prompt-animations.css?v=<%= appVersion %>">
    
    <script src="/js/dashboard.js?v=<%= appVersion %>"></script>
    <script src="/js/model-cards-handler.js?v=<%= appVersion %>"></script>
    <script src="/js/generation-loading-card.js?v=<%= appVersion %>"></script>
    <script src="/js/generation-detail-modal.js?v=<%= appVersion %>"></script>
    <script src="/js/models-loader.js?v=<%= appVersion %>"></script>
    <script src="/js/dashboard-audio.js?v=<%= appVersion %>"></script>
    <script src="/js/smart-prompt-handler.js?v=<%= appVersion %>"></script>
    <script src="/js/auto-prompt.js?v=<%= appVersion %>"></script>
    <!-- ✨ NEW: Queue Client for non-blocking generation -->
    <script src="/js/queueClient.js?v=<%= appVersion %>"></script>
    <script>
        // Initialize queue client globally
        window.queueClient = new QueueClient({
            useSSE: true,  // Use Server-Sent Events for real-time updates
            pollingInterval: 2000  // Fallback polling every 2 seconds
        });
        console.log('✅ Queue client initialized');
    </script>
    <script src="/js/dashboard-generation.js?v=<%= appVersion %>"></script>
    <script>
        // ============================================
        // Payment Modal and Dashboard Functions
        // ============================================
        
        // Global variables
        let selectedCreditsAmount = 0;
        let creditPriceIDR = 2000;
        let selectedPaymentMethod = null;
        let appliedPromo = null;
        
        // Load credit price from API
        async function loadCreditPrice() {
            try {
                const response = await fetch('/api/payment/credit-price');
                const data = await response.json();
                
                if (data.success) {
                    creditPriceIDR = parseInt(data.price);
                    console.log('💰 Credit price loaded:', creditPriceIDR);
                    
                    // Update quick select button prices
                    updatePriceDisplay();
                }
            } catch (error) {
                console.error('Error loading credit price:', error);
                // Use default if fails
                creditPriceIDR = 2000;
            }
        }

        // Update price display for quick buttons
        function updatePriceDisplay() {
            // Format price in K format for compact display
            const formatPrice = (amount) => {
                const price = amount * creditPriceIDR;
                if (price >= 1000000) {
                    return `Rp ${(price / 1000000).toFixed(price % 1000000 === 0 ? 0 : 1)}M`;
                } else if (price >= 1000) {
                    return `Rp ${(price / 1000).toFixed(price % 1000 === 0 ? 0 : 0)}K`;
                }
                return `Rp ${price.toLocaleString('id-ID')}`;
            };
            
            document.getElementById('price-10').textContent = formatPrice(10);
            document.getElementById('price-20').textContent = formatPrice(20);
            document.getElementById('price-50').textContent = formatPrice(50);
            document.getElementById('price-100').textContent = formatPrice(100);
            document.getElementById('price-200').textContent = formatPrice(200);
            document.getElementById('summaryPricePerCredit').textContent = `Rp ${creditPriceIDR.toLocaleString('id-ID')}`;
        }
        
        // Focus custom input
        function focusCustomInput() {
            document.getElementById('customCredits').focus();
            document.getElementById('customCredits').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        // Open modal
        async function openTopUpModal() {
            console.log('🔍 Checking pending transactions...');
            
            // Check pending transactions first
            try {
                const response = await fetch('/api/payment/check-pending');
                console.log('📡 Response status:', response.status);
                
                if (!response.ok) {
                    console.error('❌ API error:', response.status, response.statusText);
                    throw new Error(`API returned ${response.status}`);
                }
                
                const data = await response.json();
                console.log('📊 Pending data:', data);
                
                if (!data.can_create_new) {
                    console.log('⛔ User blocked - showing warning');
                    // Show warning notification
                    showPendingWarning(data);
                    return;
                }
                
                // Show info if there are pending transactions (but less than 3)
                if (data.pending_count > 0) {
                    console.log('ℹ️ User has pending, showing info:', data.pending_count);
                    showPendingInfo(data);
                }
            } catch (error) {
                console.error('❌ Error checking pending transactions:', error);
                // Continue to open modal even if check fails
            }
            
            console.log('✅ Opening top-up modal');
            document.getElementById('topUpModal').classList.remove('hidden');
            document.getElementById('topUpModal').classList.add('flex');
            loadCreditPrice();
        }

        // Show pending warning (blocked from creating new transaction)
        function showPendingWarning(data) {
            const { pending_count, time_remaining, transactions } = data;
            
            // Create transaction list HTML
            let transactionListHTML = '';
            if (transactions && transactions.length > 0) {
                transactionListHTML = `
                    <div class="mt-3 space-y-2">
                        <p class="text-sm font-medium text-gray-300">Transaksi Pending:</p>
                        ${transactions.slice(0, 3).map(tx => `
                            <div class="bg-white/5 rounded-lg p-3 border border-red-500/20">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <p class="text-sm font-semibold text-white">${tx.credits_amount} Credits</p>
                                        <p class="text-xs text-gray-400">${tx.payment_method}</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-sm font-bold text-yellow-400">Rp ${parseInt(tx.amount).toLocaleString('id-ID')}</p>
                                        <p class="text-xs text-gray-400">Exp: ${new Date(tx.expired_time).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' })}</p>
                                    </div>
                                </div>
                            </div>
                        `).join('')}
                    </div>
                `;
            }
            
            // Show warning modal
            const warningHTML = `
                <div class="fixed inset-0 bg-black/70 backdrop-blur-sm z-[60] flex items-center justify-center p-4" id="pendingWarningModal">
                    <div class="bg-gradient-to-br from-zinc-900 to-zinc-950 rounded-2xl shadow-2xl w-full max-w-md border border-red-500/30 transform transition-all">
                        <div class="p-6">
                            <!-- Warning Icon -->
                            <div class="flex justify-center mb-4">
                                <div class="w-16 h-16 bg-red-500/20 rounded-full flex items-center justify-center">
                                    <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                    </svg>
                                </div>
                            </div>
                            
                            <!-- Title -->
                            <h3 class="text-xl font-bold text-white text-center mb-2">
                                Transaksi Pending Maksimal
                            </h3>
                            
                            <!-- Message -->
                            <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 mb-4">
                                <p class="text-sm text-gray-300 text-center leading-relaxed">
                                    Anda memiliki <span class="font-bold text-red-400">${pending_count} transaksi</span> yang belum dibayar.
                                </p>
                                <p class="text-xs text-gray-400 text-center mt-2">
                                    Silakan selesaikan pembayaran atau tunggu hingga transaksi kadaluarsa
                                    ${time_remaining ? `(sekitar <span class="font-semibold text-yellow-400">${time_remaining}</span> lagi)` : ''}
                                </p>
                            </div>
                            
                            ${transactionListHTML}
                            
                            <!-- Actions -->
                            <div class="flex gap-3 mt-6">
                                <button onclick="closePendingWarning()" class="flex-1 px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl transition-all font-medium">
                                    Tutup
                                </button>
                                <a href="/billing" class="flex-1 px-4 py-3 bg-gradient-to-r from-red-500 to-red-600 hover:from-red-400 hover:to-red-500 text-white rounded-xl transition-all font-bold text-center shadow-lg shadow-red-500/20">
                                    Lihat Transaksi
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            // Remove existing warning if any
            const existingWarning = document.getElementById('pendingWarningModal');
            if (existingWarning) existingWarning.remove();
            
            // Add to body
            document.body.insertAdjacentHTML('beforeend', warningHTML);
        }
        
        // Close pending warning
        function closePendingWarning() {
            const modal = document.getElementById('pendingWarningModal');
            if (modal) modal.remove();
        }
        
        // Show pending info (has pending but can still create new)
        function showPendingInfo(data) {
            const { pending_count, time_remaining } = data;
            
            // Show toast notification
            const toastHTML = `
                <div class="fixed top-20 right-4 bg-gradient-to-r from-yellow-500 to-yellow-600 text-black rounded-xl shadow-2xl p-4 z-50 transform transition-all animate-slide-in-right max-w-sm" id="pendingInfoToast">
                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0">
                            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="font-bold text-sm">Info Transaksi</p>
                            <p class="text-xs mt-1">Anda memiliki ${pending_count} transaksi pending. Batas maksimal 3 transaksi.</p>
                        </div>
                        <button onclick="document.getElementById('pendingInfoToast').remove()" class="flex-shrink-0 text-black hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            `;
            
            // Remove existing toast if any
            const existingToast = document.getElementById('pendingInfoToast');
            if (existingToast) existingToast.remove();
            
            // Add to body
            document.body.insertAdjacentHTML('beforeend', toastHTML);
            
            // Auto remove after 5 seconds
            setTimeout(() => {
                const toast = document.getElementById('pendingInfoToast');
                if (toast) {
                    toast.style.transform = 'translateX(400px)';
                    toast.style.opacity = '0';
                    setTimeout(() => toast.remove(), 300);
                }
            }, 5000);
        }

        // Close modal
        function closeTopUpModal() {
            document.getElementById('topUpModal').classList.add('hidden');
            document.getElementById('topUpModal').classList.remove('flex');
            resetForm();
        }

        // Close on backdrop click
        function closeTopUpModalOnBackdrop(event) {
            if (event.target.id === 'topUpModal') {
                closeTopUpModal();
            }
        }

        // Select credits (quick buttons)
        function selectCredits(amount) {
            // Remove previous selection
            document.querySelectorAll('.credit-btn').forEach(btn => {
                btn.classList.remove('border-yellow-500', 'bg-yellow-500/10');
                btn.classList.add('border-white/10');
            });

            // Add selection to clicked button
            event.currentTarget.classList.add('border-yellow-500', 'bg-yellow-500/10');
            event.currentTarget.classList.remove('border-white/10');

            // Clear custom input
            document.getElementById('customCredits').value = '';

            // Set selected amount
            selectedCreditsAmount = amount;

            // Update summary
            updateSummary();
        }

        // Calculate price for custom input
        function calculatePrice() {
            const customInput = document.getElementById('customCredits');
            const amount = parseInt(customInput.value) || 0;

            // Remove selection from quick buttons
            document.querySelectorAll('.credit-btn').forEach(btn => {
                btn.classList.remove('border-yellow-500', 'bg-yellow-500/10');
                btn.classList.add('border-white/10');
            });

            // Set selected amount
            selectedCreditsAmount = amount;

            // Update summary
            updateSummary();
        }

        // Apply promo code
        function applyPromoCode() {
            const promoInput = document.getElementById('promoCode');
            const promoCode = promoInput.value.trim();
            const promoMessage = document.getElementById('promoMessage');
            const applyBtn = document.getElementById('applyPromoBtn');

            if (!promoCode) {
                showPromoMessage('❌ Masukkan kode promo', 'error');
                return;
            }

            // Check if credits selected
            if (!selectedCreditsAmount || selectedCreditsAmount < 1) {
                showPromoMessage('❌ Pilih jumlah credits terlebih dahulu (minimal 1 credit)', 'error');
                return;
            }

            const amount = selectedCreditsAmount * creditPriceIDR;

            // Disable button while processing
            applyBtn.disabled = true;
            applyBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            console.log('Validating promo:', { code: promoCode, amount }); // Debug log

            fetch('/api/payment/validate-promo', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    code: promoCode,
                    amount: amount
                })
            })
            .then(response => {
                console.log('Response status:', response.status); // Debug log
                return response.json();
            })
            .then(data => {
                console.log('Response data:', data); // Debug log
                
                if (data.success) {
                    appliedPromo = {
                        code: promoCode,
                        type: data.promo.type,
                        value: data.promo.value
                    };
                    showPromoMessage(`✅ ${promoCode} diterapkan!`, 'success');
                    promoInput.disabled = true;
                    applyBtn.textContent = 'Hapus';
                    applyBtn.onclick = function() { removePromoCode(); };
                    applyBtn.className = 'px-3 sm:px-4 py-2 bg-red-500/80 hover:bg-red-600 text-white text-xs sm:text-sm rounded-lg transition-all font-medium whitespace-nowrap';
                    applyBtn.disabled = false;
                    
                    updateSummary();
                } else {
                    showPromoMessage(data.message || '❌ Kode tidak valid', 'error');
                    applyBtn.disabled = false;
                    applyBtn.textContent = 'Terapkan';
                }
            })
            .catch(error => {
                console.error('Error validating promo:', error);
                showPromoMessage('❌ Terjadi kesalahan', 'error');
                applyBtn.disabled = false;
                applyBtn.textContent = 'Terapkan';
            });
        }

        // Remove promo code
        function removePromoCode() {
            appliedPromo = null;
            const promoInput = document.getElementById('promoCode');
            const applyBtn = document.getElementById('applyPromoBtn');
            
            promoInput.value = '';
            promoInput.disabled = false;
            applyBtn.textContent = 'Terapkan';
            applyBtn.onclick = function() { applyPromoCode(); };
            applyBtn.className = 'px-3 sm:px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white text-xs sm:text-sm rounded-lg transition-all font-medium whitespace-nowrap disabled:opacity-50';
            
            document.getElementById('promoMessage').classList.add('hidden');
            updateSummary();
        }

        // Show promo message
        function showPromoMessage(message, type) {
            const promoMessage = document.getElementById('promoMessage');
            const colors = {
                success: 'text-green-400',
                error: 'text-red-400',
                info: 'text-blue-400'
            };
            
            promoMessage.className = `mt-2 text-xs ${colors[type] || colors.info}`;
            promoMessage.textContent = message;
            promoMessage.classList.remove('hidden');
        }

        // Update summary display
        function updateSummary() {
            const summary = document.getElementById('priceSummary');
            const btn = document.getElementById('proceedPaymentBtn');

            if (selectedCreditsAmount >= 1) {
                let total = selectedCreditsAmount * creditPriceIDR;
                let discount = 0;

                // Apply promo discount if available
                if (appliedPromo) {
                    if (appliedPromo.type === 'percentage') {
                        discount = total * (appliedPromo.value / 100);
                    } else if (appliedPromo.type === 'fixed') {
                        discount = appliedPromo.value;
                    }
                    total = Math.max(0, total - discount);
                }

                document.getElementById('summaryCredits').textContent = `${selectedCreditsAmount} Credit${selectedCreditsAmount > 1 ? 's' : ''}`;
                
                // Show discount if applied
                const summaryContainer = document.querySelector('#priceSummary .space-y-1\\.5');
                if (summaryContainer) {
                    const existingDiscount = summaryContainer.querySelector('.promo-discount-row');
                    if (existingDiscount) {
                        existingDiscount.remove();
                    }
                }

                if (appliedPromo && discount > 0 && summaryContainer) {
                    const originalTotal = selectedCreditsAmount * creditPriceIDR;
                    const discountRow = document.createElement('div');
                    discountRow.className = 'promo-discount-row';
                    discountRow.innerHTML = `
                        <div class="flex justify-between text-xs">
                            <span class="text-gray-400">Harga Awal:</span>
                            <span class="text-white font-semibold">Rp ${originalTotal.toLocaleString('id-ID')}</span>
                        </div>
                        <div class="flex justify-between text-xs">
                            <span class="text-blue-400">
                                <i class="fas fa-tag mr-1"></i>
                                Diskon (${appliedPromo.code}):
                            </span>
                            <span class="text-blue-400 font-semibold">-Rp ${discount.toLocaleString('id-ID')}</span>
                        </div>
                    `;
                    const separator = summaryContainer.querySelector('.h-px');
                    if (separator) {
                        separator.insertAdjacentElement('beforebegin', discountRow);
                    }
                }

                document.getElementById('summaryTotal').textContent = `Rp ${total.toLocaleString('id-ID')}`;

                summary.classList.remove('hidden');
                btn.disabled = false;
            } else {
                summary.classList.add('hidden');
                btn.disabled = true;
            }
        }

        // Reset form
        function resetForm() {
            selectedCreditsAmount = 0;
            selectedPaymentMethod = null;
            appliedPromo = null;
            
            document.getElementById('customCredits').value = '';
            
            // Reset promo code
            const promoInput = document.getElementById('promoCode');
            const applyBtn = document.getElementById('applyPromoBtn');
            promoInput.value = '';
            promoInput.disabled = false;
            applyBtn.textContent = 'Terapkan';
            applyBtn.onclick = function() { applyPromoCode(); };
            applyBtn.className = 'px-3 sm:px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white text-xs sm:text-sm rounded-lg transition-all font-medium whitespace-nowrap disabled:opacity-50';
            document.getElementById('promoMessage').classList.add('hidden');
            
            document.querySelectorAll('.credit-btn').forEach(btn => {
                btn.classList.remove('border-yellow-500', 'bg-yellow-500/10');
                btn.classList.add('border-white/10');
            });
            document.getElementById('priceSummary').classList.add('hidden');
            document.getElementById('proceedPaymentBtn').disabled = true;
            document.getElementById('confirmPaymentBtn').disabled = true;
            
            // Reset to step 1
            showCreditsStep();
        }

        // Step navigation
        function showPaymentMethodsStep() {
            if (selectedCreditsAmount < 1) {
                alert('Minimal 1 credit');
                return;
            }

            // Calculate final amount with promo if applied
            let finalAmount = selectedCreditsAmount * creditPriceIDR;
            if (appliedPromo) {
                let discount = 0;
                if (appliedPromo.type === 'percentage') {
                    discount = finalAmount * (appliedPromo.value / 100);
                } else if (appliedPromo.type === 'fixed') {
                    discount = appliedPromo.value;
                }
                finalAmount = Math.max(0, finalAmount - discount);
            }

            // Update display
            document.getElementById('selectedCreditsDisplay').textContent = `${selectedCreditsAmount} Credit${selectedCreditsAmount > 1 ? 's' : ''}`;
            document.getElementById('selectedAmountDisplay').textContent = `Rp ${finalAmount.toLocaleString('id-ID')}`;

            // Hide ALL other steps first
            document.getElementById('creditsStep').classList.add('hidden');
            document.getElementById('paymentInstructionsStep').classList.add('hidden');
            
            // Then show step 2
            document.getElementById('paymentMethodsStep').classList.remove('hidden');
            
            // Update header
            document.getElementById('modalTitle').textContent = 'Metode Pembayaran';
            document.getElementById('modalSubtitle').textContent = 'Pilih metode pembayaran Anda';
            
            // Scroll to top
            document.querySelector('#paymentMethodsStep').scrollIntoView({ behavior: 'smooth', block: 'start' });
            
            // Load payment channels
            loadPaymentChannels();
        }

        function showCreditsStep() {
            // Show step 1, hide others
            document.getElementById('creditsStep').classList.remove('hidden');
            document.getElementById('paymentMethodsStep').classList.add('hidden');
            document.getElementById('paymentInstructionsStep').classList.add('hidden');
            
            // Update header
            document.getElementById('modalTitle').textContent = 'Top Up Credits';
            document.getElementById('modalSubtitle').textContent = 'Pilih atau masukkan jumlah credits';
        }

