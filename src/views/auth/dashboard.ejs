            margin-bottom: 12px;
        }
        
        .notification-empty p {
            color: #6b7280;
            font-size: 13px;
        }
    </style>
    
    <script>
        // Notification System
        let notifications = [];
        let unreadCount = 0;
        
        // Initialize
        async function initNotifications() {
            await fetchNotifications();
            setInterval(fetchNotifications, 60000); // Refresh every 60s
        }
        
        // Fetch notifications
        async function fetchNotifications() {
            try {
                const response = await fetch('/api/user/notifications');
                const data = await response.json();
                
                if (data.success) {
                    notifications = data.notifications;
                    unreadCount = data.unread_count;
                    updateNotificationBadge();
                    renderNotifications();
                }
            } catch (error) {
                console.error('Error fetching notifications:', error);
            }
        }
        
        // Update badge
        function updateNotificationBadge() {
            const badge = document.getElementById('notification-badge');
            const count = document.getElementById('notification-count');
            
            if (badge && count) {
                if (unreadCount > 0) {
                    badge.classList.remove('hidden');
                    count.textContent = unreadCount > 99 ? '99+' : unreadCount;
                } else {
                    badge.classList.add('hidden');
                }
            }
        }
        
        // Toggle panel
        function toggleNotificationPanel() {
            const panel = document.getElementById('notification-panel');
            panel.classList.toggle('hidden');
            
            if (!panel.classList.contains('hidden') && unreadCount > 0) {
                setTimeout(markAllAsRead, 2000);
            }
        }
        
        // Close when clicking outside
        document.addEventListener('click', (e) => {
            const panel = document.getElementById('notification-panel');
            const button = document.getElementById('notification-button');
            
            if (panel && button && !panel.contains(e.target) && !button.contains(e.target)) {
                panel.classList.add('hidden');
            }
        });
        
        // Render notifications
        function renderNotifications() {
            const container = document.getElementById('notification-list');
            
            if (!container) return;
            
            if (notifications.length === 0) {
                container.innerHTML = `
                    <div class="notification-empty">
                        <i class="fas fa-bell-slash"></i>
                        <p>No notifications</p>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = notifications.map(notif => {
                const icon = getNotificationIcon(notif.type);
                const timeAgo = getTimeAgo(new Date(notif.created_at));
                
                return `
                    <div class="notification-item ${notif.is_read ? 'read' : 'unread'}" 
                         onclick="handleNotificationClick(${notif.id}, '${notif.action_url || ''}')">
                        <div class="notification-icon ${notif.type}">
                            <i class="${icon}"></i>
                        </div>
                        <div class="notification-content" style="flex: 1;">
                            <h4>${notif.title}</h4>
                            <p>${notif.message}</p>
                            <span class="notification-time">${timeAgo}</span>
                        </div>
                        ${!notif.is_read ? '<div class="notification-unread-dot"></div>' : ''}
                    </div>
                `;
            }).join('');
        }
        
        // Get icon
        function getNotificationIcon(type) {
            const icons = {
                info: 'fas fa-info-circle',
                success: 'fas fa-check-circle',
                warning: 'fas fa-exclamation-triangle',
                error: 'fas fa-times-circle'
            };
            return icons[type] || icons.info;
        }
        
        // Get time ago
        function getTimeAgo(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            const intervals = {
                year: 31536000, month: 2592000, week: 604800,
                day: 86400, hour: 3600, minute: 60, second: 1
            };
            
            for (const [unit, secondsInUnit] of Object.entries(intervals)) {
                const interval = Math.floor(seconds / secondsInUnit);
                if (interval >= 1) {
                    return interval === 1 ? `1 ${unit} ago` : `${interval} ${unit}s ago`;
                }
            }
            return 'Just now';
        }
        
        // Handle click
        async function handleNotificationClick(notificationId, actionUrl) {
            try {
                await fetch(`/api/user/notifications/${notificationId}/read`, {
                    method: 'PUT'
                });
                
                const notif = notifications.find(n => n.id === notificationId);
                if (notif && !notif.is_read) {
                    notif.is_read = true;
                    unreadCount = Math.max(0, unreadCount - 1);
                    updateNotificationBadge();
                    renderNotifications();
                }
                
                if (actionUrl && actionUrl !== 'null' && actionUrl !== '') {
                    window.location.href = actionUrl;
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }
        
        // Mark all as read
        async function markAllAsRead() {
            if (unreadCount === 0) return;
            
            try {
                await fetch('/api/user/notifications/read-all', {
                    method: 'PUT'
                });
                
                notifications.forEach(n => n.is_read = true);
                unreadCount = 0;
                updateNotificationBadge();
                renderNotifications();
            } catch (error) {
                console.error('Error:', error);
            }
        }
        
        // Initialize notifications
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initNotifications);
        } else {
            initNotifications();
        }
        
        // Auto-open notification panel from mobile hash
        function checkAndOpenNotifications() {
            const hash = window.location.hash;
            console.log('Current hash:', hash);
            
            if (hash === '#open-notifications') {
                console.log('📱 Mobile notification trigger detected!');
                
                const panel = document.getElementById('notification-panel');
                const button = document.getElementById('notification-button');
                
                if (panel) {
                    // Remove hidden class
                    panel.classList.remove('hidden');
                    
                    // MOBILE FIX: Move panel to body to escape parent containers
                    if (window.innerWidth < 1024) {
                        // Check if already moved
                        if (!panel.hasAttribute('data-moved-to-body')) {
                            // Move to body
                            document.body.appendChild(panel);
                            panel.setAttribute('data-moved-to-body', 'true');
                            console.log('🔄 Panel moved to body for mobile');
                            
                            // Add close button for mobile
                            const closeBtn = document.createElement('button');
                            closeBtn.innerHTML = `
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            `;
                            closeBtn.className = 'absolute top-2.5 right-2.5 w-9 h-9 flex items-center justify-center rounded-lg bg-zinc-800/80 hover:bg-zinc-700 border border-white/10 text-gray-400 hover:text-white transition-all z-50 backdrop-blur-sm';
                            closeBtn.style.cssText = 'box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);';
                            closeBtn.onclick = function() {
                                panel.classList.add('hidden');
                                const backdrop = document.getElementById('mobile-notif-backdrop');
                                if (backdrop) backdrop.remove();
                            };
                            panel.insertBefore(closeBtn, panel.firstChild);
                            
                            // Add backdrop with theme styling
                            let backdrop = document.getElementById('mobile-notif-backdrop');
                            if (!backdrop) {
                                backdrop = document.createElement('div');
                                backdrop.id = 'mobile-notif-backdrop';
                                backdrop.style.cssText = `
                                    position: fixed;
                                    top: 0;
                                    left: 0;
                                    right: 0;
                                    bottom: 0;
                                    background: rgba(0, 0, 0, 0.6);
                                    backdrop-filter: blur(4px);
                                    z-index: 9998;
                                    animation: fadeIn 0.2s ease-out;
                                `;
                                backdrop.onclick = function() {
                                    panel.classList.add('hidden');
                                    this.remove();
                                };
                                document.body.appendChild(backdrop);
                            }
                        }
                    }
                    
                    // Scroll to top for better visibility
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                    
                    // Debug logging
                    console.log('✅ Notification panel opened');
                    console.log('Panel element:', panel);
                    console.log('Panel parent:', panel.parentElement);
                    console.log('Panel classes:', panel.className);
                    console.log('Panel computed display:', window.getComputedStyle(panel).display);
                    console.log('Panel computed position:', window.getComputedStyle(panel).position);
                    console.log('Panel computed zIndex:', window.getComputedStyle(panel).zIndex);
                    console.log('Window width:', window.innerWidth, 'Mobile:', window.innerWidth < 1024);
                    
                    // Auto mark as read after 2s
                    if (typeof unreadCount !== 'undefined' && unreadCount > 0) {
                        setTimeout(function() {
                            if (typeof markAllAsRead === 'function') {
                                markAllAsRead();
                            }
                        }, 2000);
                    }
                    
                    // Remove hash from URL (clean)
                    setTimeout(function() {
                        history.replaceState(null, null, ' ');
                    }, 100);
                } else {
                    console.error('❌ Panel or button not found!');
                    console.log('Retrying in 500ms...');
                    setTimeout(checkAndOpenNotifications, 500);
                }
            }
        }
        
        // Check on page load
        window.addEventListener('load', function() {
            setTimeout(checkAndOpenNotifications, 300);
        });
        
        // Also check on hash change
        window.addEventListener('hashchange', checkAndOpenNotifications);
        
        // ============================================
        // CUSTOM DROPDOWNS
        // ============================================
        
        // ✅ Image Type Dropdown handler moved to /js/dashboard.js
        // to avoid duplication and better code organization
        
        document.addEventListener('DOMContentLoaded', function() {
            // Model Cards Enhancement
            const modelSearch = document.getElementById('image-model-search');
            const clearSearchBtn = document.getElementById('clear-search');
            const modelCardsContainer = document.getElementById('image-model-cards');
            
            // Clear search
            modelSearch?.addEventListener('input', function(e) {
                if (e.target.value) {
                    clearSearchBtn?.classList.remove('hidden');
                } else {
                    clearSearchBtn?.classList.add('hidden');
                }
            });
            
            clearSearchBtn?.addEventListener('click', function() {
                modelSearch.value = '';
                modelSearch.dispatchEvent(new Event('input'));
                clearSearchBtn.classList.add('hidden');
            });
            
            // Video Type Dropdown Handler
            const videoTypeBtn = document.getElementById('video-type-btn');
            const videoTypeDropdown = document.getElementById('video-type-dropdown');
            const videoTypeOptions = document.querySelectorAll('.video-type-option');
            const videoTypeSelect = document.getElementById('video-type');
            
            // Toggle dropdown
            videoTypeBtn?.addEventListener('click', function(e) {
                e.stopPropagation();
                videoTypeDropdown.classList.toggle('hidden');
            });
            
            // Select option
            videoTypeOptions.forEach(option => {
                option.addEventListener('click', function() {
                    const type = this.dataset.type;
                    const desc = this.dataset.desc;
                    const icon = this.querySelector('i').className;
                    
                    // Update selected display
                    const selectedTypeEl = document.getElementById('selected-video-type');
                    const selectedDescEl = document.getElementById('selected-video-type-desc');
                    const iconEl = videoTypeBtn.querySelector('.w-8');
                    
                    selectedTypeEl.textContent = this.querySelector('.text-sm').textContent;
                    selectedTypeEl.classList.remove('text-gray-400');
                    selectedTypeEl.classList.add('text-white');
                    
                    selectedDescEl.textContent = desc;
                    selectedDescEl.classList.remove('text-gray-500');
                    selectedDescEl.classList.add('text-gray-400');
                    
                    iconEl.className = this.querySelector('.w-10').className.replace('w-10', 'w-8');
                    videoTypeBtn.querySelector('.w-8 i').className = icon;
                    
                    // Update hidden select
                    videoTypeSelect.value = type;
                    videoTypeSelect.dispatchEvent(new Event('change'));
                    
                    // Update active state
                    videoTypeOptions.forEach(opt => opt.classList.remove('active'));
                    this.classList.add('active');
                    
                    // Close dropdown
                    videoTypeDropdown.classList.add('hidden');
                });
            });
            
            // Close dropdown on outside click
            document.addEventListener('click', function(e) {
                if (videoTypeDropdown && !videoTypeBtn?.contains(e.target) && !videoTypeDropdown.contains(e.target)) {
                    videoTypeDropdown.classList.add('hidden');
                }
            });
        });
        
        // Enhanced Model Cards Rendering (will be called from models-loader.js)
        window.renderModelCards = function(models, container) {
            if (!models || models.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-8">
                        <i class="fas fa-exclamation-circle text-4xl text-gray-600 mb-3"></i>
                        <p class="text-sm text-gray-400">No models found</p>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = models.map(model => {
                const iconClass = model.type === 'image' ? 'fa-image' : 'fa-video';
                
                // Theme-based gradient colors
                let gradientClass;
                if (model.featured) {
                    // Featured models: Emerald gradient (special but matches theme)
                    gradientClass = 'from-emerald-500 to-cyan-600';
                } else if (model.type === 'image') {
                    // Image models: Violet-Blue gradient (main theme)
                    gradientClass = 'from-blue-500 to-cyan-600';
                } else {
                    // Video models: Fuchsia-Pink gradient (secondary theme)
                    gradientClass = 'from-fuchsia-500 to-pink-600';
                }
                
                return `
                    <button type="button" class="model-card w-full p-4 rounded-xl border border-white/10 hover:border-blue-500/50 bg-white/5 text-left transition-all duration-300 group" 
                            data-model-id="${model.id}"
                            onclick="selectModel('${model.id}', '${model.name}', '${model.description || ''}', ${model.cost_credits || 0})">
                        <div class="flex items-start gap-3">
                            <div class="w-12 h-12 bg-gradient-to-br ${gradientClass} rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                <i class="fas ${iconClass} text-white"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-start justify-between gap-2 mb-1">
                                    <p class="text-sm font-semibold text-white line-clamp-1">${model.name}</p>
                                    ${model.featured ? '<i class="fas fa-star text-emerald-400 text-xs"></i>' : ''}
                                </div>
                                <p class="text-xs text-gray-400 line-clamp-2 mb-2">${model.description || 'AI model for generation'}</p>
                                <div class="flex items-center gap-2 flex-wrap">
                                    ${shouldShowNewBadge(model) ? '<span class="text-xs px-2 py-1 rounded-full bg-gradient-to-r from-yellow-400 to-orange-500 text-black font-bold animate-pulse">✨ NEW</span>' : ''}
                                    <span class="text-xs px-2 py-1 rounded-full bg-blue-500/20 text-blue-300 font-semibold">
                                        ${model.category || 'General'}
                                    </span>
                                    <span class="text-xs px-2 py-1 rounded-full bg-yellow-500/20 text-yellow-300 font-semibold flex items-center gap-1">
                                        <i class="fas fa-coins"></i>
                                        ${model.cost_credits || 0.5}
                                    </span>
                                </div>
                            </div>
                            <i class="fas fa-check text-blue-400 opacity-0 group-hover:opacity-100 transition-opacity"></i>
                        </div>
                    </button>
                `;
            }).join('');
        };
        
        // Select Model Function
        window.selectModel = function(modelId, modelName, modelDesc, cost) {
            // Update hidden select
            const modelSelect = document.getElementById('image-model-select');
            modelSelect.value = modelId;
            modelSelect.dispatchEvent(new Event('change'));
            
            // Show model info
            const modelInfo = document.getElementById('image-model-info');
            document.getElementById('image-model-name').textContent = modelName;
            document.getElementById('image-model-desc').textContent = modelDesc || 'AI model for generation';
            document.getElementById('image-model-cost').querySelector('span').textContent = `${cost} credits`;
            modelInfo.classList.remove('hidden');
            
            // Update selected state
            document.querySelectorAll('.model-card').forEach(card => {
                card.classList.remove('selected');
                card.querySelector('.fa-check').style.opacity = '0';
            });
            
            const selectedCard = document.querySelector(`[data-model-id="${modelId}"]`);
            if (selectedCard) {
                selectedCard.classList.add('selected');
                selectedCard.querySelector('.fa-check').style.opacity = '1';
            }
        };

        // Profile Dropdown Toggle
        const profileBtn = document.getElementById('profile-btn');
        const profileDropdown = document.getElementById('profile-dropdown');
        
        if (profileBtn && profileDropdown) {
            profileBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                
                if (profileDropdown.classList.contains('hidden')) {
                    // Show dropdown
                    profileDropdown.classList.remove('hidden');
                    profileDropdown.style.display = 'block';
                    profileDropdown.style.opacity = '1';
                    profileDropdown.style.visibility = 'visible';
                    profileDropdown.style.pointerEvents = 'auto';
                } else {
                    // Hide dropdown
                    profileDropdown.classList.add('hidden');
                    profileDropdown.style.display = 'none';
                }
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
                    profileDropdown.classList.add('hidden');
                    profileDropdown.style.display = 'none';
                }
            });
        }
        
        // ========================================
        // MOBILE RESULTS VIEW HANDLER
        // ========================================
        const mobileResultsView = document.getElementById('mobile-results-view');
        const mobileResultsClose = document.getElementById('mobile-results-close');
        const mobileViewResultsBtn = document.getElementById('mobile-view-results-btn');
        const mobileBackToCreate = document.getElementById('mobile-back-to-create');
        const mobileResultsDisplay = document.getElementById('mobile-results-display');
        const mobileEmptyState = document.getElementById('mobile-empty-state');
        
        // Open mobile results view
        function openMobileResults() {
            if (mobileResultsView) {
                console.log('📱 Opening mobile results view...');
                
                mobileResultsView.classList.remove('hidden');
                mobileResultsView.classList.add('flex');
                mobileResultsView.style.display = 'flex';
                document.body.style.overflow = 'hidden';
                
                // Hide aside (form) on mobile to prevent conflicts
                const aside = document.querySelector('aside');
                if (aside && window.innerWidth < 1024) {
                    aside.style.display = 'none';
                    console.log('✅ Aside (form) hidden on mobile');
                }
                
                // Hide mobile header to prevent blocking
                const mobileHeader = document.getElementById('mobile-header');
                if (mobileHeader) {
                    mobileHeader.style.display = 'none';
                }
                
                // Ensure mobile navbar stays visible (z-index already set to 10004 in navbar)
                const mobileNavbar = document.getElementById('mobile-navbar');
                if (mobileNavbar) {
                    mobileNavbar.style.display = ''; // Ensure it's visible
                    console.log('✅ Mobile navbar visible');
                }
                
                // Sync results immediately
                syncResultsToMobile();
                console.log('✅ Mobile results view opened');
            } else {
                console.warn('⚠️ Mobile results view element not found');
            }
        }
        
        // Close mobile results view
        function closeMobileResults() {
            if (mobileResultsView) {
                console.log('📱 Closing mobile results view...');
                
                // Hide mobile results view completely
                mobileResultsView.classList.add('hidden');
                mobileResultsView.classList.remove('flex');
                mobileResultsView.style.display = 'none';
                document.body.style.overflow = '';
                
                // Restore mobile header
                const mobileHeader = document.getElementById('mobile-header');
                if (mobileHeader) {
                    mobileHeader.style.display = '';
                }
                
                // Ensure aside (form) is visible on mobile
                const aside = document.querySelector('aside');
                if (aside) {
                    aside.style.display = 'flex';
                    aside.style.visibility = 'visible';
                    aside.style.opacity = '1';
                    aside.style.pointerEvents = 'auto';
                    console.log('✅ Aside (form) is now visible');
                }
                
                // Restore main content visibility (for desktop)
                const mainContent = document.querySelector('main');
                if (mainContent) {
                    mainContent.style.opacity = '1';
                    mainContent.style.pointerEvents = 'auto';
                }
                
                // Navbar z-index is permanently set to 10004, no need to reset
                console.log('✅ Mobile results view closed');
            }
        }
        
        // Sync results from desktop to mobile view
        function syncResultsToMobile() {
            console.log('🔄 Syncing results to mobile view...');
            
            const resultDisplay = document.getElementById('result-display');
            if (!resultDisplay) {
                console.warn('⚠️ Result display element not found');
                return;
            }
            
            // Include both result cards AND loading cards for mobile view
            const allCards = Array.from(resultDisplay.children);
            const resultCards = allCards.filter(card => 
                (card.classList.contains('result-card') || card.classList.contains('loading-card')) && 
                card.style.display !== 'none'
            );
            
            console.log(`📊 Found ${resultCards.length} result cards to sync (including loading cards)`);
            
            if (resultCards.length > 0) {
                if (mobileEmptyState) mobileEmptyState.classList.add('hidden');
                if (mobileResultsDisplay) mobileResultsDisplay.classList.remove('hidden');
                
                // Clone cards to mobile view
                if (mobileResultsDisplay) {
                    mobileResultsDisplay.innerHTML = '';
                    resultCards.forEach((card, index) => {
                        const clonedCard = card.cloneNode(true);
                        mobileResultsDisplay.appendChild(clonedCard);
                        
                        // Handle loading cards - restart animation after cloning
                        if (card.classList.contains('loading-card')) {
                            // Restart the animation for the cloned loading card
                            if (typeof startPixelAnimation === 'function') {
                                startPixelAnimation(clonedCard);
                                console.log(`✅ Restarted animation for loading card ${index + 1}/${resultCards.length}`);
                            }
                        } else {
                            // Only attach event listeners for actual result cards
                            // Re-attach click event listener for detail modal
                            // (cloneNode doesn't copy event listeners)
                            clonedCard.addEventListener('click', (e) => {
                                // Don't open modal if clicking delete or download button
                                if (e.target.closest('button')) return;
                                
                                // Use the cloned card to open modal
                                if (typeof openGenerationDetailModal === 'function') {
                                    openGenerationDetailModal(clonedCard);
                                }
                            });
                            
                            // Re-attach fullscreen button event listeners
                            clonedCard.querySelectorAll('.btn-fullscreen').forEach(btn => {
                                // Remove inline onclick if exists
                                btn.removeAttribute('onclick');
                                
                                btn.addEventListener('click', (e) => {
                                    e.stopPropagation();
                                    e.preventDefault();
                                    const url = btn.getAttribute('data-url');
                                    const prompt = btn.getAttribute('data-prompt');
                                    const model = btn.getAttribute('data-model');
                                    
                                    console.log('🔍 Opening fullscreen viewer:', url);
                                    
                                    if (typeof window.openFullscreenViewer === 'function') {
                                        window.openFullscreenViewer(url, 0, { prompt, model });
                                    } else {
                                        console.error('❌ openFullscreenViewer not available');
                                    }
                                });
                            });
                            
                            // Re-attach share button event listeners
                            clonedCard.querySelectorAll('.btn-share').forEach(btn => {
                                // Remove inline onclick if exists
                                btn.removeAttribute('onclick');
                                
                                btn.addEventListener('click', (e) => {
                                    e.stopPropagation();
                                    e.preventDefault();
                                    
                                    console.log('📤 Opening share modal');
                                    
                                    if (typeof window.openShareModal === 'function') {
                                        window.openShareModal(btn);
                                    } else {
                                        console.error('❌ openShareModal not available');
                                    }
                                });
                            });
                            
                            // Re-attach download button event listeners
                            clonedCard.querySelectorAll('button[onclick*="downloadFile"]').forEach(btn => {
                                const onclickAttr = btn.getAttribute('onclick');
                                btn.removeAttribute('onclick');
                                
                                btn.addEventListener('click', (e) => {
                                    e.stopPropagation();
                                    e.preventDefault();
                                    
                                    // Extract URL from onclick attribute
                                    const match = onclickAttr.match(/downloadFile\('([^']+)',\s*'([^']+)'\)/);
                                    if (match) {
                                        const url = match[1];
                                        const filename = match[2];
                                        console.log('⬇️ Downloading:', filename);
                                        
                                        if (typeof window.downloadFile === 'function') {
                                            window.downloadFile(url, filename);
                                        } else {
                                            // Fallback: direct download
                                            const a = document.createElement('a');
                                            a.href = url;
                                            a.download = filename;
                                            a.click();
                                        }
                                    }
                                });
                            });
                            
                            // Re-attach delete button event listeners
                            clonedCard.querySelectorAll('button[onclick*="handleDeleteCard"]').forEach(btn => {
                                btn.removeAttribute('onclick');
                                
                                btn.addEventListener('click', (e) => {
                                    e.stopPropagation();
                                    e.preventDefault();
                                    
                                    console.log('🗑️ Deleting card');
                                    
                                    if (typeof window.handleDeleteCard === 'function') {
                                        window.handleDeleteCard(btn);
                                    } else {
                                        console.error('❌ handleDeleteCard not available');
                                    }
                                });
                            });
                            
                            console.log(`✅ Synced result card ${index + 1}/${resultCards.length} with all event listeners`);
                        }
                    });
                }
                
                // Update count
                const mobileSubtitle = document.getElementById('mobile-results-subtitle');
                if (mobileSubtitle) {
                    mobileSubtitle.textContent = `${resultCards.length} generation${resultCards.length !== 1 ? 's' : ''}`;
                }
                
                console.log('✅ Mobile view sync complete');
            } else {
                console.log('ℹ️ No results to display, showing empty state');
                if (mobileEmptyState) mobileEmptyState.classList.remove('hidden');
                if (mobileResultsDisplay) mobileResultsDisplay.classList.add('hidden');
            }
        }
        
        // Make functions globally available for mobile navbar and generation scripts
        window.openMobileResults = openMobileResults;
        window.closeMobileResults = closeMobileResults;
        window.syncResultsToMobile = syncResultsToMobile;
        
        // Event listeners for mobile results
        if (mobileResultsClose) {
            console.log('✅ Mobile results close button found, attaching listener');
            mobileResultsClose.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                console.log('🔙 Mobile results close button clicked');
                closeMobileResults();
            });
            
            // Add touch event for better mobile support
            mobileResultsClose.addEventListener('touchend', function(e) {
                e.preventDefault();
                e.stopPropagation();
                console.log('🔙 Mobile results close button touched');
                closeMobileResults();
            }, { passive: false });
        } else {
            console.warn('⚠️ Mobile results close button not found');
        }
        
        if (mobileViewResultsBtn) {
            mobileViewResultsBtn.addEventListener('click', function(e) {
                e.preventDefault();
                openMobileResults();
            });
        }
        
        if (mobileBackToCreate) {
            console.log('✅ Mobile back to create button found, attaching listener');
            
            const handleStartCreating = function(e) {
                e.preventDefault();
                e.stopPropagation();
                console.log('🎨 Start Creating button clicked - navigating to generate form');
                
                // Close the mobile results view first
                closeMobileResults();
                
                // Small delay to ensure smooth transition
                setTimeout(() => {
                    // Click the image tab to ensure it's active
                    const imageTab = document.querySelector('.creation-tab[data-mode="image"]');
                    if (imageTab && !imageTab.classList.contains('active')) {
                        imageTab.click();
                        console.log('✅ Clicked Image tab');
                    }
                    
                    // Ensure the image mode is visible
                    const imageMode = document.getElementById('image-mode');
                    const videoMode = document.getElementById('video-mode');
                    const audioMode = document.getElementById('audio-mode');
                    
                    // Hide other modes
                    if (videoMode) videoMode.classList.remove('active');
                    if (audioMode) audioMode.classList.remove('active');
                    
                    // Show image mode
                    if (imageMode) {
                        imageMode.classList.add('active');
                        console.log('✅ Image mode is now active');
                    }
                    
                    // Scroll to top of page where the form is
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                    
                    // Focus on the image textarea after a short delay
                    setTimeout(() => {
                        const imageTextarea = document.getElementById('image-textarea');
                        if (imageTextarea) {
                            imageTextarea.focus();
                            console.log('✅ Focused on image textarea');
                        }
                    }, 100);
                }, 300);
            };
            
            mobileBackToCreate.addEventListener('click', handleStartCreating);
            
            // Add touch event for better mobile support
            mobileBackToCreate.addEventListener('touchend', handleStartCreating, { passive: false });
        } else {
            console.warn('⚠️ Mobile back to create button not found');
        }
        
        // Handle hash navigation (#results) on mobile
        if (window.location.hash === '#results' && window.innerWidth < 1024) {
            setTimeout(() => openMobileResults(), 500);
        }
        
        // Update mobile results button when results change AND auto-sync if mobile view is open
        const resultObserver = new MutationObserver(function() {
            const resultDisplay = document.getElementById('result-display');
            const resultCards = resultDisplay ? resultDisplay.children : [];
            
            if (mobileViewResultsBtn) {
                if (resultCards.length > 0) {
                    mobileViewResultsBtn.classList.remove('hidden');
                    mobileViewResultsBtn.classList.add('flex');
                    const badge = document.getElementById('results-count-badge');
                    if (badge) badge.textContent = resultCards.length;
                } else {
                    mobileViewResultsBtn.classList.add('hidden');
                }
            }
            
            // Auto-sync if mobile results view is currently open
            if (mobileResultsView && !mobileResultsView.classList.contains('hidden')) {
                console.log('🔄 Auto-syncing mobile view after result change...');
                syncResultsToMobile();
            }
        });
        
        // Observe result display changes
        const resultDisplay = document.getElementById('result-display');
        if (resultDisplay) {
            resultObserver.observe(resultDisplay, { childList: true });
        }
    </script>

