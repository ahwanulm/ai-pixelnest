    <script>
        // ✨ Helper function to clean model names (remove fal.ai and fal.id references)
        function cleanModelNameFullscreen(modelName) {
            if (!modelName) return 'Unknown Model';
            
            // Remove common fal.ai and fal.id prefixes and patterns
            let cleaned = modelName
                .replace(/^fal-ai\//gi, '')      // Remove fal-ai/ prefix
                .replace(/^fal\.ai\//gi, '')     // Remove fal.ai/ prefix
                .replace(/^fal\.id\//gi, '')     // Remove fal.id/ prefix
                .replace(/^fal-id\//gi, '')      // Remove fal-id/ prefix
                .replace(/\(fal\.ai\)/gi, '')    // Remove (fal.ai) suffix
                .replace(/\(fal\.id\)/gi, '')    // Remove (fal.id) suffix
                .replace(/\[fal\.ai\]/gi, '')    // Remove [fal.ai] suffix
                .replace(/\[fal\.id\]/gi, '')    // Remove [fal.id] suffix
                .replace(/- fal\.ai$/gi, '')     // Remove - fal.ai suffix
                .replace(/- fal\.id$/gi, '')     // Remove - fal.id suffix
                .replace(/by fal\.ai/gi, '')     // Remove by fal.ai
                .replace(/by fal\.id/gi, '')     // Remove by fal.id
                .trim();
            
            // Make model name more user-friendly (optional beautification)
            // Replace dashes and underscores with spaces for better readability
            cleaned = cleaned
                .replace(/[-_]/g, ' ')           // Replace - and _ with spaces
                .replace(/\s+/g, ' ')            // Remove multiple spaces
                .trim();
            
            // Capitalize first letter of each word for better presentation
            cleaned = cleaned.split(' ')
                .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
                .join(' ');
            
            return cleaned || modelName; // Return original if cleaning results in empty string
        }
        
        // Fullscreen Media Viewer
        let fullscreenMedia = [];
        let fullscreenIndex = 0;
        let fullscreenMetadata = {};
        
        function openFullscreenViewer(media, index = 0, metadata = {}) {
            console.log('📺 Opening fullscreen viewer with z-index 10005');
            
            // media can be single URL string or array of URLs
            fullscreenMedia = Array.isArray(media) ? media : [media];
            fullscreenIndex = index;
            fullscreenMetadata = metadata;
            
            const modal = document.getElementById('fullscreen-media-modal');
            const prevBtn = document.getElementById('fullscreen-prev');
            const nextBtn = document.getElementById('fullscreen-next');
            const counter = document.getElementById('fullscreen-counter');
            
            if (!modal) {
                console.error('❌ Fullscreen modal element not found!');
                return;
            }
            
            // Show/hide navigation for multiple media
            if (fullscreenMedia.length > 1) {
                prevBtn.classList.remove('hidden');
                prevBtn.classList.add('flex');
                nextBtn.classList.remove('hidden');
                nextBtn.classList.add('flex');
                counter.textContent = `${fullscreenIndex + 1} / ${fullscreenMedia.length}`;
                counter.classList.remove('hidden');
            } else {
                prevBtn.classList.add('hidden');
                nextBtn.classList.add('hidden');
                counter.classList.add('hidden');
            }
            
            // Update metadata
            document.getElementById('fullscreen-prompt').textContent = metadata.prompt || 'No prompt';
            document.getElementById('fullscreen-model').textContent = cleanModelNameFullscreen(metadata.model) || 'Unknown model';
            
            // Show modal
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            modal.style.display = 'flex'; // Force display
            document.body.style.overflow = 'hidden';
            
            console.log('✅ Fullscreen modal opened, display:', modal.style.display, 'classes:', modal.className);
            
            // Load media
            loadFullscreenMedia(fullscreenIndex);
        }
        
        function loadFullscreenMedia(index) {
            const container = document.getElementById('fullscreen-media-container');
            const mediaUrl = fullscreenMedia[index];
            
            // Clear container
            container.innerHTML = '';
            
            // Detect media type
            const isVideo = mediaUrl.includes('.mp4') || mediaUrl.includes('.webm') || mediaUrl.includes('video');
            
            if (isVideo) {
                // Create video element
                const video = document.createElement('video');
                video.src = mediaUrl;
                video.controls = true;
                video.autoplay = true;
                video.loop = true;
                video.className = 'max-w-full max-h-[85vh] rounded-lg shadow-2xl';
                container.appendChild(video);
            } else {
                // Create image element
                const img = document.createElement('img');
                img.src = mediaUrl;
                img.alt = fullscreenMetadata.prompt || 'Generated media';
                img.className = 'max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl';
                img.loading = 'eager';
                
                // Add loading state
                img.style.opacity = '0';
                img.style.transition = 'opacity 0.3s';
                
                img.onload = function() {
                    img.style.opacity = '1';
                };
                
                container.appendChild(img);
            }
            
            // Update counter
            if (fullscreenMedia.length > 1) {
                document.getElementById('fullscreen-counter').textContent = `${index + 1} / ${fullscreenMedia.length}`;
            }
        }
        
        function navigateFullscreen(direction) {
            fullscreenIndex += direction;
            
            // Wrap around
            if (fullscreenIndex < 0) {
                fullscreenIndex = fullscreenMedia.length - 1;
            } else if (fullscreenIndex >= fullscreenMedia.length) {
                fullscreenIndex = 0;
            }
            
            loadFullscreenMedia(fullscreenIndex);
        }
        
        function closeFullscreenViewer() {
            console.log('🚪 Closing fullscreen viewer');
            
            const modal = document.getElementById('fullscreen-media-modal');
            if (!modal) {
                console.error('❌ Modal not found');
                return;
            }
            
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            modal.style.display = 'none'; // Force hide
            document.body.style.overflow = '';
            
            // Stop any playing video
            const container = document.getElementById('fullscreen-media-container');
            const video = container.querySelector('video');
            if (video) {
                video.pause();
                video.src = '';
            }
            
            // Clear data
            fullscreenMedia = [];
            fullscreenIndex = 0;
            fullscreenMetadata = {};
            
            console.log('✅ Fullscreen viewer closed');
        }
        
        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            const modal = document.getElementById('fullscreen-media-modal');
            if (!modal.classList.contains('hidden')) {
                if (e.key === 'Escape') {
                    closeFullscreenViewer();
                } else if (e.key === 'ArrowLeft') {
                    if (fullscreenMedia.length > 1) navigateFullscreen(-1);
                } else if (e.key === 'ArrowRight') {
                    if (fullscreenMedia.length > 1) navigateFullscreen(1);
                }
            }
        });
        
        // Attach event listeners to fullscreen buttons
        const fullscreenCloseBtn = document.getElementById('fullscreen-close-btn');
        const fullscreenPrevBtn = document.getElementById('fullscreen-prev');
        const fullscreenNextBtn = document.getElementById('fullscreen-next');
        
        if (fullscreenCloseBtn) {
            fullscreenCloseBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                console.log('🖱️ Close button clicked');
                closeFullscreenViewer();
            });
            console.log('✅ Fullscreen close button listener attached');
        }
        
        if (fullscreenPrevBtn) {
            fullscreenPrevBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                console.log('🖱️ Prev button clicked');
                navigateFullscreen(-1);
            });
        }
        
        if (fullscreenNextBtn) {
            fullscreenNextBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                console.log('🖱️ Next button clicked');
                navigateFullscreen(1);
            });
        }
        
        // Make function globally available
        window.openFullscreenViewer = openFullscreenViewer;
        window.closeFullscreenViewer = closeFullscreenViewer;
        window.navigateFullscreen = navigateFullscreen;
    </script>

