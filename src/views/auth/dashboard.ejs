                    </div>
                    <div class="flex justify-between py-2 border-b border-white/10">
                        <span class="text-gray-400">Credits</span>
                        <span class="font-semibold text-yellow-400">+${paymentData.creditsAmount} Credits</span>
                    </div>
                    <div class="flex justify-between py-3 bg-yellow-500/10 border border-yellow-500/20 rounded-xl px-4">
                        <span class="font-bold text-white">Total Bayar</span>
                        <span class="font-bold text-2xl text-yellow-400 font-mono">Rp ${paymentData.amountReceived.toLocaleString('id-ID')}</span>
                    </div>
                </div>
            `;

            // Payment code (VA number, etc)
            if (paymentData.payCode) {
                html += `
                    <div class="mt-6 p-4 bg-yellow-500/10 border border-yellow-500/20 rounded-xl">
                        <p class="font-bold text-white mb-2">Kode Pembayaran:</p>
                        <div class="flex items-center justify-between bg-black/30 p-4 rounded-lg border border-yellow-500/30">
                            <code class="text-2xl font-mono font-bold text-yellow-400">${paymentData.payCode}</code>
                            <button onclick="copyToClipboard('${paymentData.payCode}')" class="px-3 py-2 bg-yellow-500 hover:bg-yellow-400 text-black rounded-lg transition font-semibold">
                                <i class="fas fa-copy mr-1"></i> Copy
                            </button>
                        </div>
                    </div>
                `;
            }

            // QR Code
            if (paymentData.qrUrl) {
                html += `
                    <div class="mt-6 text-center">
                        <p class="font-bold text-white mb-3">Scan QR Code:</p>
                        <div class="inline-block p-4 bg-white rounded-xl">
                            <img src="${paymentData.qrUrl}" alt="QR Code" class="w-48 h-48">
                        </div>
                    </div>
                `;
            }

            // Action buttons
            html += `
                <div class="mt-6 flex gap-3 pt-6 border-t border-white/10">
                    ${paymentData.checkoutUrl ? `
                        <a href="${paymentData.checkoutUrl}" target="_blank" class="flex-1 px-4 py-3 bg-gradient-to-r from-yellow-500 to-yellow-600 hover:from-yellow-400 hover:to-yellow-500 text-black font-bold rounded-xl text-center transition-all">
                            <i class="fas fa-external-link-alt mr-2"></i>
                            Bayar Sekarang
                        </a>
                    ` : ''}
                    <button onclick="closeTopUpModal(); location.reload();" class="flex-1 px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold rounded-xl transition-all">
                        Selesai
                    </button>
                </div>

                <div class="mt-4 p-3 bg-blue-500/10 border border-blue-500/20 rounded-xl">
                    <p class="text-xs text-gray-400 text-center">
                        <i class="fas fa-clock mr-1"></i>
                        Expired: <strong class="text-white">${new Date(paymentData.expiredTime * 1000).toLocaleString('id-ID')}</strong>
