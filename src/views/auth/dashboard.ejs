        .notification-icon.warning i { color: #f59e0b; }
        .notification-icon.error { background: rgba(239, 68, 68, 0.15); }
        .notification-icon.error i { color: #ef4444; }
        
        .notification-content h4 {
            font-size: 13px;
            font-weight: 600;
            color: white;
            margin: 0 0 4px 0;
        }
        
        .notification-content p {
            font-size: 12px;
            color: #9ca3af;
            margin: 0 0 6px 0;
            line-height: 1.4;
        }
        
        .notification-time {
            font-size: 10px;
            color: #6b7280;
            font-family: 'JetBrains Mono', monospace;
        }
        
        .notification-unread-dot {
            width: 6px;
            height: 6px;
            background: #8b5cf6;
            border-radius: 50%;
            margin-left: auto;
            margin-top: 4px;
            box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.2);
        }
        
        .notification-empty {
            padding: 40px 20px;
            text-align: center;
        }
        
        .notification-empty i {
            font-size: 36px;
