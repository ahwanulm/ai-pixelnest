        function formatGroupName(group) {
            const names = {
                'Virtual Account': '💳 Virtual Account',
                'E-Wallet': '📱 E-Wallet',
                'Retail': '🏪 Retail / Minimarket',
                'QRIS': '📷 QRIS'
            };
            return names[group] || group;
        }

        function selectPaymentMethod(code, name) {
            selectedPaymentMethod = { code, name };
            
            // Remove previous selection
            document.querySelectorAll('.payment-method-card').forEach(card => {
                card.classList.remove('border-yellow-500', 'bg-yellow-500/10', 'ring-2', 'ring-yellow-500/30');
                // Remove check icon if exists
                const checkIcon = card.querySelector('.selected-check');
                if (checkIcon) checkIcon.remove();
            });
            
            // Add selection
            const selectedCard = document.querySelector(`[data-code="${code}"]`);
            selectedCard.classList.add('border-yellow-500', 'bg-yellow-500/10', 'ring-2', 'ring-yellow-500/30');
            
            // Add check icon
            const chevronIcon = selectedCard.querySelector('.fa-chevron-right');
            if (chevronIcon) {
                chevronIcon.outerHTML = '<i class="fas fa-check-circle text-yellow-400 text-xl selected-check"></i>';
            }
            
            // Enable confirm button
            document.getElementById('confirmPaymentBtn').disabled = false;
            
            // Scroll selected into view smoothly
            selectedCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        async function createPayment() {
            if (!selectedPaymentMethod) return;

            const btn = document.getElementById('confirmPaymentBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Memproses...';

            try {
                let amount = selectedCreditsAmount * creditPriceIDR;
                
                // Apply promo discount if available
                if (appliedPromo) {
                    let discount = 0;
                    if (appliedPromo.type === 'percentage') {
                        discount = amount * (appliedPromo.value / 100);
                    } else if (appliedPromo.type === 'fixed') {
                        discount = appliedPromo.value;
                    }
                    amount = Math.max(0, amount - discount);
                }
                
                const requestBody = {
                    amount: amount,
                    credits: selectedCreditsAmount,
                    paymentMethod: selectedPaymentMethod.code
                };
                
                // Include promo code if applied
                if (appliedPromo) {
                    requestBody.promoCode = appliedPromo.code;
                }
                
                const response = await fetch('/api/payment/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(requestBody)
                });

                const data = await response.json();

                if (data.success) {
                    showPaymentInstructions(data.data);
                } else {
                    alert('Gagal membuat pembayaran: ' + data.message);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-check mr-2"></i>Konfirmasi Pembayaran';
                }
            } catch (error) {
                console.error('Error creating payment:', error);
                alert('Terjadi kesalahan saat membuat pembayaran');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check mr-2"></i>Konfirmasi Pembayaran';
            }
        }

        function showPaymentInstructions(paymentData) {
            // Hide step 2, show step 3
            document.getElementById('paymentMethodsStep').classList.add('hidden');
            document.getElementById('paymentInstructionsStep').classList.remove('hidden');
            
            // Update header
            document.getElementById('modalTitle').textContent = 'Instruksi Pembayaran';
            document.getElementById('modalSubtitle').textContent = 'Selesaikan pembayaran Anda';

            // Build instructions HTML
            let html = `
                <div class="bg-green-500/10 border border-green-500/20 rounded-xl p-4 mb-6">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-check-circle text-green-400 text-2xl"></i>
