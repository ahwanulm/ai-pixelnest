<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="PixelNest Dashboard - AI Studio">
    <title><%= title %></title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/output.css?v=<%= appVersion %>">
    <link rel="stylesheet" href="/css/generation-styles.css?v=<%= appVersion %>">
    <link rel="stylesheet" href="/css/mobile-navbar.css?v=<%= appVersion %>">
    
    <!-- Google Model Viewer for 3D Models Support -->
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.3.0/model-viewer.min.js"></script>
    
    <style>
        /* Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }
        
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, rgba(37, 99, 235, 0.6), rgba(8, 145, 178, 0.6));
            border-radius: 10px;
        }
        
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(180deg, rgba(37, 99, 235, 0.8), rgba(8, 145, 178, 0.8));
        }
        
        /* Video Upload - Prevent Double Click on Hidden Input */
        #video-start-frame,
        #video-end-frame {
            pointer-events: none !important;
            user-select: none !important;
        }
        
        /* Model Card - Compact & Dark */
        .model-card {
            transition: all 0.2s ease;
        }
        
        .model-card:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(37, 99, 235, 0.4);
        }
        
        .model-card.selected {
            background: rgba(37, 99, 235, 0.15);
            border-color: rgba(37, 99, 235, 0.6);
        }
        
        /* Dropdown Animation */
        @keyframes dropdownSlideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        #image-type-dropdown:not(.hidden) {
            animation: dropdownSlideIn 0.2s ease-out;
        }
        
        /* Model Cards Collapse Animation */
        #image-model-cards,
        #video-model-cards {
            transition: max-height 0.3s ease, opacity 0.3s ease;
        }
        
        #image-search-container,
        #video-search-container {
            transition: display 0.3s ease;
        }
        
        /* Pinned Model Styling */
        .model-card.pinned-model {
            background: rgba(234, 179, 8, 0.08) !important;
            border-color: rgba(234, 179, 8, 0.3) !important;
        }
        
        .model-card.pinned-model:hover {
            background: rgba(234, 179, 8, 0.12) !important;
            border-color: rgba(234, 179, 8, 0.5) !important;
        }
        
        .model-card.pinned-model.selected {
            background: rgba(234, 179, 8, 0.2) !important;
            border-color: rgba(234, 179, 8, 0.6) !important;
        }
        
        /* Pin Button Hover */
        .pin-btn {
            transition: all 0.2s ease;
        }
        
        .pin-btn:hover {
            transform: scale(1.1);
        }
        
        /* Notification Animation */
        @keyframes slide-in-right {
            from {
                opacity: 0;
                transform: translateX(100%);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        .animate-slide-in-right {
            animation: slide-in-right 0.3s ease-out;
        }
        
        /* 
         * Z-Index Hierarchy (highest to lowest):
         * 10010 - Modal Controls (Close/Navigation buttons)
         * 10008 - Top Up Modal
         * 10007 - Generation Detail Modal  
         * 10006 - Share Modal
         * 10005 - Fullscreen Media Viewer
         * 10004 - Mobile Navbar
         * 10003 - Mobile Results Header
         * 10002 - Mobile Results View
         * 10001 - Mobile Header
         */
        
        /* Mobile Media Constraints - Prevent 9:16 content from being too tall */
        @media (max-width: 1023px) {
            /* Video constraints */
            #mobile-results-display video,
            #mobile-results-content video {
                max-height: 60vh !important;
                width: auto !important;
                margin: 0 auto !important;
                object-fit: contain !important;
            }
            
            /* Image constraints for portrait images */
            #mobile-results-display img[alt*="Generated Image"],
            #mobile-results-content img[alt*="Generated Image"] {
                max-height: 70vh !important;
                width: auto !important;
                margin: 0 auto !important;
                object-fit: contain !important;
            }
            
            /* Make media containers centered and constrained */
            #mobile-results-display .result-card > div > div.relative.bg-black,
            #mobile-results-content .result-card > div > div.relative.bg-black,
            #mobile-results-display .result-card > div > div.relative,
            #mobile-results-content .result-card > div > div.relative {
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
                background-color: #000 !important;
            }
            
            /* Specific height constraints for video containers */
            #mobile-results-display .result-card > div > div.relative.bg-black:has(video),
            #mobile-results-content .result-card > div > div.relative.bg-black:has(video) {
                max-height: 60vh !important;
            }
            
            /* Specific height constraints for image containers */
            #mobile-results-display .result-card > div > div.relative:has(img),
            #mobile-results-content .result-card > div > div.relative:has(img) {
                max-height: 70vh !important;
            }
            
            /* Ensure mobile results view header is not blocked and navbar is visible */
            #mobile-results-view {
                padding-top: 0 !important;
                padding-bottom: 80px !important;
            }
            
            #mobile-results-content {
                padding-top: 72px !important;
                padding-bottom: 96px !important; /* Extra padding for navbar */
            }
        }
        
        /* Tempo Buttons (Dashboard Audio) */
        /* Audio tempo buttons - REMOVED (now only in Advanced Options) */
        
    </style>
    
    <!-- IMMEDIATE CHECK - Run BEFORE page renders -->
    <script>
        // Check flag IMMEDIATELY before any rendering
        (function() {
            if (window.location.pathname === '/dashboard' && localStorage.getItem('openMobileResults') === 'true') {
                // Inject CSS to hide dashboard immediately
                const style = document.createElement('style');
                style.innerHTML = `
                    body > div:first-of-type,
                    main,
                    aside,
                    #mobile-header {
                        display: none !important;
                    }
                    #mobile-results-view {
                        display: flex !important;
                    }
                    body {
                        background: #09090b !important;
                    }
                `;
                document.head.appendChild(style);
            }
        })();
    </script>
</head>
<body class="text-white overflow-hidden">
    <!-- Mobile Header -->
    <%- include('../partials/mobile-header') %>
    
    <!-- Modern Responsive Layout -->
    <div class="flex h-screen pt-14 lg:pt-0">
        <!-- Left Sidebar - Controls (Full width on mobile, 384px on desktop) -->
        <aside class="w-full lg:w-96 bg-zinc-950 lg:border-r border-white/10 flex flex-col h-screen overflow-hidden">
            <!-- Header -->
            <div class="p-6 border-b border-white/10">
                <!-- Logo (Hidden on Mobile, visible on Desktop) -->
                <div class="hidden lg:flex items-center mb-6">
                    <a href="/" class="flex items-center gap-3">
                        <img src="/assets/img/logo/logo.png" alt="PixelNest Logo" class="h-10 w-auto">
                        <span class="font-black text-lg">PIXELNEST</span>
                    </a>
                </div>
                
                <!-- Mode Tabs -->
                <div class="grid grid-cols-3 gap-2 lg:mt-0">
                    <button class="creation-tab active group relative" data-mode="image">
                        <span class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/5 to-white/0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                        <svg class="w-4 h-4 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <span class="text-xs relative z-10">Image</span>
                    </button>
                    <button class="creation-tab group relative" data-mode="video">
                        <span class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/5 to-white/0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                        <svg class="w-4 h-4 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                        <span class="text-xs relative z-10">Video</span>
                    </button>
                    <button class="creation-tab group relative" data-mode="audio">
                        <span class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/5 to-white/0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                        <svg class="w-4 h-4 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
                        </svg>
                        <span class="text-xs relative z-10">Audio</span>
                    </button>
                </div>
            </div>

            <!-- Scrollable Controls -->
            <div class="flex-1 overflow-y-auto p-6 space-y-6">
                <!-- Image Mode -->
                <div id="image-mode" class="creation-mode active space-y-4">
                    <!-- Type (Custom Dropdown) -->
                    <div>
                        <label class="control-label">Type</label>
                        <div class="relative">
                            <!-- Selected Display -->
                            <button type="button" id="image-type-btn" class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-left flex items-center justify-between hover:bg-white/10 hover:border-blue-500/30 transition-all duration-300 group">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 bg-gray-600 rounded-lg flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-hand-pointer text-white text-sm"></i>
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold text-gray-400" id="selected-image-type">Select image type</p>
                                        <p class="text-xs text-gray-500" id="selected-image-type-desc">Choose how to create your image</p>
                                    </div>
                                </div>
                                <i class="fas fa-chevron-down text-gray-400 group-hover:text-white transition-colors"></i>
                            </button>
                            
                            <!-- Dropdown Menu -->
                            <div id="image-type-dropdown" class="hidden absolute z-20 w-full mt-2 bg-zinc-900 border border-white/10 rounded-xl shadow-2xl max-h-96 overflow-y-auto">
                                <div class="p-2 space-y-1">
                                    <button type="button" class="image-type-option w-full px-3 py-3 rounded-lg hover:bg-white/5 transition-all duration-200 text-left group" data-type="text-to-image" data-desc="Generate images from text">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                                <i class="fas fa-wand-magic-sparkles text-white"></i>
                                            </div>
                                            <div class="flex-1">
                                                <p class="text-sm font-semibold text-white mb-0.5">Text to Image</p>
                                                <p class="text-xs text-gray-400">Generate images from text descriptions</p>
                                            </div>
                                            <i class="fas fa-check text-blue-400 opacity-0 group-[.active]:opacity-100 transition-opacity"></i>
                                        </div>
                                    </button>
                                    
                                    <button type="button" class="image-type-option w-full px-3 py-3 rounded-lg hover:bg-white/5 transition-all duration-200 text-left group" data-type="edit-image" data-desc="Edit existing images with AI">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                                <i class="fas fa-magic text-white"></i>
                                            </div>
                                            <div class="flex-1">
                                                <p class="text-sm font-semibold text-white mb-0.5">Edit Image</p>
                                                <p class="text-xs text-gray-400">Modify parts of an existing image</p>
                                            </div>
                                            <i class="fas fa-check text-blue-400 opacity-0 group-[.active]:opacity-100 transition-opacity"></i>
                                        </div>
                                    </button>
                                    
                                    <button type="button" class="image-type-option w-full px-3 py-3 rounded-lg hover:bg-white/5 transition-all duration-200 text-left group" data-type="edit-multi" data-desc="Edit multiple images at once">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                                <i class="fas fa-images text-white"></i>
                                            </div>
                                            <div class="flex-1">
                                                <p class="text-sm font-semibold text-white mb-0.5">Edit Multi Image</p>
                                                <p class="text-xs text-gray-400">Edit multiple images simultaneously</p>
                                            </div>
                                            <i class="fas fa-check text-blue-400 opacity-0 group-[.active]:opacity-100 transition-opacity"></i>
                                        </div>
                                    </button>
                                    
                                    <button type="button" class="image-type-option w-full px-3 py-3 rounded-lg hover:bg-white/5 transition-all duration-200 text-left group" data-type="upscale" data-desc="Increase image resolution">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-gradient-to-br from-green-500 to-emerald-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                                <i class="fas fa-expand-arrows-alt text-white"></i>
                                            </div>
                                            <div class="flex-1">
                                                <p class="text-sm font-semibold text-white mb-0.5">Upscale</p>
                                                <p class="text-xs text-gray-400">Enhance image resolution and quality</p>
                                            </div>
                                            <i class="fas fa-check text-blue-400 opacity-0 group-[.active]:opacity-100 transition-opacity"></i>
                                        </div>
                                    </button>
                                    
                                    <button type="button" class="image-type-option w-full px-3 py-3 rounded-lg hover:bg-white/5 transition-all duration-200 text-left group" data-type="remove-bg" data-desc="Remove image background">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-gradient-to-br from-orange-500 to-red-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                                <i class="fas fa-eraser text-white"></i>
                                            </div>
                                            <div class="flex-1">
                                                <p class="text-sm font-semibold text-white mb-0.5">Remove Background</p>
                                                <p class="text-xs text-gray-400">Automatically remove image background</p>
                                            </div>
                                            <i class="fas fa-check text-blue-400 opacity-0 group-[.active]:opacity-100 transition-opacity"></i>
                                        </div>
                                    </button>
                                    
                                    <button type="button" class="image-type-option w-full px-3 py-3 rounded-lg hover:bg-white/5 transition-all duration-200 text-left group" data-type="text-to-3d" data-desc="Generate 3D models from text">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                                <i class="fas fa-cubes text-white"></i>
                                </div>
                                            <div class="flex-1">
                                                <p class="text-sm font-semibold text-white mb-0.5">Text to 3D</p>
                                                <p class="text-xs text-gray-400">Generate 3D models from text descriptions</p>
                                            </div>
                                            <i class="fas fa-check text-blue-400 opacity-0 group-[.active]:opacity-100 transition-opacity"></i>
                                        </div>
                                    </button>
                                    
                                    <button type="button" class="image-type-option w-full px-3 py-3 rounded-lg hover:bg-white/5 transition-all duration-200 text-left group" data-type="image-to-3d" data-desc="Convert image to 3D model">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                                <i class="fas fa-cube text-white"></i>
                                            </div>
                                            <div class="flex-1">
                                                <p class="text-sm font-semibold text-white mb-0.5">Image to 3D</p>
                                                <p class="text-xs text-gray-400">Convert image to 3D model</p>
                                            </div>
                                            <i class="fas fa-check text-blue-400 opacity-0 group-[.active]:opacity-100 transition-opacity"></i>
                                        </div>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Hidden select for compatibility -->
                            <select class="hidden" id="image-type">
                                <option value="" selected disabled>Select type</option>
                                <option value="text-to-image">Text to Image</option>
                                <option value="edit-image">Edit Image</option>
                                <option value="edit-multi">Edit Multi Image</option>
                                <option value="upscale">Upscale</option>
                                <option value="remove-bg">Remove Background</option>
                                <option value="text-to-3d">Text to 3D</option>
                                <option value="image-to-3d">Image to 3D</option>
                            </select>
                        </div>
                    </div>

                    <!-- Model (Enhanced with Visual Cards) -->
                    <div>
                        <label class="control-label">Model</label>
                        
                        <!-- Search Input -->
                        <div id="image-search-container" class="relative mb-3">
                            <input 
                                type="text" 
                                id="image-model-search" 
                                class="w-full px-4 py-3 pl-10 bg-white/5 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all" 
                                placeholder="Search models by name..." 
                                autocomplete="off"
                            >
                            <div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                <i class="fas fa-search"></i>
                            </div>
                            <button type="button" id="clear-search" class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white transition-colors">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        
                        <!-- Model Cards Container (Collapsible) -->
                        <div id="image-model-cards-wrapper" class="mb-3">
                            <div id="image-model-cards" class="space-y-1.5 max-h-96 overflow-y-auto pr-2 custom-scrollbar transition-all duration-300">
                                <!-- Placeholder - Models will load after type selection -->
                                <div class="text-center py-8">
                                    <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-3">
                                        <i class="fas fa-mouse-pointer text-gray-500 text-2xl"></i>
                                    </div>
                                    <p class="text-sm text-gray-400">Select a type to load models</p>
                                </div>
                            </div>
                            
                            <!-- Expand Button (Hidden by default) -->
                            <button type="button" id="expand-image-models" class="hidden w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 transition-all text-sm text-gray-400 hover:text-white flex items-center justify-center gap-2 mt-2">
                                <i class="fas fa-chevron-down"></i>
                                <span>Show all models</span>
                            </button>
                        </div>
                        
                        <!-- Hidden select for compatibility -->
                        <select class="hidden" id="image-model-select">
                            <option value="">Loading models...</option>
                        </select>
                        
                        <!-- Selected Model Info -->
                        <div id="image-model-info" class="mt-3 p-4 bg-gradient-to-r from-blue-500/10 to-cyan-500/10 border border-blue-500/20 rounded-xl hidden">
                            <div class="flex items-start gap-3">
                                <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-brain text-white"></i>
                                </div>
                                <div class="flex-1">
                                    <p class="text-sm font-bold text-white mb-1" id="image-model-name"></p>
                                    <p class="text-xs text-gray-400 leading-relaxed mb-2" id="image-model-desc"></p>
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span id="image-model-badge" class="text-xs px-2 py-1 rounded-full bg-blue-500/20 text-blue-300 font-semibold"></span>
                                        <span id="image-model-cost" class="text-xs px-2 py-1 rounded-full bg-yellow-500/20 text-yellow-300 font-semibold flex items-center gap-1">
                                            <i class="fas fa-coins"></i>
                                            <span>0.5 credits</span>
                                        </span>
                                </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Prompt -->
                    <div>
                        <label class="control-label">Prompt</label>
                        <textarea 
                            id="image-textarea"
                            class="control-textarea"
                            rows="5"
                            placeholder="Describe your image..."
                        ></textarea>
                        <div class="mt-1 text-xs text-gray-600 text-right font-mono">
                            <span id="image-counter">0</span> / 1000
                        </div>
                    </div>

                    <!-- Image Upload (for edit modes) -->
                    <div id="image-upload-section" class="hidden">
                        <div class="flex items-center justify-between mb-2">
                            <label class="control-label mb-0">
                            <span id="image-upload-label">Upload Image</span>
                            <span id="image-upload-label-multi" class="hidden">Upload Images (Multiple)</span>
                        </label>
                            <!-- Add Image Button (for dynamic mode) -->
                            <button type="button" id="add-image-field-btn" class="hidden px-3 py-1.5 bg-gradient-to-r from-blue-600 to-cyan-600 text-white text-xs rounded-lg hover:from-blue-700 hover:to-cyan-700 transition flex items-center gap-1.5 font-medium">
                                <i class="fas fa-plus"></i>
                                <span>Add Image</span>
                            </button>
                        </div>
                        
                        <!-- Dynamic Upload Fields Container -->
                        <div id="dynamic-upload-fields" class="space-y-3">
                            <!-- Primary Upload Field (always visible) -->
                            <div class="upload-field-item" data-field-index="0">
                        <div class="relative border-2 border-dashed border-white/20 rounded-lg p-4 text-center hover:border-white/50 transition-all duration-300 cursor-pointer group hover:scale-[1.02]">
                            <span class="absolute inset-0 bg-white/5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                                    <input type="file" id="image-upload" accept="image/*" class="hidden image-upload-input">
