    <!-- Suno Duration Hide Logic -->
    <script>
        (function() {
            const audioDurationContainer = document.getElementById('audio-duration-container');
            const audioTypeOptions = document.querySelectorAll('.audio-type-option');
            const audioTypeSelect = document.getElementById('audio-type-select');
            const audioTypeBtn = document.getElementById('audio-type-btn');
            const audioTypeDropdown = document.getElementById('audio-type-dropdown');
            const audioModelSelect = document.getElementById('audio-model-select');
            
            // Function to check if duration should be hidden
            function shouldHideDuration() {
                const audioType = audioTypeSelect?.value || '';
                const selectedModel = audioModelSelect?.value || '';
                
                // Hide duration for text-to-music (Suno) or any Suno model
                return audioType === 'text-to-music' || selectedModel.toLowerCase().includes('suno');
            }
            
            // Function to update duration container visibility (exposed globally)
            window.updateDurationVisibility = function updateDurationVisibility() {
                if (!audioDurationContainer) return;
                
                if (shouldHideDuration()) {
                    audioDurationContainer.style.display = 'none';
                    console.log('🎵 Duration hidden for Suno model (tempo is in Advanced Options)');
                } else {
                    audioDurationContainer.style.display = 'block';
                    console.log('🎵 Duration shown for non-Suno model');
                }
            }
            
            // Select Audio Tempo function - REMOVED (tempo now only in Advanced Options)
            
            // Audio Type Dropdown Handler - REMOVED (handled by dashboard-audio.js)
            // The dropdown functionality is now handled by dashboard-audio.js to avoid conflicts
            
            // Listen for audio model changes
            if (audioModelSelect) {
                audioModelSelect.addEventListener('change', updateDurationVisibility);
            }
            
            // Listen for audio type select changes (from other sources)
            if (audioTypeSelect) {
                audioTypeSelect.addEventListener('change', updateDurationVisibility);
            }
            
            // Initial check on page load
            setTimeout(updateDurationVisibility, 500);
        })();
    </script>

