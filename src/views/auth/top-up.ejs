<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PixelNest AI</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/favicon.png">
  
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
      min-height: 100vh;
    }
    
    .payment-channel-card {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      backdrop-filter: blur(10px);
    }
    
    .payment-channel-card:hover {
      transform: translateY(-4px) scale(1.02);
      box-shadow: 0 20px 40px rgba(59, 130, 246, 0.2);
    }
    
    .payment-channel-card.selected {
      border-color: #fbbf24 !important;
      background: linear-gradient(135deg, rgba(251, 191, 36, 0.15), rgba(245, 158, 11, 0.15)) !important;
      box-shadow: 0 0 0 2px rgba(251, 191, 36, 0.3) !important;
    }
    
    .payment-channel-card.selected .fa-chevron-right {
      display: none;
    }
    
    .payment-channel-card.selected::after {
      content: '\f058';
      font-family: 'Font Awesome 6 Free';
      font-weight: 900;
      color: #fbbf24;
      font-size: 1.25rem;
    }
    
    .amount-btn {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      backdrop-filter: blur(10px);
    }
    
    .amount-btn:hover {
      transform: translateY(-2px) scale(1.05);
      box-shadow: 0 10px 20px rgba(251, 191, 36, 0.2);
    }
    
    .amount-btn.selected {
      background: linear-gradient(135deg, #fbbf24, #f59e0b);
      color: #000;
      font-weight: 700;
      box-shadow: 0 10px 30px rgba(251, 191, 36, 0.4);
    }
    
    .loading-spinner {
      border: 3px solid rgba(255, 255, 255, 0.1);
      border-top: 3px solid #fbbf24;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    
    .glass-card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .gradient-border {
      position: relative;
      background: linear-gradient(135deg, rgba(251, 191, 36, 0.1), rgba(245, 158, 11, 0.1));
      border: 1px solid rgba(251, 191, 36, 0.3);
    }
    
    .gradient-border::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 2px;
      background: linear-gradient(135deg, #fbbf24, #f59e0b);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity 0.3s;
    }
    
    .gradient-border:hover::before {
      opacity: 1;
    }
    
    .animate-fade-in {
      animation: fadeIn 0.3s ease-out;
    }
    
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    /* Mobile Top-Up Page Styles */
    @media (max-width: 1023px) {
      /* Hide desktop header on mobile top-up page */
      body > header {
        display: none !important;
      }
      
      /* Show mobile header */
      #mobile-header {
        display: block !important;
      }
      
      /* Adjust page padding for mobile header */
      .min-h-screen {
        padding-top: 4rem !important;
      }
      
      /* Ensure mobile header buttons are clickable */
      #mobile-header button,
      #mobile-header a {
        pointer-events: auto !important;
        position: relative;
        z-index: 1;
      }
      
      /* Force z-index for top-up button */
      #mobile-header a[href="/api/payment/top-up"] {
        z-index: 2 !important;
      }
      
      /* Force z-index for dots menu button */
      #mobile-menu-dots-btn {
        z-index: 2 !important;
      }
    }
    
    @media (min-width: 1024px) {
      /* Hide mobile header on desktop */
      #mobile-header {
        display: none !important;
      }
    }
  </style>
</head>
<body class="bg-zinc-950 text-white">
  
  <%- include('../partials/header') %>
  <%- include('../partials/mobile-header') %>

  <div class="min-h-screen pt-16 lg:pt-24 pb-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      
      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-4 mb-4">
          <a href="/dashboard" class="w-10 h-10 lg:w-12 lg:h-12 flex items-center justify-center glass-card rounded-xl hover:bg-white/10 transition-all">
            <i class="fas fa-arrow-left text-gray-400"></i>
          </a>
          <div>
            <h1 class="text-2xl lg:text-4xl font-bold bg-gradient-to-r from-yellow-400 to-yellow-600 bg-clip-text text-transparent">
              <i class="fas fa-wallet mr-2 lg:mr-3"></i>Top Up Credits
            </h1>
            <p class="mt-2 text-sm lg:text-base text-gray-400">Isi ulang credits untuk menggunakan AI Generation</p>
          </div>
        </div>
        
        <!-- Current Balance -->
        <div class="mt-6 p-4 lg:p-6 glass-card gradient-border rounded-2xl relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-yellow-500/10 to-yellow-600/10"></div>
          <div class="relative z-10 flex items-center justify-between">
            <div>
              <p class="text-xs lg:text-sm text-gray-400">Saldo Credits Saat Ini</p>
              <p class="text-3xl lg:text-5xl font-bold mt-2 bg-gradient-to-r from-yellow-400 to-yellow-600 bg-clip-text text-transparent font-mono"><%= user.credits %></p>
              <p class="text-xs lg:text-sm mt-2 text-gray-500">
                ≈ Rp <%= (user.credits * creditPriceIDR).toLocaleString('id-ID') %>
              </p>
            </div>
            <div class="text-5xl lg:text-7xl text-yellow-500/20">
              <i class="fas fa-coins"></i>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-8">
        
        <!-- Main Form -->
        <div class="lg:col-span-2 space-y-4 lg:space-y-6">
          
          <!-- Step 1: Amount Selection -->
          <div class="glass-card rounded-2xl p-4 lg:p-6">
            <div class="flex items-center mb-4 lg:mb-6">
              <div class="w-10 h-10 lg:w-12 lg:h-12 bg-gradient-to-r from-yellow-500 to-yellow-600 rounded-xl flex items-center justify-center font-bold text-sm lg:text-base mr-3 shadow-lg shadow-yellow-500/20">
                1
              </div>
              <h2 class="text-xl lg:text-2xl font-bold text-white">Pilih Jumlah</h2>
            </div>

            <!-- Quick Amount Buttons -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 lg:gap-3 mb-4 lg:mb-6">
              <button class="amount-btn px-3 py-3 lg:px-4 lg:py-4 bg-white/5 border-2 border-white/10 rounded-xl font-semibold transition-all duration-300 group" data-amount="50000">
                <div class="text-yellow-400 text-sm lg:text-lg">Rp 50.000</div>
                <span class="block text-xs text-gray-500 mt-1"><%= Math.floor(50000 / creditPriceIDR) %> Credits</span>
              </button>
              <button class="amount-btn px-3 py-3 lg:px-4 lg:py-4 bg-white/5 border-2 border-white/10 rounded-xl font-semibold transition-all duration-300 group" data-amount="100000">
                <div class="text-yellow-400 text-sm lg:text-lg">Rp 100.000</div>
                <span class="block text-xs text-gray-500 mt-1"><%= Math.floor(100000 / creditPriceIDR) %> Credits</span>
              </button>
              <button class="amount-btn px-3 py-3 lg:px-4 lg:py-4 bg-white/5 border-2 border-white/10 rounded-xl font-semibold transition-all duration-300 group" data-amount="250000">
                <div class="text-yellow-400 text-sm lg:text-lg">Rp 250.000</div>
                <span class="block text-xs text-gray-500 mt-1"><%= Math.floor(250000 / creditPriceIDR) %> Credits</span>
              </button>
              <button class="amount-btn px-3 py-3 lg:px-4 lg:py-4 bg-white/5 border-2 border-white/10 rounded-xl font-semibold transition-all duration-300 group" data-amount="500000">
                <div class="text-yellow-400 text-sm lg:text-lg">Rp 500.000</div>
                <span class="block text-xs text-gray-500 mt-1"><%= Math.floor(500000 / creditPriceIDR) %> Credits</span>
              </button>
            </div>

            <!-- Custom Amount Input -->
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">
                Atau Masukkan Jumlah Custom
              </label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400 font-semibold">Rp</span>
                <input 
                  type="text" 
                  id="customAmount" 
                  class="w-full pl-12 pr-4 py-3 bg-white/5 border-2 border-white/10 rounded-xl text-white placeholder-gray-500 focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 text-lg font-semibold transition-all"
                  placeholder="10.000"
                  value=""
                >
              </div>
              <p class="mt-2 text-sm text-gray-500">
                Minimal: Rp <%= creditPriceIDR.toLocaleString('id-ID') %> (1 Credit) | 1 Credit = Rp <%= creditPriceIDR.toLocaleString('id-ID') %>
              </p>
              
              <!-- Credits Preview -->
              <div id="creditsPreview" class="mt-4 p-4 bg-yellow-500/10 border border-yellow-500/20 rounded-xl hidden">
                <div class="flex items-center justify-between">
                  <span class="text-gray-300">Credits yang Didapat:</span>
                  <span class="text-3xl font-bold text-yellow-400 font-mono" id="creditsAmount">0</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 2: Payment Method Selection -->
          <div class="glass-card rounded-2xl p-4 lg:p-6">
            <div class="flex items-center mb-4 lg:mb-6">
              <div class="w-10 h-10 lg:w-12 lg:h-12 bg-gradient-to-r from-yellow-500 to-yellow-600 rounded-xl flex items-center justify-center font-bold text-sm lg:text-base mr-3 shadow-lg shadow-yellow-500/20">
                2
              </div>
              <h2 class="text-xl lg:text-2xl font-bold text-white">Pilih Metode Pembayaran</h2>
            </div>

            <div id="paymentChannelsContainer" class="space-y-6">
              <!-- Loading -->
              <div class="text-center py-8">
                <div class="loading-spinner mx-auto"></div>
                <p class="mt-4 text-gray-400">Memuat metode pembayaran...</p>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="text-center">
            <button 
              id="submitPayment" 
              class="w-full lg:w-auto px-6 lg:px-10 py-3 lg:py-4 bg-gradient-to-r from-yellow-500 to-yellow-600 hover:from-yellow-400 hover:to-yellow-500 text-black font-bold text-sm lg:text-base rounded-xl shadow-lg shadow-yellow-500/30 hover:shadow-yellow-500/50 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed disabled:shadow-none transform hover:scale-105"
              disabled
            >
              <i class="fas fa-credit-card mr-2"></i>
              Lanjutkan Pembayaran
            </button>
          </div>

        </div>

        <!-- Sidebar -->
        <div class="space-y-4 lg:space-y-6">
          
          <!-- Voucher/Promo Code Card -->
          <div class="glass-card rounded-2xl p-4 lg:p-6 sticky top-16 lg:top-24 border-2 border-violet-500/20">
            <h3 class="text-lg lg:text-xl font-bold mb-3 lg:mb-4 text-white">
              <i class="fas fa-ticket-alt mr-2 text-violet-400"></i>
              Kode Promo
            </h3>
            
            <div class="space-y-4">
              <div>
                <label class="block text-sm text-gray-300 mb-2">
                  <i class="fas fa-gift mr-1"></i>
                  Punya kode voucher?
                </label>
                <div class="flex gap-2">
                  <input type="text" 
                         id="voucherCode" 
                         placeholder="Masukkan kode"
                         class="flex-1 px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:border-violet-500 focus:ring-2 focus:ring-violet-500/20 focus:outline-none transition-all uppercase"
                         maxlength="20">
                  <button onclick="applyVoucher()" 
                          id="applyVoucherBtn"
                          class="px-6 py-2.5 bg-gradient-to-r from-violet-500 to-fuchsia-600 hover:from-violet-400 hover:to-fuchsia-500 text-white font-bold rounded-lg transition-all shadow-lg shadow-violet-500/20 hover:shadow-violet-500/40 disabled:opacity-50 disabled:cursor-not-allowed">
                    <i class="fas fa-check mr-1"></i>
                    Apply
                  </button>
                </div>
              </div>
              
              <!-- Voucher Result -->
              <div id="voucherResult" class="hidden"></div>
              
              <!-- Voucher Info -->
              <div class="pt-3 border-t border-white/10">
                <p class="text-xs text-gray-400">
                  <i class="fas fa-info-circle mr-1"></i>
                  Bonus credits akan ditambahkan setelah pembayaran berhasil
                </p>
              </div>
            </div>
          </div>
          
          <!-- Summary -->
          <div class="glass-card rounded-2xl p-4 lg:p-6">
            <h3 class="text-lg lg:text-xl font-bold mb-3 lg:mb-4 text-white">
              <i class="fas fa-receipt mr-2 text-yellow-400"></i>
              Ringkasan Pembayaran
            </h3>
            
            <div class="space-y-3">
              <div class="flex justify-between py-2 border-b border-white/10">
                <span class="text-gray-400">Jumlah</span>
                <span class="font-semibold text-white" id="summaryAmount">Rp 0</span>
              </div>
              <div class="flex justify-between py-2 border-b border-white/10">
                <span class="text-gray-400">Credits Dasar</span>
                <span class="font-semibold text-yellow-400" id="summaryCredits">0 Credits</span>
              </div>
              
              <!-- Voucher Bonus (Hidden by default) -->
              <div id="voucherBonusRow" class="hidden flex justify-between py-2 border-b border-white/10">
                <span class="text-violet-400">
                  <i class="fas fa-gift mr-1"></i>
                  Bonus Voucher
                </span>
                <span class="font-semibold text-violet-400" id="voucherBonusAmount">+0 Credits</span>
              </div>
              
              <div class="flex justify-between py-2 border-b border-white/10">
                <span class="text-gray-400">Biaya Admin</span>
                <span class="font-semibold text-white" id="summaryFee">Rp 0</span>
              </div>
              
              <!-- Total Credits (with bonus) -->
              <div class="flex justify-between py-2 bg-violet-500/10 border border-violet-500/20 rounded-xl px-3">
                <span class="font-bold text-white">Total Credits</span>
                <span class="font-bold text-2xl text-violet-400 font-mono" id="totalCredits">0</span>
              </div>
              
              <div class="flex justify-between py-3 bg-yellow-500/10 border border-yellow-500/20 rounded-xl px-3">
                <span class="font-bold text-white">Total Bayar</span>
                <span class="font-bold text-2xl text-yellow-400 font-mono" id="summaryTotal">Rp 0</span>
              </div>
            </div>

            <div class="mt-6 p-4 bg-blue-500/10 border border-blue-500/20 rounded-xl">
              <p class="text-sm text-gray-300">
                <i class="fas fa-info-circle text-blue-400 mr-2"></i>
                Pembayaran akan diproses otomatis setelah Anda menyelesaikan transaksi
              </p>
            </div>
          </div>

          <!-- Payment History -->
          <div class="glass-card rounded-2xl p-4 lg:p-6">
            <h3 class="text-lg lg:text-xl font-bold mb-3 lg:mb-4 text-white">
              <i class="fas fa-history mr-2 text-purple-400"></i>
              Riwayat Terakhir
            </h3>
            
            <div class="space-y-3">
              <% if (paymentHistory && paymentHistory.length > 0) { %>
                <% paymentHistory.slice(0, 5).forEach(payment => { %>
                  <div class="flex items-center justify-between py-3 border-b border-white/10">
                    <div class="flex-1">
                      <p class="text-sm font-semibold text-white"><%= payment.payment_name %></p>
                      <p class="text-xs text-gray-500">
                        <%= new Date(payment.created_at).toLocaleDateString('id-ID') %>
                      </p>
                    </div>
                    <div class="text-right">
                      <p class="text-sm font-semibold text-yellow-400">+<%= payment.credits_amount %></p>
                      <% if (payment.status === 'PAID') { %>
                        <span class="text-xs px-2 py-1 bg-green-500/20 text-green-400 rounded-full">Sukses</span>
                      <% } else if (payment.status === 'UNPAID') { %>
                        <span class="text-xs px-2 py-1 bg-yellow-500/20 text-yellow-400 rounded-full">Pending</span>
                      <% } else { %>
                        <span class="text-xs px-2 py-1 bg-red-500/20 text-red-400 rounded-full">Gagal</span>
                      <% } %>
                    </div>
                  </div>
                <% }); %>
              <% } else { %>
                <p class="text-sm text-gray-500 text-center py-4">Belum ada riwayat pembayaran</p>
              <% } %>
            </div>

            <% if (paymentHistory && paymentHistory.length > 5) { %>
              <a href="/payment/history" class="mt-4 block text-center text-sm text-yellow-400 hover:text-yellow-300 font-semibold transition-colors">
                Lihat Semua <i class="fas fa-arrow-right ml-1"></i>
              </a>
            <% } %>
          </div>

        </div>

      </div>

    </div>
  </div>

  <!-- Payment Modal -->
  <div id="paymentModal" class="fixed inset-0 bg-black/70 backdrop-blur-sm hidden items-center justify-center z-[9999] p-4" onclick="if(event.target === this) closePaymentModal()">
    <div class="bg-gradient-to-br from-zinc-900 to-zinc-950 rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto border border-white/10" onclick="event.stopPropagation()">
      <div class="p-6">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-2xl font-bold text-white">
            <i class="fas fa-receipt mr-2 text-yellow-400"></i>
            Detail Pembayaran
          </h3>
          <button onclick="closePaymentModal()" class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-white/10 text-gray-400 hover:text-white transition-all">
            <i class="fas fa-times text-xl"></i>
          </button>
        </div>

        <div id="paymentModalContent" class="space-y-6">
          <!-- Will be filled by JavaScript -->
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    let selectedAmount = 0;
    let selectedPaymentMethod = null;
    let paymentChannels = {};
    let appliedVoucher = null;
    let voucherBonus = 0;
    const creditPriceIDR = <%= creditPriceIDR %>;

    // Load payment channels
    async function loadPaymentChannels() {
      try {
        // 🔥 FIX: Add cache busting and no-cache headers
        const timestamp = new Date().getTime();
        const response = await fetch(`/api/payment/channels?_=${timestamp}`, {
          cache: 'no-store',
          headers: {
            'Cache-Control': 'no-cache',
            'Pragma': 'no-cache'
          }
        });
        const data = await response.json();
        
        if (data.success) {
          paymentChannels = data.data;
          renderPaymentChannels();
        }
      } catch (error) {
        console.error('Error loading payment channels:', error);
        document.getElementById('paymentChannelsContainer').innerHTML = `
          <div class="text-center py-8 text-red-600">
            <i class="fas fa-exclamation-circle text-4xl mb-4"></i>
            <p>Gagal memuat metode pembayaran</p>
          </div>
        `;
      }
    }

    // Render payment channels
    function renderPaymentChannels() {
      const container = document.getElementById('paymentChannelsContainer');
      let html = '';

      // Category colors mapping
      const categoryColors = {
        'E-Wallet': { hover: 'hover:from-blue-500/10 hover:to-blue-600/10 hover:border-blue-500/50', icon: 'text-blue-400' },
        'Virtual Account': { hover: 'hover:from-green-500/10 hover:to-green-600/10 hover:border-green-500/50', icon: 'text-green-400' },
        'QRIS': { hover: 'hover:from-purple-500/10 hover:to-purple-600/10 hover:border-purple-500/50', icon: 'text-purple-400' },
        'Retail': { hover: 'hover:from-orange-500/10 hover:to-orange-600/10 hover:border-orange-500/50', icon: 'text-orange-400' }
      };

      for (const [group, channels] of Object.entries(paymentChannels)) {
        const colors = categoryColors[group] || categoryColors['E-Wallet'];
        
        html += `
          <div class="mb-4">
            <div class="flex items-center gap-2 mb-3 pb-2 border-b border-white/10">
              <h4 class="font-bold text-white text-sm">${formatGroupName(group)}</h4>
              <span class="ml-auto text-xs text-gray-400 bg-white/5 px-2 py-0.5 rounded-md">${channels.length} metode</span>
            </div>
            <div class="grid grid-cols-1 gap-2">
        `;

        channels.forEach(channel => {
          html += `
            <button 
              class="payment-channel-card group relative overflow-hidden px-3 py-3 bg-gradient-to-r from-zinc-900/50 to-zinc-800/50 ${colors.hover} border-2 border-white/10 rounded-xl transition-all duration-300 text-left backdrop-blur-sm"
              data-code="${channel.code}"
              data-name="${channel.name}"
              onclick="selectPaymentMethod('${channel.code}', '${channel.name}')"
            >
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-2 flex-1">
                  ${channel.icon_url ? `
                    <div class="w-10 h-10 bg-white/10 rounded-lg p-1.5 flex items-center justify-center group-hover:bg-white/20 transition-all flex-shrink-0">
                      <img src="${channel.icon_url}" alt="${channel.name}" class="w-full h-full object-contain">
                    </div>
                  ` : ''}
                  <div class="flex-1 min-w-0">
                    <p class="font-semibold text-white text-sm truncate">${channel.name}</p>
                    <p class="text-xs text-gray-400 mt-0.5">
                      <i class="fas fa-coins text-yellow-400 mr-1"></i>
                      Min: Rp ${channel.minimum_amount.toLocaleString('id-ID')}
                    </p>
                  </div>
                </div>
                <i class="fas fa-chevron-right text-gray-500 group-hover:${colors.icon} transition-colors text-sm flex-shrink-0"></i>
              </div>
            </button>
          `;
        });

        html += `
            </div>
          </div>
        `;
      }

      container.innerHTML = html;
    }

    // Format group name
    function formatGroupName(group) {
      const names = {
        'Virtual Account': 'Virtual Account',
        'E-Wallet': 'E-Wallet',
        'Retail': 'Retail / Minimarket',
        'QRIS': 'QRIS'
      };
      return names[group] || group;
    }

    // Amount button handlers
    document.querySelectorAll('.amount-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const amount = parseInt(this.dataset.amount);
        selectAmount(amount);
        
        document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('selected'));
        this.classList.add('selected');
      });
    });

    // Custom amount input handler
    const customAmountInput = document.getElementById('customAmount');
    customAmountInput.addEventListener('input', function(e) {
      let value = e.target.value.replace(/[^\d]/g, '');
      if (value) {
        const amount = parseInt(value);
        e.target.value = amount.toLocaleString('id-ID');
        selectAmount(amount);
        
        document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('selected'));
      } else {
        selectAmount(0);
      }
    });

    // Select amount
    function selectAmount(amount) {
      selectedAmount = amount;
      
      if (amount >= creditPriceIDR) {
        const credits = Math.floor(amount / creditPriceIDR);
        document.getElementById('creditsPreview').classList.remove('hidden');
        document.getElementById('creditsAmount').textContent = credits;
        
        updateSummary();
        checkFormValidity();
      } else {
        document.getElementById('creditsPreview').classList.add('hidden');
      }
    }

    // Select payment method
    function selectPaymentMethod(code, name) {
      selectedPaymentMethod = { code, name };
      
      document.querySelectorAll('.payment-channel-card').forEach(card => {
        card.classList.remove('selected');
      });
      
      document.querySelector(`[data-code="${code}"]`).classList.add('selected');
      
      if (selectedAmount >= creditPriceIDR) {
        calculateFee();
      }
      
      checkFormValidity();
    }

    // Calculate fee
    async function calculateFee() {
      if (!selectedAmount || !selectedPaymentMethod) return;
      
      try {
        const response = await fetch('/api/payment/calculate-fee', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            amount: selectedAmount,
            paymentMethod: selectedPaymentMethod.code
          })
        });
        
        const data = await response.json();
        
        if (data.success) {
          updateSummary(data.data);
        }
      } catch (error) {
        console.error('Error calculating fee:', error);
      }
    }

    // Update summary
    function updateSummary(feeData = null) {
      const credits = Math.floor(selectedAmount / creditPriceIDR);
      const totalCreditsWithBonus = credits + voucherBonus;
      
      document.getElementById('summaryAmount').textContent = 
        selectedAmount > 0 ? `Rp ${selectedAmount.toLocaleString('id-ID')}` : 'Rp 0';
      
      document.getElementById('summaryCredits').textContent = 
        credits > 0 ? `${credits} Credits` : '0 Credits';
      
      // Show/hide voucher bonus row
      if (voucherBonus > 0) {
        document.getElementById('voucherBonusRow').classList.remove('hidden');
        document.getElementById('voucherBonusAmount').textContent = `+${voucherBonus} Credits`;
      } else {
        document.getElementById('voucherBonusRow').classList.add('hidden');
      }
      
      // Update total credits
      document.getElementById('totalCredits').textContent = 
        totalCreditsWithBonus > 0 ? `${totalCreditsWithBonus}` : '0';
      
      if (feeData) {
        const fee = feeData.fee.customer || 0;
        const total = feeData.totalAmount || selectedAmount;
        
        document.getElementById('summaryFee').textContent = `Rp ${fee.toLocaleString('id-ID')}`;
        document.getElementById('summaryTotal').textContent = `Rp ${total.toLocaleString('id-ID')}`;
      } else {
        document.getElementById('summaryFee').textContent = 'Rp 0';
        document.getElementById('summaryTotal').textContent = `Rp ${selectedAmount.toLocaleString('id-ID')}`;
      }
    }

    // Check form validity
    function checkFormValidity() {
      const submitBtn = document.getElementById('submitPayment');
      
      if (selectedAmount >= creditPriceIDR && selectedPaymentMethod) {
        submitBtn.disabled = false;
      } else {
        submitBtn.disabled = true;
      }
    }

    // Submit payment
    document.getElementById('submitPayment').addEventListener('click', async function() {
      if (!selectedAmount || !selectedPaymentMethod) return;
      
      this.disabled = true;
      this.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Memproses...';
      
      try {
        const requestData = {
          amount: selectedAmount,
          paymentMethod: selectedPaymentMethod.code
        };
        
        // Add voucher code if applied
        if (appliedVoucher) {
          requestData.voucherCode = appliedVoucher.code;
        }
        
        const response = await fetch('/api/payment/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(requestData)
        });
        
        const data = await response.json();
        
        if (data.success) {
          showPaymentModal(data.data);
        } else {
          // Check if it's a pending transaction limit error
          if (response.status === 429) {
            showPendingLimitError(data);
          } else {
            alert('Gagal membuat pembayaran: ' + data.message);
          }
          this.disabled = false;
          this.innerHTML = '<i class="fas fa-credit-card mr-2"></i>Lanjutkan Pembayaran';
        }
      } catch (error) {
        console.error('Error creating payment:', error);
        alert('Terjadi kesalahan saat membuat pembayaran');
        this.disabled = false;
        this.innerHTML = '<i class="fas fa-credit-card mr-2"></i>Lanjutkan Pembayaran';
      }
    });

    // Show pending limit error
    function showPendingLimitError(data) {
      const { pending_count, time_remaining, message } = data;
      
      const errorHTML = `
        <div class="fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center z-[9999] p-4" id="pendingLimitErrorModal">
          <div class="bg-gradient-to-br from-zinc-900 to-zinc-950 rounded-2xl shadow-2xl max-w-md w-full border border-red-500/30">
            <div class="p-6">
              <!-- Error Icon -->
              <div class="flex justify-center mb-4">
                <div class="w-16 h-16 bg-red-500/20 rounded-full flex items-center justify-center">
                  <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                  </svg>
                </div>
              </div>
              
              <!-- Title -->
              <h3 class="text-xl font-bold text-white text-center mb-2">
                Transaksi Pending Maksimal
              </h3>
              
              <!-- Message -->
              <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 mb-4">
                <p class="text-sm text-gray-300 text-center leading-relaxed">
                  ${message}
                </p>
              </div>
              
              <!-- Info -->
              <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 mb-4">
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-yellow-400 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <div>
                    <p class="text-sm font-medium text-yellow-400">Apa yang harus dilakukan?</p>
                    <ul class="text-xs text-gray-300 mt-2 space-y-1 list-disc list-inside">
                      <li>Selesaikan pembayaran yang pending</li>
                      <li>Atau tunggu hingga transaksi kadaluarsa${time_remaining ? ` (${time_remaining})` : ''}</li>
                      <li>Maksimal 3 transaksi pending aktif</li>
                    </ul>
                  </div>
                </div>
              </div>
              
              <!-- Actions -->
              <div class="flex gap-3">
                <button onclick="closePendingLimitError()" class="flex-1 px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl transition-all font-medium">
                  Tutup
                </button>
                <a href="/billing" class="flex-1 px-4 py-3 bg-gradient-to-r from-red-500 to-red-600 hover:from-red-400 hover:to-red-500 text-white rounded-xl transition-all font-bold text-center shadow-lg shadow-red-500/20">
                  Lihat Transaksi
                </a>
              </div>
            </div>
          </div>
        </div>
      `;
      
      // Remove existing error modal if any
      const existingModal = document.getElementById('pendingLimitErrorModal');
      if (existingModal) existingModal.remove();
      
      // Add to body
      document.body.insertAdjacentHTML('beforeend', errorHTML);
    }
    
    // Close pending limit error
    function closePendingLimitError() {
      const modal = document.getElementById('pendingLimitErrorModal');
      if (modal) modal.remove();
    }

    // Show payment modal
    function showPaymentModal(paymentData) {
      const modal = document.getElementById('paymentModal');
      const content = document.getElementById('paymentModalContent');
      
      let html = `
        <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 mb-6">
          <div class="flex items-center">
            <i class="fas fa-check-circle text-green-400 text-2xl mr-3"></i>
            <div>
              <p class="font-bold text-green-400">Pembayaran Berhasil Dibuat!</p>
              <p class="text-sm text-gray-300">Silakan selesaikan pembayaran sebelum expired</p>
            </div>
          </div>
        </div>

        <div class="space-y-3">
          <div class="flex justify-between py-2 border-b border-white/10">
            <span class="text-gray-400">Metode Pembayaran</span>
            <span class="font-semibold text-white">${paymentData.paymentName}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-white/10">
            <span class="text-gray-400">Jumlah</span>
            <span class="font-semibold text-white">Rp ${paymentData.amount.toLocaleString('id-ID')}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-white/10">
            <span class="text-gray-400">Credits</span>
            <span class="font-semibold text-yellow-400">+${paymentData.creditsAmount} Credits</span>
          </div>
          <div class="flex justify-between py-3 bg-yellow-500/10 border border-yellow-500/20 rounded-xl px-4">
            <span class="font-bold text-white">Total Bayar</span>
            <span class="font-bold text-2xl text-yellow-400 font-mono">Rp ${paymentData.amountReceived.toLocaleString('id-ID')}</span>
          </div>
        </div>
      `;

      // Payment instructions
      if (paymentData.payCode) {
        html += `
          <div class="mt-6 p-4 bg-yellow-500/10 border border-yellow-500/30 rounded-xl">
            <p class="font-bold text-white mb-3">Kode Pembayaran:</p>
            <div class="flex items-center justify-between bg-zinc-800/50 p-3 rounded-lg border-2 border-dashed border-yellow-500/50">
              <code class="text-2xl font-mono font-bold text-yellow-400">${paymentData.payCode}</code>
              <button onclick="copyToClipboard('${paymentData.payCode}')" class="px-4 py-2 bg-gradient-to-r from-yellow-500 to-yellow-600 hover:from-yellow-400 hover:to-yellow-500 text-black font-bold rounded-lg transition-all shadow-lg shadow-yellow-500/20">
                <i class="fas fa-copy mr-1"></i> Copy
              </button>
            </div>
          </div>
        `;
      }

      if (paymentData.qrUrl) {
        html += `
          <div class="mt-6 text-center">
            <p class="font-bold text-white mb-4">Scan QR Code:</p>
            <div class="inline-block p-4 bg-white rounded-xl">
              <img src="${paymentData.qrUrl}" alt="QR Code" class="w-64 h-64 object-contain">
            </div>
          </div>
        `;
      }

      html += `
        <div class="mt-6 flex gap-3">
          ${paymentData.checkoutUrl ? `
            <a href="${paymentData.checkoutUrl}" target="_blank" class="flex-1 px-4 py-3 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 text-white font-bold rounded-xl text-center shadow-lg transition-all">
              <i class="fas fa-external-link-alt mr-2"></i>
              Bayar Sekarang
            </a>
          ` : ''}
          <button onclick="closePaymentModal(); location.reload();" class="flex-1 px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold rounded-xl transition-all">
            Tutup
          </button>
        </div>

        <div class="mt-4 p-3 bg-blue-500/10 border border-blue-500/20 rounded-lg">
          <p class="text-xs text-gray-300 text-center">
            <i class="fas fa-clock mr-1 text-blue-400"></i>
            Pembayaran akan expired pada: <strong class="text-blue-400">${new Date(paymentData.expiredTime * 1000).toLocaleString('id-ID')}</strong>
          </p>
        </div>
      `;

      content.innerHTML = html;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    // Close modal
    function closePaymentModal() {
      const modal = document.getElementById('paymentModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    // Copy to clipboard
    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => {
        // Show toast notification
        const toast = document.createElement('div');
        toast.className = 'fixed top-24 right-4 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-2xl z-[10000] animate-fade-in';
        toast.innerHTML = '<i class="fas fa-check-circle mr-2"></i>Kode berhasil dicopy!';
        document.body.appendChild(toast);
        
        setTimeout(() => {
          toast.style.opacity = '0';
          setTimeout(() => toast.remove(), 300);
        }, 2000);
      });
    }

    // Apply Voucher
    async function applyVoucher() {
      const input = document.getElementById('voucherCode');
      const button = document.getElementById('applyVoucherBtn');
      const resultDiv = document.getElementById('voucherResult');
      const code = input.value.trim().toUpperCase();
      
      if (!code) {
        showVoucherResult('⚠️ Masukkan kode voucher terlebih dahulu', 'error');
        return;
      }
      
      const originalHTML = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
      
      try {
        const response = await fetch('/api/user/promo/validate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code })
        });
        
        const data = await response.json();
        
        if (data.success) {
          const promo = data.promo;
          appliedVoucher = promo;
          voucherBonus = promo.credits_bonus || 0;
          
          // Show success
          resultDiv.className = 'p-4 bg-green-500/10 border border-green-500/30 rounded-lg animate-fade-in';
          resultDiv.innerHTML = `
            <div class="flex items-start gap-3">
              <i class="fas fa-check-circle text-green-400 text-xl mt-0.5"></i>
              <div class="flex-1">
                <h4 class="font-bold text-green-400 mb-1">Voucher Valid!</h4>
                <p class="text-sm text-gray-300 mb-2">${promo.description || 'Kode voucher berhasil diterapkan'}</p>
                ${promo.credits_bonus > 0 ? `
                  <div class="flex items-center gap-2 text-violet-400 font-semibold">
                    <i class="fas fa-gift"></i>
                    <span>+${promo.credits_bonus} Bonus Credits</span>
                  </div>
                ` : ''}
                <p class="text-xs text-gray-400 mt-2">
                  <i class="fas fa-info-circle mr-1"></i>
                  Bonus akan ditambahkan setelah pembayaran
                </p>
              </div>
            </div>
          `;
          resultDiv.classList.remove('hidden');
          
          // Disable input and button
          input.disabled = true;
          button.innerHTML = '<i class="fas fa-check mr-1"></i> Applied';
          button.classList.add('opacity-50', 'cursor-not-allowed');
          
          // Update summary
          updateSummary();
          
        } else {
          // Show error
          resultDiv.className = 'p-4 bg-red-500/10 border border-red-500/30 rounded-lg animate-fade-in';
          resultDiv.innerHTML = `
            <div class="flex items-start gap-3">
              <i class="fas fa-times-circle text-red-400 text-xl mt-0.5"></i>
              <div>
                <h4 class="font-bold text-red-400 mb-1">Voucher Tidak Valid</h4>
                <p class="text-sm text-gray-300">${data.message || 'Kode voucher tidak valid atau sudah kadaluarsa'}</p>
              </div>
            </div>
          `;
          resultDiv.classList.remove('hidden');
          
          button.disabled = false;
          button.innerHTML = originalHTML;
        }
      } catch (error) {
        console.error('Error applying voucher:', error);
        showVoucherResult('❌ Gagal memvalidasi voucher', 'error');
        button.disabled = false;
        button.innerHTML = originalHTML;
      }
    }
    
    // Show voucher result
    function showVoucherResult(message, type) {
      const resultDiv = document.getElementById('voucherResult');
      const bgClass = type === 'error' ? 'bg-red-500/10 border-red-500/30' : 'bg-yellow-500/10 border-yellow-500/30';
      const iconClass = type === 'error' ? 'fas fa-times-circle text-red-400' : 'fas fa-info-circle text-yellow-400';
      
      resultDiv.className = `p-3 ${bgClass} border rounded-lg animate-fade-in`;
      resultDiv.innerHTML = `
        <div class="flex items-center gap-2">
          <i class="${iconClass}"></i>
          <p class="text-sm text-gray-300">${message}</p>
        </div>
      `;
      resultDiv.classList.remove('hidden');
      
      setTimeout(() => {
        resultDiv.classList.add('hidden');
      }, 3000);
    }
    
    // Allow Enter key on voucher input
    document.addEventListener('DOMContentLoaded', function() {
      loadPaymentChannels();
      
      const voucherInput = document.getElementById('voucherCode');
      if (voucherInput) {
        voucherInput.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            applyVoucher();
          }
        });
      }
      
      // Check pending transactions on page load
      checkPendingTransactionsOnLoad();
    });
    
    // Check pending transactions and show banner if needed
    async function checkPendingTransactionsOnLoad() {
      try {
        const response = await fetch('/api/payment/check-pending');
        const data = await response.json();
        
        if (data.pending_count > 0) {
          showPendingBanner(data);
        }
      } catch (error) {
        console.error('Error checking pending transactions:', error);
      }
    }
    
    // Show pending transactions banner
    function showPendingBanner(data) {
      const { pending_count, can_create_new, time_remaining } = data;
      
      const bannerColor = can_create_new ? 'yellow' : 'red';
      const bannerIcon = can_create_new ? 
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>' : 
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>';
      
      const bannerHTML = `
        <div class="glass-card border-l-4 border-${bannerColor}-400 p-4 mb-6 relative z-10" id="pendingBanner">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-${bannerColor}-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                ${bannerIcon}
              </svg>
            </div>
            <div class="ml-3 flex-1">
              <h3 class="text-sm font-medium text-${bannerColor}-800">
                ${can_create_new ? 'Informasi Transaksi' : 'Batas Transaksi Tercapai'}
              </h3>
              <div class="mt-2 text-sm text-${bannerColor}-700">
                <p>
                  ${can_create_new 
                    ? `Anda memiliki ${pending_count} transaksi pending. Anda masih dapat membuat ${3 - pending_count} transaksi lagi.`
                    : `Anda memiliki ${pending_count} transaksi pending (maksimal 3). Silakan selesaikan pembayaran atau tunggu hingga transaksi kadaluarsa${time_remaining ? ` (${time_remaining})` : ''}.`
                  }
                </p>
              </div>
              <div class="mt-4">
                <div class="-mx-2 -my-1.5 flex">
                  <a href="/billing" class="bg-${bannerColor}-100 px-3 py-2 rounded-md text-sm font-medium text-${bannerColor}-800 hover:bg-${bannerColor}-200 transition-colors">
                    Lihat Transaksi
                  </a>
                  <button onclick="document.getElementById('pendingBanner').remove()" class="ml-3 bg-${bannerColor}-100 px-3 py-2 rounded-md text-sm font-medium text-${bannerColor}-800 hover:bg-${bannerColor}-200 transition-colors">
                    Tutup
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      `;
      
      // Insert banner at the top of the form
      const container = document.querySelector('.max-w-7xl.mx-auto');
      if (container) {
        const firstChild = container.firstElementChild;
        firstChild.insertAdjacentHTML('afterbegin', bannerHTML);
      }
    }
  </script>

</body>
</html>

