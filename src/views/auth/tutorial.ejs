<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="/css/generation-styles.css">
    <script src="/js/theme-manager.js"></script>
    
    <style>
        .tutorial-step {
            scroll-margin-top: 100px;
        }
        
        .tutorial-nav {
            position: sticky;
            top: 80px;
            max-height: calc(100vh - 100px);
            overflow-y: auto;
        }
        
        .tutorial-nav::-webkit-scrollbar {
            width: 4px;
        }
        
        .tutorial-nav::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
        }
        
        .tutorial-nav::-webkit-scrollbar-thumb {
            background: rgba(139, 92, 246, 0.5);
            border-radius: 10px;
        }
        
        .tutorial-nav::-webkit-scrollbar-thumb:hover {
            background: rgba(139, 92, 246, 0.7);
        }
        
        .video-placeholder {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(219, 39, 119, 0.1));
            border: 2px dashed rgba(139, 92, 246, 0.3);
        }
        
        .image-placeholder {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(16, 185, 129, 0.1));
            border: 2px dashed rgba(59, 130, 246, 0.3);
        }
    </style>
</head>
<body class="text-white bg-zinc-950">
    <!-- Mobile Header -->
    <%- include('../partials/mobile-header') %>
    
    <!-- Top Bar (Same as Dashboard) - Hidden on Mobile -->
    <div class="hidden lg:block border-b border-white/10 bg-zinc-950/50 backdrop-blur-xl sticky top-0 z-50">
        <div class="px-8 py-4 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a href="/" class="flex items-center gap-3">
                    <img src="/assets/img/logo/logo.png" alt="PixelNest Logo" class="h-10 w-auto">
                    <span class="font-black text-lg">PIXELNEST</span>
                </a>
                <span class="text-gray-600">/</span>
                <h2 class="text-sm font-semibold text-gray-400">Tutorial</h2>
            </div>
            
            <div class="flex items-center gap-6">
                <a href="/dashboard" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
                    <span class="relative z-10">Dashboard</span>
                    <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
                </a>
                <a href="/explore" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
                    <span class="relative z-10">Explore</span>
                    <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
                </a>
                <a href="/tutorial" class="relative text-sm text-white font-semibold transition-all duration-300 group">
                    <span class="relative z-10">Tutorial</span>
                    <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-100 transition-opacity duration-300"></span>
                    <span class="absolute bottom-0 left-0 w-full h-0.5 bg-white transition-all duration-300"></span>
                </a>
                <a href="/billing" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
                    <span class="relative z-10">Billing</span>
                    <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
                </a>
                
                <!-- Credits Display with Top-up Button -->
                <div class="flex items-center gap-2">
                    <div class="relative px-3 py-1.5 bg-yellow-500/10 border border-yellow-500/20 rounded-lg group hover:border-yellow-500/40 transition-all duration-300 hover:scale-105 cursor-default">
                        <span class="absolute inset-0 bg-yellow-500/5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                        <div class="flex items-center gap-2 relative z-10">
                            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                            </svg>
                            <span class="text-sm font-bold text-yellow-400 font-mono"><%= (user.credits || 0).toFixed(1) %></span>
                        </div>
                    </div>
                    
                    <a href="/billing" class="relative group flex items-center justify-center w-8 h-8 bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-lg hover:from-yellow-400 hover:to-yellow-500 transition-all duration-300 hover:scale-110 hover:rotate-90 shadow-lg shadow-yellow-500/20 hover:shadow-yellow-500/40" title="Top Up Credits">
                        <span class="absolute inset-0 bg-white/20 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                        <svg class="w-5 h-5 text-white relative z-10 font-bold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                        </svg>
                    </a>
                </div>
                
                <!-- Profile Dropdown -->
                <div class="relative">
                    <button id="profile-btn" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
                        <% if (user && user.avatar_url) { %>
                            <img src="<%= user.avatar_url %>" alt="<%= user.name %>" class="w-8 h-8 rounded-full border-2 border-violet-500">
                        <% } else if (user) { %>
                            <div class="w-8 h-8 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-full flex items-center justify-center text-xs font-bold">
                                <%= user.name.charAt(0).toUpperCase() %>
                            </div>
                        <% } %>
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    
                    <div id="profile-dropdown" class="hidden absolute right-0 mt-2 w-56 bg-zinc-900 border border-white/10 rounded-lg shadow-xl overflow-hidden z-[10000]">
                        <div class="px-4 py-3 border-b border-white/10">
                            <p class="text-sm font-semibold text-white"><%= user.name %></p>
                            <p class="text-xs text-gray-400 truncate"><%= user.email %></p>
                        </div>
                        <div class="py-2">
                            <a href="/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                Profile
                            </a>
                            <a href="/feature-request" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                Request Model AI
                            </a>
                            <a href="/usage" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                                </svg>
                                Usage
                            </a>
                            <a href="/billing" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                                </svg>
                                Billing
                            </a>
                            <a href="/referral/dashboard" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors group">
                                <svg class="w-4 h-4 text-yellow-400 group-hover:text-yellow-300 transition-colors" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                                </svg>
                                Referral Program
                            </a>
                        </div>
                        <% if (user.role === 'admin') { %>
                            <div class="border-t border-white/10">
                                <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2 text-sm text-violet-400 hover:bg-violet-500/10 hover:text-violet-300 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                    Admin Panel
                                </a>
                            </div>
                        <% } %>
                        <div class="border-t border-white/10">
                            <a href="/logout" class="flex items-center gap-3 px-4 py-2 text-sm text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                </svg>
                                Logout
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="min-h-screen pt-20 lg:pt-8 py-8 px-4 lg:px-8 pb-24">
        <div class="max-w-7xl mx-auto">
            <!-- Hero Section -->
            <div class="mb-12 text-center">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-violet-500/10 to-fuchsia-500/10 border border-violet-500/20 rounded-full mb-6">
                    <i class="fas fa-graduation-cap text-violet-400"></i>
                    <span class="text-sm font-semibold text-violet-300">PANDUAN LENGKAP</span>
                </div>
                <h1 class="text-5xl font-bold bg-gradient-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent mb-4">
                    Tutorial PixelNest
                </h1>
                <p class="text-xl text-gray-400 max-w-2xl mx-auto">
                    Pelajari cara menggunakan PixelNest AI Video Studio untuk membuat konten visual yang menakjubkan
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
                <!-- Sidebar Navigation -->
                <div class="lg:col-span-1">
                    <div class="tutorial-nav glass-strong rounded-2xl p-6">
                        <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Daftar Isi</h3>
                        <nav class="space-y-2">
                            <a href="#getting-started" class="block px-4 py-2 text-sm rounded-lg hover:bg-white/5 transition-colors text-gray-300 hover:text-white">
                                <i class="fas fa-rocket w-4 mr-2 text-violet-400"></i>
                                Memulai
                            </a>
                            <a href="#dashboard-overview" class="block px-4 py-2 text-sm rounded-lg hover:bg-white/5 transition-colors text-gray-300 hover:text-white">
                                <i class="fas fa-th-large w-4 mr-2 text-blue-400"></i>
                                Overview Dashboard
                            </a>
                            <a href="#generate-image" class="block px-4 py-2 text-sm rounded-lg hover:bg-white/5 transition-colors text-gray-300 hover:text-white">
                                <i class="fas fa-image w-4 mr-2 text-green-400"></i>
                                Generate Image
                            </a>
                            <a href="#generate-video" class="block px-4 py-2 text-sm rounded-lg hover:bg-white/5 transition-colors text-gray-300 hover:text-white">
                                <i class="fas fa-video w-4 mr-2 text-fuchsia-400"></i>
                                Generate Video
                            </a>
                            <a href="#models-guide" class="block px-4 py-2 text-sm rounded-lg hover:bg-white/5 transition-colors text-gray-300 hover:text-white">
                                <i class="fas fa-brain w-4 mr-2 text-purple-400"></i>
                                Memilih Model AI
                            </a>
                            <a href="#credits-topup" class="block px-4 py-2 text-sm rounded-lg hover:bg-white/5 transition-colors text-gray-300 hover:text-white">
                                <i class="fas fa-coins w-4 mr-2 text-yellow-400"></i>
                                Top-up Credits
                            </a>
                            <a href="#gallery-usage" class="block px-4 py-2 text-sm rounded-lg hover:bg-white/5 transition-colors text-gray-300 hover:text-white">
                                <i class="fas fa-images w-4 mr-2 text-cyan-400"></i>
                                Menggunakan Gallery
                            </a>
                            <a href="#tips-tricks" class="block px-4 py-2 text-sm rounded-lg hover:bg-white/5 transition-colors text-gray-300 hover:text-white">
                                <i class="fas fa-lightbulb w-4 mr-2 text-orange-400"></i>
                                Tips & Tricks
                            </a>
                        </nav>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="lg:col-span-3 space-y-8">
                    <!-- Step 1: Getting Started -->
                    <section id="getting-started" class="tutorial-step glass-strong rounded-2xl overflow-hidden">
                        <div class="px-8 py-6 bg-gradient-to-r from-violet-500/10 to-fuchsia-500/10 border-b border-white/10">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 bg-gradient-to-br from-violet-500 to-fuchsia-600 rounded-xl flex items-center justify-center">
                                    <i class="fas fa-rocket text-white text-xl"></i>
                                </div>
                                <div>
                                    <span class="text-xs font-semibold text-violet-400 uppercase tracking-wider">STEP 1</span>
                                    <h2 class="text-2xl font-bold">Memulai dengan PixelNest</h2>
                                </div>
                            </div>
                        </div>
                        
                        <div class="p-8 space-y-6">
                            <p class="text-gray-300 leading-relaxed">
                                Selamat datang di PixelNest! Platform AI Video Studio yang memudahkan Anda membuat konten visual berkualitas tinggi hanya dengan deskripsi teks.
                            </p>
                            
                            <div class="space-y-4">
                                <h3 class="text-lg font-semibold text-white flex items-center gap-2">
                                    <i class="fas fa-check-circle text-green-400"></i>
                                    Apa yang Anda Butuhkan:
                                </h3>
                                <ul class="space-y-3 ml-6">
                                    <li class="flex items-start gap-3 text-gray-300">
                                        <span class="w-6 h-6 bg-violet-500/20 border border-violet-500/30 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                                            <span class="text-xs font-bold text-violet-400">1</span>
                                        </span>
                                        <div>
                                            <strong class="text-white">Akun PixelNest</strong> - Sudah punya! ✓
                                        </div>
                                    </li>
                                    <li class="flex items-start gap-3 text-gray-300">
                                        <span class="w-6 h-6 bg-violet-500/20 border border-violet-500/30 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                                            <span class="text-xs font-bold text-violet-400">2</span>
                                        </span>
                                        <div>
                                            <strong class="text-white">Credits</strong> - Diperlukan untuk generate (lihat section Top-up Credits)
                                        </div>
                                    </li>
                                    <li class="flex items-start gap-3 text-gray-300">
                                        <span class="w-6 h-6 bg-violet-500/20 border border-violet-500/30 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                                            <span class="text-xs font-bold text-violet-400">3</span>
                                        </span>
                                        <div>
                                            <strong class="text-white">Ide/Deskripsi</strong> - Apa yang ingin Anda buat?
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </section>

                    <!-- Step 2: Dashboard Overview -->
                    <section id="dashboard-overview" class="tutorial-step glass-strong rounded-2xl overflow-hidden">
                        <div class="px-8 py-6 bg-gradient-to-r from-blue-500/10 to-cyan-500/10 border-b border-white/10">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-xl flex items-center justify-center">
                                    <i class="fas fa-th-large text-white text-xl"></i>
                                </div>
                                <div>
                                    <span class="text-xs font-semibold text-blue-400 uppercase tracking-wider">STEP 2</span>
                                    <h2 class="text-2xl font-bold">Overview Dashboard</h2>
                                </div>
                            </div>
                        </div>
                        
                        <div class="p-8 space-y-6">
                            <p class="text-gray-300 leading-relaxed">
                                Dashboard adalah pusat kontrol Anda. Di sini Anda bisa membuat generasi baru dan melihat hasil real-time.
                            </p>
                            
                            <!-- Video/Image Placeholder -->
                            <div class="video-placeholder rounded-xl p-8 flex items-center justify-center aspect-video">
                                <div class="text-center">
                                    <i class="fas fa-play-circle text-6xl text-violet-400 mb-4"></i>
                                    <p class="text-lg font-semibold text-white mb-2">Video Tutorial: Dashboard Overview</p>
                                    <p class="text-sm text-gray-400">[Placeholder - Video akan ditambahkan]</p>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="glass rounded-xl p-4">
                                    <div class="flex items-center gap-3 mb-3">
                                        <div class="w-10 h-10 bg-violet-500/20 rounded-lg flex items-center justify-center">
                                            <i class="fas fa-sliders-h text-violet-400"></i>
                                        </div>
                                        <h4 class="font-semibold text-white">Left Panel</h4>
                                    </div>
