<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - PixelNest AI</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/favicon.png">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="/css/mobile-navbar.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: #0a0a0a;
      min-height: 100vh;
      font-family: 'Space Grotesk', sans-serif;
    }
    
    .transaction-card {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .transaction-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(251, 191, 36, 0.15);
    }
    
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 9999px;
      font-size: 12px;
      font-weight: 600;
    }
    
    .status-badge.paid {
      background: rgba(16, 185, 129, 0.2);
      color: #10b981;
      border: 1px solid rgba(16, 185, 129, 0.3);
    }
    
    .status-badge.unpaid {
      background: rgba(251, 191, 36, 0.2);
      color: #fbbf24;
      border: 1px solid rgba(251, 191, 36, 0.3);
    }
    
    .status-badge.expired {
      background: rgba(239, 68, 68, 0.2);
      color: #ef4444;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }
    
    .status-badge.failed {
      background: rgba(156, 163, 175, 0.2);
      color: #9ca3af;
      border: 1px solid rgba(156, 163, 175, 0.3);
    }
  </style>
</head>
<body class="bg-zinc-950 text-white">
  <!-- Mobile Header -->
  <%- include('../partials/mobile-header') %>
  
  <!-- Top Navigation Bar (Hidden on mobile) -->
  <div class="hidden lg:block border-b border-white/10 bg-zinc-950/50 backdrop-blur-xl sticky top-0 z-50">
    <div class="px-8 py-4 flex items-center justify-between">
      <!-- Logo & Title -->
      <div class="flex items-center gap-4">
        <a href="/dashboard" class="flex items-center gap-3">
          <img src="/assets/img/logo/logo.png" alt="PixelNest Logo" class="h-10 w-auto">
          <span class="font-black text-lg">PIXELNEST</span>
        </a>
        <span class="text-gray-600">/</span>
        <h2 class="text-sm font-semibold text-gray-400">Billing & History</h2>
      </div>
      
      <!-- Navigation Links -->
      <div class="flex items-center gap-6">
        <a href="/dashboard" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
          <span class="relative z-10">Dashboard</span>
          <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/explore" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
          <span class="relative z-10">Explore</span>
          <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/tutorial" class="relative text-sm text-gray-400 hover:text-white transition-all duration-300 hover:scale-110 group">
          <span class="relative z-10">Tutorial</span>
          <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-white group-hover:w-full transition-all duration-300"></span>
        </a>
        <a href="/billing" class="relative text-sm text-white font-semibold transition-all duration-300 group">
          <span class="relative z-10">Billing</span>
          <span class="absolute inset-0 -z-10 bg-gradient-to-r from-white/0 via-white/10 to-white/0 rounded-lg blur-sm opacity-100 transition-opacity duration-300"></span>
          <span class="absolute bottom-0 left-0 w-full h-0.5 bg-white transition-all duration-300"></span>
        </a>
        
        <!-- Credits Display -->
        <div class="flex items-center gap-2">
          <div class="relative px-3 py-1.5 bg-yellow-500/10 border border-yellow-500/20 rounded-lg group hover:border-yellow-500/40 transition-all duration-300 hover:scale-105 cursor-default">
            <span class="absolute inset-0 bg-yellow-500/5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
            <div class="flex items-center gap-2 relative z-10">
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm font-bold text-yellow-400 font-mono"><%= (user.credits || 0).toFixed(1) %></span>
            </div>
          </div>
          
          <!-- Top-up Button -->
          <a href="/api/payment/top-up" class="relative group flex items-center justify-center w-8 h-8 bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-lg hover:from-yellow-400 hover:to-yellow-500 transition-all duration-300 hover:scale-110 hover:rotate-90 shadow-lg shadow-yellow-500/20 hover:shadow-yellow-500/40" title="Top Up Credits">
            <span class="absolute inset-0 bg-white/20 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
            <svg class="w-5 h-5 text-white relative z-10 font-bold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
          </a>
        </div>
        
        <!-- Profile Dropdown -->
        <div class="relative">
          <button id="profile-btn" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <% if (user && user.avatar_url) { %>
              <img src="<%= user.avatar_url %>" alt="<%= user.name %>" class="w-8 h-8 rounded-full border-2 border-violet-500">
            <% } else if (user) { %>
              <div class="w-8 h-8 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-full flex items-center justify-center text-xs font-bold">
                <%= user.name.charAt(0).toUpperCase() %>
              </div>
            <% } %>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          
          <!-- Dropdown Menu -->
                    <div id="profile-dropdown" class="hidden absolute right-0 mt-2 w-56 bg-zinc-900 border border-white/10 rounded-lg shadow-xl overflow-hidden z-[10000]">
            <div class="px-4 py-3 border-b border-white/10">
              <p class="text-sm font-semibold text-white"><%= user.name %></p>
              <p class="text-xs text-gray-400 truncate"><%= user.email %></p>
            </div>
            <div class="py-2">
              <a href="/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                Profile
              </a>
              <a href="/feature-request" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Request Model AI
              </a>
              <a href="/usage" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
                Usage
              </a>
              <a href="/billing" class="flex items-center gap-3 px-4 py-2 text-sm text-white bg-white/5 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                </svg>
                Billing
              </a>
              <a href="/referral/dashboard" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors group">
                <svg class="w-4 h-4 text-yellow-400 group-hover:text-yellow-300 transition-colors" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                </svg>
                Referral Program
              </a>
            </div>
            <% if (user.role === 'admin') { %>
              <div class="border-t border-white/10">
                <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2 text-sm text-violet-400 hover:bg-violet-500/10 hover:text-violet-300 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  Admin Panel
                </a>
              </div>
            <% } %>
            <div class="border-t border-white/10">
              <a href="/logout" class="flex items-center gap-3 px-4 py-2 text-sm text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Logout
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="min-h-screen pt-20 lg:pt-8 py-4 lg:py-8 px-4 lg:px-8 pb-24 lg:pb-8">
    <div class="max-w-7xl mx-auto">
      
      <!-- Page Header -->
      <div class="mb-6 lg:mb-8">
        <h1 class="text-2xl lg:text-3xl font-bold bg-gradient-to-r from-yellow-400 to-yellow-600 bg-clip-text text-transparent mb-2">
          <i class="fas fa-file-invoice-dollar mr-2"></i>Billing & History
        </h1>
        <p class="text-sm lg:text-base text-gray-400">Riwayat transaksi dan pembayaran Anda</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-8">
        
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
          
          <!-- Current Balance Card -->
          <div class="bg-gradient-to-br from-zinc-900/50 to-zinc-950/50 backdrop-blur-sm border border-white/10 rounded-2xl p-6 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-yellow-500/10 to-yellow-600/10"></div>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <p class="text-sm text-gray-400 mb-1">Current Balance</p>
                  <p class="text-5xl font-bold text-yellow-400 font-mono"><%= user.credits %></p>
                  <p class="text-sm text-gray-500 mt-2">
                    Credits Available
                  </p>
                </div>
                <div class="text-7xl text-yellow-500/20">
                  <i class="fas fa-wallet"></i>
                </div>
              </div>
              <div class="pt-4 border-t border-white/10">
                <a href="/api/payment/top-up" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-yellow-500 to-yellow-600 hover:from-yellow-400 hover:to-yellow-500 text-black font-bold rounded-xl transition-all shadow-lg shadow-yellow-500/20">
                  <i class="fas fa-plus"></i>
                  Top Up Credits
                </a>
              </div>
            </div>
          </div>

          <!-- Transaction History -->
          <div class="bg-gradient-to-br from-zinc-900/50 to-zinc-950/50 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-2xl font-bold text-white">
                <i class="fas fa-history text-purple-400 mr-2"></i>
                Transaction History
              </h2>
              <select id="filterStatus" class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-sm focus:ring-2 focus:ring-yellow-500">
                <option value="all">All Status</option>
                <option value="PAID">Paid</option>
                <option value="UNPAID">Unpaid</option>
                <option value="EXPIRED">Expired</option>
                <option value="FAILED">Failed</option>
              </select>
            </div>

            <% if (transactions && transactions.length > 0) { %>
              <div class="space-y-4">
                <% transactions.forEach(tx => { %>
                  <div class="transaction-card bg-white/5 border border-white/10 rounded-xl p-5 hover:border-yellow-500/30">
                    <div class="flex items-start justify-between mb-3">
                      <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                          <h3 class="font-bold text-white text-lg"><%= tx.payment_name %></h3>
                          <span class="status-badge <%= tx.status.toLowerCase() %>">
                            <% if (tx.status === 'PAID') { %>
                              <i class="fas fa-check-circle"></i> Paid
                            <% } else if (tx.status === 'UNPAID') { %>
                              <i class="fas fa-clock"></i> Pending
                            <% } else if (tx.status === 'EXPIRED') { %>
                              <i class="fas fa-times-circle"></i> Expired
                            <% } else { %>
                              <i class="fas fa-ban"></i> Failed
                            <% } %>
                          </span>
                        </div>
                        <p class="text-gray-400 text-sm">
                          <i class="fas fa-hashtag mr-1"></i>
                          <%= tx.reference %>
                        </p>
                        <p class="text-gray-500 text-xs mt-1">
                          <i class="fas fa-calendar mr-1"></i>
                          <%= new Date(tx.created_at).toLocaleString('id-ID', { 
                            day: '2-digit', 
                            month: 'long', 
                            year: 'numeric', 
                            hour: '2-digit', 
                            minute: '2-digit' 
                          }) %>
                        </p>
                      </div>
                      <div class="text-right">
                        <p class="text-2xl font-bold text-yellow-400 font-mono">+<%= tx.credits_amount %></p>
                        <p class="text-gray-400 text-sm">credits</p>
                      </div>
                    </div>

                    <div class="flex items-center justify-between pt-3 border-t border-white/10">
                      <div class="flex items-center gap-4 text-sm">
                        <span class="text-gray-400">
                          <i class="fas fa-money-bill-wave mr-1"></i>
                          Rp <%= tx.amount.toLocaleString('id-ID') %>
                        </span>
                        <% if (tx.amount_received) { %>
                          <span class="text-green-400">
                            <i class="fas fa-arrow-right mr-1"></i>
                            Rp <%= tx.amount_received.toLocaleString('id-ID') %>
                          </span>
                        <% } %>
                      </div>
                      <div class="flex items-center gap-2">
                        <% if (tx.status === 'UNPAID') { %>
                          <button onclick="viewPaymentDetail('<%= tx.reference %>')" 
                                  class="px-4 py-2 bg-gradient-to-r from-yellow-500 to-yellow-600 hover:from-yellow-400 hover:to-yellow-500 text-black font-bold rounded-lg transition text-sm">
                            <i class="fas fa-receipt mr-1"></i>
                            Lihat Detail & Bayar
                          </button>
                          <button onclick="syncPaymentStatus('<%= tx.reference %>')" 
                                  class="px-3 py-2 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg transition text-sm border border-white/20"
                                  title="Refresh payment status">
                            <i class="fas fa-sync-alt"></i>
                          </button>
                        <% } else if (tx.status === 'PAID') { %>
                          <span class="text-green-400 text-sm font-semibold">
                            <i class="fas fa-check-circle mr-1"></i>
                            Completed
                          </span>
                        <% } %>
                      </div>
                    </div>

                    <% if (tx.pay_code && tx.status === 'UNPAID') { %>
                      <div class="mt-3 p-3 bg-yellow-500/10 border border-yellow-500/30 rounded-lg">
                        <p class="text-xs text-yellow-300 font-semibold mb-1">Payment Code:</p>
                        <div class="flex items-center justify-between">
                          <code class="text-yellow-400 font-mono font-bold"><%= tx.pay_code %></code>
                          <button onclick="copyToClipboard('<%= tx.pay_code %>')" 
                                  class="px-3 py-1 bg-yellow-500 hover:bg-yellow-400 text-black rounded text-xs font-semibold transition">
                            <i class="fas fa-copy mr-1"></i>Copy
                          </button>
                        </div>
                      </div>
                    <% } %>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="text-center py-12">
                <div class="text-gray-600 text-6xl mb-4">
                  <i class="fas fa-receipt"></i>
                </div>
                <p class="text-gray-400 text-lg mb-2">No transactions yet</p>
                <p class="text-gray-500 text-sm mb-6">Start by topping up your credits!</p>
                <a href="/api/payment/top-up" 
                   class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-yellow-500 to-yellow-600 hover:from-yellow-400 hover:to-yellow-500 text-black font-bold rounded-xl transition-all">
                  <i class="fas fa-plus"></i>
                  Top Up Now
                </a>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          
          <!-- Quick Stats -->
          <div class="bg-gradient-to-br from-zinc-900/50 to-zinc-950/50 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
            <h3 class="text-lg font-bold text-white mb-4">
              <i class="fas fa-chart-line text-blue-400 mr-2"></i>
              Statistics
            </h3>
            
            <div class="space-y-4">
              <div class="flex items-center justify-between py-3 border-b border-white/10">
                <span class="text-gray-400 text-sm">Total Transactions</span>
                <span class="text-white font-bold text-lg"><%= stats.total || 0 %></span>
              </div>
              <div class="flex items-center justify-between py-3 border-b border-white/10">
                <span class="text-gray-400 text-sm">Successful</span>
                <span class="text-green-400 font-bold text-lg"><%= stats.paid || 0 %></span>
              </div>
              <div class="flex items-center justify-between py-3 border-b border-white/10">
                <span class="text-gray-400 text-sm">Pending</span>
                <span class="text-yellow-400 font-bold text-lg"><%= stats.unpaid || 0 %></span>
              </div>
              <div class="flex items-center justify-between py-3">
                <span class="text-gray-400 text-sm">Total Spent</span>
                <span class="text-white font-bold text-lg">Rp <%= (stats.totalAmount || 0).toLocaleString('id-ID') %></span>
              </div>
            </div>
          </div>

          <!-- Recent Activity -->
          <div class="bg-gradient-to-br from-zinc-900/50 to-zinc-950/50 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
            <h3 class="text-lg font-bold text-white mb-4">
              <i class="fas fa-bolt text-yellow-400 mr-2"></i>
              Recent Activity
            </h3>
            
            <% if (recentActivity && recentActivity.length > 0) { %>
              <div class="space-y-3">
                <% recentActivity.forEach(activity => { %>
                  <div class="flex items-start gap-3 py-2">
                    <div class="w-8 h-8 bg-<%= activity.type === 'topup' ? 'green' : 'red' %>-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                      <i class="fas fa-<%= activity.type === 'topup' ? 'arrow-up' : 'arrow-down' %> text-<%= activity.type === 'topup' ? 'green' : 'red' %>-400 text-xs"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-white text-sm font-semibold truncate"><%= activity.description %></p>
                      <p class="text-gray-500 text-xs"><%= new Date(activity.created_at).toLocaleDateString('id-ID') %></p>
                    </div>
                    <span class="text-<%= activity.type === 'topup' ? 'green' : 'red' %>-400 text-sm font-bold">
                      <%= activity.type === 'topup' ? '+' : '-' %><%= activity.credits %>
                    </span>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <p class="text-gray-500 text-sm text-center py-4">No recent activity</p>
            <% } %>
          </div>

          <!-- Claim Code Card -->
          <div class="bg-gradient-to-br from-green-500/10 to-emerald-600/10 border border-green-500/30 rounded-2xl p-6">
            <h3 class="text-lg font-bold text-white mb-4">
              <i class="fas fa-gift text-green-400 mr-2"></i>
              Claim Free Credits
            </h3>
            
            <div class="space-y-4">
              <div>
                <label class="block text-sm text-gray-300 mb-2">Punya kode claim?</label>
                <div class="flex gap-2">
                  <input type="text" 
                         id="claimCodeInput" 
                         placeholder="Masukkan kode claim"
                         class="flex-1 px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:border-green-500 focus:ring-2 focus:ring-green-500/20 focus:outline-none transition-all"
                         style="text-transform: uppercase;">
                  <button onclick="claimCredits()" 
                          id="claimCodeBtn"
                          class="px-6 py-2.5 bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-400 hover:to-emerald-500 text-white font-bold rounded-lg transition-all shadow-lg shadow-green-500/20 hover:shadow-green-500/40">
                    <i class="fas fa-gift mr-1"></i>
                    Claim
                  </button>
                </div>
              </div>
              
              <!-- Claim Result -->
              <div id="claimResult" class="hidden">
                <!-- Result will be inserted here -->
              </div>
              
              <!-- Info Claim Code -->
              <div class="pt-4 border-t border-white/10">
                <p class="text-xs text-gray-400 mb-2">
                  <i class="fas fa-bolt mr-1"></i>
                  Claim code memberikan credits <strong>gratis LANGSUNG</strong> tanpa perlu pembayaran
                </p>
                <p class="text-xs text-green-400/80">
                  <i class="fas fa-check-circle mr-1"></i>
                  Credits akan <strong>otomatis ditambahkan SEKARANG</strong> ke saldo Anda
                </p>
              </div>
            </div>
          </div>

          <!-- Help Card -->
          <div class="bg-gradient-to-br from-blue-500/10 to-purple-600/10 border border-blue-500/30 rounded-2xl p-6">
            <div class="flex items-start gap-3">
              <i class="fas fa-info-circle text-blue-400 text-xl mt-1"></i>
              <div>
                <h4 class="font-bold text-white mb-2">Need Help?</h4>
                <p class="text-gray-300 text-sm mb-3">
                  Jika ada masalah dengan transaksi, silakan hubungi support kami.
                </p>
                <a href="mailto:support@pixelnest.ai" 
                   class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 text-sm font-semibold">
                  <i class="fas fa-envelope"></i>
                  Contact Support
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Profile dropdown toggle
    document.getElementById('profile-btn').addEventListener('click', function() {
      const dropdown = document.getElementById('profile-dropdown');
      dropdown.classList.toggle('hidden');
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', function(event) {
      const profileBtn = document.getElementById('profile-btn');
      const dropdown = document.getElementById('profile-dropdown');
      
      if (!profileBtn.contains(event.target) && !dropdown.contains(event.target)) {
        dropdown.classList.add('hidden');
      }
    });

    // Filter transactions by status
    document.getElementById('filterStatus').addEventListener('change', function() {
      const status = this.value.toUpperCase();
      const cards = document.querySelectorAll('.transaction-card');
      
      cards.forEach(card => {
        const statusBadge = card.querySelector('.status-badge');
        const cardStatus = statusBadge.textContent.trim().toUpperCase();
        
        if (status === 'ALL' || cardStatus.includes(status)) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });

    // Sync payment status from Tripay
    async function syncPaymentStatus(reference) {
      const button = event.currentTarget;
      const originalHTML = button.innerHTML;
      
      // Disable button and show loading
      button.disabled = true;
      button.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Syncing...';
      
      try {
        const response = await fetch(`/api/payment/sync/${reference}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        });
        
        const data = await response.json();
        
        if (data.success) {
          if (data.data.newStatus === 'PAID') {
            showNotification('✅ Payment confirmed! Credits added: +' + data.data.creditsAdded, 'success');
            // Reload page after 1 second
            setTimeout(() => location.reload(), 1000);
          } else if (data.data.status === 'PAID') {
            showNotification('✅ Payment already processed', 'success');
            setTimeout(() => location.reload(), 1000);
          } else {
            showNotification('ℹ️ Status: ' + data.data.status, 'info');
            button.disabled = false;
            button.innerHTML = originalHTML;
          }
        } else {
          showNotification('❌ ' + data.message, 'error');
          button.disabled = false;
          button.innerHTML = originalHTML;
        }
      } catch (error) {
        console.error('Error syncing payment:', error);
        showNotification('❌ Failed to sync payment status', 'error');
        button.disabled = false;
        button.innerHTML = originalHTML;
      }
    }

    // Copy to clipboard
    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => {
        showNotification('✅ Payment code copied!', 'success');
      }).catch(() => {
        // Fallback
        const textArea = document.createElement('textarea');
        textArea.value = text;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand('copy');
        document.body.removeChild(textArea);
        showNotification('✅ Payment code copied!', 'success');
      });
    }

    // Show notification
    function showNotification(message, type) {
      const notification = document.createElement('div');
      let bgColor = 'bg-gray-800';
      if (type === 'success') bgColor = 'bg-green-500';
      else if (type === 'error') bgColor = 'bg-red-500';
      else if (type === 'info') bgColor = 'bg-blue-500';
      
      notification.className = `fixed top-4 right-4 px-6 py-3 rounded-xl shadow-2xl z-50 ${bgColor} text-white font-semibold animate-fade-in`;
      notification.textContent = message;
      document.body.appendChild(notification);
      
      setTimeout(() => {
        notification.style.opacity = '0';
        notification.style.transform = 'translateY(-20px)';
        notification.style.transition = 'all 0.3s ease';
        setTimeout(() => notification.remove(), 300);
      }, 3000);
    }

    // Claim Credits Function
    async function claimCredits() {
      const input = document.getElementById('claimCodeInput');
      const button = document.getElementById('claimCodeBtn');
      const resultDiv = document.getElementById('claimResult');
      const code = input.value.trim().toUpperCase();
      
      if (!code) {
        showNotification('⚠️ Masukkan kode claim terlebih dahulu', 'error');
        return;
      }
      
      const originalHTML = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Claiming...';
      
      try {
        const response = await fetch('/api/user/claim-credits', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code })
        });
        
        const data = await response.json();
        
        if (data.success) {
          // Show success result
          resultDiv.className = 'p-4 bg-green-500/10 border border-green-500/30 rounded-lg';
          resultDiv.innerHTML = `
            <div class="flex items-start gap-3">
              <i class="fas fa-check-circle text-green-400 text-2xl mt-0.5"></i>
              <div class="flex-1">
                <h4 class="font-bold text-green-400 mb-1">✓ Credits Claimed Successfully!</h4>
                <p class="text-sm text-gray-300 mb-2">${data.description}</p>
                <div class="flex gap-2 text-xs mb-3">
                  <span class="px-3 py-1.5 bg-green-500/20 text-green-300 rounded-full font-bold">
                    <i class="fas fa-coins mr-1"></i> +${data.credits_claimed} Credits
                  </span>
                  <span class="px-3 py-1.5 bg-blue-500/20 text-blue-300 rounded-full font-bold">
                    <i class="fas fa-wallet mr-1"></i> New Balance: ${data.new_balance} Credits
                  </span>
                </div>
                <p class="text-xs text-green-400/80">
                  <i class="fas fa-bolt mr-1"></i>
                  Credits telah <strong>LANGSUNG ditambahkan</strong> ke saldo Anda!
                </p>
              </div>
            </div>
          `;
          resultDiv.classList.remove('hidden');
          
          // Update credit display in header
          const creditsElements = document.querySelectorAll('[id*="credit"], .credit-display');
          creditsElements.forEach(el => {
            if (el.textContent && !isNaN(el.textContent.trim())) {
              el.textContent = data.new_balance;
            }
          });
          
          // Success notification
          showNotification(`🎉 Berhasil claim ${data.credits_claimed} credits!`, 'success');
          
          // Clear input and disable after successful claim
          input.value = '';
          input.disabled = true;
          button.disabled = true;
          button.innerHTML = '<i class="fas fa-check mr-1"></i> Claimed';
          
          // Reload page after 2 seconds to update everything
          setTimeout(() => location.reload(), 2000);
          
        } else {
          // Show error result
          resultDiv.className = 'p-4 bg-red-500/10 border border-red-500/30 rounded-lg';
          resultDiv.innerHTML = `
            <div class="flex items-start gap-3">
              <i class="fas fa-times-circle text-red-400 text-xl mt-0.5"></i>
              <div>
                <h4 class="font-bold text-red-400 mb-1">Invalid Claim Code</h4>
                <p class="text-sm text-gray-300">${data.message || 'Kode claim tidak valid atau sudah digunakan'}</p>
              </div>
            </div>
          `;
          resultDiv.classList.remove('hidden');
          
          showNotification('❌ ' + data.message, 'error');
          button.disabled = false;
          button.innerHTML = originalHTML;
        }
      } catch (error) {
        console.error('Error claiming credits:', error);
        resultDiv.className = 'p-4 bg-red-500/10 border border-red-500/30 rounded-lg';
        resultDiv.innerHTML = '<p class="text-sm text-red-400">Terjadi kesalahan. Silakan coba lagi.</p>';
        resultDiv.classList.remove('hidden');
        
        showNotification('❌ Gagal claim credits', 'error');
        button.disabled = false;
        button.innerHTML = originalHTML;
      }
    }
    
    // Allow Enter key to claim credits
    document.addEventListener('DOMContentLoaded', () => {
      const claimInput = document.getElementById('claimCodeInput');
      if (claimInput) {
        claimInput.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            claimCredits();
          }
        });
      }
      
      // Check pending transactions on page load
      checkPendingOnBillingPage();
    });
    
    // Check pending transactions and show banner if needed
    async function checkPendingOnBillingPage() {
      try {
        const response = await fetch('/api/payment/check-pending');
        if (!response.ok) return;
        
        const data = await response.json();
        
        if (data.pending_count >= 3) {
          showPendingWarningBanner(data);
        } else if (data.pending_count > 0) {
          showPendingInfoBanner(data);
        }
      } catch (error) {
        console.error('Error checking pending transactions:', error);
      }
    }
    
    // Show warning banner (3+ pending - blocked)
    function showPendingWarningBanner(data) {
      const { pending_count, time_remaining } = data;
      
      const bannerHTML = `
        <div class="bg-gradient-to-r from-red-500/20 to-red-600/20 border-l-4 border-red-500 p-4 mb-6 rounded-r-lg" id="pendingWarningBanner">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
              <div class="w-10 h-10 bg-red-500/20 rounded-full flex items-center justify-center">
                <i class="fas fa-exclamation-triangle text-red-400 text-lg"></i>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-red-400 mb-2">
                ⛔ Batas Transaksi Pending Tercapai
              </h3>
              <p class="text-sm text-gray-300 mb-3">
                Anda memiliki <strong class="text-red-400">${pending_count} transaksi pending</strong> yang belum dibayar. 
                Anda tidak dapat membuat transaksi baru hingga salah satu transaksi diselesaikan atau kadaluarsa.
              </p>
              ${time_remaining ? `
                <p class="text-xs text-gray-400 mb-3">
                  <i class="far fa-clock mr-1"></i>
                  Transaksi tertua akan kadaluarsa dalam <strong class="text-yellow-400">${time_remaining}</strong>
                </p>
              ` : ''}
              <div class="flex gap-2 flex-wrap">
                <span class="px-3 py-1 bg-red-500/20 border border-red-500/30 rounded-full text-xs text-red-300">
                  <i class="fas fa-ban mr-1"></i> Maksimal 3 transaksi pending
                </span>
                <span class="px-3 py-1 bg-yellow-500/20 border border-yellow-500/30 rounded-full text-xs text-yellow-300">
                  <i class="fas fa-hourglass-half mr-1"></i> Selesaikan atau tunggu expired
                </span>
              </div>
            </div>
            <button onclick="document.getElementById('pendingWarningBanner').remove()" class="flex-shrink-0 text-gray-400 hover:text-white transition-colors">
              <i class="fas fa-times"></i>
            </button>
          </div>
        </div>
      `;
      
      insertBannerAtTop(bannerHTML);
    }
    
    // Show info banner (1-2 pending - still allowed)
    function showPendingInfoBanner(data) {
      const { pending_count } = data;
      const remaining = 3 - pending_count;
      
      const bannerHTML = `
        <div class="bg-gradient-to-r from-yellow-500/20 to-yellow-600/20 border-l-4 border-yellow-500 p-4 mb-6 rounded-r-lg" id="pendingInfoBanner">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
              <div class="w-10 h-10 bg-yellow-500/20 rounded-full flex items-center justify-center">
                <i class="fas fa-info-circle text-yellow-400 text-lg"></i>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-yellow-400 mb-2">
                ℹ️ Informasi Transaksi Pending
              </h3>
              <p class="text-sm text-gray-300 mb-2">
                Anda memiliki <strong class="text-yellow-400">${pending_count} transaksi pending</strong>. 
                Anda masih dapat membuat <strong class="text-green-400">${remaining} transaksi lagi</strong> sebelum mencapai batas maksimal.
              </p>
              <div class="flex gap-2 flex-wrap">
                <span class="px-3 py-1 bg-yellow-500/20 border border-yellow-500/30 rounded-full text-xs text-yellow-300">
                  <i class="fas fa-layer-group mr-1"></i> ${pending_count}/3 pending
                </span>
                <span class="px-3 py-1 bg-green-500/20 border border-green-500/30 rounded-full text-xs text-green-300">
                  <i class="fas fa-check-circle mr-1"></i> ${remaining} slot tersisa
                </span>
              </div>
            </div>
            <button onclick="document.getElementById('pendingInfoBanner').remove()" class="flex-shrink-0 text-gray-400 hover:text-white transition-colors">
              <i class="fas fa-times"></i>
            </button>
          </div>
        </div>
      `;
      
      insertBannerAtTop(bannerHTML);
    }
    
    // Helper to insert banner at top of main content
    function insertBannerAtTop(html) {
      const mainContainer = document.querySelector('.max-w-7xl.mx-auto.px-8.py-8');
      if (mainContainer && mainContainer.firstElementChild) {
        mainContainer.firstElementChild.insertAdjacentHTML('afterbegin', html);
      }
    }
    
    // Clear promo code
    function clearPromoCode() {
      sessionStorage.removeItem('appliedPromoCode');
      document.getElementById('promoCodeInput').value = '';
      document.getElementById('promoCodeInput').disabled = false;
      document.getElementById('applyPromoBtn').disabled = false;
      document.getElementById('applyPromoBtn').innerHTML = '<i class="fas fa-check mr-1"></i> Apply';
      document.getElementById('promoResult').classList.add('hidden');
      showNotification('✅ Promo code removed', 'success');
    }
    
    // View payment detail
    async function viewPaymentDetail(reference) {
      try {
        // Fetch payment detail from backend
        const response = await fetch(`/api/payment/detail/${reference}`);
        const data = await response.json();
        
        if (!data.success) {
          showNotification('❌ ' + (data.message || 'Failed to load payment detail'), 'error');
          return;
        }
        
        // Show payment modal with detail
        showPaymentDetailModal(data.data);
        
      } catch (error) {
        console.error('Error loading payment detail:', error);
        showNotification('❌ Failed to load payment detail', 'error');
      }
    }
    
    // Show payment detail modal
    function showPaymentDetailModal(paymentData) {
      const modal = document.createElement('div');
      modal.id = 'paymentDetailModal';
      modal.className = 'fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center z-50 p-4';
      modal.onclick = (e) => {
        if (e.target === modal) closePaymentDetailModal();
      };
      
      // Format expired time
      const expiredTime = new Date(paymentData.expired_time);
      const now = new Date();
      const isExpired = expiredTime < now;
      
      modal.innerHTML = `
        <div class="bg-gradient-to-br from-zinc-900 to-zinc-950 border border-white/20 rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
          <!-- Header -->
          <div class="sticky top-0 bg-gradient-to-r from-yellow-500 to-yellow-600 p-6 border-b border-white/10">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-2xl font-bold text-black">
                  <i class="fas fa-receipt mr-2"></i>
                  Detail Pembayaran
                </h3>
                <p class="text-black/70 text-sm mt-1">${paymentData.payment_name}</p>
              </div>
              <button onclick="closePaymentDetailModal()" class="text-black hover:text-black/70 text-2xl transition-colors">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>
          
          <!-- Content -->
          <div class="p-6 space-y-6">
            
            ${isExpired ? `
              <div class="bg-red-500/20 border border-red-500/30 rounded-xl p-4">
                <p class="text-red-400 font-bold flex items-center gap-2">
                  <i class="fas fa-exclamation-triangle"></i>
                  Transaksi ini sudah expired
                </p>
                <p class="text-red-300 text-sm mt-1">Silakan buat transaksi baru untuk melanjutkan.</p>
              </div>
            ` : `
              <div class="bg-green-500/20 border border-green-500/30 rounded-xl p-4">
                <p class="text-green-400 font-semibold flex items-center gap-2">
                  <i class="fas fa-clock"></i>
                  Transaksi akan expired pada:
                </p>
                <p class="text-white text-lg font-bold mt-1">${expiredTime.toLocaleString('id-ID', { 
                  day: '2-digit', 
                  month: 'long', 
                  year: 'numeric', 
                  hour: '2-digit', 
                  minute: '2-digit' 
                })}</p>
              </div>
            `}
            
            <!-- QR Code (if available) -->
            ${paymentData.qr_url ? `
              <div class="bg-white/5 border border-white/10 rounded-xl p-6 text-center">
                <h4 class="text-lg font-bold text-white mb-4">
                  <i class="fas fa-qrcode mr-2 text-yellow-400"></i>
                  Scan QR Code
                </h4>
                <div class="inline-block p-4 bg-white rounded-xl">
                  <img src="${paymentData.qr_url}" alt="QR Code" class="w-64 h-64 mx-auto">
                </div>
                <p class="text-gray-400 text-sm mt-4">
                  Scan QR code di atas menggunakan aplikasi ${paymentData.payment_name}
                </p>
              </div>
            ` : ''}
            
            <!-- Payment Code (if available) -->
            ${paymentData.pay_code ? `
              <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4">
                <p class="text-yellow-300 font-semibold mb-2">
                  <i class="fas fa-hashtag mr-1"></i>
                  Payment Code:
                </p>
                <div class="flex items-center justify-between bg-black/30 rounded-lg p-3">
                  <code class="text-yellow-400 font-mono text-xl font-bold">${paymentData.pay_code}</code>
                  <button onclick="copyToClipboard('${paymentData.pay_code}')" 
                          class="px-4 py-2 bg-yellow-500 hover:bg-yellow-400 text-black rounded-lg transition font-semibold">
                    <i class="fas fa-copy mr-1"></i>Copy
                  </button>
                </div>
              </div>
            ` : ''}
            
            <!-- Payment URL (if available) -->
            ${paymentData.checkout_url ? `
              <div class="bg-violet-500/10 border border-violet-500/30 rounded-xl p-4">
                <p class="text-violet-300 font-semibold mb-2">
                  <i class="fas fa-link mr-1"></i>
                  Payment URL:
                </p>
                <a href="${paymentData.checkout_url}" target="_blank" 
                   class="block px-4 py-3 bg-gradient-to-r from-violet-500 to-violet-600 hover:from-violet-400 hover:to-violet-500 text-white rounded-lg transition font-semibold text-center">
                  <i class="fas fa-external-link-alt mr-2"></i>
                  Buka Halaman Pembayaran
                </a>
              </div>
            ` : ''}
            
            <!-- Transaction Details -->
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 space-y-3">
              <h4 class="text-lg font-bold text-white mb-3">
                <i class="fas fa-info-circle mr-2 text-blue-400"></i>
                Informasi Transaksi
              </h4>
              
              <div class="flex justify-between py-2 border-b border-white/10">
                <span class="text-gray-400">Referensi</span>
                <span class="font-mono text-white">${paymentData.reference}</span>
              </div>
              
              <div class="flex justify-between py-2 border-b border-white/10">
                <span class="text-gray-400">Metode Pembayaran</span>
                <span class="text-white font-semibold">${paymentData.payment_name}</span>
              </div>
              
              <div class="flex justify-between py-2 border-b border-white/10">
                <span class="text-gray-400">Jumlah</span>
                <span class="text-white font-semibold">Rp ${paymentData.amount.toLocaleString('id-ID')}</span>
              </div>
              
              <div class="flex justify-between py-2 border-b border-white/10">
                <span class="text-gray-400">Biaya Admin</span>
                <span class="text-white font-semibold">Rp ${(paymentData.fee_customer || 0).toLocaleString('id-ID')}</span>
              </div>
              
              <div class="flex justify-between py-3 bg-yellow-500/10 border border-yellow-500/20 rounded-xl px-4">
                <span class="font-bold text-white">Total Bayar</span>
                <span class="font-bold text-2xl text-yellow-400 font-mono">Rp ${paymentData.amount_received.toLocaleString('id-ID')}</span>
              </div>
              
              <div class="flex justify-between py-2 border-b border-white/10">
                <span class="text-gray-400">Credits</span>
                <span class="font-semibold text-yellow-400">+${paymentData.credits_amount} Credits</span>
              </div>
            </div>
            
            <!-- Actions -->
            <div class="flex gap-3">
              <button onclick="syncPaymentStatus('${paymentData.reference}')" 
                      class="flex-1 px-4 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl transition border border-white/20">
                <i class="fas fa-sync-alt mr-2"></i>
                Refresh Status
              </button>
              <button onclick="closePaymentDetailModal()" 
                      class="px-4 py-3 bg-gray-600 hover:bg-gray-700 text-white font-semibold rounded-xl transition">
                <i class="fas fa-times mr-2"></i>
                Tutup
              </button>
            </div>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
    }
    
    // Close payment detail modal
    function closePaymentDetailModal() {
      const modal = document.getElementById('paymentDetailModal');
      if (modal) {
        modal.remove();
      }
    }
    
    // Close modal on ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closePaymentDetailModal();
      }
    });
  </script>

  <!-- Mobile Navigation Bar -->
  <%- include('../partials/mobile-navbar') %>
</body>
</html>

