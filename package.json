{
  "name": "pixelnest",
  "version": "2.0.0",
  "description": "AI Automation Platform - Automate Smarter, Grow Faster",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"npm run watch:css\"",
    "worker": "node worker.js --queue=pgboss",
    "worker:custom": "node worker.js --queue=custom",
    "dev:worker": "nodemon worker.js --queue=pgboss",
    "dev:all": "concurrently \"nodemon server.js\" \"nodemon worker.js\" \"npm run watch:css\"",
    "restart:worker": "bash restart-worker.sh",
    "init-db": "node src/config/initDatabase.js",
    "setup-db": "node src/config/setupDatabase.js",
    "verify-db": "node src/config/verifyDatabase.js",
    "check-columns": "node src/config/checkColumns.js",
    "fix-columns": "node src/config/fixColumnInconsistencies.js",
    "populate-models": "node scripts/populateModels.js",
    "reset-db": "npm run setup-db && npm run populate-models && npm run verify-db",
    "reset-db:full": "node src/scripts/resetDatabase.js",
    "nuke-db": "node src/scripts/resetDatabase.js",
    "migrate:auth": "node src/config/migratePasswordAuth.js",
    "migrate:auth-columns": "node src/config/migrateAuthColumns.js",
    "migrate:email-activation": "node src/config/migrateEmailActivation.js",
    "migrate:fal": "node src/config/migrateFalAi.js",
    "migrate:models": "node src/config/migrateModels.js",
    "migrate:pricing": "node src/config/migratePricing.js",
    "migrate:sendgrid": "node src/config/migrateSendGrid.js",
    "migrate:fix-schema": "node run-migration-fix.js",
    "cleanup:jobs": "node src/scripts/cleanupExpiredJobs.js",
    "cleanup:jobs:dry-run": "node src/scripts/cleanupExpiredJobs.js --dry-run",
    "cleanup:jobs:force": "node src/scripts/cleanAllPendingJobs.js --force",
    "cleanup:jobs:preview": "node src/scripts/cleanAllPendingJobs.js --dry-run",
    "cleanup:invalid-jobs": "node src/scripts/clearInvalidJobs.js",
    "cleanup:failed-jobs": "node src/scripts/clearAllFailedJobs.js",
    "cleanup:sessions": "node src/scripts/clearStaleSessions.js",
    "update:pricing": "node src/scripts/updateFalPricing.js",
    "sync:models": "node src/scripts/syncFalModels.js",
    "cleanup:fal": "node src/scripts/cleanupFalMigration.js",
    "init-admin": "node src/config/adminDatabase.js",
    "make-admin": "node src/scripts/makeAdmin.js",
    "create-admin": "node src/scripts/createDefaultAdmin.js",
    "check-api": "node src/scripts/checkApiConfig.js",
    "fix:pricing-view": "node src/scripts/fixModelPricingView.js",
    "verify:pricing": "node src/scripts/verifyFalPricing.js",
    "check:sora": "node src/scripts/checkAndFixSora2.js",
    "fix:video-base": "node src/scripts/fixVideoBaseCredit.js",
    "give:credits": "node src/scripts/giveDefaultCredits.js",
    "init:credits-settings": "node src/scripts/initDefaultCreditsSettings.js",
    "fix:profit-margin": "node src/scripts/fixProfitMargin.js",
    "fix:video-pricing": "node src/scripts/fixVideoModelPricing.js",
    "update:all-video-models": "node src/scripts/updateAllVideoModels.js",
    "validate:model": "node src/scripts/validateModelBeforeImport.js",
    "import:model": "node src/scripts/importModelWithValidation.js",
    "add:pricing-type-column": "node src/scripts/addPricingTypeColumn.js",
    "fix:sora2": "node src/scripts/fixSora2Pricing.js",
    "update:pricing-function": "node src/scripts/updatePricingFunction.js",
    "fix:pricing-config": "node src/scripts/fixPricingConfig.js",
    "fix:all-pricing": "node src/scripts/fixAllPricingIssues.js",
    "simplify:pricing": "node src/scripts/simplifyPricingSystem.js",
    "update:real-pricing": "node src/scripts/updateRealFalPricing.js",
    "sync:real-pricing": "node src/scripts/syncRealFalPricing.js",
    "sync:fal-api-pricing": "node src/scripts/updateRealFalPricing.js",
    "fix:base-credit": "node src/scripts/fixBaseCreditUSD.js",
    "migrate:tripay": "node src/config/migrateTripayPayment.js",
    "sync:tripay-channels": "node sync-tripay-channels.js",
    "fix:payment-channels": "bash fix-payment-deployment.sh",
    "verify:payment-channels": "bash verify-payment-channels.sh",
    "update:db-consistency": "node update-database-consistency.js",
    "init:credit-price": "node src/scripts/initCreditPriceConfig.js",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "watch:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "deploy:zip": "bash create-zip.sh",
    "deploy:zip:node": "node create-deployment-zip.js",
    "deploy:vps": "./deploy-vps.sh",
    "deploy:pm2": "sudo bash deploy-pixelnest.sh",
    "post:deploy": "bash post-deploy.sh",
    "test:callback": "node test-suno-callback.js",
    "test:callback:health": "node test-suno-callback.js --health",
    "check:suno": "node check-suno-status.js",
    "check:suno:config": "node check-suno-status.js --config"
  },
  "keywords": [
    "ai",
    "automation",
    "nodejs",
    "express",
    "postgresql",
    "tailwindcss"
  ],
  "author": "Ahwanulm",
  "license": "MIT",
  "dependencies": {
    "@fal-ai/serverless-client": "^0.15.0",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.1.2",
    "compression": "^1.7.4",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.3",
    "pg-boss": "^11.1.1",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
